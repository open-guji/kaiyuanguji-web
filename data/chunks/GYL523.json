{"GYL523SuaYf":{"id":"GYL523SuaYf","type":"work","title":"禹貢合注","authors":[{"name":"夏允彝","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《禹貢合注》•五卷","author_info":"明夏允彝撰","summary":"明夏允彝撰。允彝字彝仲，華亭人。崇禎丁丑進士，官長樂縣知縣。遭母憂歸。福王時召為吏部主事，以終制辭，南都失守，投水死。事蹟附見《明史•陳子龍傳》。是書多證合時務，指言得失。又雜取《水經注》及諸家小說，旁載山水形狀及諸奇異。似乎博贍，實於《經》義無關也。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":5}},"GYL523tfcZu":{"id":"GYL523tfcZu","type":"work","title":"尚書義疏","authors":[{"name":"蔣家駒","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《尚書義疏》","author_info":"國朝蔣家駒撰","summary":"國朝蔣家駒撰。家駒字千里，丹陽人。康熙庚午舉人，官懷集縣知縣。是編亦高頭講章之類，鈔本綴以圈點，其體段皆類時文。","edition":"無卷數，檢討蕭芝家藏本"}]},"GYL5239ifFM":{"id":"GYL5239ifFM","type":"work","title":"尚書要旨","authors":[{"name":"王肯堂","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《尚書要旨》•三十卷","author_info":"明王肯堂撰","summary":"明王肯堂撰。肯堂字宇泰，金壇人，樵之子也。萬曆己丑進士，官至福建布政司參政。事蹟附見《明史•樵傳》。是書承樵所著《尚書別記》，鈔撮緒言，敷衍其說，以備時文之用。其《經》文較講義低二格，每節惟書首尾二句，亦如時文之體然。","edition":"兩江總督采進本"}],"juan_count":{"number":30},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=2697996","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02042352","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":1711,"paragraph_count":16941,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL523ULsyZ":{"id":"GYL523ULsyZ","type":"work","title":"讀尚書略記","authors":[{"name":"朱朝瑛","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《讀尚書略記》","author_info":"明朱朝瑛撰","summary":"明朱朝瑛撰。朝瑛有《讀易略記》，已著錄。此書力辨攻古文者之非，殊失深考。其所注釋，亦不過隨文敷衍。在所作諸經《略記》之中獨為最下。","edition":"無卷數，浙江巡撫采進本"}]},"GYL523VnBQT":{"id":"GYL523VnBQT","type":"work","title":"書繹","authors":[{"name":"楊文彩","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《書繹》•六卷","author_info":"明楊文彩撰","summary":"明楊文彩撰。文彩字治文，寧都人。是編冠以《指略》十六條、《先儒論》二十一條、《四十二篇亡書目》、次《汲塚周書篇名》。其餘卷次，一如蔡《傳》。文彩崇信古文，其注或如策論，或如語錄，或如時文批語，無複先儒詀經之體。前有其門人魏禧《序》，推尊甚至。文彩《自序》亦謂：“及閘人魏叔子共處一室，相與揚榷，正謬薙繁。義有未盡，複著為論，以補所未逮。是書之成，其功為多。”然禧工於文章，而學問則多講權略，解經亦非所長也。","edition":"江西巡撫采進本"}],"juan_count":{"number":6}},"GYL523JHmyH":{"id":"GYL523JHmyH","type":"work","title":"尚書傳翼","authors":[{"name":"陸鍵","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《尚書傳翼》•十卷","author_info":"明陸鍵撰","summary":"明陸鍵撰。鍵字實府，秀水人。其時又有一陸鍵，平湖人，萬曆丙午舉人。未知一人二人也。是書惟敷衍蔡沈之說，無所異同，故曰《傳翼》，然於《集傳》實無所發明。其體例全似語錄，亦頗不雅馴。","edition":"浙江巡撫采進本"}],"juan_count":{"number":10},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=547452","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02042392","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":703,"paragraph_count":6539,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL523k9BhR":{"id":"GYL523k9BhR","type":"work","title":"書經疏略","authors":[{"name":"張沐","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《書經疏略》•六卷","author_info":"國朝張沐撰","summary":"國朝張沐撰。沐有《周易疏略》，已著錄。是書從注疏本，以《書序》分冠諸篇。又從古本合為一篇，列於卷首。其次第與孔安國《傳》及鄭康成所注百篇之《序》俱互有異同。又所載孔安國《序》，於《春秋左氏傳》句闕其“左氏”二字，解之曰：“《傳》附《經》左曰《左傳》。以人號傳，古無此體。”考《左傳》或曰《左氏》，或曰《左邱》，漢以來說者不同，總為人姓。沐乃以為左右之左，殊駭視聽。且謂傳以人號，古無此體，是並《漢藝文志》亦未見矣。蓋沐著《春秋疏略》，以《左傳》為孔子作，故於此書亦護其說耳。所解多襲蔡《傳》，其獨出己見者率多杜撰。如解《無逸篇》“則知小人之依”句曰：“於是知小民者君子之所依賴以安也。”豈複成文義乎？","edition":"江南巡撫采進本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=158994","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02042491","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":644,"paragraph_count":6533,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL523MD4gX":{"id":"GYL523MD4gX","type":"work","title":"尚書揆一","authors":[{"name":"鄒期楨","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《尚書揆一》•六卷","author_info":"明鄒期楨撰","summary":"明鄒期楨撰。期楨字公寧，無錫人。萬曆中諸生。《江南通志•儒林傳》附見《吳桂森》傳中，稱“與桂森俱從高攀龍學，稱兩素衣先生”。是書專主蔡《傳》，而雜引諸儒之說以發明之，蓋為科舉而作。書成於萬曆丙辰，前有高攀龍《序》，又有《讀尚書六要》，其孫升所述也。國朝康熙庚戌，其門人顧宸序而刊之。","edition":"浙江汪啟淑家藏本"}],"juan_count":{"number":6}},"GYL523pQQ8f":{"id":"GYL523pQQ8f","type":"work","title":"尚書口義","authors":[{"name":"劉懷志","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《尚書口義》•六卷","author_info":"國朝劉懷志撰","summary":"國朝劉懷志撰。懷志字貞儒，武強人。康熙中左都御史謙之父也。其孫自潔原《跋》稱為大司空，蓋其贈官，然未詳何以贈工部尚書也。是書於《經》文之內注小字以貫串之，大旨悉遵蔡《傳》，而衍以通俗之文以便童蒙。凡蔡《傳》所謂錯簡者，俱移易《經》文以從之。凡蔡《傳》所謂衍文者，則徑從刪薙。可謂信《傳》而不信《經》矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=453003","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02042497","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":332,"paragraph_count":2861,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL523a8mYb":{"id":"GYL523a8mYb","type":"work","title":"尚書解意","authors":[{"name":"李楨扆","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《尚書解意》•六卷","author_info":"明李楨扆撰","summary":"明李楨扆撰。楨扆字華麓，任邱人。是編不甚訓詁名物，亦不甚闡發義理，惟尋繹語意，標舉章旨、節旨，務使明白易曉而止。蓋專為初學而設，故名以《解意》雲。","edition":"直隸總督采進本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=690555","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02042460","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":630,"paragraph_count":6295,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL523eSfqH":{"id":"GYL523eSfqH","type":"work","title":"九州山水考","authors":[{"name":"孫承澤","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《九州山水考》•三卷","author_info":"國朝孫承澤撰","summary":"國朝孫承澤撰。是書取《禹貢》所載山水，分類相從。山凡四十有三，正導者二十有七，雜見者十有六。水凡四十有二，正導者九，雜見者三十有三。附以澤九，原隰十。冠以水道會通源委，皆首標其名，而以所合諸水旁行斜貫，引以烏絲，略似族譜世系，與地圖之式迥殊。中多附論時事，引明代諸人議論事實以相證佐，如水利、海運之類，與《經》義多不相關。蓋借事抒議，不專為注《經》設也。書首標曰《格致錄卷》，而卷字之上缺一字未鐫。其子目乃題《九州山水考》上、中、下字。蓋其《格致錄》中之一種，刊而未竣者耳。","edition":"安徽巡撫采進本"}],"juan_count":{"number":3},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7393494","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/NLG312001066432","type":"text+image","metadata":{"edition":"刻本","version":"v4","total_page":100,"paragraph_count":175,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL52316rfy":{"id":"GYL52316rfy","type":"work","title":"書經說意","authors":[{"name":"沈偉","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《書經說意》·十卷","author_info":"明沈偉撰","summary":"明沈偉撰。偉號虹野，吳江人。嘉靖壬子舉人。是書分節總論，大旨不出講章之習。所標某句截、某句斷者尤陋。案朱彝尊《經義考》有杜氏偉《尚書說意》，不著卷數，注云“未見”。考偉本姓杜，少育於沈漢家，因冒其姓，後乃歸宗。此書蓋其未複姓時所著，故仍題沈姓。彝尊所載，則據其後而言之也。","edition":"江西巡撫采進本"}],"juan_count":{"number":10}},"GYL523B9xgF":{"id":"GYL523B9xgF","type":"work","title":"尚書辨解","authors":[{"name":"郝敬","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《尚書辨解》•十卷","author_info":"明郝敬撰","summary":"明郝敬撰。敬有《周易正解》，已著錄。是編前八卷解伏書二十八篇，後二卷辨孔書，故曰《辨解》。其解“周公居東”為就管叔以兄弟之義感之，解“罪人斯得”為成王與太公、召公誅管叔而周公不與聞，他若周公稱成王為孺子為國史代公之辭，非自周公口出，其說多與先儒異。蓋敬之解經，無不以私意穿鑿，亦不但此書為然也。","edition":"浙江汪啟淑家藏本"}],"juan_count":{"number":10},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=104847","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=445393","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7490943","type":"text"},{"id":"shidianguji-wanlihaoqianqiuhaoqi","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02072645","type":"text+image","metadata":{"edition":"萬曆郝千秋郝千石刻九部經解本","version":"v4","total_page":672,"paragraph_count":5293,"check_type":"AI整理"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02042368","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":658,"paragraph_count":6509,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL523cxgYw":{"id":"GYL523cxgYw","type":"work","title":"尚書集解","authors":[{"name":"孫承澤","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《尚書集解》•二十卷","author_info":"國朝孫承澤撰","summary":"國朝孫承澤撰。承澤號退谷，山東益都人。世隸上林苑籍，故自稱曰北平。前明崇禎辛未進士，官兵科給事中。李自成僣位，受偽職為四川防禦使。入國朝，官至吏部侍郎。平生以尊崇朱子得名，而是書篤信古文，與朱子獨異。所解自蔡沈《集傳》外，多采呂祖謙《書說》、金履祥《表注》、許謙《叢說》，而力斥馬融、鄭康成。蓋欲尊宋學，故不得不抑漢儒。然宋儒解經惟《易》、《詩》、《春秋》掊擊漢學，其《尚書》、三《禮》實不甚異同。承澤堅持門戶，又並排斥之耳。然千古之是非，曷可掩也？","edition":"直隸總督采進本"}],"juan_count":{"number":20},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=3739203","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02042465","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":1032,"paragraph_count":7644,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL523mXoGs":{"id":"GYL523mXoGs","type":"work","title":"古文尚書考","authors":[{"name":"陸隴其","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《古文尚書考》•一卷","author_info":"國朝陸隴其撰","summary":"國朝陸隴其撰。隴其字稼書，平湖人。康熙庚戌進士，官嘉定、靈壽二縣知縣，行取御史。雍正二年從祀孔子廟庭。乾隆二年賜諡清獻。是書原載隴其《三魚堂集》中，曹溶《學海類編》始摘錄別行。大旨惟據朱子告輔廣之言，以申古文《尚書》非偽。然《朱子語錄》曰：“《書序》恐不是孔安國所作，只是魏、晉時文字。”又曰：“孔氏《書傳》某疑決非安國所注，恐是魏晉間人托安國為名，與毛公《詩傳》大段不同。”又曰：“傳之子孫，以貽後代，漢時無這般文章。嘗疑安國書是假書。漢儒訓釋文字有疑則闕，此卻盡釋之。豈有千百年前人說底話，收拾於灰燼屋壁之中，與口傳之餘更無一字訛舛。況孔書至東晉方出，前此諸儒皆不曾見，可疑之甚。”然則未子辨古文非真，不一而足，未可據輔廣所記一條，遂謂他弟子所記皆非朱子語也。","edition":"編修程晉芳家藏本"}],"juan_count":{"number":1},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=89413","type":"text"},{"id":"shidianguji-qianlongchangshujian","name":"识典古籍","url":"https://www.shidianguji.com/book/HY3216","type":"text+image","metadata":{"edition":"乾隆常熟蔣氏省吾堂刻本","version":"v5","total_page":127,"paragraph_count":81,"check_type":"粗校"}},{"id":"shidianguji-qianlongwushiqisongt","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02072669","type":"text+image","metadata":{"edition":"乾隆五十七年宋廷弼刻本","version":"v2","total_page":127,"paragraph_count":1249,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL523ny6hm":{"id":"GYL523ny6hm","type":"work","title":"尚書惜陰錄","authors":[{"name":"徐世沐","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《尚書惜陰錄》•六卷","author_info":"國朝徐世沐撰","summary":"國朝徐世沐撰。世沐有《周易惜陰錄》，已著錄。是編乃世沐七十二歲時作。其篤信古文，猶先儒之舊論。至於尊古文而排抑今文，則變本而加厲矣。其排抑今文，惟以不全為辭，不思古文五十八篇亦不足百篇之數也。其說皆因蔡《傳》而衍之，往往支離於文外，如解“蒙羽其藝”，謂：“蒙多蒙昧，亦要隨刊。羽多禽鳥，亦必翦除。益稷之有勞可知。”夫益稷佐禹，豈必在此二山。且以山名一字穿鑿生義，然則熊耳必多冬蟄之獸，外方必為中矩之形哉？又如解“厥貢惟土五色”，謂：“徐之東原乃中原正地，厥土五色而赤多，亦文明天辟。孔子雖為兗產，實徐產也。”斯文之統，蓋像地靈，是與《經》義何涉也？至謂唐尚無史，舜乃設史追書，故曰《虞書》。謂舜以諸侯之禮祀瞽瞍，二妣並祔，正舜母，繼象母，一一秩之不紊，大小宗無餘憾，故官曰秩宗。益不知其所據矣。","edition":"兩江總督采進本"}],"juan_count":{"number":6}},"GYL523sGzzT":{"id":"GYL523sGzzT","type":"work","title":"舜典補亡","authors":[{"name":"毛奇齡","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《舜典補亡》•一卷","author_info":"國朝毛奇齡撰","summary":"國朝毛奇齡撰。奇齡有《仲氏易》，已著錄。《舜典》舊無篇首二十八字，至梁姚方興始得別本於大航頭以補之，其事本屬可疑。然相沿已久，無可刊削之理。所謂有其舉之，莫敢廢也。奇齡堅信古文而獨不信二《典》之分篇，遂以為自“月正元日”以下乃為《舜典》而闕其前半篇，遂摭《史記》以補之。夫司馬遷書豈可以補《經》？即用遷書為補，亦何可前半遷書，後半忽接以古《經》，混合為一？奇齡以竄亂古《經》詆朱子，而所為又加甚焉，雖善辨者殆亦難為之辭矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":1}},"GYL5238HMpT":{"id":"GYL5238HMpT","type":"work","title":"書帷別記","authors":[{"name":"王樵","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《書帷別記》•四卷","author_info":"明王樵撰","summary":"明王樵撰。樵所著《尚書日記》十六卷，說者稱其該洽，已著於錄。此書則為科舉而作，曰《別記》者，所以別於《日記》也。書前舊有萬曆甲申《自序》，見朱彝尊《經義考》。此本不載，蓋偶佚之。","edition":"浙江汪啟淑家藏本"}],"juan_count":{"number":4},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=8628492","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02042348","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":558,"paragraph_count":6077,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL523GrUYP":{"id":"GYL523GrUYP","type":"work","title":"禹貢匯疏","authors":[{"name":"茅瑞徵","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《禹貢匯疏》•十五卷","author_info":"明茅瑞徵撰","summary":"明茅瑞徵撰。其書前冠《圖經》二卷。上卷二十四圖，皆鄭曉原本。下卷二十四圖，則瑞徵所補輯也。次以《九州》為九卷，《導山》、《導水》各一卷。而“九州攸同”至末自為一卷。又采摭大禹神怪之事為《附錄》一卷。書作於崇禎壬申，多藉以抒寫時事。故其《自序》曰：“讀《禹貢》者詳九州之山川，則可供聚米之畫；習澮渠之岐路，則可商飛輓之宜；察東南之物力，則當念杼軸之空；考甸服之遺制，則當興樹藝之利，而挈要於底慎財賦一語。疏解浩繁，可一言以蔽之。如必句櫛字比，執今圖志疑古山川，此不離經生之耳食，何益孔、蔡之舊文？”蓋其志不在於解經也。然徵引浩繁而無所斷制，動引及天文分野，未免氾濫。至其《附錄》一卷，盡摭雜家之言，侈談靈異，則非惟無與於《經》義，亦並無關於時事矣，豈說經之體哉？","edition":"兩淮鹽政采進本"}],"juan_count":{"number":15},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=406432","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4734633","type":"text"},{"id":"shidianguji-chongzhenkanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA00670","type":"text+image","metadata":{"edition":"崇禎05年刊本","version":"v5","total_page":1201,"paragraph_count":9038,"check_type":"AI整理"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02042384","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":1189,"paragraph_count":5832,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL523ika7y":{"id":"GYL523ika7y","type":"work","title":"尚書體要","authors":[{"name":"錢肅潤","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《尚書體要》•六卷","author_info":"國朝錢肅潤撰","summary":"國朝錢肅潤撰。肅潤字礎日，無錫人。是書章分句解，止於隨文生義，未能有所折衷。其訓《禹貢》“三江”，既以松江、婁江、東江為三江，又謂“江、漢發源於梁，合流於荊，入海於揚，定是江、漢，為何又生松江、婁江、東江出來”云云，則又主蘇氏岷江為中江、嶓塚為北江、豫章為南江之說矣。又雲：“東湖未築以前，江水直注太湖，是岷江、嶓塚、豫章三江未嘗不通震澤也。”考江水雖入海於揚，然自古未與震澤通。若如是說，則京口以東皆成巨浸矣。殊為無據。惟其辨九江有三，頗為詳晰，差足備考耳。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7898220","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02042485","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":1038,"paragraph_count":8973,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL52375Veo":{"id":"GYL52375Veo","type":"work","title":"書經疑問","authors":[{"name":"姚舜牧","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《書經疑問》•十二卷","author_info":"明姚舜牧撰","summary":"明姚舜牧撰。舜牧有《易經疑問》，已著錄。是編於《經》義罕所考定，惟推尋文句，以意說之，往往穿鑿杜撰。如解《堯典》“湯湯洪水方割”雲：“湯湯如湯滾沸一般樣。”解《舜典》“有能奮庸熙帝之載”曰：“載字下得極妙。天下事重且大矣，帝王以一身擔當負荷如車載者然。”可謂游談無根矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":12}},"GYL523ba4yV":{"id":"GYL523ba4yV","type":"work","title":"禹貢通解","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《禹貢通解》•一卷","author_info":"舊本題“槜李邵璜撰”","summary":"舊本題“槜李邵璜撰”。不著時代。前有寶坻杜立德《序》，當為國朝人。而其圖中稱北直隸、稱承天府，皆明人語。疑《序》為立德未入國朝以前作也。立德之《序》，頗斥據後代地理以疑蔡《傳》之非，乃並河源之說亦指為不近理。而璜之所注，乃與蔡《傳》多有異同。其循《傳》發揮者謂之《通解》。其不從《傳》者謂之《辨異》。每州之首，及導山、導水各列為圖，自雲多本之鄭曉、夏允彝。然其《青州圖》下即駁允彝之說，亦不盡用二家也。是書頗有意於考正，而所學未博，引據疏略，視胡渭諸家不止上下床之別矣。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":1}},"GYL5233yTXm":{"id":"GYL5233yTXm","type":"work","title":"禹貢山川郡邑考","authors":[{"name":"王鑒","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《禹貢山川郡邑考》·四卷","author_info":"明王鑒撰","summary":"明王鑒撰。鑒字汝明，無錫人。嘉靖乙丑進士，官至太僕寺卿。事蹟附見《明史·邵寶傳》。其書以《禹貢》水道為主，每條用水名標目，而曆引諸書所載源流分合於下。其名為《經》文所無而見於蔡氏《傳》者，並附釋之。山名亦同此例。郡邑名則專取蔡《傳》所有者釋之，然地名僅載其沿革至到，山名引書亦頗略。惟水道稍詳，亦未為該博。朱彝尊《經義考》不著錄。《無錫縣誌》列鑒名於《文苑傳》，亦不言其著有此書。疑草創之稿，未行於世歟？","edition":"浙江汪啟淑家藏本"}],"juan_count":{"number":4},"resources":[{"id":"shidianguji-qingchaoben","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ892411999021610223921","type":"text+image","metadata":{"edition":"清抄本","version":"v1","total_page":212,"paragraph_count":1999,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL523Q5fYK":{"id":"GYL523Q5fYK","type":"work","title":"書經集意","authors":[{"name":"萬嗣達","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《書經集意》•六卷","author_info":"明萬嗣達撰","summary":"明萬嗣達撰。嗣達字孝仲，潯陽人。其履貫無可考。《自序》稱天啟壬戌書於陪京。《序》中謂“雲曹簡靜”，蓋官南京刑部時所作。書中分節講論，蓋家塾課蒙之本。至《禹貢》內雜引明代漕輓東壩諸事，以便答策，尤非解經之體矣。","edition":"江西巡撫采進本"}],"juan_count":{"number":6}},"GYL523zN8S3":{"id":"GYL523zN8S3","type":"work","title":"禹貢解","authors":[{"name":"晏斯盛","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《禹貢解》•八卷","author_info":"國朝晏斯盛撰","summary":"國朝晏斯盛撰。斯盛有《楚蒙山房易經解》，已著錄。《禹貢》一篇，自注疏而外，無慮數十百家。迨胡渭《禹貢錐指》出，條分縷晰，辨正詳博。斯盛是編，大概全取渭書而變其體例。中如渭引《水經注》“漳至斥漳縣入河”，斯盛則以《漢志》“斥漳”下應劭雲“漳水出治北入河”蓋言漢時漳水在治北，其雲“入河”者，以下流至阜城言也。漳水逕行鄴東，已當入故大河，若漢時阜城以上安得有河？渭據《水經注》“濟曆琅槐縣故城北，淄入馬車瀆，逕琅槐故城南”，故言淄、濟各自入海。斯盛以《漢書》“甾至博昌入泲”師古注雲“泲音子禮反”，孔疏引作“入海”，誤也。甾入泲不在馬車瀆，而在琅槐東之博昌界。其辨別亦頗精密。至其論碣石，據《漢志》驪成之大碣石山即今昌黎縣北二十里所謂仙人台、天橋柱者，不取王橫淪於海中之說。又謂河濟相通，浮濟自陶邱而西以達于河，周以後滎川道窒，至東漢時僅存滎菏澤渚之本源，故《漢志》雲“軼出滎陽北平地”，非《禹貢》、《職方》舊跡，不取三伏三見之說。其他如冀之恒衛，以恒由恒山得名，滱水出靈邱縣北高氏山，與渾源州恒山相連屬。衛由惡池得名，衛轉曰惡，惡轉曰虖，滱即恒，虖虖它即衛。皆因渭說而附益之。導河後附歷代徙流，亦因渭之書，刪繁就簡。於雍之黑水欲以打沖河當之，究不協“入於海”之文，且漫無實證。又渭不知今呼老黃河者為宋之二股河，而以為二股河行唐馬頰河故道。斯盛亦曰二股河尋唐景福以前馬頰河之道也。則又沿渭之誤，不能糾正矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":8},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7051671","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02042572","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":584,"paragraph_count":4777,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL523FRB7V":{"id":"GYL523FRB7V","type":"work","title":"虞書箋","authors":[{"name":"茅瑞徵","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《虞書箋》•二卷","author_info":"明茅瑞徵撰","summary":"明茅瑞徵撰。瑞徵字伯符，歸安人。萬曆辛丑進士，官至南京光祿寺卿。解官後自號苕上漁父，又稱澹泊居士。此書前有《自序》，言：“南局多暇，讀唐、虞論治之書，輒次數語。”蓋即官光祿時作也。考《定陵注略》，瑞徵官職方郎中時，欲黜一副將不遂，反為所構。又御史姚永濟、韓浚皆有所請托，瑞徵不從，遂合力排擠之去。其人蓋亦錚錚者，而此書所箋，大抵敷衍舊說，無所發明。如解“柔遠能邇”句雲“柔字下得最妙”，解“惟時亮天工”句雲“即熙帝載意”，解“天敘有典”節雲“兩我字正與兩天字相應”，解“慎乃在位”句雲“即慎乃有位”：皆膚淺不足採錄。殆閑曹無事，姑以遣日，本無意於著書，而其子漫付剞劂耳。","edition":"浙江巡撫采進本"}],"juan_count":{"number":2},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=6164667","type":"text"},{"id":"shidianguji-mingchongzhenkeben","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ892411999025594156992","type":"text+image","metadata":{"edition":"明崇禎刻本","version":"v2","total_page":221,"paragraph_count":1085,"check_type":"AI整理"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02042382","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":220,"paragraph_count":1834,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL523hGaqd":{"id":"GYL523hGaqd","type":"work","title":"尚書引義","authors":[{"name":"王夫之","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《尚書引義》•六卷","author_info":"國朝王夫之撰","summary":"國朝王夫之撰。夫之有《尚書稗疏》，已著錄。此複推論其大義，多取後世事為之糾正。如論《堯典》“欽明”，則以辟王氏良知。論《舜典》“玄德”，則以辟老氏玄旨。論“依永”、“和聲”，斥宋濂、詹同等用九宮填郊廟樂章之陋。論“象以典刑”，攻鍾繇、陳群等言複肉刑之非。論“人心、道心”，證釋氏明心見性之誤。論“聰明、明威”，破呂不韋《月令》、劉向等《五行傳》之謬。論“甲胄起戎”，見秦漢以後制置之失。論“知之非艱，行之維艱”，詆朱陸學術之短。論《洪範》“九疇”，薄蔡氏數學為無稽。論“周公居東”，鄙季友避難為無據。議論馳騁，頗根理要。至於“王敬作所，不可不敬德”及“所其無逸”等句，從孔《傳》而非呂、蔡，亦有依據。惟《文侯之命》以為與《詩》錄《小弁》之意同，為孔子有取於平王，至謂“高宗諒暗”與“豐昵”同為不惠於義，則其論太創。又謂黃帝至帝舜皆以相而紹位，古之命相，猶後世之建嗣。又謂虞、夏有百揆，商有阿衡，皆相也。至周則六卿各率其屬，周之不置相自文王起。此皆臆斷之辭。他若論“微子去紂”，恐文王有易置之謀，“周公營洛”，亦以安商民反側之心。則益涉於權術作用，不可訓矣。","edition":"湖南巡撫采進本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=305255","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=8627526","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02042480","type":"text+image","metadata":{"edition":"刻本","version":"v9","total_page":764,"paragraph_count":690,"check_type":"粗校"}},{"id":"shidianguji-daoguangershierwangs","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02072656","type":"text+image","metadata":{"edition":"道光二十二年王氏守遺經書屋刻本","version":"v4","total_page":352,"paragraph_count":473,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL523XDUqM":{"id":"GYL523XDUqM","type":"work","title":"禹貢廣覽","authors":[{"name":"許胥臣","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《禹貢廣覽》•三卷","author_info":"明許胥臣撰","summary":"明許胥臣撰。胥臣，錢塘人。茲編首載《九州總圖》，次以九州各為一圖，而《經》文分附於後。又以導山、導水、南條、北條分析為圖，亦各以《經》文附焉。至“九州攸同”及“五百里甸服”諸條，又分《山水總敘》及《弼服》諸名，體例頗為詳悉。而《經》文下所引諸家注釋，則粗明訓詁，未足為考證之資也。","edition":"浙江吳玉墀家藏本"}],"juan_count":{"number":3}},"GYL523fqHQj":{"id":"GYL523fqHQj","type":"work","title":"尚書近指","authors":[{"name":"孫奇逢","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《尚書近指》•六卷","author_info":"國朝孫奇逢撰","summary":"國朝孫奇逢撰。奇逢有《讀易大旨》，已著錄。是書前有《自序》，以主敬存心為《尚書》之綱領。其說多標舉此義，不甚詮釋《經》文。然蔡沈《書集傳序》所謂“堯舜存此心，桀紂亡此心，太甲、成王困而存此心”者，已先揭大旨，不煩重演矣。","edition":"江西巡撫采進本"}],"juan_count":{"number":6}},"GYL523NbgFy":{"id":"GYL523NbgFy","type":"work","title":"尚書葦籥","authors":[{"name":"潘士遴","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《尚書葦籥》•二十一卷","author_info":"明潘士遴撰","summary":"明潘士遴撰。士遴字叔獻，烏程人。天啟壬戌進士，官至大理寺寺副。是書大意欲囊括漢、宋諸儒而折衷以己見。然博引繁稱，卮言多而精理少。其《凡例》高自標置，謂“從來說經非稽天之射，即無病之呻。《葦籥》指點虛實，筆光開洞，真可引人心氣，資人聰明。其經如經星之左旋，其緯如緯星之右轉，無可增減，無可贊宣。煙霞寶氣，結為祥光瑞靄。萬古執迷，一旦葦籥獨見曉焉”云云。自古以來，著述之家，未有誇誕至於如是者。其華而不實，亦可概見矣。目錄止二十一卷，而分編則為五十八卷。蓋以篇數為子卷也。","edition":"兩江總督采進本"}],"juan_count":{"number":21},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=3475815","type":"text"},{"id":"shidianguji-chongzhenkanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA00650","type":"text+image","metadata":{"edition":"崇禎07年刊本","version":"v14","total_page":3994,"paragraph_count":35705,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL5232YA6s":{"id":"GYL5232YA6s","type":"work","title":"書經講義會編","authors":[{"name":"申時行","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《書經講義會編》·十二卷","author_info":"明申時行撰","summary":"明申時行撰。時行字汝默，號瑤泉，長洲人。嘉靖壬戌進士第一，官至大學士。諡文定。事蹟具《明史》本傳。是編乃時行官翰林直日講時所進。其說皆恪守蔡《傳》，務取淺近易明。考徐允錫作鄭曉《禹貢說跋》雲：“嘗屬徐瑤泉作《虞商周書說》，以補所未備。”徐瑤泉者，即謂時行，蓋時行初冒徐姓。允錫跋作於隆慶二年，時猶未複姓也。據其所言，時行蓋深於《尚書》者。然其《書》說竟不及成，惟此編存於世雲。","edition":"江西巡撫采進本"}],"juan_count":{"number":12},"resources":[{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02042324","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":1792,"paragraph_count":17742,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL523E2ZY3":{"id":"GYL523E2ZY3","type":"work","title":"書傳會衷","authors":[{"name":"曹學佺","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《書傳會衷》•十卷","author_info":"明曹學佺撰","summary":"明曹學佺撰。學佺有《易經通論》，已著錄。是書自一卷《堯典》至六卷《召誥》，題曰《書傳會衷》。七卷《洛誥》以下則題曰《書傳折衷》。篇帙相連，而兩名互見，莫喻其故。今姑從其前名，以歸畫一。其說多沿襲舊文，間自立議，則又舛誤。如四嶽舊說以為四人，學佺則以為一人而總四岳諸侯之事。不知下文“僉曰”為眾應之辭也。其以三江為松江、婁江、東江，九江為洞庭，則皆取舊說之不可信者。《洪範》之“六，三德”不取鄭康成臣道之說，而用孔《傳》，亦為寡識也。","edition":"江蘇周厚堉家藏本"}],"juan_count":{"number":10},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1439787","type":"text"},{"id":"shidianguji-kanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA00134","type":"text+image","metadata":{"edition":"刊本","version":"v6","total_page":715,"paragraph_count":6422,"check_type":"AI整理"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02042375","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":704,"paragraph_count":6446,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL523YhU7h":{"id":"GYL523YhU7h","type":"work","title":"尚書講義","authors":[{"name":"蔡璋","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《尚書講義》","author_info":"明蔡璋撰","summary":"明蔡璋撰。璋字達夫，無錫人。是書順文敷衍，無所發明。即其開卷釋“曰若”若字作設問之如字解，則大略可睹矣。書凡兩冊，為明季寫本。當時朱墨標識猶存，疑即璋之原稿雲。","edition":"無卷數，兩江總督采進本"}],"books":["CXVzpUuaLbR"],"resources":[{"id":"shidianguji-sikuquanshuben","name":"识典古籍","url":"https://www.shidianguji.com/book/SK0176","type":"text+image","metadata":{"edition":"四庫全書本","version":"v2","total_page":868,"paragraph_count":577,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL523qqhZZ":{"id":"GYL523qqhZZ","type":"work","title":"禹貢正義","authors":[{"name":"曹爾成","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《禹貢正義》•三卷","author_info":"國朝曹爾成撰","summary":"國朝曹爾成撰。爾成字得忍，無錫人。是書成於康熙甲寅，據蔡氏《集傳》為本。或偶出己見，又於古無稽。如揚之三江，則以為錢塘江有兩源，北源為黟江，西源為太末江，並錢塘而為三。梁之沱、潛，則以為皆江之別源，而非江漢別流。其說導水也，於“導河”節以“東過洛汭”為禹過之，以大陸為去河絕遠，禹從洚水取陸路到高平之處，下“又北”接上“北過洚水”，非自大陸又北。於“導漾”節“過三澨至於大別”，亦為禹取陸路，從三澨至大別，下“南入于江”接上“又東為滄浪之水”而轉南，非自大別而南。於“導江”節“過九江，至於東陵”為禹從九江取陸路至東陵，於“東迤北”接上“又東至於澧”，非自東陵又東。於“導沇水”節以“東出於陶邱北，又東”為濟之正派。下“至於菏”為分流，南行通泗。“又東北”接“又東”正派，非自菏又東北。其“又北東入於海”，以“又北”為分流，北出為沮而合於灉，以“東入於海”為正派。皆膠滯破碎，使文理不相貫也。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":3},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=6710748","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02042501","type":"text+image","metadata":{"edition":"刻本","version":"v1","total_page":255,"paragraph_count":2245,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL523wYDRh":{"id":"GYL523wYDRh","type":"work","title":"禹貢臆參","authors":[{"name":"楊陸榮","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《禹貢臆參》","author_info":"國朝楊陸榮撰","summary":"國朝楊陸榮撰。陸榮有《易互》，已著錄。是書於《經》文之下詳載蔡《傳》，而並錄《地理今釋》以糾其誤。亦間附己說，然頗有攻詰未當者。若“三江既入，震澤厎定”一條，《初學記》引鄭康成注：“漢江為北江，右合彭蠡為南江，岷江居中為中江。”後儒咸主鄭義，而陸榮力攻之，謂《周禮•職方》於荊州曰：“其川江漢”，於揚州曰“其川三江，”若江漢即三江之二，又何以一表之於荊，又表之於揚也？考《職方氏》有曰：“河東曰兗州，其川河、泲。東北曰幽州，其川河、泲。”一河、泲而既表之於兗，又表之於幽，陸榮又何以難之也？陸榮又謂：“《職方氏》曰：其川三江，其浸五湖。苟彭蠡可以為南江，則是一水而分列於川浸。”蓋主李善、司馬貞之注，以彭蠡為五湖之一。然虞翻、韋昭、張勃、酈道元、張守節、陸龜蒙、李宗諤諸家皆與善及貞注不同，則五湖必兼彭蠡，尚未可確定，亦不得執以駁三江矣。","edition":"無卷數，江蘇巡撫采進本"}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7325052","type":"text"}]},"GYL523KmmFd":{"id":"GYL523KmmFd","type":"work","title":"尚書晚訂","authors":[{"name":"史維堡","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《尚書晚訂》•十二卷","author_info":"明史維堡撰","summary":"明史維堡撰。維堡字心傳，金壇人。萬曆丙辰進士，官至工部郎中。是書本名《尚書集覽》，後更名《晚訂》，蓋取晚年論定之意也。大旨以蔡《傳》為藍本，惟考據典故，頗引舊文，不盡同於蔡《傳》。蓋參用朱子“《尚書》名物度數當看注疏”之語也。","edition":"編修勵守謙家藏本"}],"juan_count":{"number":12},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=958392","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02042399","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":1111,"paragraph_count":10860,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL523CbG79":{"id":"GYL523CbG79","type":"work","title":"禹貢備遺增注","authors":[{"name":"胡瓚","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《禹貢備遺增注》•二卷","author_info":"明胡瓚撰","summary":"明胡瓚撰。其曾孫宗緒增注。瓚字伯玉，桐城人。萬曆乙未進士。官至江西布政司參政。宗緒字襲參，雍正庚戌進士，官至國子監司業。是書先發明《禹貢》書法，別為卷首。自“禹敷土”至“西戎即敘”為一卷，“道岍及岐”以下為一卷。依《經》附注，多遵蔡氏《集傳》。宗緒增注，則間引蔡《傳》原文以證其同異。如謂淄水入海不入流。考《左傳•昭公二十六年》，“成人伐齊師之飲馬於淄者。”杜注雲：“淄水出泰山梁父縣，西北入汶。”鄭樵誤會其文，遂據此謂濰淄之淄為入汶不入海，固為牽合。蔡《傳》雲淄水東入濟，亦不知通淄濟之間乃漢時事，有《河渠書》可證也。《禹貢》之淄出益都縣東南岳陽山，曆今臨淄、博興、樂安至壽光縣，北由清水泊入海，水道顯然。此糾正之得實者也。至謂汾本西流，則從蔡《傳》。考《水經注》：“汾水出太原汾陽縣北管涔山，南流與東、西溫谿合。”以今地輿考之，自汾陽至臨汾縣東，皆南流。自此而南，西流經曲沃縣，所謂故絳也。由曲沃至河津、榮河諸縣，則皆西流。蔡《傳》未為明晰。如是之類，尚未盡正也。","edition":"兩江總督采進本"}],"juan_count":{"number":2}},"GYL523v6uzo":{"id":"GYL523v6uzo","type":"work","title":"書經詳說","authors":[{"name":"冉覲祖","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《書經詳說》","author_info":"國朝冉覲祖撰","summary":"國朝冉覲祖撰。覲祖有《易經詳說》，已著錄。是書以蔡《傳》為主，旁引孔《傳》、孔《疏》及宋元以下諸家之說以釋之。雖證引證，頗繁，然如六宗、三江皆援據諸說而終以蔡《傳》為主。其有稍異於《傳》者，多削而不錄。如《文侯之命》引孔《疏》，其下注雲：“《傳》、《疏》多與蔡《傳》說異，故僅錄此。”又如《費誓》“徂茲淮夷”句引孔《傳》，亦必注其下雲：“徂訓往征，與蔡《傳》異。”蓋篤守宋學，不肯一字異同者也。","edition":"無卷數河南巡撫采進本"}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=6852291","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02042504","type":"text+image","metadata":{"edition":"刻本","version":"v14","total_page":6540,"paragraph_count":9226,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL5235TSp7":{"id":"GYL5235TSp7","type":"work","title":"禹貢玄珠","authors":[{"name":"俞鯤","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《禹貢玄珠》·一卷","author_info":"明俞鯤撰","summary":"明俞鯤撰。鯤字之鵬，嘉興人。是書朱彝尊《經義考》不著錄，而別載其《百家尚書匯解》，列於申時行、袁仁之後，屠本畯、鄧元錫之前。蓋嘉、隆間人也。大旨取《禹貢篇》蔡沈《集傳》刪節浮文，歸於簡要。於青州濰、淄二水，則據毛晃《禹貢指南》之說，謂淄入海而以蔡《傳》淄入泲者為誤，亦間有考證。然大致主於詮釋文句，於山川地理未能洞悉原委。卷末附《九州總歌》，《導山導水歌》、《九州田法賦法歌》，尤村塾記誦之學矣。","edition":"兩江總督采進本"}],"juan_count":{"number":1}},"GYL523RUH7m":{"id":"GYL523RUH7m","type":"work","title":"禹貢圖注","authors":[{"name":"艾南英","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《禹貢圖注》","author_info":"明艾南英撰","summary":"明艾南英撰。南英字千子，東鄉人。天啟甲子舉人。朱聿鍵僣號於福建，以為監察御史。病卒於延平。事蹟具《明史•文苑傳》。楊陸榮《三藩紀事本末》則以為殉節自經。傳聞異辭，莫之詳也。是編以《禹貢》九州分繪九圖，列於各州《經》文之前。又繪《五服圖》，列於“五百里甸服”一節之前。後附《輿地總圖》，據明代郡縣，紀其大略。採錄蔡注之簡明者為內注，有不可廢者仍錄為外注。其圖與注俱頗簡略，無足以資考證，南英《自序》亦雲為便於童蒙記誦也。","edition":"無卷數，江西巡撫采進本"}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=832005","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=2930553","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02042443","type":"text+image","metadata":{"edition":"刻本","version":"v1","total_page":149,"paragraph_count":1250,"check_type":"AI整理"}}],"has_text":true,"has_image":true,"books":["CXZVBbqKkVD"]},"GYL523xvq19":{"id":"GYL523xvq19","type":"work","title":"禹貢譜","authors":[{"name":"王澍","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《禹貢譜》•二卷","author_info":"國朝王澍撰","summary":"國朝王澍撰。澍字若霖，亦或自書為篛林，金壇人。康熙壬辰進士，曆官給事中。是書各著《經》文於前，而附圖於後。州為二圖，一言疆界，一言貢道。導山、導水及山川、田賦亦各有圖，凡四十圖。大抵皆本蔡《傳》，而參以諸家之說。條理簡明，頗易尋覽。然多因仍舊說，依違遷就，不能折衷歸一。與胡渭《錐指》蓋未可同日語也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":2},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=205582","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=6672345","type":"text"},{"id":"shidianguji-kangxikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY2350","type":"text+image","metadata":{"edition":"康熙刻本","version":"v5","total_page":164,"paragraph_count":20,"check_type":"粗校"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02042571","type":"text+image","metadata":{"edition":"刻本","version":"v4","total_page":135,"paragraph_count":122,"check_type":"粗校"}}],"has_text":true,"has_image":true}}