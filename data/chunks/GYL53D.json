{"GYL53DAmi8w":{"id":"GYL53DAmi8w","type":"work","title":"存菴奏疏","authors":[{"name":"徐越","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《存菴奏疏》•","author_info":"國朝徐越撰","summary":"國朝徐越撰。越字山琢，山陽人，順治壬辰進士，官至監察御史，遷兵部督捕左理事官，仍留御史之任。是集皆其所上奏疏，自順治十七年至康熙十二年止，凡五十四篇。皆具年月，並恭載諭旨。《江南通志》稱其在台十有三年，所條奏皆有關時政之大者。言漕河事先後凡十六疏，曆陳淮、黃分合變遷及兩河沖決狀尤悉。","edition":"無卷數，江蘇巡撫采進本"}]},"GYL53Db6SjH":{"id":"GYL53Db6SjH","type":"work","title":"大儒奏議","authors":[{"name":"邵寶","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《大儒奏議》•六卷","author_info":"明邵寶編","summary":"明邵寶編。寶有《左觿》，已著錄。是書取宋二程子及朱子奏議匯抄成帙。蓋寶督學江西時所刊。然三子以道學傳，不以經濟見也。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":6}},"GYL53DMX7vw":{"id":"GYL53DMX7vw","type":"work","title":"督漕疏草","authors":[{"name":"董訥","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《督漕疏草》•二十二卷","author_info":"國朝董訥撰","summary":"國朝董訥撰。訥字茲重，號默菴，平原人，康熙丁未進士，官至江南總督。是編乃其督理漕河時所上疏草，皆吏牘之文。","edition":"山東巡撫采進本"}],"juan_count":{"number":22},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4150578","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02048196","type":"text+image","metadata":{"edition":"刻本","version":"v5","total_page":3239,"paragraph_count":25235,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53DtEgB9":{"id":"GYL53DtEgB9","type":"work","title":"古奏議","authors":[{"name":"黃汝亨","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《古奏議》•","author_info":"明黃汝亨編","summary":"明黃汝亨編。汝亨字貞父，仁和人，萬曆戊戌進士，官至江西提學僉事，轉布政司參議。此書輯古人奏議，自戰國迄於唐、宋，共一百一十首。每首系以評論。然若蘇秦、范睢、韓非輩，不過辨士功利之談。論文則當取其工，論奏議則當斥其詭，奈何托始於是也。","edition":"無卷數，兩江總督采進本"}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=876290","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=200610","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=6444465","type":"text"},{"id":"shidianguji-wanliershijiuwudejuk","name":"识典古籍","url":"https://www.shidianguji.com/book/HY2941","type":"text+image","metadata":{"edition":"萬曆二十九年(1601)吳德聚刻本","version":"v6","total_page":930,"paragraph_count":5919,"check_type":"AI整理"}},{"id":"shidianguji-wanliershijiuwudejuk-1","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02082453","type":"text+image","metadata":{"edition":"萬曆二十九年吳德聚刻本","version":"v2","total_page":870,"paragraph_count":8044,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53DvNHPm":{"id":"GYL53DvNHPm","type":"work","title":"二李先生奏議","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《二李先生奏議》•二卷","summary":"明徐宗夔所編李夢陽、李三才二人奏議也。夢陽以風節振一世。三才結納東林，亦負當代之望，而智數用事，不及夢陽之伉直，其為人不甚相類。宗夔以二人俱產關中，故合刻之。末各附詩數首，於體例亦為不倫。宗夔字效虞，蘇州人。","edition":"副都御史黃登賢家藏本"}],"juan_count":{"number":2}},"GYL53DxYaTq":{"id":"GYL53DxYaTq","type":"work","title":"奏議稽詢","authors":[{"name":"曹本榮","role":"編","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《奏議稽詢》•四十四卷","author_info":"國朝曹本榮編","summary":"國朝曹本榮編。本榮，黃岡人，順治己丑進士，官至侍講學士。是書仿《歷代名臣奏議》之體，匯輯自周訖明諸臣奏疏，分三十六門。然自《君德》至《弭盜》六十五門，止二十六卷。其中《律曆》一門，又有錄無書。最後《禦邊》一門，自二十七卷起至四十四卷止，共十八卷。未免繁簡不倫，體例未能盡善，疑草創未全之本也。（以上總集）","comment":"──右“詔令奏議類”奏議之屬，九十部、八百十八卷，內十部無卷數，皆附《存目》。","edition":"湖北巡撫采進本"}],"juan_count":{"number":44}},"GYL53D8e6vK":{"id":"GYL53D8e6vK","type":"work","title":"疏稿","authors":[{"name":"胡文學","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《疏稿》•一卷","author_info":"國朝胡文學撰","summary":"國朝胡文學撰。文學字卜言，鄞縣人，順治壬辰進士，官至福建道監察御史。此即為御史時題奏之稿也。自順治十七年起，至康熙元年巡視兩淮鹽政止，凡十六篇。","edition":"兩江總督采進本"}],"juan_count":{"number":1},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/疏稿","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=3507267","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02048179","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":167,"paragraph_count":1027,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53Dr74xX":{"id":"GYL53Dr74xX","type":"work","title":"右編補","authors":[{"name":"姚文蔚","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《右編補》•十卷","author_info":"明姚文蔚編","summary":"明姚文蔚編。文蔚字元素，錢塘人，萬曆壬辰進士，官至太僕寺卿。初，唐順之為《右編》，其書未完。劉曰寧補而輯之，尚多闕略。文蔚因取永樂中所修《名臣奏議》，拾其所遺。其門目則仍從《奏議》之舊，分四十二類，大抵皆習見之文。特於順之所不錄者，覆為掇拾，以成一編耳。","edition":"直隸總督采進本"}],"juan_count":{"number":10},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=628668","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=2195031","type":"text"},{"id":"shidianguji-wanlikanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA04050","type":"text+image","metadata":{"edition":"萬曆39年刊本","version":"v9","total_page":1520,"paragraph_count":1197,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-wanlisanshijiuliushe","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02082443","type":"text+image","metadata":{"edition":"萬曆三十九年劉伸等刻本","version":"v3","total_page":1507,"paragraph_count":14309,"check_type":"AI整理"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02048339","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":1513,"paragraph_count":14307,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53DdE3wu":{"id":"GYL53DdE3wu","type":"work","title":"右編","authors":[{"name":"唐順之","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《右編》•四十卷","author_info":"明唐順之編","summary":"明唐順之編。順之有《廣右戰功錄》，已著錄。是編所錄皆歷代名臣論事之文，凡分二十一門、九十子目。古來崇論宏議，切於事情，可資法戒者，菁華略備。其曰《右編》者，取右史記言之義也。然其稿未定而順之沒。後萬曆中焦竑得其殘本，南京國子監祭酒劉曰甯、司業朱國楨仿左編義例，為定其部分，且補其遺軼，付之梓。然其中所補之文，如司馬師《上高貴鄉公勸學書》、李斯《諫秦王逐客書》及唐武后時諸臣所上書，多以詞藻見收，恐非順之本意。又如《論晉鑄刑鼎》一書，自是左氏之文，而題曰仲尼，尤為無識。蓋明自萬曆以後，國運既頹，士風亦佻，凡所著述，率竊據前人舊帙，而以私智變亂之。曰寧等之補此書，亦其一也。","edition":"直隸總督采進本"}],"juan_count":{"number":40}},"GYL53DKLprs":{"id":"GYL53DKLprs","type":"work","title":"平嶽疏議","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《平嶽疏議》•一卷、《平海疏議》•一卷、附《平海諮文》•一卷","summary":"、","comment":"《師中小劄》•一卷（山西巡撫采進本）國朝萬正色撰。正色號中庵，晉江人，康熙十三年，正色以岳州水師總兵官征吳三桂，累立戰功。《平嶽疏議》作於是時。尋提督福建水師，同總督姚啟盛平海壇及金、廈兩島。《平海疏議》及《諮文》作於是時。《小劄》亦是時師中作也。"}],"juan_count":{"number":1},"additional_works":[{"book_title":"師中小劄","n_juan":1}]},"GYL53DCzh4T":{"id":"GYL53DCzh4T","type":"work","title":"楊黃門奏疏","authors":[{"name":"楊雍建","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《楊黃門奏疏》•","author_info":"國朝楊雍建撰","summary":"國朝楊雍建撰。雍建字自西，一字以齋，海甯人，順治乙未進士，官至兵部侍郎。此編乃其官給事中時所上奏疏，故以黃門為名。前有康熙元年《胡兆龍序》，謂雍建壬寅假歸，梓其前後疏章三十餘篇。又《自序》雲：曆吏、禮、兵、刑四垣，章凡三十餘上。今卷內實五十一篇。末四篇稱《西台奏議》，蓋康熙十八年官左副都御史時也。《目錄》後有《自識》雲：餘以內升，複入垣署，章奏及西台諸疏，原稿散失無存。賴吾侄存理中發留心搜輯，得以續梓。然則此所載者蓋合前後所刻通為一編矣。","edition":"無卷數，浙江巡撫采進本"}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=3516246","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02048180","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":344,"paragraph_count":2701,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53DXXY5m":{"id":"GYL53DXXY5m","type":"work","title":"赤城論諫錄","authors":[{"name":"謝鐸、黃孔昭同","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《赤城論諫錄》•十卷","author_info":"明謝鐸、黃孔昭同編","summary":"明謝鐸、黃孔昭同編。鐸字鳴治，天順甲申進士，官至禮部侍郎，兼國子監祭酒，諡文肅。孔昭字世顯，天順庚辰進士，官至工部侍郎，諡文毅。事蹟具《明史》本傳。二人皆天臺人。是編裒其鄉先輩奏議，自南宋至明初，凡十四人，文六十六篇。又吳芾、葉夢鼎二人在宋末亦以言事著稱，而奏稿不可複得，亦附名於後。略載其出處行事，以存其人焉。","edition":"浙江巡撫采進本"}],"juan_count":{"number":10},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=6950424","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02048233","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":490,"paragraph_count":4001,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53DR3Lj1":{"id":"GYL53DR3Lj1","type":"work","title":"奏議稿","authors":[{"name":"江蘩","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《奏議稿》•","author_info":"國朝江蘩撰","summary":"國朝江蘩撰。蘩有《四譯館考》，已著錄。是編冠以康熙二十五年十月蘩由靈寶縣知縣擢御史時禦試策二道。次為陝西道御史時疏三篇，次為巡視東城時疏二篇，次為協理江西道時疏三篇，次為巡視北城時疏一篇，次為巡視長蘆鹽課時疏三篇，次為掌山東道時疏一篇、掌京畿道時疏一篇。","edition":"無卷數，江西巡撫采進本"}]},"GYL53DkMsEw":{"id":"GYL53DkMsEw","type":"work","title":"兩朝疏鈔","authors":[{"name":"顧爾行","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《兩朝疏鈔》•十二卷","author_info":"明顧爾行編","summary":"明顧爾行編。爾行，歸安人，萬曆甲戌進士，官大名府推官。初，張瀚撰《疏議輯略》，所載止武宗以前，故爾行複錄世宗、穆宗朝諸疏，以續其書。明至世宗以後，紀綱日弛，議論日多。當時諸疏，或忿爭詬戾，使聽者不平；或支蔓冗遝，使讀者欲臥。士大夫淳厚忠朴之風，自是漸壞。其間忠義激發，非為名計者，亦參雜其中，混淆而不能別矣。是則世運為之也。","edition":"浙江範懋柱家天一閣藏本"}],"juan_count":{"number":12}},"GYL53D52WRM":{"id":"GYL53D52WRM","type":"work","title":"大觀堂文集","authors":[{"name":"餘縉","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《大觀堂文集》•三卷","author_info":"國朝餘縉撰","summary":"國朝餘縉撰。縉字仲紳，號浣公，諸暨人，順治壬辰進士，官至河南道監察御史。是集即其官御史時所上諸疏，凡四十三篇。其外官告病諸疏，皆縉私擬未上之稿，未嘗見之施行，不當一例附入也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":3},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=8441574","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02034967","type":"text+image","metadata":{"edition":"刻本","version":"v4","total_page":1174,"paragraph_count":6810,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53DF8JH5":{"id":"GYL53DF8JH5","type":"work","title":"撫黔奏疏","authors":[{"name":"楊雍建","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《撫黔奏疏》•八卷","author_info":"國朝楊雍建撰","summary":"國朝楊雍建撰。雍建自康熙十八年巡撫貴州，凡在任六年。內升兵部侍郎，閱一年有餘，告請終養。是編合載貴州及兵部奏疏共五百四十一篇。","edition":"浙江巡撫采進本"}],"juan_count":{"number":8},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4558215","type":"text","details":"楊雍建編"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7007277","type":"text"},{"id":"shidianguji-jindaizhongguoshilia","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02026663","type":"text+image","metadata":{"edition":"近代中國史料叢刊影印本","version":"v2","total_page":1340,"paragraph_count":3363,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53DovmtT":{"id":"GYL53DovmtT","type":"work","title":"留台奏議","authors":[{"name":"朱吾弼、李雲鵠、蕭如松、孫居相同","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《留台奏議》•二十卷","author_info":"明朱吾弼、李雲鵠、蕭如松、孫居相同編","summary":"明朱吾弼、李雲鵠、蕭如松、孫居相同編。取正、嘉、隆、萬間南京御史所上奏疏，分二十門。所載諸疏，四人自撰者為多。露才揚己，蓋所不免焉。吾弼有《朱子奏議》，已著錄。雲鵠字黃羽，內鄉人，萬曆壬辰進士。如松字鶴侶，內江人。居相字伯輔，沁水人。並萬曆壬辰進士。時皆官南京御史，故與吾弼同輯是編也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":20}},"GYL53DVMF1h":{"id":"GYL53DVMF1h","type":"work","title":"河防疏略","authors":[{"name":"朱之錫","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《河防疏略》•二十卷","author_info":"國朝朱之錫撰","summary":"國朝朱之錫撰。之錫字孟九，號梅麓，義烏人，康熙壬辰進士，官至兵部尚書、都察院右副都御史、總督河道。是編即其治河奏稿也。（以上專集）","edition":"兩淮馬裕家藏本"}],"juan_count":{"number":20},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=884287","type":"text"},{"id":"shidianguji-kangxiqihanxiangguan","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02083169","type":"text+image","metadata":{"edition":"康熙七年寒香館刻本","version":"v5","total_page":1052,"paragraph_count":6910,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53DTAwwd":{"id":"GYL53DTAwwd","type":"work","title":"撫豫宣化錄","authors":[{"name":"田文鏡","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《撫豫宣化錄》•四卷","author_info":"國朝田文鏡撰","summary":"國朝田文鏡撰。文鏡，正黃旗漢軍，官至河東總督，諡端肅。是編乃文鏡官河南巡撫時，《奏疏》一卷、《條奏》一卷、《文移》一卷、《告示》一卷。內《文移》又分一子卷。均始於雍正二年七月，迄五年九月。惟《告示》迄於五年正月。前有河南布政使費金吾、按察使彭維新、分守開歸河道楊夢琬、河務兵備道祝兆鵬、分守河北兵備道朱藻、分巡南汝光道孫蘭芬會請刊刻詳文一道，及文鏡批詞。","edition":"內府藏本"}],"juan_count":{"number":4},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=5974695","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02048218","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":1267,"paragraph_count":10093,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53DHDDeF":{"id":"GYL53DHDDeF","type":"work","title":"於山奏牘","authors":[{"name":"于成龍","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《於山奏牘》•七卷、附《詩詞》•一卷","author_info":"國朝于成龍撰","summary":"國朝于成龍撰。成龍字北溟，永寧人。前明拔貢生。入國朝，授廣西羅城縣知縣。官至湖廣總督。此集刊於康熙癸亥，自卷一至卷七，皆載其歷任所上奏疏，及詳文、牌示並一時同官往來書牘。第八卷則《詩詞》，而終之以《制藝》一首。其後《政書》之刻，即因此本而增損之。此編蓋猶其初稿。至於詩詞，本非所長。《制藝》一首，尤不入格。亦不如《政書》之刊除潔淨也。","edition":"江蘇周厚堉家藏本"}],"juan_count":{"number":7},"related_works":[{"id":"GYLt1F7Vr1V","title":"於山詩詞"}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=588765","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=8528310","type":"text"},{"id":"shidianguji-kangxiershiersanhanl","name":"识典古籍","url":"https://www.shidianguji.com/book/HY2636","type":"text+image","metadata":{"edition":"康熙二十二年(1683)三韓劉鼎刻本","version":"v7","total_page":808,"paragraph_count":2573,"check_type":"AI整理"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02048189","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":747,"paragraph_count":4989,"check_type":"AI整理"}},{"id":"shidianguji-liudingqingkangxikeb","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ892411999028269149816","type":"text+image","metadata":{"edition":"劉鼎清康熙22年刻本","version":"v1","total_page":802,"paragraph_count":1805,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53Dzucwh":{"id":"GYL53Dzucwh","type":"work","title":"孔子編年","authors":[{"name":"胡舜陟","role":"撰","dynasty":"宋"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《孔子編年》•五卷","author_info":"舊本題宋胡舜陟撰","summary":"舊本題宋胡舜陟撰。考書首有紹興八年《舜陟序》，乃自靜江罷歸之日，命其子仔所撰，非舜陟自作也。舜陟字汝明，績溪人。大觀三年進士。靖康間官侍御史。南渡初，知廬州，有禦寇功。更歷數鎮，最後為廣西經略使。欲為秦檜父建祠，高登不可，因劾登以媚檜。會以他事忤檜意，亦逮治死於獄。事蹟具《宋史》本傳。仔字元任，後流寓吳興。當輯《詩話》行於世，即所謂苕溪漁隱者是也。是書輯錄孔子言行，以《論語》、《春秋三傳》、《禮記》、《家語》、《史記》諸家所載，按歲編排，體例亦如年譜。其不曰年譜而曰編年，尊聖人也。自周、秦之間，讖緯雜出，一切詭異神怪之說，率托諸孔子，大抵誕謾不足信。仔獨依據經傳，考尋事實，大旨以《論語》為主，而附以他書。其采掇頗為審慎。惟諸書紀錄聖言，不能盡載其歲月，仔既限以編年，不免時有牽合。如《左氏•襄公二十一年•鄭人遊鄉校傳》，仲尼聞是語也云云。《杜預注》謂仲尼於是年實是十歲，長而後聞之。知孔子為此言，不當在是年也。仔乃系其事於十歲之下，殊為疏舛。又《禮記•儒行篇》，對魯哀公云云，則系之六十八歲。《哀公問篇》，大禮何如云云，則又系之七十二歲。不知何所據而雲然。此類尤失於穿鑿。然由宋迄元明，集聖跡者，其書日多，亦猥雜日甚。仔所論次，猶為近古。故錄冠《傳記》之首，以見濫觴所自焉。","edition":"浙江範懋柱家天一閣藏本"}],"books":["CXVzsb2Nmhh"],"juan_count":{"number":5},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/孔子編年","type":"text"},{"id":"wikisource-siku","name":"维基文库（四庫全書本）","url":"https://zh.wikisource.org/wiki/孔子編年_(四庫全書本)","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=205942","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=406083","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=6505650","type":"text"},{"id":"shidianguji-sikuquanshuben","name":"识典古籍","url":"https://www.shidianguji.com/book/SK0877","type":"text+image","metadata":{"edition":"四庫全書本","version":"v10","total_page":216,"paragraph_count":152,"check_type":"粗校"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02020811","type":"text+image","metadata":{"edition":"刻本","version":"v7","total_page":253,"paragraph_count":269,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL53D2tuCj":{"id":"GYL53D2tuCj","type":"work","title":"西台奏議","authors":[{"name":"楊素蘊","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《西台奏議》•一卷、《京兆奏議》•一卷、附《曲徙錄》•一卷","author_info":"國朝楊素蘊撰","summary":"國朝楊素蘊撰。素蘊字筠湄，宜君人，順治壬辰進士，官至湖廣巡撫。《西台奏議》，其為四川道監察御史時所上。《京兆奏議》，其官順天府尹時所上。《曲徙錄》則東明劉祚昌集其劾奏吳三桂疏，又謫官複起始末也。然三桂逆跡一形，素蘊即邀擢用，未可謂之“曲突徙薪無恩澤”也。祚昌之命名，亦不思之甚矣。","edition":"陝西巡撫采進本"}],"juan_count":{"number":1},"additional_works":[{"book_title":"曲徙錄","n_juan":1}],"related_works":[{"id":"GYLt1DYBYcw","title":"京兆奏議"}]},"GYL53Dg3xxF":{"id":"GYL53Dg3xxF","type":"work","title":"明疏議輯略","authors":[{"name":"張瀚","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《明疏議輯略》•三十七卷","author_info":"明張瀚編","summary":"明張瀚編。是書乃瀚官大名知府時，督學御史阮鶚以世所行《名臣經濟錄》、《名臣奏議》二書去取猥雜，因屬瀚別加刪補，以成此本。略仿《宋名臣奏議》之例，分《君道》、《聖學》、《修省》、《厘正》、《納諫》、《史職》、《銓選》、《考課》、《財計》、《賦役》、《征榷》、《漕運》、《荒政》、《禮儀》、《律曆》、《陵廟》、《祀典》、《制科》、《學校》、《武備》、《征伐》、《撫治》、《馬政》、《禦邊》、《議獄》、《屯田》、《河渠》、《營繕》、《風紀》、《糾劾》三十門。然當時有所避忌，所載亦不能盡備也。","edition":"內府藏本"}],"juan_count":{"number":37}},"GYL53DiBaAs":{"id":"GYL53DiBaAs","type":"work","title":"嘉隆疏鈔","authors":[{"name":"張鹵","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《嘉隆疏鈔》•二十卷","author_info":"明張鹵編","summary":"明張鹵編。鹵字召和，儀封人，嘉靖乙未進士，曆官右副都御史，調南京太常寺卿。是編專錄嘉靖、隆慶兩朝臣僚奏疏，分三十七類，凡四百餘篇。蓋續張瀚《疏議輯略》而作。故類例雖稍有出入，而大致略相仿佛雲。","edition":"內府藏本"}],"juan_count":{"number":20}}}