{"GYL53PDvQGP":{"id":"GYL53PDvQGP","type":"work","title":"吳中往哲記","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《吳中往哲記》•一卷、《續吳中往哲記》•一卷、《續吳中往哲記補遺》•一卷","author_info":"《吳中往哲記》，明楊循吉撰","summary":"《吳中往哲記》，明楊循吉撰。《續記》、《補遺》，皆黃魯曾撰。循吉有《蘇州府纂修志略》，已著錄。魯曾字得之，吳縣人，正德丙子舉人。循吉書見《明史•藝文志》，卷數與此相符，記明初蘇州府人物，自《勳德》至《冠衲》，分七目，凡四十一人。《續記》自《忠節》至《散逸》，分十七目，凡四十人。《補遺》自《審進》至《釋行》，分十九目，凡三十一人。其《補遺》原目本一卷，此本分作二卷，又改其《釋行第十七》為“第一”，則刊刻者之誤也。書中所列小傳，皆寥寥數言，未見端末。又如徐有貞以險忮敗，而循吉稱為四海物望，蓋未免鄉曲之私。吳寬位終禮部尚書，而魯曾乃題作東閣大學士，尤顯然訛謬，則亦不足徵信矣。","edition":"浙江汪啟淑家藏本"}],"juan_count":{"number":1},"additional_works":[{"book_title":"續吳中往哲記","n_juan":1},{"book_title":"續吳中往哲記補遺","n_juan":1}],"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/吳中往哲記","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=980091","type":"text"},{"id":"shidianguji-mingkeben","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ89241199901862373724","type":"text+image","metadata":{"edition":"明刻本","version":"v1","total_page":166,"paragraph_count":1110,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53P7PX4B":{"id":"GYL53P7PX4B","type":"work","title":"尊鄉錄節要","authors":[{"name":"王弼","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《尊鄉錄節要》•四卷","author_info":"明王弼撰","summary":"明王弼撰。弼，黃岩人，成化乙未進士，官至興化府知府。初，謝鐸嘗著《尊鄉錄》四十一卷，載其鄉先達事實。弼複以己意其大略。取十大儒、五大臣、六忠臣、十五孝子，各為之《贊》。卷末附《拾遺》二十事，事各為詩。","edition":"浙江汪啟淑家藏本"}],"juan_count":{"number":4},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=2974224","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02048690","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":108,"paragraph_count":1160,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53P9X8Go":{"id":"GYL53P9X8Go","type":"work","title":"考亭淵源錄","authors":[{"name":"宋端儀","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《考亭淵源錄》•二十四卷","author_info":"明宋端儀撰","summary":"明宋端儀撰，薛應旂重修。端儀字孔時，莆田人。成化辛丑進士，官至廣東提學僉事，事蹟具《明史》本傳。應旂有《四書人物考》，已著錄。此編仿《伊洛淵源錄》之例，首列延平李侗，籍溪胡憲、屏山劉子翬、白水劉勉之四人，以溯師承之所自。次載朱子始末。次及同時友人，至南軒張栻以下七人。次則備列考亭門人，自勉齋黃榦以下二百九十三人。其二十三卷則門人之無記述文字者，但列其名，凡八十八人。末卷則考亭叛徒趙師雍、傅伯壽、胡紘等三人，亦用《伊洛淵源錄》載邢恕例也。史稱端儀慨建文朝忠臣湮沒，乃搜輯遺書，為《革除錄》。建文忠臣之有錄，自端儀始。然其書今未見，即此書原本亦未見，世所行者惟應旂重修之本。應旂作《宋元通鑒》，於道學宗派，多所紀錄，此書蓋猶是意。然應旂初學於王守仁，講陸氏之學。晚乃研窮洛、閩之旨，兼取朱子。故其書《目錄》後有雲：“兩先生實所以相成，非所以相反。”遂以陸九淵兄弟三人列《考亭淵源錄》中，名實未免乖舛也。","edition":"浙江吳玉墀家藏本"}],"juan_count":{"number":24},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=6490425","type":"text"},{"id":"shidianguji-tianbaokanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA04165","type":"text+image","metadata":{"edition":"天保09年刊本","version":"v9","total_page":938,"paragraph_count":3910,"check_type":"AI整理"}},{"id":"shidianguji-longqingkeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02083767","type":"text+image","metadata":{"edition":"隆慶刻本","version":"v4","total_page":927,"paragraph_count":3133,"check_type":"AI整理"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02048691","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":937,"paragraph_count":2261,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53PG6hLT":{"id":"GYL53PG6hLT","type":"work","title":"吳中故實記","authors":[{"name":"楊循吉","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《吳中故實記》•一卷、《續記》•一卷、《補遺》一卷","author_info":"舊本題明楊循吉撰","summary":"舊本題明楊循吉撰。檢勘其文，即循吉《吳中往哲記》、黃魯曾《往哲續記》、《補遺》原本。惟於標題中刊去“往哲”二字，易以“故實”二字。蓋書賈劖舊版，改易新名以售欺者也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":1},"additional_works":[{"book_title":"續記","n_juan":1},{"book_title":"補遺","n_juan":1}]},"GYL53PMoDCb":{"id":"GYL53PMoDCb","type":"work","title":"蘇材小纂","authors":[{"name":"祝允明","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《蘇材小纂》•六卷","author_info":"明祝允明撰","summary":"明祝允明撰。允明字希哲，長洲人，弘治壬子舉人，官至應天府通判，《明史•文苑傳》附見《徐禎卿傳》中。是書記天順以後蘇州人物。前有《自序》，稱弘治改元，詔中外諸司，撰集事蹟，上史館為實錄，簡允明等數弟子員司其事，因私纂紀為此書。第一曰《簪纓》，纂徐有貞以下十九人。第二曰《邱壑》，纂杜瓊以下五人。第三曰《孝德》，纂朱灝一人。第四曰《女憲》，纂王妙鳳以下三人。第五曰《方術》，纂張豫等二人。大約本之碑誌行狀，而稍為考據異同，注於本文之下。其敘徐有貞事，頗有諱飾。蓋允明為有貞外孫，親串之私，不能無所假借雲。","edition":"戶部尚書王際華家藏本"}],"juan_count":{"number":6}},"GYL53P5DDz7":{"id":"GYL53P5DDz7","type":"work","title":"宋遺民錄","authors":[{"name":"程敏政","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《宋遺民錄》•十五卷","author_info":"明程敏政撰","summary":"明程敏政撰。敏政字克勤，休甯人，成化丙戌進士，官至禮部右侍郎，事蹟具《明史•文苑傳》。此書前列王炎午、謝翱、唐玨三人事蹟，及其遺文。而後人詩文之為三人作者，並類列焉。七卷以後，則附錄張宏毅、方鳳、吳思齊、龔開、汪元量、梁棟、鄭思肖、林德暘等八人。第十五卷紀元順帝為宋瀛國公子，引余應詩、袁忠徹記以實之。至謂虞集私侍文宗之妃，說殊妄誕，所引亦自相矛盾。蓋文宗時嘗下詔書，稱順帝非明宗之子，斥居靜江。好事者因造為此言，其荒唐本不待辨。敏政乃從而信之，乖謬甚矣。","edition":"副都御史黃登賢家藏本"}],"juan_count":{"number":15},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=784070","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4605414","type":"text"},{"id":"shidianguji-xianghechangpinghong","name":"识典古籍","url":"https://www.shidianguji.com/book/NA04143","type":"text+image","metadata":{"edition":"享和03年昌平黌寫本","version":"v9","total_page":453,"paragraph_count":2648,"check_type":"AI整理"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02048684","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":455,"paragraph_count":576,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53P32vv3":{"id":"GYL53P32vv3","type":"work","title":"伊洛淵源續錄","authors":[{"name":"謝鐸","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《伊洛淵源續錄》•六卷","author_info":"明謝鐸撰","summary":"明謝鐸撰。鐸有《赤城論諫錄》，已著錄。是書所錄，凡二十一人。蓋繼朱子《伊洛淵源錄》而作，以朱子為宗主，始於羅從彥、李侗，朱子之學所自來也。佐以張栻、呂祖謙，朱子友也。自黃幹而下，終於何基、王柏，皆傳朱子之學者也。然所載張栻等七人，則全錄《宋史•道學傳》。呂祖謙等七人，則全錄《宋史•儒林傳》。李侗等六人，略采行狀、志銘、遺事。其輔廣一人，則但載姓名裏居，僅數十字而止，尤為疏略。案廣即世所稱慶源輔氏，《明一統志》載其始末甚詳，鐸偶未考耳。《明史》鐸本傳，載其為南京國子監祭酒時，上言六事。其三曰正祀典，乃請進宋儒楊時而退吳澄，為禮部尚書傅瀚所持，僅進時而澄祀如故。夫澄之學雖曰未醇，然較受蔡京之薦者則有間矣。鐸欲以易澄，蓋以道南一脈之故，而曲諱其出處也。然則是錄之作，其亦不出門戶之見矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=2465964","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02048682","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":1075,"paragraph_count":5050,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53PBk7CK":{"id":"GYL53PBk7CK","type":"work","title":"鹿城書院集","authors":[{"name":"鄧淮","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《鹿城書院集》•","author_info":"明鄧淮撰","summary":"明鄧淮撰。淮，吉水人，成化辛丑進士，弘治中官溫州府知府。以南宋時溫州之士游二程、張、朱之門者，有周行己等二十三人。乃命永嘉知縣汪循即鹿城建書院，祀二程、張、朱，而以行己等侑焉。複輯諸人志銘、家傳及其遺事緒論見於志書、語錄中者，匯為此編。雖亦講學家標榜之書，然永嘉學派，頗異新安。淮不分門戶於其間，則視黨同伐異者，其公私相去遠矣。","edition":"無卷數，浙江巡撫采進本"}]},"GYL53PKfbyy":{"id":"GYL53PKfbyy","type":"work","title":"掾曹名臣錄","authors":[{"name":"王瓊","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《掾曹名臣錄》•一卷、《續集》•一卷","author_info":"明王瓊撰","summary":"明王瓊撰。瓊有《晉溪奏議》，已著錄。是編乃瓊官南京戶部侍郎時，見諸吏中有知琴書可教誨者，因採錄明興以來由掾曹而列名臣者，編為此書，以示勸勉，凡劉敏等九人。又《續集》一卷，凡劉本等四人。前有正德甲戌瓊《自序》，後有南京戶部郎中卞師敏《跋》。","edition":"浙江範懋柱家天一閣藏本"}],"juan_count":{"number":1},"additional_works":[{"book_title":"續集","n_juan":1}],"resources":[{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY5877","type":"text+image","metadata":{"edition":"刻本","version":"v4","total_page":48,"paragraph_count":52,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true}}