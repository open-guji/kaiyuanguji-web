{"GYL53V6uZ5h":{"id":"GYL53V6uZ5h","type":"work","title":"昆山人物傳","authors":[{"name":"張大複","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《昆山人物傳》•十卷、《名宦傳》•一卷","author_info":"明張大複撰","summary":"明張大複撰。大複字元長，昆山人，與歸有光同時。是書舊本題曰《梅花草堂集》。而以《昆山人物傳》、《昆山名宦傳》為子目，蓋皆編入集中。故總以集名，實則各一書也。先是，方鵬有《昆山人物志》六卷。此則斷自明代，起洪武至萬曆，得三百餘人。其間父子祖孫以類附傳，略如史體。又於官是土者取十五人，為《名宦傳》附之。敍述尚為雅潔，而詞多揚詡，亦不免標榜之習。其《名宦傳》別有鈔本，題曰《玉峰名宦傳》，析為二卷。佚其中《王南昌傳》一篇，僅有十四人，又佚其論尾數行。蓋傳鈔脫漏，不及集本之完整也。","edition":"浙江鮑士恭家藏本"}],"juan_count":{"number":10},"related_works":[{"id":"GYLt1EeXwpb","title":"昆山名宦傳"}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=666537","type":"text"},{"id":"shidianguji-keqingyongzhengerwan","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02084334","type":"text+image","metadata":{"edition":"刻清雍正二年汪中鵬重修本","version":"v3","total_page":823,"paragraph_count":7309,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53VCc4wq":{"id":"GYL53VCc4wq","type":"work","title":"儒林全傳","authors":[{"name":"魏顯國","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《儒林全傳》•二十卷","author_info":"明魏顯國撰","summary":"明魏顯國撰。所錄自孔子至元吳澄，皆採錄前史，與《相臣傳》同。","edition":"浙江汪啟淑家藏本"}],"juan_count":{"number":20},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7536000","type":"text","details":"（明魏顯國撰"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02048870","type":"text+image","metadata":{"edition":"刻本","version":"v5","total_page":703,"paragraph_count":3397,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53V4gaAB":{"id":"GYL53V4gaAB","type":"work","title":"貧士傳","authors":[{"name":"黃姬水","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《貧士傳》•二卷","author_info":"明黃姬水撰","summary":"明黃姬水撰。姬水字淳父，吳縣人，黃省曾之侄也。是編載自周至明初貧士七十五人，各為之贊。漏略殊甚。至如莊周貸粟監河侯一事，亦列之貧士中，尤不倫也。","edition":"內府藏本"}],"juan_count":{"number":2},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/貧士傳","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=180433","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02048862","type":"text+image","metadata":{"edition":"刻本","version":"v5","total_page":95,"paragraph_count":70,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-wanlishenshishangbai","name":"识典古籍","url":"https://www.shidianguji.com/book/HY6230","type":"text+image","metadata":{"edition":"萬曆沈氏尚白齋刻本","version":"v4","total_page":108,"paragraph_count":76,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-keben-1","name":"识典古籍","url":"https://www.shidianguji.com/book/HY5923","type":"text+image","metadata":{"edition":"刻本","version":"v4","total_page":74,"paragraph_count":60,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL53VHexsh":{"id":"GYL53VHexsh","type":"work","title":"元相臣傳","authors":[{"name":"魏顯國","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《元相臣傳》•十二卷","author_info":"明魏顯國撰","summary":"明魏顯國撰。其書紀元代丞相自耶律楚材至普顏不花二十六人，各自為傳，全襲《元史》之文，未嘗別有搜討。又前後淩亂脫誤。如《元史•宰相表》載安童為右丞相，始世祖至元二年乙丑，訖於二十七年庚寅。不忽術為平章政事，始至元二十八年辛卯，訖成宗元貞二年丙申。是不忽術後於安童凡二十七年。此書列不忽術於安童前，殊為倒置。又如世祖庚申元年王文統、趙璧為平章政事，尤在史天澤諸人之前。其相業俱見本傳，而此書均汰之。蓋不特於正史之外無所徵引，且於正史之中亦多所掛漏矣。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":12}},"GYL53VfHr23":{"id":"GYL53VfHr23","type":"work","title":"鎮平世系記","authors":[{"name":"朱睦","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《鎮平世系記》•二卷","author_info":"明朱睦撰","summary":"明朱睦撰。睦有《易學識遺》，已著錄。永樂元年，封周定王第八子有爌為鎮平王，睦其六世孫也。以明代玉牒於正德以後多略，遂纂述有爌以下八世支派，以成此書。前曰《例義》，次《世系》，次《世傳》，次《內傳》，次《述訓》。","edition":"浙江範懋柱家天一閣藏本"}],"juan_count":{"number":2}},"GYL53Vz1ST9":{"id":"GYL53Vz1ST9","type":"work","title":"棲真志","authors":[{"name":"夏樹芳","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《棲真志》•四卷","author_info":"明夏樹芳撰","summary":"明夏樹芳撰。樹芳字茂卿，江陰人，萬曆乙酉舉人。是編取周秦至元代之修真棲靜者，各詳其事蹟，陳繼儒為之序。其中時代頗顛舛。至於江淹、謝靈運、李賀、歐陽修、蘇軾、黃庭堅、秦觀、朱子諸人，凡談論詞章，語意偶類釋老者，即引而入《志》，尤牽合不倫。","edition":"浙江巡撫采進本"}],"juan_count":{"number":4},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1151769","type":"text","details":"（明百般樹芳撰"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02048941","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":289,"paragraph_count":955,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53VawFsu":{"id":"GYL53VawFsu","type":"work","title":"春秋名臣傳","authors":[{"name":"姚咨","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《春秋名臣傳》•十三卷","author_info":"明姚咨撰","summary":"明姚咨撰。咨字舜咨，無錫人。初，其邑人邵寶為是書未畢，咨續成之。始於周之辛伯，迄於虞之宮之奇，凡一百四十八人，傳末各附以小贊。大旨與宋王當《春秋列國臣傳》相出入。而其義例乃譏當書用魯史編年之非。然既標以《春秋》，則自應用《春秋》之年月。若各從列國，轉致錯互難明。以是議當，未為允也。","edition":"浙江汪啟淑家藏本"}],"juan_count":{"number":13}},"GYL53VogDLB":{"id":"GYL53VogDLB","type":"work","title":"聖學宗傳","authors":[{"name":"周汝登","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《聖學宗傳》•十八卷","author_info":"明周汝登編","summary":"明周汝登編。汝登字繼元，又字海門，嵊縣人，萬曆丁丑進士，官至南京尚寶司卿，《明史•儒林傳》附載《王畿傳》。末稱王守仁傳王艮，艮傳徐樾，樾傳顏鈞，鈞傳羅汝芳，汝芳傳楊起元及汝登。起元清修姱節，然其學不諱禪。汝登更欲合儒釋而會通之，輯《聖學宗傳》，盡采先儒語類禪者以入。蓋萬曆以後，士大夫講學者多類此云云。即此書也。首載《黃卷正系圖》，其序自伏羲傳至伊川程子。下分二支。一支朱子以下，不系一人。一支則陸九淵之下系以王守仁。並稱卷是圖信陽明篤，敘統系明，與《聖學宗傳》足相發明雲。","edition":"兩淮馬裕家藏本"}],"juan_count":{"number":18},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=358775","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=84656","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4342986","type":"text","details":"（明周汝登撰"},{"id":"shidianguji-kanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA02207","type":"text+image","metadata":{"edition":"刊本(跋刊)","version":"v8","total_page":1476,"paragraph_count":1745,"check_type":"粗校"}},{"id":"shidianguji-wanlisanshisidongyue","name":"识典古籍","url":"https://www.shidianguji.com/book/HY2008","type":"text+image","metadata":{"edition":"萬曆三十四年(1606)東越王氏刻本（有抄補）","version":"v5","total_page":1492,"paragraph_count":13345,"check_type":"AI整理"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02048909","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":1468,"paragraph_count":12158,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53VKswoD":{"id":"GYL53VKswoD","type":"work","title":"忠節錄","authors":[{"name":"張朝瑞","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《忠節錄》•六卷","author_info":"明張朝瑞撰","summary":"明張朝瑞撰。朝瑞字子禎，海州人，隆慶戊辰進士，官至南京鴻臚寺卿。朝瑞以宋端儀《革除錄》至郎瑛《萃忠集》，記遜國諸臣事者凡十七家，互有舛漏，因輯此書。載當時湔雪之旨於卷首，明非私撰。自第一卷至五卷，記徐輝祖以下凡一百六十三人，附錄十六人。以官階為敘，不分差等。第六卷曰《考誤》。如辨建文於天順中由滇至京，唯太監吳亮識之。當時“三楊”皆其舊臣，不應僅一吳亮能識舊主。而建文時年六十四，亦不得有九十餘歲。其考證最為明確。所列十七家書外，尚有高璧之《幽光錄》、陸時中之《逸史》、薑清之《秘史》、王會之《野史》、袁褧之《奉天刑賞錄》諸書，朝瑞未及搜考，然大概已備於此矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=111996","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=871953","type":"text","details":"（明張朝瑞撰"},{"id":"shidianguji-wanlikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02084206","type":"text+image","metadata":{"edition":"萬曆刻本","version":"v5","total_page":338,"paragraph_count":1984,"check_type":"AI整理"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02048877","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":341,"paragraph_count":1385,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53VT4Swh":{"id":"GYL53VT4Swh","type":"work","title":"聖門人物志","authors":[{"name":"郭子章","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《聖門人物志》•十二卷","author_info":"明郭子章撰","summary":"明郭子章撰。子章有《蠙衣生易解》，已著錄。是書則子章官晉陽時所輯。凡遊於聖門與私淑而得從祀廟廡者，各為之小傳，附以贊論。首《孔子世家》，次《先賢》，次《先儒》，而以有明之會典祀儀終焉。其中雜以周汝登、羅汝芳諸人之論。其時心學橫流，故子章多主張其說。《孟子傳論》謂孔子之學，以從心所欲不逾矩為的。顏子從之末由，而孟子雲能者從之。又雲：心之官則思，即孔子從心之旨。猶主持門戶之見也。","edition":"江西巡撫采進本"}],"juan_count":{"number":12},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=663402","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=713292","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4620225","type":"text","details":"（明郭子章撰"},{"id":"shidianguji-wanliershierzhaoyank","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02083638","type":"text+image","metadata":{"edition":"萬曆二十二年趙彥刻本","version":"v6","total_page":467,"paragraph_count":2220,"check_type":"AI整理"}},{"id":"shidianguji-wanlifujiankeben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY3973","type":"text+image","metadata":{"edition":"萬曆福建刻本","version":"v5","total_page":496,"paragraph_count":1491,"check_type":"AI整理"}},{"id":"shidianguji-yetianminmingkeben","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ89241199902669073001","type":"text+image","metadata":{"edition":"葉天民明刻本","version":"v3","total_page":406,"paragraph_count":1386,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53Vwq9P5":{"id":"GYL53Vwq9P5","type":"work","title":"漢唐宋名臣錄","authors":[{"name":"李廷機","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《漢唐宋名臣錄》•五卷","author_info":"明李廷機撰","summary":"明李廷機撰。廷機字爾張，晉江人，萬曆癸未進士，官至禮部尚書、東閣大學士，諡文清，事蹟具《明史》本傳。是書所錄，自漢文翁至宋杜衍，凡六十人。《黃起士序》，謂其錄取嚴而用意微。蓋藉以諷當時廷臣，有為而發，故不求全備雲。","edition":"兩江總督采進本"}],"juan_count":{"number":5},"resources":[{"id":"shidianguji-kanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA02189","type":"text+image","metadata":{"edition":"刊本(序刊)","version":"v10","total_page":1011,"paragraph_count":620,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL53VXR35q":{"id":"GYL53VXR35q","type":"work","title":"國士懿軌","authors":[{"name":"余養蒙","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《國士懿軌》•十卷","author_info":"明余養蒙撰","summary":"明余養蒙撰。養蒙，臨海人。《自序》謂稟大中丞耿公之命而為之者。案《明史•耿定向傳》，弟定力，隆慶辛未進士，官至南京兵部右侍郎。時方為南京都御史，故稱大中丞也。書前有《定力序》，複有諭官屬文一首。大旨以當時專重科目，名實不副，故取古今來士子出於太學及以貲郎起家者，自列國訖明初，凡一百二十七人，刪節諸史及志乘各為之傳。意欲以矯偏重之弊。然舉一代之進士，概以籠鷹檻駒目之，殊不免於矯枉過直矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":10}},"GYL53V2beo1":{"id":"GYL53V2beo1","type":"work","title":"靖難功臣錄","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《靖難功臣錄》•一卷","author_info":"不著撰人名氏","summary":"不著撰人名氏。黃虞稷《千頃堂書目》有此書，而闕其卷數。此本為明嘉靖中魯藩宗人當㴐編入《明朝典故》者。只此一卷，未知為完書否也。所載姚廣孝、李友直、譚淵、朱能、張玉、武勝、顧成、李彬、孫岩、陳珪、劉中孚、徐忠、薛錄、陳賢、陳瑄、吳中、金忠、徐增壽凡十八人。後又附以封爵名數凡三十四人。敍述簡略，不足以資考證也。","edition":"左都御史張若溎家藏本"}],"juan_count":{"number":1},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/靖難功臣錄","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=838180","type":"text"}]},"GYL53VAfD91":{"id":"GYL53VAfD91","type":"work","title":"歷代相臣傳","authors":[{"name":"魏顯國","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《歷代相臣傳》•一百六十八卷","author_info":"明魏顯國撰","summary":"明魏顯國撰。顯國字汝忠，南昌人，隆慶丁卯舉人。是書《明史•藝文志》著錄，卷數與此本相合。大抵全鈔史傳原文，無所褒貶，亦無所考正。所敘歷代相臣職名，如南朝制一條，以梁初罷相國置丞相，罷丞相置司徒，後又置相國，位列丞相上。不知置相國列丞相上乃陳制，非梁制。又謂唐魏徵以秘書監參預朝政，始有“參議得失”、“參知政事”之名。不知其時先以吏部尚書杜淹參議朝政，故有是名。又謂開元以後宰相為鹽鐵、轉運、延資庫使，名尤不正。不知其時以宰相兼攝是官，非以是官為宰相。況其時太微宮使、太清宮使多以宰相兼之，不僅延資庫使也。又以李光弼列於宰相。不知光弼為河中節度，惟加平章，不治政事，乃唐之使相。唐末節度加侍中、中書令、三公、三師者甚多，皆使相，非宰相。載於史志者甚詳。元之參議中書省事，乃六曹管轄，官止四品，亦非宰相。故《元史•宰相表》不列是官。又元制三公非相職，故別立《三公三師表》。今俱列於宰相，舛訛既甚，掛漏尤多。至於各史《宰相列傳》，或采或置，茫無義例，更未免疏脫矣。","edition":"直隸總督采進本"}],"juan_count":{"number":168},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=164633","type":"text","details":"魏顯國"},{"id":"shidianguji-kanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA02190","type":"text+image","metadata":{"edition":"刊本","version":"v52","total_page":1953,"paragraph_count":1202,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-wanlisanshisidengyig","name":"识典古籍","url":"https://www.shidianguji.com/book/HY2053","type":"text+image","metadata":{"edition":"萬曆三十四年(1606)鄧以誥等刻本","version":"v15","total_page":965,"paragraph_count":779,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL53VNkYf1":{"id":"GYL53VNkYf1","type":"work","title":"吳中人物志","authors":[{"name":"張","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《吳中人物志》•十二卷","author_info":"明張撰","summary":"明張撰。字景春，長洲人。是編成於隆慶庚午。所輯吳中人物，上自成周，迄於明代。分《孝友》、《忠義》、《吏治》、《薦舉》、《宦跡》、《儒林》、《文苑》、《閨秀》、《逸民》、《流寓》、《列仙》、《方外》十二門，各系以論贊。同郡皇甫汸為之序。吳中人物，自王賓、楊循吉、祝允明、朱存理等遞有撰述。此本因而廣之，較諸家稍備。然事皆不著出典，未免無徵不信也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":12},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=8762301","type":"text"},{"id":"shidianguji-longqingzhangfengyiz","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02084319","type":"text+image","metadata":{"edition":"隆慶張鳳翼張燕翼刻本","version":"v6","total_page":567,"paragraph_count":3513,"check_type":"AI整理"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02048880","type":"text+image","metadata":{"edition":"刻本","version":"v6","total_page":568,"paragraph_count":3356,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53VQt9sd":{"id":"GYL53VQt9sd","type":"work","title":"輔世編","authors":[{"name":"唐鶴徵","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《輔世編》•六卷","author_info":"明唐鶴徵撰","summary":"明唐鶴徵撰。鶴徵有《周易象義》，已著錄。是書取明代諸臣，次其行事。起洪武初李善長、劉基，訖嘉靖中曾銑、胡宗愈，凡五十二人。崇禎間，其門人陳睿謨巡撫湖廣，為評校刊版。其敘稱戎務孔亟之時，輒取名臣傳略，仿其行事，多得變通之法。間嘗抄書有得，多與我師凝庵唐先生《輔世編》合者，因綜其成稿，翼以己意，勒成一書。則是編已不盡鶴徵原本矣。其所采諸人事實，多主戰略。蓋睿謨身在戎行，意切時用，有所為而為之者也。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":6}},"GYL53Vd7Ywy":{"id":"GYL53Vd7Ywy","type":"work","title":"戰國人才言行錄","authors":[{"name":"秦瀹","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《戰國人才言行錄》•十卷","author_info":"明秦瀹撰","summary":"明秦瀹撰。瀹，無錫人。是書成於隆慶中。類次戰國人物，起魏文侯，迄荊軻，凡一百四十九人，皆抄錄《戰國策》、《史記》之文而稍刪節之。","edition":"浙江範懋柱家天一閣藏本"}],"juan_count":{"number":10},"resources":[{"id":"shidianguji-jingyeshuyuankanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA02187","type":"text+image","metadata":{"edition":"敬業書院刊本","version":"v6","total_page":267,"paragraph_count":2067,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53VmpjEF":{"id":"GYL53VmpjEF","type":"work","title":"貂璫史鑒","authors":[{"name":"張世則","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《貂璫史鑒》•四卷","author_info":"明張世則撰","summary":"明張世則撰。世則，諸城人，萬曆甲戌進士，官至四川安綿兵備副使。是書嘗於萬曆二十年進呈，得旨下禮部，禮部覆疏附焉。書凡六條。一曰《主君》，首載明太祖禁抑內臣不得干預外事，然後敘歷代寵閹之弊。二曰《弼臣》，載歷朝相臣與宦寺離合之跡。三曰《妍範》，載閹之賢者。四曰《媸戒》，載閹之惡者。五曰《國祚》，載秦漢以來寺人之尤能亂國者。六曰《沿革》，則閹宦職官志也。宦寺賢者，萬中不得一二。世則方指陳炯戒，將以啟迪君心。而所列《妍範》一條，如勃鞮之斬袪、繆賢之薦士、裴寂之宮人私侍、高力士之贊立太子，皆目為佳事，殊多謬戾。又列及明代寺人，而以阮安預其間，益不可訓矣。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":4},"resources":[{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02048905","type":"text+image","metadata":{"edition":"刻本","version":"v6","total_page":347,"paragraph_count":1025,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-mingwanlikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ89241199900548498732","type":"text+image","metadata":{"edition":"明萬曆刻本","version":"v1","total_page":354,"paragraph_count":3373,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53VVEk1m":{"id":"GYL53VVEk1m","type":"work","title":"豫章書","authors":[{"name":"郭子章","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《豫章書》•一百二十二卷","author_info":"明郭子章撰","summary":"明郭子章撰。是書蓋江西之總志，全用史體為之。分《大記》二十卷、《志》二十二卷、《表》十卷、《事紀》二卷、《列傳》六十八卷，前無《序》而有《總目》。其《總目》以為《列傳》六十六卷，刊本誤也。其體例蓋本諸《華陽國志》。然冗雜太甚，去常璩所撰遠矣。","edition":"江西巡撫采進本"}],"juan_count":{"number":122}},"GYL53VEnN1u":{"id":"GYL53VEnN1u","type":"work","title":"歷代守令傳","authors":[{"name":"魏顯國","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《歷代守令傳》•二十四卷","author_info":"明魏顯國撰","summary":"明魏顯國撰。自宓不齊、仲由至劉秉直，為《歷代循吏》二十一卷。又自郅都至敬羽，為《歷代酷吏》三卷。於史傳原文之外，間有所增，而亦多蕪雜。","edition":"兩淮馬裕家藏本"}],"juan_count":{"number":24}},"GYL53VjeSAB":{"id":"GYL53VjeSAB","type":"work","title":"宗譜纂要","authors":[{"name":"王應昌","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《宗譜纂要》•一卷","author_info":"明王應昌撰","summary":"明王應昌撰，其子錟續成之。應昌字亮之，嵊縣人，萬曆癸酉舉人。錟字長穎，入國朝官上海縣知縣。是書敘歷代理學源流。分《開天一世祖》、《承天第一宗》、《達天第一宗》、《翼天第一宗》。標目已近乎二氏。至以荀卿、揚雄與孔子並列，尤為失倫。其分載諸儒支派，大率與黃宗羲《明儒學案》相出入。蓋為門戶而設，不為學問而設也。","edition":"安徽巡撫采進本"}],"juan_count":{"number":1}},"GYL53VsZvwq":{"id":"GYL53VsZvwq","type":"work","title":"歷朝璫鑒","authors":[{"name":"徐學聚","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《歷朝璫鑒》•四卷","author_info":"明徐學聚撰","summary":"明徐學聚撰。學聚字敬輿，蘭谿人，萬曆癸未進士，官至副都御史，巡撫福建。是編輯錄歷代宦官事蹟，自周秦以迄於明。分“善可為法”、“惡可為戒”二種，而於明代紀載尤詳。第所錄僅至世宗朝而止，則仍不免有所避忌。又元李邦寧，即嘗入太學代祀孔子，致大風滅燭之異者，其狂妄可知，乃入之“善可為法”中，進退亦未甚允也。","edition":"編修汪如藻家藏本"}],"juan_count":{"number":4}},"GYL53VuhYAT":{"id":"GYL53VuhYAT","type":"work","title":"鹽梅志","authors":[{"name":"李茂春","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《鹽梅志》•二十卷","author_info":"明李茂春撰","summary":"明李茂春撰。茂春字蔚元，杞縣人，萬曆癸未進士，是編採取歷代賢相嘉言善行，錄成一編。始於皋陶，終於範純仁，凡六十六人。","edition":"內府藏本"}],"juan_count":{"number":20},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=226068","type":"text","details":"李茂春"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1086723","type":"text","details":"（明李茂春輯"},{"id":"shidianguji-wanlisanshiqikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY2081","type":"text+image","metadata":{"edition":"萬曆三十七年(1609)刻本","version":"v11","total_page":924,"paragraph_count":2057,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-wanlikanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA02191","type":"text+image","metadata":{"edition":"萬曆37年刊本","version":"v8","total_page":920,"paragraph_count":3526,"check_type":"AI整理"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02048926","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":905,"paragraph_count":4082,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53VhU967":{"id":"GYL53VhU967","type":"work","title":"江右名賢編","authors":[{"name":"喻均、劉元卿同","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《江右名賢編》•二卷","author_info":"明喻均、劉元卿同撰","summary":"明喻均、劉元卿同撰。均，新建人，隆慶戊辰進士，官至按察使副使。元卿有《易大象觀》，已著錄。萬曆中，巡按江西御史臨清陳大夔議修通志。因先欲輯《名賢》一門，屬均與元鄉司其事。分《名臣》、《節義》、《理學》、《忠諫》、《方正》、《清介》、《隱逸》、《儒行》、《治功》、《文學》、《孝友》十一目。所紀凡二百四十有八人。門類太多，頗涉瑣碎。又所載有明一代人物，尤為氾濫。前有巡撫都御史邊維垣及大夔《序》，後有元卿《序》。元卿謂理一而已，安得紛紛區目。則知分目冗複，出於均意，即元卿亦心非之矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":2},"resources":[{"id":"shidianguji-wanlikanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA04173","type":"text+image","metadata":{"edition":"萬曆20年刊本","version":"v4","total_page":324,"paragraph_count":2470,"check_type":"AI整理"}}],"has_text":true,"has_image":true}}