{"GYL53eSDnMM":{"id":"GYL53eSDnMM","type":"work","title":"全史論贊","authors":[{"name":"項篤壽","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《全史論贊》•八十卷","author_info":"明項篤壽編","summary":"明項篤壽編。篤壽有《小司馬奏草》，已著錄。是書以諸史浩繁，難於尋究，特撮其《論贊》，以備觀覽。凡《史記》七卷，《漢書》六卷，《後漢書》五卷，《三國志》三卷，《晉書》四卷，《宋書》、《南齊書》各三卷，《梁書》二卷，《陳書》、《魏書》各三卷，《北齊書》、《後周書》、《南史》各二卷，《北史》三卷，《隋書》二卷，《唐書》七卷，《五代史》五卷，《宋史》六卷，《遼史》、《金史》、《元史》各四卷。然讀史必先知其事之始末，而後可斷其人之是非。今篤壽惟存其《論》，使稱善者不知其所以善，稱惡者不知其所以惡，仍於讀史者無益也。","comment":"（案此書皆取《論贊》，宜入《史評》，然皆摘錄於諸史，非所自評也。故仍入之《史鈔類》焉。）","edition":"江蘇巡撫采進本"}],"juan_count":{"number":80},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=252267","type":"text"}]},"GYL53ed4ZrF":{"id":"GYL53ed4ZrF","type":"work","title":"史觿","authors":[{"name":"謝肇淛","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《史觿》•十七卷","author_info":"明謝肇淛撰","summary":"明謝肇淛撰。肇淛字在杭，福建長樂人，萬曆壬辰進士，官至廣西右布政使，《明史•文苑傳》附見《鄭善夫傳》中。是書摘“十七史”中隱僻字句。標列成編。凡一史為一卷。謂之“觿”者，《自序》以為解結之義。人之有疑甚於結，故求其解而筆之也。然於《史》、《漢》、《三國》諸書，原有舊注者，所載尚為明晰。於《晉書》以下原本無注者，亦僅錄舊文，絕無考證，仍不足以釋學者之疑。則所雲求其解者，亦徒虛語矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":17},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=185987","type":"text"},{"id":"shidianguji-chongzhensanjiananhu","name":"识典古籍","url":"https://www.shidianguji.com/book/HY2091","type":"text+image","metadata":{"edition":"崇禎三年(1630)建安黃氏景晉齋刻本","version":"v9","total_page":839,"paragraph_count":4236,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53eMut4f":{"id":"GYL53eMut4f","type":"work","title":"兩漢雋言","authors":[{"name":"淩迪知","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《兩漢雋言》•十卷","author_info":"明淩迪知編","summary":"明淩迪知編。宋林越作《漢雋》，所采止於《西漢》。迪知因仿越體例，輯《後漢》故實，與越書合為一編，改題今名。自第一卷至十卷，皆林氏之舊，題曰《前集》。十一卷至十六卷，迪知所續者，題曰《後集》。采摭亦備。然不自為一書，而補葺舊本，創立新名，是則明人之結習矣。","edition":"內府藏本"}],"juan_count":{"number":10},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=528525","type":"text","details":"林越、凌迪知、劉兼、林越"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=643800","type":"text","details":"林越、凌迪知、劉兼、林越"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=982100","type":"text","details":"林越、凌迪知、劉兼、林越"},{"id":"shidianguji-wanlisilingshiguizhi","name":"识典古籍","url":"https://www.shidianguji.com/book/HY2085","type":"text+image","metadata":{"edition":"萬曆四年(1576)凌氏桂芝館刻文林綺繡本","version":"v14","total_page":726,"paragraph_count":105,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL53ei7Tn7":{"id":"GYL53ei7Tn7","type":"work","title":"史臠","authors":[{"name":"余文龍","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《史臠》•二十五卷","author_info":"明余文龍編","summary":"明余文龍編。文龍字起潛，古田人，萬曆辛丑進士，官南京工部主事。其書雜錄舊史，餖飣殊甚，與《讀史快編》正同。但《快編》止於《唐》，此則抄至《金》、《元》耳。","edition":"兩江總督采進本"}],"juan_count":{"number":25},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=8149836","type":"text"},{"id":"shidianguji-wanlikanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA02271","type":"text+image","metadata":{"edition":"萬曆46年刊本","version":"v11","total_page":2504,"paragraph_count":20938,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53eQ6B8j":{"id":"GYL53eQ6B8j","type":"work","title":"四史鴻裁","authors":[{"name":"穆文熙","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《四史鴻裁》•四十卷","author_info":"明穆文熙編","summary":"明穆文熙編。文熙有《七雄策纂》，已著錄。是編選錄《左傳》十二卷、《國語》八卷、《戰國策》八卷、《史記》十二卷，皆略注字義，無所發明，批點尤為弇陋。其括此四書曰“四史”，亦杜撰無稽也。","edition":"通行本"}],"juan_count":{"number":40},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=831401","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=2545818","type":"text"},{"id":"shidianguji-wanlishibadongjunzhu","name":"识典古籍","url":"https://www.shidianguji.com/book/HY4010","type":"text+image","metadata":{"edition":"萬曆十八年(1590)東郡朱朝聘山西刻本","version":"v9","total_page":2337,"paragraph_count":31454,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53euZBMq":{"id":"GYL53euZBMq","type":"work","title":"讀史集","authors":[{"name":"楊以任","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《讀史集》•四卷","author_info":"明楊以任撰","summary":"明楊以任撰。以任字維節，瑞金人，崇禎辛未進士，官國子監博士。是編摘諸史中事蹟之可快可恨及有膽有識者，分為《快》、《恨》、《膽》、《識》四集，每條下略綴評語，詞多佻纖。","edition":"江蘇周厚堉家藏本"}],"juan_count":{"number":4},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7033605","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02049988","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":846,"paragraph_count":5657,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53eEn4md":{"id":"GYL53eEn4md","type":"work","title":"史要編","authors":[{"name":"梁夢龍","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《史要編》•十卷","author_info":"明梁夢龍編","summary":"明梁夢龍編。夢龍字乾吉，真定人，嘉靖癸丑進士，官至吏部尚書，諡貞敏，事蹟具《明史》本傳。其書雜采諸史之文為《正史》三卷、《編年》三卷、《雜史》三卷、《史評》一卷。《自序》謂學者罕睹全史，是編上下數千載，盛衰得失之跡，大凡具在，蓋為鄉塾無書者設也。","edition":"浙江範懋柱家天一閣藏本"}],"juan_count":{"number":10},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=3379446","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02049763","type":"text+image","metadata":{"edition":"刻本","version":"v5","total_page":390,"paragraph_count":1008,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53e1kzCf":{"id":"GYL53e1kzCf","type":"work","title":"兩晉南北奇談","authors":[{"name":"王渙","role":"撰","dynasty":"宋"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《兩晉南北奇談》•六卷","author_info":"舊本題宋王渙撰","summary":"舊本題宋王渙撰。渙為仁宗慶曆末睢陽五老之一。王辟之《澠水燕談》，稱其官為太子賓客，祝穆《事文類聚》載錢明逸《五老會詩序》，稱為太原人，其事蹟則未詳。然世僅傳渙《五老會詩》一首，不聞其著此書。鄭樵以下諸家書目，亦不著錄。考太學進士題名碑，弘治丙辰科有王渙，象山人。《明史•藝文志》有渙所著《墨池手錄》三卷。此本自稱墨池王渙，與墨池之號相合，知此書為明王渙撰。其稱太原，蓋舉郡望耳。其書摘錄《晉書》以下八史瑣語雜事。王士禎《居易錄》稱，嘗見書賈攜《兩晉奇談》，不雲誰作，疑即此書也。","edition":"兩江總督采進本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1702329","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02049581","type":"text+image","metadata":{"edition":"刻本","version":"v5","total_page":177,"paragraph_count":248,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL53e67aLo":{"id":"GYL53e67aLo","type":"work","title":"讀書漫筆","authors":[{"name":"方瀾","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《讀書漫筆》•十八卷","author_info":"明方瀾撰","summary":"明方瀾撰。瀾，莆田人，正德丁丑進士，官禮部郎中。是書上自《漢書》，下迄《唐書》，隨筆採摘其字句，兼及訓詁，亦時論斷其是非，發明殊鮮。","edition":"兩淮馬裕家藏本"}],"juan_count":{"number":18}},"GYL53eCZ5r7":{"id":"GYL53eCZ5r7","type":"work","title":"史記鈔","authors":[{"name":"茅坤","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《史記鈔》•六十五卷","author_info":"明茅坤編","summary":"明茅坤編。坤有《徐海本末》，已著錄。是編刪削《史記》之文，亦略施評點。然坤雖好講古文，恐未必能刊正司馬遷也。","edition":"兩江總督采進本"}],"juan_count":{"number":65},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=761316","type":"text"},{"id":"shidianguji-taichangyuanwuchengm","name":"识典古籍","url":"https://www.shidianguji.com/book/SDZJ0103","type":"text+image","metadata":{"edition":"泰昌元年乌程闵氏刊朱墨套印本","version":"v7","total_page":2286,"paragraph_count":1033,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL53efCB4s":{"id":"GYL53efCB4s","type":"work","title":"讀史快編","authors":[{"name":"趙維寰","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《讀史快編》•四十四卷","author_info":"明趙維寰撰","summary":"明趙維寰撰。維寰字無聲，平湖人，萬曆庚子舉人。是書於諸史之中摘錄其新異之事，始於《史記》，迄《新唐書》，割裂翦裁，漫無義例。","edition":"內府藏本"}],"juan_count":{"number":44}},"GYL53eWXge3":{"id":"GYL53eWXge3","type":"work","title":"古今彝語","authors":[{"name":"汪應蛟","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《古今彝語》•十二卷","author_info":"明汪應蛟撰","summary":"明汪應蛟撰。應蛟字潛夫，婺源人，萬曆甲戌進士，官至戶部尚書，諡清簡，事蹟具《明史》本傳。是書雜錄史文，上起唐、虞，下迄於元，去取漫無義例，特興之所至而已。","edition":"浙江巡撫采進本"}],"juan_count":{"number":12},"resources":[{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02049835","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":951,"paragraph_count":9254,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53eorfVh":{"id":"GYL53eorfVh","type":"work","title":"二十一史論贊輯要","authors":[{"name":"彭以明","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《二十一史論贊輯要》•三十六卷","author_info":"明彭以明編","summary":"明彭以明編。以明，廬陵人，萬曆中諸生。是編採錄諸史《論贊》，以課其子。抄撮之學，非讀史之正法也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":36},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=321794","type":"text","details":"彭以明、彭惟成、彭惟直"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=694826","type":"text","details":"彭以明、周起元、袁文紹"},{"id":"shidianguji-wanlisanshiqipengwei","name":"识典古籍","url":"https://www.shidianguji.com/book/HY2105","type":"text+image","metadata":{"edition":"萬曆三十七年(1609)彭惟成、彭惟直刻本","version":"v27","total_page":2067,"paragraph_count":2441,"check_type":"AI整理"}},{"id":"shidianguji-wanlikanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA02264","type":"text+image","metadata":{"edition":"萬曆39年刊本","version":"v11","total_page":1894,"paragraph_count":2059,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53eARUdV":{"id":"GYL53eARUdV","type":"work","title":"史纂左編","authors":[{"name":"唐順之","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《史纂左編》•一百二十四卷","author_info":"明唐順之撰","summary":"明唐順之撰。順之有《廣右戰功錄》，已著錄。是書以歷代正史所載君臣事蹟，纂集成編。別立義例，分《君》、《相》、《名臣》、《謀臣》、《後》、《公主》、《戚》、《儲》、《宗》、《宦》、《幸》、《奸》、《篡》、《亂》、《莽》、《鎮》、《夷》、《儒》、《隱逸》、《獨行》、《烈婦》、《方技》、《釋》、《道》凡二十四門。其意欲取千古興衰治亂之大者，切著其所以然，故其體與他史稍異。然其間詳略去取，實有不可解者。如《君紀》只列漢、唐、宋三朝，偏安者皆不得與，而隗囂、公孫述、李筠、李重進諸人乃反附入。於列代宦官酷吏敘之極詳，固將以垂鑒戒，而唐之楊複恭、來俊臣、周興等尤為元惡巨憝，乃反見遺。又以房琯為中興之相、高駢為平亂之將，褒貶既已失平。以紇石烈為人名，姓氏幾於莫辨。其他妄為升降，顛倒乖錯之處，不可勝言。殆與李贄之《藏書》狂誕相等。乃贄《書》世猶多相詬病，而是編獨未有糾其失者，殆震於順之之名，不敢議歟。","edition":"安徽巡撫采進本"}],"juan_count":{"number":124}},"GYL53eGrz8o":{"id":"GYL53eGrz8o","type":"work","title":"左國腴詞","authors":[{"name":"淩迪知","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《左國腴詞》•八卷","author_info":"明淩迪知撰","summary":"明淩迪知撰。迪知字穉哲，烏程人，嘉靖丙辰進士，官至兵部員外郎。是編采《左傳》、《國語》字句，分類編輯。凡《左傳》五卷，為類四十；《國語》三卷，為類四十有三。所摘皆僅存一二語，既不具其始末，又不標為何人之言。且注與正文，混淆不辨。非惟不足以資考證，並不可以供撏撦。與所撰《太史華句》、《兩漢雋言》、《文選錦字》諸書，體例皆仿林越《漢雋》。而冗雜破碎，又出《漢雋》之下。如“以從欲鮮濟”一語，列之《澗溪類》中，蓋誤以為“濟川”之“濟”也。是尚足與論乎？","edition":"內府藏本"}],"juan_count":{"number":8},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=117329","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=245858","type":"text"},{"id":"shidianguji-kanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA04404","type":"text+image","metadata":{"edition":"刊本","version":"v4","total_page":316,"paragraph_count":2123,"check_type":"AI整理"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02049767","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":314,"paragraph_count":2283,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53ekz4du":{"id":"GYL53ekz4du","type":"work","title":"南北史鈔","authors":[{"name":"周詩雅","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《南北史鈔》•","author_info":"明周詩雅撰","summary":"明周詩雅撰。詩雅字廷吹，武進人，萬曆己未進士。是編摘錄《南北史》新奇纖佻之事，以為談助，然不及後來沈名蓀、朱昆田書之有條理。","edition":"無卷數，兩江總督采進本"}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=3810273","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02049965","type":"text+image","metadata":{"edition":"刻本","version":"v4","total_page":913,"paragraph_count":4342,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53e3wHGj":{"id":"GYL53e3wHGj","type":"work","title":"分類通鑒","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《分類通鑒》•四卷","author_info":"不著撰人名氏","summary":"不著撰人名氏。明弘治中河間知府施槃刊於郡齋，亦不雲誰作。其書分類猥雜，標題弇陋，蓋即《通鑒總類》之節本，又沈樞之重佁矣。","edition":"兩江總督采進本"}],"juan_count":{"number":4}},"GYL53eUMPZy":{"id":"GYL53eUMPZy","type":"work","title":"宋史纂要","authors":[{"name":"王思義","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《宋史纂要》•二十卷","author_info":"明王思義撰","summary":"明王思義撰。思義字允明，松江人。《宋史》極為煩冗，是書僅刪存二十卷，可謂約矣。然班、範皆號謹嚴，而兩《漢書》卷帙猶富。宋之歷年，幾於匹漢，而縮為寥寥數卷，謂事增文省，殆必不然。至以《遼金史》附宋之後，等諸《晉書》之載劉、石，尤南北史臣互相詬厲之見，非公論也。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":20}},"GYL53eatGnB":{"id":"GYL53eatGnB","type":"work","title":"史裁","authors":[{"name":"吳士奇","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《史裁》•二十六卷","author_info":"明吳士奇撰","summary":"明吳士奇撰。士奇字無奇，歙縣人，萬曆壬辰進士，官至太常寺卿。是書節錄史文，始自春秋，迄於宋元，雜采舊論，亦間以己意斷之。既非編年，又非紀傳，惟隨意抄撮而已。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":26},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=5253003","type":"text"}]},"GYL53ergaW3":{"id":"GYL53ergaW3","type":"work","title":"史品赤函","authors":[{"name":"陳仁錫","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《史品赤函》•四卷","author_info":"明陳仁錫編","summary":"明陳仁錫編。仁錫有《係詞十篇書》，已著錄。是編所錄，上起古初，下迄於《晉書》，或采其文，或節錄一二事，茫無義例。尤時時參以偽撰。如《雲長遇害不屈》一篇，不知其從何來，而《劉聰辱懷湣》一篇，稱聰為漢昭烈玄孫，雲出《續三國志》，亦未見有是書也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":4}},"GYL53exUU55":{"id":"GYL53exUU55","type":"work","title":"宋史存","authors":[{"name":"文德翼","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《宋史存》•二卷","author_info":"明文德翼撰","summary":"明文德翼撰。德翼字用昭，德化人，崇禎甲戌進士，官嘉興府推官。是編采掇《宋史列傳》，而刪潤其文。始於宗澤，終於文天祥。蓋福王時所作，故獨寓意於紹興以後雲。","edition":"浙江鮑士恭家藏本"}],"juan_count":{"number":2}},"GYL53eYhyi7":{"id":"GYL53eYhyi7","type":"work","title":"史書纂略","authors":[{"name":"馬維銘","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《史書纂略》•二百二十卷","author_info":"明馬維銘撰","summary":"明馬維銘撰。維銘字新甫，平湖人，萬曆庚辰進士，官至兵部職方司主事。是書取“二十一史”《本紀》、《列傳》，各撮取大略，匯成一編。蓋亦通史之例。然去取失宜，疏略太甚，非博非約，殆兩無所居也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":220},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=5244453","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02049847","type":"text+image","metadata":{"edition":"刻本","version":"v5","total_page":7812,"paragraph_count":50105,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53eKjazb":{"id":"GYL53eKjazb","type":"work","title":"太史華句","authors":[{"name":"淩迪知","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《太史華句》•八卷","author_info":"明淩迪知編","summary":"明淩迪知編。是編成於萬曆丁丑。《明史•藝文志》著錄，卷數與此本相同。皆摘《史記》字句，以類編次。司馬遷史家巨擘，其文豈可以句摘，句又豈可以華目。蓋王、李割剝秦、漢之風，至明季而未殄，故書肆尚鐫此等書，以投時好耳。","edition":"浙江汪啟淑家藏本"}],"juan_count":{"number":8},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=118552","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=869367","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02049771","type":"text+image","metadata":{"edition":"刻本","version":"v5","total_page":311,"paragraph_count":70,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-wanlikanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA04402","type":"text+image","metadata":{"edition":"萬曆刊本","version":"v5","total_page":316,"paragraph_count":2080,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53e8FBZR":{"id":"GYL53e8FBZR","type":"work","title":"諸史品節","authors":[{"name":"陳深","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《諸史品節》•三十九卷","author_info":"明陳深編","summary":"明陳深編。深有《周禮訓雋》，已著錄。是書所采，自《國語》以及《後漢書》，皆隨意雜鈔，漫無體例。","edition":"兩江總督采進本"}],"juan_count":{"number":39},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=193857","type":"text","details":"陳深"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=5905737","type":"text"},{"id":"shidianguji-wanlikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY2112","type":"text+image","metadata":{"edition":"萬曆刻本","version":"v17","total_page":3677,"paragraph_count":8839,"check_type":"AI整理"}}],"has_text":true,"has_image":true}}