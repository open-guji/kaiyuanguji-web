{"GYL53x5xvHu":{"id":"GYL53x5xvHu","type":"work","title":"萬曆嚴州府志","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《萬曆嚴州府志》•二十四卷","summary":"是書為萬曆甲寅所修。首頁題名，叢雜無緒。或曰主修，或曰同修，或曰纂修，或曰續修，或曰彙集，莫知撰人為誰。蓋與事者爭欲附名，故瞀亂如是。前載舊志凡例，頗見體裁。是志乃不肯遵用之，多所更張，務求諧俗。則其書可知矣。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":24}},"GYL53xS58JT":{"id":"GYL53xS58JT","type":"work","title":"海昌外志","authors":[{"name":"談遷","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《海昌外志》•","author_info":"國朝談遷撰","summary":"國朝談遷撰。遷字孺木，一字仲木，海寧人。是志題曰“海昌”，以海甯為吳海昌郡，從古名也。書不分卷帙，所列凡《輿地》、《食貨》、《職官》、《建置》、《選舉》、《人物》、《叢談》、《藝文》八門。以篇頁計之，當為八卷，偶未標題耳。遷學頗博涉，較舊志多所考證。而人物瑣分門類，典籍不詳卷帙，猶沿地志之積習焉。","edition":"無卷數，浙江巡撫采進本"}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=8020266","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02051727","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":684,"paragraph_count":8661,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53xcuuoM":{"id":"GYL53xcuuoM","type":"work","title":"杭志三詰三誤辨","authors":[{"name":"毛奇齡","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《杭志三詰三誤辨》•一卷","author_info":"國朝毛奇齡撰","summary":"國朝毛奇齡撰。奇齡有《仲氏易》，已著錄。是編因杭州舊志稱“今地本皆江水，由隋、唐來人力畚築而成”，因為此辨。三詰者，一詰秦定會稽郡有海鹽、餘杭、錢塘、富春四縣，何以錢塘獨無地；二詰西部都尉為重鎮，何以僻處靈隱山中；三詰由富春以至海寧，無不兩岸平地，緣江如線，何以上一折甫接吳山，忽西翻靈隱，下一折不走龕赭，忽北越臨平。三誤者，一由劉道真《錢塘記》誤讀《漢書》“西部都尉治武林山，武林水所出，東入海”之文。不以“西部都尉治”為句，而以“治武林山”為句；二由不考劉昭注《郡國志》已駁秦始皇由餘杭渡江之說，而仍襲其誤；三由江水東合臨浦，而劉氏誤以臨浦為臨湖，又誤以臨湖為臨平湖。又附載宋之問《靈隱寺詩》、“吳越王鐵幢浦”二條。以為不足辨者，不在所詰所辨之數焉。","edition":"浙江巡撫采進本"}],"juan_count":{"number":1},"resources":[{"id":"shidianguji-qingkangxijiankeben","name":"识典古籍","url":"https://www.shidianguji.com/book/NLG312001070654","type":"text+image","metadata":{"edition":"清康熙間[1662-1722]刻本","version":"v2","total_page":26,"paragraph_count":25,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53xhDp63":{"id":"GYL53xhDp63","type":"work","title":"臺灣紀略","authors":[{"name":"林謙光","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《臺灣紀略》•一卷","author_info":"國朝林謙光撰","summary":"國朝林謙光撰。謙光字芝楣，長樂人。是編乃康熙二十三年平定鄭克塽以後所作。分十三篇，一曰《形勢》，二曰《沿革》，三曰《建置》，四曰《山川》，五曰《沙線礁嶼》，六曰《城郭》，七曰《戶役賦稅》，八曰《學校選舉》，九曰《津梁》，十曰《天時》，十一曰《地理》，十二曰《風俗》，十三曰《物產》，而附以《澎湖版圖》。開闢之初，規模草創。故其文皆略存梗概，不及新志之詳明。然固新志之椎輪也。","edition":"大學士英廉購進本"}],"juan_count":{"number":1}},"GYL53xqvzNK":{"id":"GYL53xqvzNK","type":"work","title":"遼載前集","authors":[{"name":"林本裕","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《遼載前集》•二卷","author_info":"國朝林本裕撰","summary":"國朝林本裕撰。本裕字益長，奉天人。是編備載盛京故事，自序云：“折衷於《盛京志》。《前集》則仿龍門志乘，《後集》則仿涑水編年。”今《後集》未見，此其《前集》也。首《總論》，次《圖考》，餘分二十一門，亦頗勤於搜采。然留都記載，而地名仍題前代之稱，於體例終為乖迕。是亦不檢之過也。","edition":"兩淮馬裕家藏本"}],"juan_count":{"number":2}},"GYL53x8Eb4s":{"id":"GYL53x8Eb4s","type":"work","title":"天台縣志","authors":[{"name":"張宏代","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《天台縣志》•二十卷","author_info":"明張宏代撰","summary":"明張宏代撰。胡來聘續修。宏代，靈壁人。來聘，全州人。皆天台知縣也。宏代書不知成於何年，來聘所續則成於萬曆乙卯。前十三卷，隨事立類，為大目十一，小目五十有八。詩文別為七卷，附於後。","edition":"兩淮馬裕家藏本"}],"juan_count":{"number":20},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=383414","type":"text","details":"李德燿"},{"id":"shidianguji-kangxiershierkeben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY0166","type":"text+image","metadata":{"edition":"康熙二十二年刻本","version":"v15","total_page":1438,"paragraph_count":2839,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-qingkangxikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/NLG312001074579","type":"text+image","metadata":{"edition":"清康熙23年[1684]刻本","version":"v3","total_page":1136,"paragraph_count":10471,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53xB4W5D":{"id":"GYL53xB4W5D","type":"work","title":"泰州志","authors":[{"name":"劉萬春","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《泰州志》•十卷","author_info":"明劉萬春撰","summary":"明劉萬春撰。萬春字公孕，泰州人。萬曆丙辰進士，官至浙江布政司參政。是書成於崇禎癸酉，與他志體例略同，而意主黜偽存真，頗不徇其鄉曲。其論學究而驀理學之堂，方技而割隱君之席，及諛墓之文，雖工不錄者，皆切中州郡志書之弊也。","edition":"兩淮馬裕家藏本"}],"juan_count":{"number":10},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=857986","type":"text","details":"褚世暄"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=6426651","type":"text","details":"王有慶"},{"id":"shidianguji-yongzhengliukeben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY0223","type":"text+image","metadata":{"edition":"雍正六年刻本","version":"v8","total_page":2098,"paragraph_count":2645,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-guangxusanshisiben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL01034352","type":"text+image","metadata":{"edition":"光緒三十四年本","version":"v5","total_page":1724,"paragraph_count":10029,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53xMousD":{"id":"GYL53xMousD","type":"work","title":"清江縣誌","authors":[{"name":"秦鏞","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《清江縣誌》•八卷","author_info":"明秦鏞撰","summary":"明秦鏞撰。鏞，無錫人。崇禎丁丑進士，官清江縣知縣。清江向無志，崇禎壬午，鏞始創修。凡分八目，視他志稍為簡明。","edition":"兩淮馬裕家藏本"}],"juan_count":{"number":8},"resources":[{"id":"shidianguji-qingshunzhikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/NLG312001072245","type":"text+image","metadata":{"edition":"清順治2年[1645]刻本","version":"v3","total_page":684,"paragraph_count":4882,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53xG7Q15":{"id":"GYL53xG7Q15","type":"work","title":"萬曆溫州府志","authors":[{"name":"王光蘊","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《萬曆溫州府志》•十八卷","author_info":"明王光蘊撰","summary":"明王光蘊撰。光蘊字季宣，溫州人。官至甯國府同知。是編成於萬曆丁巳，凡為類十二，為目七十四。頗多舛略，如《形勝門》只略敍舊志數行，而梁邱遲《永嘉郡教》所稱“控山帶海”云云，祝穆《方輿勝覽》所稱“郡當甌越之沖”云云，皆未之載。此皆失諸眉睫之前。《學校門》只載梅溪、雁山兩書院，而永嘉書院之建於宋時，載於王圻《續文獻通考》者，亦不及詳。其掛漏可想。又《治行志》中分《郡良吏》、《邑良吏》為二門，體例亦嫌繁碎也。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":18},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4167996","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02051681","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":2096,"paragraph_count":18039,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53xajcjH":{"id":"GYL53xajcjH","type":"work","title":"杞紀","authors":[{"name":"張貞","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《杞紀》•二十二卷","author_info":"國朝張貞撰","summary":"國朝張貞撰。貞字起元，號杞園，安邱人。康熙壬子拔貢，官翰林院孔目。是書以安邱東北界接高昌諸邑，為杞國舊地，爰采史傳之有關於杞者，綜其條目。曰《圖考》，曰《星土》，曰《輿地》，曰《山川》，曰《系年》，曰《沿革》，曰《封建》，曰《年表》，曰《世次》，曰《原古》，曰《分國》，曰《系家》（案，司馬貞《史記索隱》改世家為系家，乃避唐諱，此誤襲其名），曰《苗裔》，曰《春秋經傳》，曰《經傳別解》，曰《人物》，曰《遺書》，曰《藝林》，曰《雜綴》。王士禎序，稱其“有良史才”。以安邱一隅，上溯太康斟鄩之故居，下迄國朝數千年事談，所采之書凡四百餘種，可謂勤矣。然以為杞之故墟，既於《系年》錄《春秋》經文之載杞事者，復為《年表》、《世次》、《系家》，不幾於疊床架屋乎？且又全錄《春秋》經傳及《經傳別解》為四卷，不更贅乎？於《遺書》錄《夏小正》，於《人物》收姮娥，其氾濫抑又甚矣。《藝林》內錄《齊風•汶水湯湯》之詩，則以徐州入濟之汶為青州入濰之汶。至如《振鷺》、《有瞽》，顧炎武《大禹陵》詩，皆一例采入，尤不免地志之錮習也。","edition":"河南巡撫采進本"}],"juan_count":{"number":22},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=394859","type":"text","details":"張貞"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=6522015","type":"text"},{"id":"shidianguji-kangxisishiwuxiuwush","name":"识典古籍","url":"https://www.shidianguji.com/book/HY0204","type":"text+image","metadata":{"edition":"康熙四十五年修五十五年刻本","version":"v7","total_page":956,"paragraph_count":960,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02051759","type":"text+image","metadata":{"edition":"刻本","version":"v5","total_page":901,"paragraph_count":4846,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53xt4baw":{"id":"GYL53xt4baw","type":"work","title":"揚州府志","authors":[{"name":"張萬壽","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《揚州府志》•四十卷","author_info":"國朝張萬壽撰","summary":"國朝張萬壽撰。萬壽字鶴秋，浮山人。康熙中官揚州府知府。《揚州府志》自明成化至萬壽，凡經五修，而益繁蕪。考書首載萬曆中楊洵舊志序，歷敘門目，其端緒尚為清整。萬壽多所增益，其體例轉不及原書也。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":40},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=811524","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02037498","type":"text+image","metadata":{"edition":"刻本","version":"v8","total_page":1807,"paragraph_count":13768,"check_type":"AI整理"}},{"id":"shidianguji-yongzhengkeben","name":"识典古籍","url":"https://www.shidianguji.com/book/NLG312001079666","type":"text+image","metadata":{"edition":"雍正11年刻本","version":"v5","total_page":2982,"paragraph_count":11236,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53xYZKfD":{"id":"GYL53xYZKfD","type":"work","title":"永平府志","authors":[{"name":"宋琬","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《永平府志》•二十四卷","author_info":"國朝宋琬撰","summary":"國朝宋琬撰。琬字玉叔，號荔裳，萊陽人。順治丁亥進士，官至四川按察使。琬與施閏章齊名，時號“南施北宋”。而此志不見所長，卷端題永平府知府蕭山張朝琮重修，其竄亂失真歟？","edition":"內府藏本"}],"juan_count":{"number":24},"resources":[{"id":"shidianguji-kangxiwushikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY0338","type":"text+image","metadata":{"edition":"康熙五十年刻本","version":"v7","total_page":2428,"paragraph_count":4853,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-guangxuwujingshengsh","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL01034699","type":"text+image","metadata":{"edition":"光緒五年敬勝書院本","version":"v6","total_page":5034,"paragraph_count":30781,"check_type":"AI整理"}},{"id":"shidianguji-qianlongsanshibakebe","name":"识典古籍","url":"https://www.shidianguji.com/book/HY4110","type":"text+image","metadata":{"edition":"乾隆三十八年(1773)刻本","version":"v3","total_page":2463,"paragraph_count":24699,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53x33daf":{"id":"GYL53x33daf","type":"work","title":"萬曆嘉定縣志","authors":[{"name":"韓浚","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《萬曆嘉定縣志》•二十卷","author_info":"明韓浚撰","summary":"明韓浚撰。浚字邃之，淄川人。官嘉定縣知縣。元至元中秦輔之始創縣誌。明自洪熙至嘉靖，凡經四修。浚於萬曆乙巳復續為是編，頗勝他志之鄙陋，然亦時有疏舛。如以《水利》列於《人物》之後，已覺不倫。以古跡及寺觀敘於《雜記門》中，更為非例。又如《疆域考》稱“自宋分崑山之東境以置縣”，不知《南畿志》載“宋割崑山安亭等五鄉，於練祁市置縣”，《輿地考》載嘉定縣原名疁城鄉也。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":20}},"GYL53xvwCSj":{"id":"GYL53xvwCSj","type":"work","title":"河套志","authors":[{"name":"陳履中","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《河套志》•六卷","author_info":"國朝陳履中撰","summary":"國朝陳履中撰。履中字執夫，商邱人。官至分巡寧夏兵備道。是志成於乾隆壬戌。凡河套之建置、沿革、山川、城堡、關塞、古跡、物產，悉分門匯載。末附以《藝文》二卷。如引《魏書》以證涿祁山之為榆林府地，引《冊府元龜》藥彥稠為邠州節度使，補五代沿革之闕。又證後魏代郡之即漢朔方郡。據《通鑒注》大城之屬朔方，以證《漢書》列傳之大城塞，徵引頗為繁富。","edition":"江西巡撫采進本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=949144","type":"text","details":"陳履中"},{"id":"shidianguji-qianlongqikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY0246","type":"text+image","metadata":{"edition":"乾隆七年刻本","version":"v5","total_page":824,"paragraph_count":512,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL53xJtd9y":{"id":"GYL53xJtd9y","type":"work","title":"萬曆襄陽府志","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《萬曆襄陽府志》•五十一卷","author_info":"不著撰人名氏","summary":"不著撰人名氏。卷首宜城胡價序，稱郡守吳公勒成。凡為目二十有六。明封襄藩於襄陽，故敘歷代藩封，別作《襄世家》一卷，於例應爾。至以孔子曾適楚國，遂於《古跡》之外別出《聖跡》一門，則冗碎甚矣。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":51}},"GYL53xmaQEB":{"id":"GYL53xmaQEB","type":"work","title":"琅鹽井志","authors":[{"name":"沈鼐","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《琅鹽井志》•四卷","author_info":"國朝沈鼐撰","summary":"國朝沈鼐撰。鼐字枚臣，長洲人。由貢生官雲南琅鹽井鹽課提舉。是書成於康熙壬辰，因來度舊志重為增輯。首列《圖考》，次分《天文》、《地理》、《建設》、《賦役》、《官師》、《學校》、《選舉》、《祠祀》、《人物》、《藝文》，凡十類。","edition":"浙江巡撫采進本"}],"juan_count":{"number":4},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=275026","type":"text","details":"趙淳、孫元相"},{"id":"shidianguji-qianlongershiyikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY0295","type":"text+image","metadata":{"edition":"乾隆二十一年刻本","version":"v3","total_page":566,"paragraph_count":909,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL53xUFRNX":{"id":"GYL53xUFRNX","type":"work","title":"西寧志","authors":[{"name":"蘇銑","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《西寧志》•七卷","author_info":"國朝蘇銑撰","summary":"國朝蘇銑撰。銑，交河人。順治丙戌進士。由衛輝府推官行取監察御史，巡按山西。裁闕改補西寧道，又調嶺東道。是編即其順治十二年官西寧道時所作。西寧在國初為軍民指揮使司，本臨邊之地，文獻罕徵。故其書亦潦草冗雜，絕無體例。蓋創始者難工也。","edition":"內府藏本"}],"juan_count":{"number":7}},"GYL53xy4ofM":{"id":"GYL53xy4ofM","type":"work","title":"湖南通志","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《湖南通志》•一百七十四卷","summary":"國朝大學士陳宏謀等監修。湖南省治即唐之武安軍，原與荊鄂兼立節鎮。宋代亦分荊湖南北兩路，至明代始並隸湖廣布政使。而幅《巾員》廣闊，形勢各殊。本朝康熙三年，始析置湖南布政司，以控制嶺嶠。其後修通志者，仍合湖南北為一編。又書局開於武昌，未免詳近而略遠。故湖南事蹟，未能賅備。乾隆二十一年，宏謀巡撫湖南，因與藩臬諸臣創修此志，以補其闕。共分三十七門。其中如《山川》一門，全志每縣只載數條，此則分列方隅。《職官》一門，全志文職至知府，武職至遊擊而止，此則同知、通判、守備，具錄無遺。《選舉》一門，全志詳文而略武，此則兩途並登。故所載雖止九府四州，而卷帙則較全志贏幾十之四五云。","edition":"通行本"}],"juan_count":{"number":174},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=599864","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=157153","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=803677","type":"text"},{"id":"shidianguji-guangxukeben","name":"识典古籍","url":"https://www.shidianguji.com/book/NLG312001076076","type":"text+image","metadata":{"edition":"光緒11年刻本","version":"v9","total_page":22924,"paragraph_count":82839,"check_type":"AI整理"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/NLG312001076073","type":"text+image","metadata":{"edition":"刻本","version":"v5","total_page":14644,"paragraph_count":59169,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53xf8tis":{"id":"GYL53xf8tis","type":"work","title":"蕭山縣志刊誤","authors":[{"name":"毛奇齡","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《蕭山縣志刊誤》•三卷","author_info":"國朝毛奇齡撰","summary":"國朝毛奇齡撰。以蕭山新修縣誌踳駁失考，因逐各條為之釐正。凡沿革之誤二條，稱名之誤一條，封屬之誤二條，坊里之誤二條，古跡之誤三十八條，人物之誤三十五條。（案，毛奇齡此二編，本非郡縣誌書。而列於郡縣志書中者，以所刊正者乃郡縣志書，猶《新唐書糾繆》列於正史之例也。）","edition":"浙江巡撫采進本"}],"juan_count":{"number":3},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=6892050","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02051767","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":114,"paragraph_count":1122,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53xDw6w1":{"id":"GYL53xDw6w1","type":"work","title":"萬曆餘杭縣志","authors":[{"name":"戴日強","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《萬曆餘杭縣志》•十卷","author_info":"明戴日強撰","summary":"明戴日強撰。日強，蒙城人。官餘杭縣知縣。是編成於萬曆丙辰，分十門，子目六十有二。中間紀載多舛誤，如《沿革門》云：“漢高帝時屬荊吳國。”不知漢時餘杭為西部都尉治，仍屬會稽郡。《城墉門》云：“古城在今縣溪南，莫詳所始。”不知《咸淳臨安志》載漢熹平二年所改，經兩次遷移，至後唐時號為清平軍。殊為疏於考訂。至第一卷既立《山川》一門，而九卷又別立《徑山志》；既有《古跡》一門，又別立《洞霄志》，更為冗複矣。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":10},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=6511545","type":"text"}]},"GYL53xPwX5q":{"id":"GYL53xPwX5q","type":"work","title":"崇禎碭山縣志","authors":[{"name":"劉芳","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《崇禎碭山縣志》•二卷","author_info":"明劉芳撰","summary":"明劉芳撰。芳字百子，石屏人。官碭山縣知縣。先是，萬曆戊午，知縣陳秉良屬邑人王文煥撰縣志，二旬而成。崇禎己卯，芳復與邑人汪用霖續修此編。其《沿革》載“東漢為梁國碭山縣”，不知東漢時沛國亦分界其地。又云“晉省歸夏邑”，不知《南畿志》載“晉下邑即碭地”，非省並也。又以下邑作夏邑，更誤矣。又分門至四十二，率多冗雜。如既以《水土》為一門，又以《風俗》為一門；以《古跡》為一門，又以《八景》為一門，殊紛紜少緒也。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":2},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=5875185","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02051725","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":320,"paragraph_count":2558,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53xWRiSb":{"id":"GYL53xWRiSb","type":"work","title":"續安邱志","authors":[{"name":"王訓","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《續安邱志》•二十五卷","author_info":"國朝王訓撰","summary":"國朝王訓撰。訓字敷彝，安邱人。順治丁亥進士，官萬全縣知縣。是編續馬文煒之書，體例相近。凡例稱馬《志》二十八卷，今《續》二十五卷者，地理封建，本無可續。如俷德不至，害及一邑，則亦略之。惡惡短也。","edition":"兵部侍郎紀昀家藏本"}],"juan_count":{"number":25}},"GYL53xjSo1Z":{"id":"GYL53xjSo1Z","type":"work","title":"登封縣志","authors":[{"name":"張聖誥","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《登封縣志》•十卷","author_info":"國朝張聖誥撰","summary":"國朝張聖誥撰。聖誥字紫書，號韋菴，廣寧人。官登封縣知縣。初，順治五年，聖誥之叔父朝端知登封，始創修縣志。康熙十八年，聖誥族兄壎亦知是縣，又續增之。康熙三十一年，聖誥又知是縣，復因舊本重修。一姓相承，遞相纂輯，其事頗異。書分九門，曰《圖繪》，曰《輿地》，曰《嶽祀》，曰《建置》，曰《山川》，曰《職官》，曰《方外》，曰《物產》，曰《藝文》。體例與他志略同。惟他志景必有八，八景之詩必七律，最為惡習。聖誥力破是例，差有識云。","edition":"內府藏本"}],"juan_count":{"number":10},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=683218","type":"text","details":"焦欽寵、張聖誥"},{"id":"shidianguji-kangxisanshiwuben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY4331","type":"text+image","metadata":{"edition":"康熙三十五年(1696)本","version":"v8","total_page":793,"paragraph_count":5719,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL53xooP9h":{"id":"GYL53xooP9h","type":"work","title":"師宗州志","authors":[{"name":"管棆","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《師宗州志》•二卷","author_info":"國朝管棆撰","summary":"國朝管棆撰。棆，武進人。官師宗州知州。是書成於康熙丁酉，分九《圖》，五《紀略》，九《考》，四《傳》。師宗舊無志，是書草創簡略，粗具大綱。附藝文於各門中，用宋人舊例。惟多錄己作，殆成紀遊之集，則未免輿記之結習耳。","edition":"兩淮馬裕家藏本"}],"juan_count":{"number":2}}}