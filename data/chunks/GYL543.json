{"GYL54371N3y":{"id":"GYL54371N3y","type":"work","title":"普陀山志","authors":[{"name":"周應賓","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《普陀山志》•六卷","author_info":"明周應賓撰","summary":"明周應賓撰。應賓有《九經考》，已著錄。普陀山在浙江之定海。是編因舊志重輯，凡六卷，十五門。而應賓自序稱五卷，十七門。勘驗卷帙，並無闕佚，未審何以矛盾也。","edition":"兩淮馬裕家藏本"}],"juan_count":{"number":6},"resources":[{"id":"shidianguji-wanlikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY0110","type":"text+image","metadata":{"edition":"萬曆刻本","version":"v4","total_page":630,"paragraph_count":1153,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL543xSWjH":{"id":"GYL543xSWjH","type":"work","title":"峴山志","authors":[{"name":"張睿卿","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《峴山志》•六卷","author_info":"明張睿卿撰","summary":"明張睿卿撰。睿卿字稚通，號心岳，歸安人。《湖州府志》稱其博雅豪邁，遊歷山川，以著書為樂。然是書頗無體例。此峴山乃烏程之一山，非城邑郡縣之比。而首曰《建置》，名實已不相副。次曰《勝概》，而多與《建置》互見，不過雜載詩文。三曰《遺愛》，敘古名賢王右軍以下數人，終於王世貞，皆湖州大吏，與山不甚相涉。四曰《社會》，五曰《放生》，六曰《藝文》，又先散載各門，均失之叢濫也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=3662517","type":"text"}]},"GYL543o8QNB":{"id":"GYL543o8QNB","type":"work","title":"惠山古今考","authors":[{"name":"談修","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《惠山古今考》•十卷、《附錄》•三卷、《補遺》一卷","author_info":"明談修撰","summary":"明談修撰。修字思永，無錫人。是編以無錫惠山為一邑勝境。唐張祐題詩有“小洞穿斜竹，重階夾細莎”之句，而舊跡已湮，修營建以複其舊。故首卷載《小洞重階考》，及祠院庵觀諸《考》，自二卷至十卷，則自唐及明之詩文。《附錄》三卷，皆同人賦贈之作。《補遺》一卷，則雜記惠山遺事。卷末自跋，有“夢惠山之神”云云，則未免幻妄矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":10},"additional_works":[{"book_title":"附錄","n_juan":3},{"book_title":"補遺","n_juan":1}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7075515","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02052245","type":"text+image","metadata":{"edition":"刻本","version":"v6","total_page":807,"paragraph_count":6322,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL543BxtGw":{"id":"GYL543BxtGw","type":"work","title":"太姥志","authors":[{"name":"史起欽","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《太姥志》•一卷","author_info":"明史起欽撰","summary":"明史起欽撰。起欽字敬所，鄞縣人。萬曆己丑進士，官福寧州知州。太姥山在福寧州境，傳堯時有老母業采藍，後得仙去，故以為名。中有鍾離岩、一線天諸勝跡，起欽因創為此書，成於萬曆乙未。前列圖，次列記序及題詠之作。然山以岩壑寺宇為主，法當分門編載。起欽但為總繪一圖，悉不加分別詮次，非體例也。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":1}},"GYL543MGze3":{"id":"GYL543MGze3","type":"work","title":"華嶽全集","authors":[{"name":"華陰縣知縣李時芳","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《華嶽全集》•十三卷","author_info":"舊本題明華陰縣知縣李時芳撰","summary":"舊本題明華陰縣知縣李時芳撰。今案時芳之本，《千頃堂書目》作十卷，乃嘉靖四十一年所修。至萬曆二十四年，汝州張維新為潼關道副使，以時芳書多舛錯，與華陰縣知縣貴陽馬明卿重加詮敘。前載《圖說》、《形勝》、《物產》、《靈異》、《封號》，後載《藝文》，增成十三卷。前有巡撫賈待問序，及維新自序，述之頗詳。題時芳所撰，誤也。後六年壬寅，知縣河間馮嘉會又增文數篇，亦注於書內。至所載國朝祭告之文，與宋琬、蔣超諸人之詩，則莫知誰所續入。考其中多有潼關道溧陽狄敬姓名，意者即敬所增歟？","edition":"兩淮鹽政采進本"}],"juan_count":{"number":13},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=287542","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=451899","type":"text"}]},"GYL5431GALP":{"id":"GYL5431GALP","type":"work","title":"京口三山續志","authors":[{"name":"徐邦佐、陳朝用、朱文山同","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《京口三山續志》•四卷","author_info":"明徐邦佐、陳朝用、朱文山同撰","summary":"明徐邦佐、陳朝用、朱文山同撰。邦佐號雁洲，浦城人。官鎮江府教授。朝用號南湖，寧都人；文山號仰泉，常寧人。皆官鎮江府訓導。是書成於隆慶中，以補史宗道《三山志》之闕，故以《續志》為名。專取當時人遊覽詩賦，匯萃成帙、而邦佐等所自作，附錄尤夥。蓋意在釣名，於三山考訂無涉也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":4}},"GYL543VCVRh":{"id":"GYL543VCVRh","type":"work","title":"雁山志勝","authors":[{"name":"徐待聘","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《雁山志勝》•四卷","author_info":"明徐待聘撰","summary":"明徐待聘撰。待聘字廷珍，常熟人。萬曆辛丑進士，官至按察使副使。是編乃其官樂清知縣時所撰。卷一為山之名勝及人物、土產、雜事，二卷三卷皆佛刹，四卷則所自作詩文也。其凡例有曰：“舊志凡詩賦題雁山者，或以臨蒞，或以要津，皆旁搜而詮之，而文之微占於山者亦聚焉。又有欲世識其名者，賂剞劂氏私刻攙入，真贗並收，薰蕕莫辨。山靈有知，定當作嘔，今皆刪去”云云。其言可謂深中地志之陋習。然舊作雖已汰除，而又獨錄己作一卷，其亦尤而效之矣。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":4}},"GYL543eWbno":{"id":"GYL543eWbno","type":"work","title":"恒嶽志","authors":[{"name":"趙之韓、王濬初同","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《恒嶽志》•二卷","author_info":"明趙之韓、王濬初同撰","summary":"明趙之韓、王濬初同撰。之韓，汜水人。官渾源州知州。濬初，山陰縣舉人。是書成於萬曆壬子。其目十一，曰《外紀》、《星紀》、《山紀》、《廟紀》、《祀紀》、《事紀》、《物紀》、《游紀》、《仙紀》、《文紀》、《詩紀》。搜考頗稱詳核。又以自宋以來皆祠北嶽於上曲陽，故複取《曲陽嶽廟詩》附於卷末。後五年，知州衡陽張述齡為刻而行之。然其《文紀》有目無書，已非完本矣。","edition":"兩淮馬裕家藏本"}],"juan_count":{"number":2},"resources":[{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02052308","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":452,"paragraph_count":4006,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL543ipW5V":{"id":"GYL543ipW5V","type":"work","title":"煙雲手鏡","authors":[{"name":"楊繼益","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《煙雲手鏡》•二卷","author_info":"明楊繼益撰","summary":"明楊繼益撰。繼益始末未詳。前有萬曆甲寅自序，稱居恒遊思險遠，因檢閱群書，摭其山川喜懼之境，錄成二帙。然所載諸山水，俱隨手雜錄，抄撮舊文，無所損益。既不注原書之名，前後次序亦無義例。如上卷有房山、石徑山，而房山水洞又在下卷。上卷有牛首山、鐘山，而獅子山又在下卷。以至廬山之與瀑布，金山之與妙高臺，皆顛倒破析，棼如亂絲。以比《名勝志》、《遊名山記》諸書，可謂每況愈下矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":2}},"GYL543vGDfD":{"id":"GYL543vGDfD","type":"work","title":"崆峒山志","authors":[{"name":"李應奇","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《崆峒山志》•三卷","author_info":"明李應奇撰","summary":"明李應奇撰。應奇字鶴崖，平涼人。崆峒山在平涼府城西。是書成於萬曆中，凡分七門，曰《分野》，曰《建革》，曰《疆域》，曰《形勝》，曰《田賦》，曰《仙跡》，曰《題詠》。然一山之志，即不應及分野、建革，而中間兼記及瓦亭關、會盟壇之類，又殊似府志之體例，殊叢雜無限斷也。","edition":"江蘇周厚堉家藏本"}],"juan_count":{"number":3},"resources":[{"id":"shidianguji-qingjiaqingkeben","name":"识典古籍","url":"https://www.shidianguji.com/book/NLG312001080145","type":"text+image","metadata":{"edition":"清嘉慶24年[1819]刻本","version":"v4","total_page":252,"paragraph_count":728,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL543aA1ef":{"id":"GYL543aA1ef","type":"work","title":"天臺山方外志","authors":[{"name":"釋無盡","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《天臺山方外志》•三十卷","author_info":"明釋無盡撰","summary":"明釋無盡撰。案，錢希言《犬會園•釋異篇》曰：“有門法師名傳燈，一號無盡，太末人也。出家天臺之高明寺。少精煉戒行，學識高出道流。嘗撰《天臺山志》，甚有禪藻”云云。則無盡者乃其號也。天臺山自孫綽作賦以來，登臨題詠，翰墨流傳，已多見於地志。此書成於萬曆癸卯，出自釋家之手，述梵跡者為多，與專志山川者體例稍殊。故別題曰《方外志》焉。","edition":"浙江汪啟淑家藏本"}],"juan_count":{"number":30},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=384444","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02052224","type":"text+image","metadata":{"edition":"刻本","version":"v10","total_page":1031,"paragraph_count":855,"check_type":"AI整理"}},{"id":"shidianguji-youxijiangtangmingwa","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ89241199902322140197","type":"text+image","metadata":{"edition":"幽溪講堂明萬曆29年刻本","version":"v2","total_page":1000,"paragraph_count":10206,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL543cLJij":{"id":"GYL543cLJij","type":"work","title":"幽溪別志","authors":[{"name":"釋無盡","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《幽溪別志》•十六卷","author_info":"明釋無盡撰","summary":"明釋無盡撰。幽溪在天臺山，無盡常居其地，因撰是志。凡十六門，每門附以藝文，而同時人所作為多。名為地志，實同社刻。《犬會園》稱其所至講席如雲，蓋明末標榜之風，浸淫乎方以外矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":16},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1804062","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02052235","type":"text+image","metadata":{"edition":"刻本","version":"v9","total_page":690,"paragraph_count":5398,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL543E9BM1":{"id":"GYL543E9BM1","type":"work","title":"續刻麻姑山志","authors":[{"name":"左宗郢","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《續刻麻姑山志》•十七卷","author_info":"明左宗郢撰","summary":"明左宗郢撰，國朝何天爵、邱時彬重修。宗郢，南城人。萬曆己丑進士，官至太常寺少卿。天爵、時彬皆建昌人。麻姑山唐時隸撫州，故顏真卿《麻姑仙壇記》有“撫州南城縣”之語，今則在建昌府城西十裏。宗郢志見於《明史•藝文志》，著錄卷數相同。此本每標籤題，或稱麻姑而去“山”字，或又加“洞天”字，或加“丹霞”字。名目紛然，可知體例之龐雜。考《明史》作《續刻麻姑山志》，今姑從標目焉。","edition":"浙江汪啟淑家藏本"}],"juan_count":{"number":17}},"GYL543K9PRR":{"id":"GYL543K9PRR","type":"work","title":"蜀中名勝記","authors":[{"name":"曹學佺","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《蜀中名勝記》•三十卷","author_info":"明曹學佺撰","summary":"明曹學佺撰。學佺有《易經通論》，已著錄。案，學佺所著，本無此書之名。此本乃萬曆戊午福清林茂之摘其《蜀中廣記》內《名勝》一門，刻之南京，而鍾惺為之序。不知其何所取也。","edition":"浙江鮑士恭家藏本"}],"juan_count":{"number":30},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=180957","type":"text"}]},"GYL543PTHi7":{"id":"GYL543PTHi7","type":"work","title":"九疑山志","authors":[{"name":"蔣鐄","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《九疑山志》•九卷","author_info":"明蔣鐄撰","summary":"明蔣鐄撰。鐄，長洲人。萬曆中官甯遠縣知縣。九疑山在甯遠縣南四十裏，相傳舜葬其地，有舜廟焉。雖輿記流傳，而舊無專志，鐄始創修此編。首紀祭舜陵文，次載形勝、古跡、人物、仙釋、土產，次錄前人碑記詩文。崇禎中，平陵俞向葵為令，複補圖於卷首。","edition":"兩淮馬裕家藏本"}],"juan_count":{"number":9},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=396585","type":"text","details":"蔣鐄、俞向葵"},{"id":"shidianguji-chongzhenkeben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY0115","type":"text+image","metadata":{"edition":"崇禎刻本","version":"v7","total_page":394,"paragraph_count":573,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL543zfVeo":{"id":"GYL543zfVeo","type":"work","title":"上天竺山志","authors":[{"name":"釋廣賓","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《上天竺山志》•十五卷","author_info":"明釋廣賓撰","summary":"明釋廣賓撰。天竺為東南巨刹，舊有李金庭志。廣賓以其附會舛訛，甚至偽撰明太祖《竺隱說》一篇以炫俗，乃刪補而成此書。曰《普門示現品》，曰《尊宿住持品》，曰《器界莊嚴品》，曰《帝王檀越品》，曰《宰官外護品》，曰《風範隆汙品》，曰《詩文紀述品》，凡七門。其《風範隆汙》一品，於寺僧汙行，備書不隱，較他志獨存直筆。據總目尚有卷首一卷，此本已佚不存。","edition":"兩淮馬裕家藏本"}],"juan_count":{"number":15}},"GYL5434BT3d":{"id":"GYL5434BT3d","type":"work","title":"齊雲山志","authors":[{"name":"魯點","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《齊雲山志》•五卷","author_info":"明魯點撰","summary":"明魯點撰。點字子與，南漳人。萬曆癸未進士，官休甯縣知縣。齊雲山在休寧縣，名齊雲岩，蓋白嶽西北分支也。上有北極佑聖真君神祠，明代數經修葺，嘉靖中始有齊雲山之號。茲志因雲岩舊本而重輯之，分三十七目。卷前又有順治中告示二通，又後人刊入，非原書之舊矣。","edition":"浙江汪啟淑家藏本"}],"juan_count":{"number":5},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=871302","type":"text","details":"魯點"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=6393915","type":"text"},{"id":"shidianguji-wanlikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY0108","type":"text+image","metadata":{"edition":"萬曆刻本","version":"v5","total_page":518,"paragraph_count":1971,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02052179","type":"text+image","metadata":{"edition":"刻本","version":"v5","total_page":626,"paragraph_count":4242,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL5439qH4K":{"id":"GYL5439qH4K","type":"work","title":"太嶽太和山志","authors":[{"name":"田玉","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《太嶽太和山志》•十七卷","author_info":"明田玉撰","summary":"明田玉撰。玉不知何許人，萬曆中宦官也。太和山即湖廣均州之武當山，相傳為北極玄武修真地。明成祖即位時，自謂得神之祐，因尊為太嶽，敕建宮觀，常遣內臣司其香火。嘉靖間，提督太監王佐始創為志，太監呂評續增之。萬曆癸未，玉複增廣為此本。前載修建廟宇始末實事，並仙跡、徵應、物產，後載唐、宋、元、明序記詩賦等作。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":17},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=5403492","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL06030025","type":"text+image","metadata":{"edition":"刻本","version":"v10","total_page":832,"paragraph_count":4297,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL543geD1R":{"id":"GYL543geD1R","type":"work","title":"天目山志","authors":[{"name":"徐嘉泰","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《天目山志》•四卷","author_info":"明徐嘉泰撰","summary":"明徐嘉泰撰。嘉泰字道亨，循州人。官於潛縣知縣。是書乃萬曆甲寅嘉泰因舊志重修。浙江有東西二天目，東天目在臨安縣之西五十裏，西天目在於潛縣西北四十五裏。據此書所圖，則本屬一山。東西水源若兩目然，故曰天目。然此書所紀多屬西天目事，統稱《天目山志》，非也。","edition":"浙江汪啟淑家藏本"}],"juan_count":{"number":4},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4964469","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02052241","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":396,"paragraph_count":1636,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL543kx7J7":{"id":"GYL543kx7J7","type":"work","title":"海陽山水志","authors":[{"name":"丁惟曜","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《海陽山水志》•四卷","author_info":"明丁惟曜撰","summary":"明丁惟曜撰。惟曜字貞白，休寧人。是書成於萬曆戊午。紀休甯境內名勝，凡山二十九篇，水八篇，各冠以圖。所錄藝文，但載記、序、銘、頌諸體，而不及詩詞。較他志之濫列題詠者，稍為簡淨。然嚴於去取可矣，竟廢此一體，則又矯枉過直也。","edition":"江蘇周厚堉家藏本"}],"juan_count":{"number":4}},"GYL543SKtZu":{"id":"GYL543SKtZu","type":"work","title":"羅浮野乘","authors":[{"name":"韓晃","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《羅浮野乘》•六卷","author_info":"明韓晃撰","summary":"明韓晃撰。晃字賓仲，南海人。萬曆庚子舉人，官青田縣知縣。是編首《全圖》，次《名峰》，次《勝跡》，次《仙釋》，次《品物》，次《逸事》。書成於崇禎己卯。其兄晟，字寅仲，亦著《羅浮副墨》，今未見。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=8014341","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02052219","type":"text+image","metadata":{"edition":"刻本","version":"v5","total_page":411,"paragraph_count":1703,"check_type":"AI整理"}},{"id":"shidianguji-kangxijiankeben","name":"识典古籍","url":"https://www.shidianguji.com/book/NLG312001076845","type":"text+image","metadata":{"edition":"康熙間刻本","version":"v1","total_page":419,"paragraph_count":918,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL543GGnZd":{"id":"GYL543GGnZd","type":"work","title":"嵩書","authors":[{"name":"傅梅","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《嵩書》•二十二卷","author_info":"明傅梅撰","summary":"明傅梅撰。梅字元鼎，邢臺人。萬曆辛卯舉人，由登封縣知縣擢刑部主事。與員外郎陸夢龍力爭梃擊一案，鄭氏之黨中以察典，罷官。後起為台州府知府。崇禎中，解職家居。大兵下順德，抗節死，贈太常寺少卿。事蹟附見《明史•張問達傳》。乾隆乙未，賜諡忠節。是編乃其官登封知縣時所作。分《星政》、《峙勝》、《卜營》、《宸望》、《嶽生》、《官履》、《岩棲》、《黃裔》、《竺業》、《物華》、《靈緒》、《顏始》、《章成》為十三篇，立名頗嫌塗飾。全書意在廣搜，亦殊多駁雜。","edition":"兩江總督采進本"}],"juan_count":{"number":22},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=780692","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=599190","type":"text"},{"id":"shidianguji-wanlikanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA03183","type":"text+image","metadata":{"edition":"萬曆40年刊本","version":"v15","total_page":1711,"paragraph_count":1480,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-wanlikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02086608","type":"text+image","metadata":{"edition":"萬曆刻本","version":"v5","total_page":1694,"paragraph_count":12074,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL543Y2QS3":{"id":"GYL543Y2QS3","type":"work","title":"泰山紀事","authors":[{"name":"宋燾","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《泰山紀事》•三卷","author_info":"明宋燾撰","summary":"明宋燾撰。燾字繹田，泰安州人。萬曆辛丑進士，官翰林院編修。此書一卷曰《天集》，記天神事。二卷曰《地集》，記古跡。三卷曰《人集》，記名宦人物。所言神鬼冥報，已涉荒誕；至泰山太守、泰安知州為守土之官，柳下惠、王章、羊祐諸人亦不過生長其鄉，並未岩棲穀汲，乃概行摭入，不知於岱宗故事何涉也。","edition":"山東巡撫采進本"}],"juan_count":{"number":3},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=2519367","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02052223","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":208,"paragraph_count":1047,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL543qG1ao":{"id":"GYL543qG1ao","type":"work","title":"九鯉湖志","authors":[{"name":"黃天全","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《九鯉湖志》•六卷","author_info":"明黃天全撰","summary":"明黃天全撰。天全，莆田人。其書成於萬曆中。九鯉湖在福建仙遊縣，天全以舊志僅載遊覽之作，而遺山水，乃重為厘訂。分為《山水》、《建置》、《夢驗》、《藝文》四門。《夢驗》者，以九鯉湖祠乃閩人祈夢處也。","edition":"兩淮馬裕家藏本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7719039","type":"text"},{"id":"shidianguji-unknown","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02052252","type":"text+image","metadata":{"edition":"未知","version":"v3","total_page":261,"paragraph_count":1158,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL543sPcoR":{"id":"GYL543sPcoR","type":"work","title":"龍門志","authors":[{"name":"樊得仁","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《龍門志》•三卷","author_info":"明樊得仁撰","summary":"明樊得仁撰。得仁不知何許人。是書首載《龍門圖》及事蹟，次紀文類，次紀詩類。首卷考證甚陋。若龍門特為河水所經過，止載《水經注》“河水又南出龍門口”諸條足矣，至摭及歷代河源，則迂闊無當。又《玉海》雲：“梁山之北有龍門山，大禹所鑿，通孟津，河口廣八十步。”是書既已引之，而後又引此數語，別標曰“出《魏•地理志》”。顛倒重複，殊為蕪雜。","edition":"浙江範懋柱家天一閣藏本"}],"juan_count":{"number":3},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=5599602","type":"text"}]}}