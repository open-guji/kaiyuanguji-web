{"GYL545sgGib":{"id":"GYL545sgGib","type":"work","title":"惠陽山水紀勝","authors":[{"name":"吳騫","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《惠陽山水紀勝》•四卷","author_info":"國朝吳騫撰","summary":"國朝吳騫撰。騫字益存，號樂園，當塗人。康熙辛未進士，官至惠州府知府。是編以羅浮與西湖各分上下二卷。其紀羅浮，則本宋廣業《羅浮志》，稍為芟節；其紀西湖，則本近人增輯《西湖志》而更編之，亦間有所補正。他如霍山、河源、龍川亦隸惠州，稱名勝，而志不及焉。蓋專為二地作也。惠州在漢曰南海，晉曰東官，隋、唐或曰循，或曰雷鄉。至宋仁宗時，始曰惠州。而惠陽之名則於傳無之。以是標題，亦相沿杜撰之文矣。","edition":"浙江汪啟淑家藏本"}],"juan_count":{"number":4},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=364284","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02052435","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":720,"paragraph_count":4943,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL545oTk8o":{"id":"GYL545oTk8o","type":"work","title":"羅浮山志會編","authors":[{"name":"宋廣業","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《羅浮山志會編》•二十二卷","author_info":"國朝宋廣業撰","summary":"國朝宋廣業撰。廣業字澄溪，長洲人。康熙中官至山東濟東道。後因其子志益為瑞州知府，就養官署。以羅浮為嶺南勝地，而舊志簡略，遂重為考訂。網羅闕逸，計事增舊十之五。後來羅浮諸志，多以是為藍本雲。","edition":"兩淮馬裕家藏本"}],"juan_count":{"number":22},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=733093","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=5535075","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=227679","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/ZWDS0219","type":"text+image","metadata":{"edition":"刻本","version":"v7","total_page":1414,"paragraph_count":1537,"check_type":"粗校"}},{"id":"shidianguji-kangxiwushiliukeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02086624","type":"text+image","metadata":{"edition":"康熙五十六年刻本","version":"v7","total_page":1321,"paragraph_count":7002,"check_type":"AI整理"}},{"id":"shidianguji-keben-1","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02052422","type":"text+image","metadata":{"edition":"刻本","version":"v4","total_page":1375,"paragraph_count":3302,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL545iQrCw":{"id":"GYL545iQrCw","type":"work","title":"玉華洞志","authors":[{"name":"陳文在","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《玉華洞志》•六卷","author_info":"國朝陳文在撰","summary":"國朝陳文在撰。文在字新我，將樂人。將樂縣南十裏許有玉華洞，幽深窅窈，秉炬乃入。其中石鍾乳滴成人物諸形，千態萬狀，一一曲肖，為閩中奇觀。明萬曆壬辰，邑令海陽林熙春始為志。順治甲午，邑令曲阜孔興訓重修，歲久版毀。康熙乙未，文在又複修之。冠以圖景，而序記賦詩之屬，以次備錄。末有《慶玉華詩》一冊，則以邑人鬻煤燒鑿，洞且頹壞。雍正辛亥，邑令馮景曾始禁開窯場，邑人作詩慶之，並匯成帙，附於志末雲。","edition":"浙江巡撫采進本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=3549651","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02052417","type":"text+image","metadata":{"edition":"刻本","version":"v4","total_page":487,"paragraph_count":1261,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL545vWBiw":{"id":"GYL545vWBiw","type":"work","title":"西樵志","authors":[{"name":"馬符錄","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《西樵志》•六卷","author_info":"國朝馬符錄撰","summary":"國朝馬符錄撰。符錄字受之，南海人。官陸豐縣訓導。西樵山屬南海縣，在廣州府城西南一百二十裏。明萬曆辛卯，郡人霍守尚初為之志，歲久散佚。國朝羅國器重修未竟，符錄乃因其舊本，輯為此編。詳於人物藝文，而略於考證，故山中金石之文悉不錄雲。","edition":"浙江汪啟淑家藏本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=8495181","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02052439","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":104,"paragraph_count":870,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL5458B5Af":{"id":"GYL5458B5Af","type":"work","title":"西湖夢尋","authors":[{"name":"張岱","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《西湖夢尋》•五卷","author_info":"國朝張岱撰","summary":"國朝張岱撰。岱字陶菴，自號蝶菴居士，家本劍州，僑寓錢塘。是編乃於杭州兵燹之後，追記舊遊。以《北路》、《西路》、《南路》、《中路》、《外景》五門，分記其勝。每景首為小序，而雜采古今詩文列於其下。岱所自作尤夥，亦附著焉。其體例全仿劉侗《帝京景物略》，其詩文亦全沿公安、竟陵之派。","edition":"浙江鮑士恭家藏本"}],"juan_count":{"number":5},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/西湖夢尋","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=293924","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=63615","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=878121","type":"text"},{"id":"shidianguji-kangxikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02086721","type":"text+image","metadata":{"edition":"康熙刻本","version":"v11","total_page":280,"paragraph_count":304,"check_type":"粗校"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02052331","type":"text+image","metadata":{"edition":"刻本","version":"v9","total_page":250,"paragraph_count":271,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-kangxigujianzhanglik","name":"识典古籍","url":"https://www.shidianguji.com/book/NLG312001061382","type":"text+image","metadata":{"edition":"康熙56年古劍張禮刻本","version":"v8","total_page":299,"paragraph_count":252,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL545qYfVy":{"id":"GYL545qYfVy","type":"work","title":"羅浮外史","authors":[{"name":"錢以塏","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《羅浮外史》•","author_info":"國朝錢以塏撰","summary":"國朝錢以塏撰。以塏字蔗山，嘉善人。康熙中曆官東莞、茂名二縣知縣。羅浮山屬於博羅，而遊人登眺則多由東莞之石龍鄉。以塏官東莞時，其父瑛就養縣署，往游羅浮，記其名勝。以塏因參考諸籍，以成此編。首列圖二十，次述山中名勝靈跡為五十八篇。大抵多因仍舊志，又多以近人詩參錯其中，頗為冗雜。","edition":"無卷數，浙江巡撫采進本"}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7031814","type":"text"},{"id":"shidianguji-kangxijiankeben","name":"识典古籍","url":"https://www.shidianguji.com/book/NLG312001076850","type":"text+image","metadata":{"edition":"康熙間刻本","version":"v3","total_page":112,"paragraph_count":156,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL5452RsT5":{"id":"GYL5452RsT5","type":"work","title":"四明山志","authors":[{"name":"黃宗羲","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《四明山志》•九卷","author_info":"國朝黃宗羲撰","summary":"國朝黃宗羲撰。宗羲有《易學象數論》，已著錄。四明山舊稱名勝，而岩壑幽邃，文士罕能周曆，故記載多疏。宗羲家於北七十峰之下，嘗捫蘿越險，尋覽匝月，得以考求古跡，訂正訛傳。乃博采諸書，輯為此志，凡九門。宗羲記誦淹通，序述亦特詳贍。惟所收詩文過博，並以友朋倡和之作牽連附入，猶不出地志之習。又既列名勝，複以皮陸九《題丹山圖》、《詠石田山房》，別出三門。其諸門之內既附詩，於各條下又別出《詩括》、《文括》二門，為例亦未免不純也。","edition":"江蘇周厚堉家藏本"}],"juan_count":{"number":9},"resources":[{"id":"shidianguji-kangxisishihuangbing","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02086563","type":"text+image","metadata":{"edition":"康熙四十年黃炳刻本","version":"v5","total_page":348,"paragraph_count":2143,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL545aaj8B":{"id":"GYL545aaj8B","type":"work","title":"湘山志","authors":[{"name":"徐泌","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《湘山志》•八卷","author_info":"國朝徐泌撰","summary":"國朝徐泌撰。泌字鶴汀，衢州人。康熙中官全州知府。以州有湘山寺，祀無量壽佛，率郡人謝允複等考佛出身本末，並山水、古跡、藝文，輯為是書。","edition":"浙江巡撫采進本"}],"juan_count":{"number":8},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1557969","type":"text"}]},"GYL545GqZbV":{"id":"GYL545GqZbV","type":"work","title":"蟂磯山志","authors":[{"name":"柯願","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《蟂磯山志》•二卷","author_info":"國朝柯願撰","summary":"國朝柯願撰。願字又鄒，龍溪人。康熙甲辰進士，以主事督理蕪湖鈔關。蟂磯山在蕪湖西南七裏大江中。《江南通志》雲：“蟂，老蛟也。”今磯有石穴，廣一丈，深不可測。按《廣韻》：“蟂，古堯切。水蟲，似蛇，四足，能害人。”賈誼《吊屈原文》所謂“偭蟂獺以隱處”者是也。《通志》所雲，未知何本。山上有靈澤夫人祠，相傳蜀先主妃孫權妹死葬於此，故廟祀焉。其事不見於史傳，殆齊東之語耳。是編蓋因明邊維垣舊本原文重訂。首為圖，末附載扁聯。所錄率荒唐之說，惟弘治中劉淮、嘉靖中王宗聖二記，稍能引據史傳，以駁俚說，而亦終歸於附會。餘皆蕪雜。又凡例稱“降乩之作不錄”，而卷末仍有諸葛亮、徐庶、鄧芝之詩，皆七言絕句，殆足笑噱。尤前後自相矛盾雲。","edition":"安徽巡撫采進本"}],"juan_count":{"number":2},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=2431869","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02052344","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":273,"paragraph_count":2260,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL545RMzTy":{"id":"GYL545RMzTy","type":"work","title":"嵩岳廟史","authors":[{"name":"景日昣","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《嵩岳廟史》•十卷","author_info":"國朝景日昣撰","summary":"國朝景日昣撰。是書以嵩嶽廟舊未有志，因創為編輯。分《圖繪》、《星野》、《沿革》、《形勢》、《營建》、《祀典》、《靈異》、《嶽生》、《詩賦》、《藝文》，各為一卷。其凡例謂“漢武之登封，孝明之巡幸，胡後、武曌之離宮別院，事涉遊盤，無關秩祀，概從刪削”，可謂矜慎。然《靈異類》中所引述《異記》、《虞初志》諸書，半是寓言。《藝文類》載《嵩嶽嫁女記》，尤為不經。《詩賦》、《藝文》析為二類，金石之文如《石闕碑》別見於《營建類》中，亦為錯亂，則亦仍地志之龐雜而已。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":10},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=947089","type":"text","details":"景東暘"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=5179755","type":"text"},{"id":"shidianguji-kangxisanshiwutaiyiy","name":"识典古籍","url":"https://www.shidianguji.com/book/HY2703","type":"text+image","metadata":{"edition":"康熙三十五年(1696)太壹園刻本","version":"v15","total_page":624,"paragraph_count":460,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-qingkangxikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/NLG312001080127","type":"text+image","metadata":{"edition":"清康熙35年[1696]刻本","version":"v4","total_page":615,"paragraph_count":1455,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL545UEbKm":{"id":"GYL545UEbKm","type":"work","title":"雞足山志","authors":[{"name":"範承勳","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《雞足山志》•十卷","author_info":"國朝範承勳撰","summary":"國朝範承勳撰。承勳，鑲黃旗漢軍。大學士文程之子，浙閩總督承謨之弟，官至雲貴總督。雞足山在雲南賓川州東一百里，一頂三支，儼如雞距，在蒼山、洱海之間，相傳為迦葉尊者入定處。佛寺最多，故志山者多述佛門之事。是編乃康熙三十一年承勳因舊本增修，分《圖紀》、《考證》、《星野》、《形勢》、《山水》、《寺院》、《人物》、《靈跡》、《物產》、《藝文》，凡十門，而以《迦葉像贊》冠於卷端焉。","edition":"浙江汪啟淑家藏本"}],"juan_count":{"number":10},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=51651","type":"text"},{"id":"shidianguji-kangxisanshiyikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY2569","type":"text+image","metadata":{"edition":"康熙三十一年(1692)刻本","version":"v8","total_page":900,"paragraph_count":1047,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL545gHEzK":{"id":"GYL545gHEzK","type":"work","title":"廬山志","authors":[{"name":"毛德琦","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《廬山志》•十五卷","author_info":"國朝毛德琦撰","summary":"國朝毛德琦撰。德琦字心齋，鄞縣人。由貢生官星子縣知縣。是編取桑喬《廬山紀事》、吳煒《廬山續志》二書，匯而訂之。首《星野》，次《輿地》，次《祀典》，次《隱逸》，次《仙釋》，次《物產》，次《雜誌》，次《災祥》，共一卷。次《山川分紀》十二卷。次《藝文》二卷。琦自序雲：“山川分紀多仍其舊，文翰則隨時而增。”書之冗濫，二語已自道之矣。","edition":"安徽巡撫采進本"}],"juan_count":{"number":15},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/廬山志","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=100525","type":"text","details":"毛德琦"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1617477","type":"text"},{"id":"shidianguji-kangxiwushibakeqianl","name":"识典古籍","url":"https://www.shidianguji.com/book/HY2523","type":"text+image","metadata":{"edition":"康熙五十八年(1719)刻乾隆五十八年(1793)順德堂補刻本","version":"v7","total_page":1917,"paragraph_count":15064,"check_type":"AI整理"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02052403","type":"text+image","metadata":{"edition":"刻本","version":"v4","total_page":1881,"paragraph_count":12807,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL545DvGtF":{"id":"GYL545DvGtF","type":"work","title":"百城煙水","authors":[{"name":"徐崧、張大純同","role":"編","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《百城煙水》•九卷","author_info":"國朝徐崧、張大純同編","summary":"國朝徐崧、張大純同編。崧，吳江人。大純，長洲人。前有尤侗序，大略稱崧有詩名，好遊佳山水。間嘗綴集吳地古跡為此書。取華嚴南詢之意以名之。其友張大純助其捃摭，未畢而崧歿，大純因重加纂輯刊行。凡蘇州府及所屬諸縣名勝山川，並為臚載。然每條詮敘簡略，而所錄題詠至夥。蓋頗仿祝穆《方輿勝覽》之例，以詞藻為尚，而不主考證。然穆書遍及州郡，此獨有姑蘇一隅。穆書於前人著述採擷甚富，而此所收率系近人之作，並附入己詩。則又出穆書之下矣。書刊於康熙庚午，時尚未升太倉為直隸州，故太倉及嘉定、崇明二縣皆列於此書雲。","edition":"浙江巡撫采進本"}],"juan_count":{"number":9},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/百城煙水","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=431131","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=624845","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=93281","type":"text","details":"徐崧、張大純"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02052338","type":"text+image","metadata":{"edition":"刻本","version":"v6","total_page":829,"paragraph_count":330,"check_type":"粗校"}},{"id":"shidianguji-kangxikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY2736","type":"text+image","metadata":{"edition":"康熙刻本","version":"v6","total_page":857,"paragraph_count":2768,"check_type":"AI整理"}},{"id":"shidianguji-kangxiershijiukeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02086832","type":"text+image","metadata":{"edition":"康熙二十九年刻本","version":"v3","total_page":828,"paragraph_count":5188,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL545NVPcB":{"id":"GYL545NVPcB","type":"work","title":"說嵩","authors":[{"name":"景日昣","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《說嵩》•三十二卷","author_info":"國朝景日昣撰","summary":"國朝景日昣撰。日昣字東陽，登封人。康熙辛未進士，官至戶部侍郎。是書自卷一至卷八，統紀嵩高及二室。卷九以下，分《星野》、《形勝》、《封域》、《巡祀》、《古跡》、《金石》、《傳人》、《物產》、《仙釋》、《摭異》、《藝林》、《風什》九門。考嵩山為中嶽，本於《爾雅》、《毛詩》，故《史記》主其說。胡渭《禹貢錐指》信《爾雅》前條“河南華”之文，而指後條“嵩高為中嶽”乃後人附益。然鄭康成注《大司樂》，謂華為中嶽；而注《小宗伯》，則以嵩為中嶽。賈疏謂《大司樂注》據鎬京，《小宗伯注》據洛邑，其說似可與《爾雅》前後二文相證。即雲後人附益，而康成已兼據之矣。又外方之為嵩山，見於《尚書》孔注、《水經注》諸書。金吉甫乃謂嵩高非外方，殊妄。此書於中嶽宗《史記》，於外方引《水經注》。考核殊不謬。然《嵩書》及《嵩山志》、《天下名山志》之類，於此山形勝沿革，已為廣徵博輯。此特綜匯舊文，踵而成之耳。","edition":"直隸總督采進本"}],"juan_count":{"number":32},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=964745","type":"text","details":"景日珍"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1755702","type":"text"},{"id":"shidianguji-kangxiyueshengtangke","name":"识典古籍","url":"https://www.shidianguji.com/book/HY2515","type":"text+image","metadata":{"edition":"康熙嶽生堂刻本","version":"v15","total_page":1710,"paragraph_count":14193,"check_type":"AI整理"}},{"id":"shidianguji-kangxikanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA03184","type":"text+image","metadata":{"edition":"康煕55年刊本","version":"v3","total_page":1644,"paragraph_count":18206,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL545Xkp7q":{"id":"GYL545Xkp7q","type":"work","title":"普陀山志","authors":[{"name":"朱謹、陳璿同","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《普陀山志》•十五卷","author_info":"國朝朱謹、陳璿同撰","summary":"國朝朱謹、陳璿同撰。謹有《中庸本旨》，已著錄。璿始末未詳。普陀山在定海縣東海中，佛經稱為觀音大士道場。自梁迄明，代有興建。是志所述，本末頗具，而敍事冗遝無法。","edition":"內府藏本"}],"juan_count":{"number":15},"resources":[{"id":"shidianguji-kangxisishisankeben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY0198","type":"text+image","metadata":{"edition":"康熙四十三年刻本","version":"v9","total_page":900,"paragraph_count":2395,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-kangxisishisanpujisi","name":"识典古籍","url":"https://www.shidianguji.com/book/HY2577","type":"text+image","metadata":{"edition":"康熙四十三年(1704)普濟寺刻本","version":"v10","total_page":856,"paragraph_count":2070,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL545dQe8X":{"id":"GYL545dQe8X","type":"work","title":"林屋民風","authors":[{"name":"王維德","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《林屋民風》•十二卷","author_info":"國朝王維德撰","summary":"國朝王維德撰。維德字洪緒，吳縣人。是書成於康熙癸巳。因蔡昇《太湖志》、王鏊《震澤編》、翁澍《具區志》而廣之。林屋為洞庭西山之別名。維德乙太湖諸山，洞庭最大，故舉以名其集，而諸山則附載焉。其所採錄，賦詠居多，考證殊鮮。如所載馬跡山引《毗陵志》以證舊志之誤；津裏山之一名秦履山，引《四蕃志》以證《具區志》之非，特偶然一見耳。目錄載附《見聞錄》一卷，此本無之，或偶佚歟？","edition":"浙江鮑士恭家藏本"}],"juan_count":{"number":12},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=2659650","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02052395","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":779,"paragraph_count":6472,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL5455JUJs":{"id":"GYL5455JUJs","type":"work","title":"四明山古跡記","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《四明山古跡記》•五卷","author_info":"不著撰人名氏，亦無序跋","summary":"不著撰人名氏，亦無序跋。詳書中所載，即黃宗羲所撰《四明山志》稿本也。宗羲《四明山志》自序有曰：“壬午歲，餘作《四明志》，亡友陸文虎欲刻之而未果。癸丑歲盡，偶展此卷，文虎評校之朱墨，如初脫手。然其間凡例不齊，詞不雅馴。重為竄改，始得成書。”其序作於康熙十一年。所稱壬午，蓋明崇禎十六年也。此書不署年月，亦無文虎姓名題識，而中有朱墨數處，與宗羲序合。殆即文虎評校之本歟？其第三卷、四卷、五卷內有黃時貞添注四條。其一條稱壬辰六月識，又一條述老人談天啟間事，當在順治九年以後。或時貞得此稿本，又以意為訂正耶？《四明山志》既有成書，此未定之草，固可置而不論矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":5}},"GYL545KfUbq":{"id":"GYL545KfUbq","type":"work","title":"嶽麓志","authors":[{"name":"趙寧","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《嶽麓志》•八卷","author_info":"國朝趙寧撰","summary":"國朝趙寧撰。甯字又裔，山陰人。官長沙府同知。是志因舊本增輯，成於康熙丁卯。第一卷為《新典》及《圖說》、二卷為《山水》、《古跡》、《新建寺觀》、《疆域》，三卷為《書院》，四卷以下皆《藝文》也。卷首序文，自為一巨冊，當全書四分之一。同修姓氏列至一百四十二人，則其書可知矣。","edition":"浙江汪啟淑家藏本"}],"juan_count":{"number":8}},"GYL545B6Msu":{"id":"GYL545B6Msu","type":"work","title":"穹窿山志","authors":[{"name":"李標","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《穹窿山志》•六卷","author_info":"國朝李標撰","summary":"國朝李標撰。山在蘇州府城西。是編前四卷雜錄序記、疏引等作，後二卷紀遊覽題贈之詩。蓋是時道士施亮生居此山，方以符術鳴於東南。其書實為亮生而作，非專志山之名勝也。","edition":"兩淮馬裕家藏本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=8822358","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02052333","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":537,"paragraph_count":690,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL545kb9H1":{"id":"GYL545kb9H1","type":"work","title":"羅浮山志","authors":[{"name":"陶敬益","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《羅浮山志》•十二卷","author_info":"國朝陶敬益撰","summary":"國朝陶敬益撰。敬益，江寧人。康熙中官博羅縣知縣。是編因黎惟敬舊志，益以僧塵異《名峰圖說》，互相補輯，合為一書。然首有《圖經》，又有《名峰圖》，又有《岩洞志》。前後繁複，殊無義例。是則兼取兩家，未能融鑄翦裁之故也。","edition":"內府藏本"}],"juan_count":{"number":12},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=295795","type":"text","details":"宋廣業"},{"id":"shidianguji-kangxiwushiliukeben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY0205","type":"text+image","metadata":{"edition":"康熙五十六年刻本","version":"v11","total_page":1492,"paragraph_count":3352,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-kangxiwushiwusongzhi","name":"识典古籍","url":"https://www.shidianguji.com/book/HY2536","type":"text+image","metadata":{"edition":"康熙五十五年(1716)宋志益刻本","version":"v9","total_page":1426,"paragraph_count":9749,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL545yRUSB":{"id":"GYL545yRUSB","type":"work","title":"武夷九曲志","authors":[{"name":"王複禮","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《武夷九曲志》•十六卷","author_info":"國朝王複禮撰","summary":"國朝王複禮撰。複禮有《家禮辨定》，已著錄。武夷山在福建崇安縣南三十裏，其溪九曲。宋劉道元初為作志，其後屢有增輯。是書成於康熙五十七年，前卷既以詩文分入《山水》，而後卷又列《藝文》一門，體例頗雜。又附錄己作，連篇累牘，是竟以山經為家集矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":16},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4193373","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02052440","type":"text+image","metadata":{"edition":"刻本","version":"v7","total_page":843,"paragraph_count":5009,"check_type":"AI整理"}}],"has_text":true,"has_image":true}}