{"GYL547rXdCs":{"id":"GYL547rXdCs","type":"work","title":"武林志餘","authors":[{"name":"張暘","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《武林志餘》•三十二卷","author_info":"國朝張暘撰","summary":"國朝張暘撰。暘字東榑，號滌岑，錢塘人。是書搜輯武林諸名勝，於道觀、祠廟、名賢、古跡，紀載尤詳。其末一卷，附錄方物，亦頗有考訂。名《志餘》者，欲以補前志所未備也。然采摭頗富，而體例未精，往往失之冗雜。所錄近人題詠，亦殊少別裁。","edition":"浙江巡撫采進本"}],"juan_count":{"number":32}},"GYL547k3Rr7":{"id":"GYL547k3Rr7","type":"work","title":"通元觀志","authors":[{"name":"吳陳琰","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《通元觀志》•二卷","author_info":"國朝吳陳琰撰","summary":"國朝吳陳琰撰。陳琰有《春秋三傳同異考》，已著錄。通元觀在錢塘縣。宋紹興中，劉鹿泉請於高宗，建為修真之所。嘉靖中，姜南始志之。陳琰以薑志未備，更為此書。","edition":"浙江巡撫采進本"}],"juan_count":{"number":2}},"GYL547nDivB":{"id":"GYL547nDivB","type":"work","title":"孔宅志","authors":[{"name":"諸紹禹","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《孔宅志》•六卷","author_info":"國朝諸紹禹撰","summary":"國朝諸紹禹撰。紹禹，松江人。青浦縣治之北，地名孔宅。舊有孔子廟，相傳隋末孔子三十四代裔孫蘇州刺史禎僑寓於吳，乃立家廟，並葬先聖衣冠於此。後漸湮廢，明陸應陽重修之，始述為《孔廟記》，陳功又作《續記》。康熙中，紹禹增刪舊本，以成是編。案：禎生於隋代，不應尚存先聖衣冠。即有之，亦不應攜至吳中。且隋時郡縣，並無蘇州之名。其說殊未可盡信也。","edition":"兩江總督采進本"}],"juan_count":{"number":6},"resources":[{"id":"shidianguji-qingpuxianshuqingkan","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ892411999032771164170","type":"text+image","metadata":{"edition":"青浦縣署清康熙刻本","version":"v3","total_page":549,"paragraph_count":2462,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL547WRRCK":{"id":"GYL547WRRCK","type":"work","title":"崇恩志略","authors":[{"name":"僧智藏","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《崇恩志略》•七卷","author_info":"國朝僧智藏撰","summary":"國朝僧智藏撰。智藏字竺堂，安福人。崇恩寺在廬陵，創自吳赤烏中，屢經廢興。康熙丙午，智藏重修之，因輯是書。一卷《山水道場》及歷代住持上堂《語錄》，二卷《記疏》，三卷《詩對聯》，四卷《序》，五卷《啟書》，六卷《雜著法語》，七卷《法產》。大旨在張惶佛教，以外護為至榮。體例蕪雜之甚。","edition":"江西巡撫采進本"}],"juan_count":{"number":7}},"GYL547hGChD":{"id":"GYL547hGChD","type":"work","title":"白鹿書院志","authors":[{"name":"毛德琦","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《白鹿書院志》•十九卷","author_info":"國朝毛德琦撰","summary":"國朝毛德琦撰。德琦有《廬山志》，已著錄。康熙甲午，德琦為星子縣知縣，因取廖文英原志重加訂正。分類凡十，曰《形勝》，曰《興複》，曰《沿革》，曰《先獻》，曰《主洞》，曰《學規》，曰《書籍》，曰《藝文》，曰《祀典》，曰《田賦》。《形勝》等七門，皆因舊志，《興複》、《主洞》、《書籍》三門，則德琦所增也。","edition":"安徽巡撫采進本"}],"juan_count":{"number":19},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=418389","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=516118","type":"text"},{"id":"shidianguji-kanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA04603","type":"text+image","metadata":{"edition":"刊本(序刊)","version":"v27","total_page":1138,"paragraph_count":1824,"check_type":"粗校"}},{"id":"shidianguji-kangxiwushijiukeqian","name":"识典古籍","url":"https://www.shidianguji.com/book/HY1809","type":"text+image","metadata":{"edition":"康熙五十九年(1720)刻乾隆六十年(1795)同治十年(1871)補刻印本","version":"v17","total_page":1174,"paragraph_count":1045,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-kangxiwushiqikezhouz","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02086498","type":"text+image","metadata":{"edition":"康熙五十七年刻周兆蘭等補修本","version":"v7","total_page":1146,"paragraph_count":9112,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL547TbWBy":{"id":"GYL547TbWBy","type":"work","title":"青原志略","authors":[{"name":"僧大然","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《青原志略》•十三卷","author_info":"國朝僧大然撰","summary":"國朝僧大然撰，施閏章補輯。大然始末未詳。閏章字尚白，號愚山，宣城人。順治己丑進士，官至江西布政司參議。康熙己未，召試博學鴻詞，授翰林院侍讀。青原為吉州名勝，自唐行思禪師開山說法以後，遂為巨刹。至明王守仁、羅洪先、歐陽德諸人於此講學，故第三卷特立《書院》一門，略記當時問對之語。而其所採錄皆理之近於禪宗者，則緇流援儒入墨，藉以自張其教也。","edition":"兩淮馬裕家藏本"}],"juan_count":{"number":13},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=557587","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7757340","type":"text"},{"id":"shidianguji-kangxibakeben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY0130","type":"text+image","metadata":{"edition":"康熙八年刻本","version":"v8","total_page":742,"paragraph_count":1912,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02052534","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":729,"paragraph_count":2007,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL547yckeT":{"id":"GYL547yckeT","type":"work","title":"宋東京考","authors":[{"name":"周城","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《宋東京考》•二十卷","author_info":"國朝周城撰","summary":"國朝周城撰。城號石匏，嘉興人。是書前有雍正辛亥王珻序，稱城“客大樑三載，隨境討蒐，以成此書”。其凡例有雲：“建隆以前，東京非宋；靖康而後，宋不東京。”蓋專紀汴都一百七十年之遺跡而作也。每條皆援引舊書，列其原文。蓋仿朱彝尊《日下舊聞》之體。然多引類書，其博贍殊不及彝尊。又多載雜事，務盈卷帙。如所引《宋稗類抄》“二近侍爭辨貴賤由天”一事，因首有仁宗禦便殿一語，遂列之《宮殿類》中。然則一代帝王，何事不在宮殿內，豈勝載乎？他如造字台、吹台、繁台，卷中所引各書，皆謂一台而數名。乃於繁台則併入吹台，又別立造字台名之類。多彼此牴牾，無所考證。其精核亦不及彝尊也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":20},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=116901","type":"text"},{"id":"shidianguji-qianlongkanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA04670","type":"text+image","metadata":{"edition":"乾隆03年刊本","version":"v5","total_page":742,"paragraph_count":565,"check_type":"粗校"}},{"id":"shidianguji-qianlongkeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02086858","type":"text+image","metadata":{"edition":"乾隆刻本","version":"v5","total_page":727,"paragraph_count":4841,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL547c5FD1":{"id":"GYL547c5FD1","type":"work","title":"白鹿書院志","authors":[{"name":"廖文英","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《白鹿書院志》•十六卷","author_info":"國朝廖文英撰","summary":"國朝廖文英撰。文英有《正字通》，已著錄。初，唐李渤與其兄涉讀書廬山，蓄一白鹿甚馴，因名白鹿洞。宋初置書院於五老峰下。朱子守南康軍，援嶽麓書院例，疏請敕額，遂為四大書院之一。康熙中，文英為南康知府，因即舊志修輯，以成是書。意求繁富，頗失翦裁。","edition":"安徽巡撫采進本"}],"juan_count":{"number":16},"resources":[{"id":"shidianguji-kanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA04603","type":"text+image","metadata":{"edition":"刊本(序刊)","version":"v27","total_page":1138,"paragraph_count":1824,"check_type":"粗校"}},{"id":"shidianguji-kangxiwushijiukeqian","name":"识典古籍","url":"https://www.shidianguji.com/book/HY1809","type":"text+image","metadata":{"edition":"康熙五十九年(1720)刻乾隆六十年(1795)同治十年(1871)補刻印本","version":"v17","total_page":1174,"paragraph_count":1045,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-kangxiwushiqikezhouz","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02086498","type":"text+image","metadata":{"edition":"康熙五十七年刻周兆蘭等補修本","version":"v7","total_page":1146,"paragraph_count":9112,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL5474chKd":{"id":"GYL5474chKd","type":"work","title":"禹門寺志","authors":[{"name":"戴英","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《禹門寺志》•六卷","author_info":"明戴英撰","summary":"明戴英撰。英字上慎，宜興人。崇禎甲戌進士。禹門寺在宜興之龍池山。是編前志山寺僧侶，後紀碑銘序記詩文，多未雅馴。","edition":"兩江總督采進本"}],"juan_count":{"number":6}},"GYL547ezXvF":{"id":"GYL547ezXvF","type":"work","title":"靈穀寺志","authors":[{"name":"吳雲","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《靈穀寺志》•十六卷","author_info":"國朝吳雲撰","summary":"國朝吳雲撰。雲號舫翁，安福人。靈谷寺在江寧鍾山之左，明太祖遷梁寶志塔於此，改賜今名，而號其山曰“紫金”。舊有景泰間僧潔菴、嘉靖間黃河二志。康熙庚辰，雲重輯為是編。前有雲自序，及寺僧寂曙所紀修輯緣起。凡分二十四類，其門目皆因明志之舊，僅略為刪補耳。","edition":"兩江總督采進本"}],"juan_count":{"number":16}},"GYL547QiuLB":{"id":"GYL547QiuLB","type":"work","title":"二樓小志","authors":[{"name":"程元愈","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《二樓小志》•四卷","author_info":"國朝程元愈撰","summary":"國朝程元愈撰，汪越、沈廷璐又補葺之。與佟賦偉《二樓紀略》一書相為表裏，皆記甯國府南北樓事。北樓即謝朓之高齋，南樓即文昌台。明嘉靖中知府朱大器所建也。賦偉書旁涉他事，殊為龐雜。此輯錄歷代題詠，並記南樓建造之始末，差為有緒。越有《讀史記十表》，已著錄。元愈字偕柳，廷璐字元佩，皆寧國人。","edition":"浙江巡撫采進本"}],"juan_count":{"number":4},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=691968","type":"text","details":"程元愈、汪越、沈廷璐、佟賦偉"},{"id":"shidianguji-kangxiwushijiukeben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY0212","type":"text+image","metadata":{"edition":"康熙五十九年刻本","version":"v7","total_page":1033,"paragraph_count":1562,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL5477ScKy":{"id":"GYL5477ScKy","type":"work","title":"鄧尉聖恩寺志","authors":[{"name":"周永年","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《鄧尉聖恩寺志》•十八卷","author_info":"明周永年撰","summary":"明周永年撰。永年字安期，吳江人。鄧尉故有《沈津志》，茲編乃踵而增之。凡梵宇、名釋、序記、語錄，無不備載。大約於寺之建置本末，尤為詳悉。故以《聖恩寺志》為名。書成於崇禎十五年，而中有康熙中碑刻，及宋犖、徐秉義詩文。蓋後人所續入也。","edition":"江蘇周厚堉家藏本"}],"juan_count":{"number":18},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=216194","type":"text"},{"id":"shidianguji-chongzhenshiqikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02086472","type":"text+image","metadata":{"edition":"崇禎十七年刻本","version":"v9","total_page":417,"paragraph_count":586,"check_type":"粗校"}},{"id":"shidianguji-chongzhenkanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA03164","type":"text+image","metadata":{"edition":"崇禎17年刊本","version":"v11","total_page":442,"paragraph_count":1131,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL547pML8o":{"id":"GYL547pML8o","type":"work","title":"丹霞洞天志","authors":[{"name":"蕭韻","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《丹霞洞天志》•十七卷","author_info":"國朝蕭韻撰","summary":"國朝蕭韻撰。韻字明彝，南城人。康熙中舉人。明萬曆中，建昌府知府鄔齊雲，嘗屬郡人左宗郢為《麻姑山志》，久而版毀。康熙中，湖東道羅森，複令韻增補成之。首系以圖，次列考、表、志、記諸目，而於題詠詞賦為尤詳。","edition":"兩江總督采進本"}],"juan_count":{"number":17}},"GYL5471hQcP":{"id":"GYL5471hQcP","type":"work","title":"延壽寺紀略","authors":[{"name":"釋圓複","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《延壽寺紀略》•一卷","author_info":"明釋圓複撰","summary":"明釋圓複撰。圓複字休遠，鄞縣人。與屠隆同時。延壽寺在鄞縣南三裏，舊號保恩院。宋祥符間，改為延壽寺。是書詳述知禮禪師本末，及宋相曾公亮置買莊田舊事，他無所載。蓋自備古刹之典故而已。","edition":"兩淮馬裕家藏本"}],"juan_count":{"number":1}},"GYL547tfERV":{"id":"GYL547tfERV","type":"work","title":"東林書院志","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《東林書院志》•二十二卷","author_info":"國朝高嵀，高嶐、高廷珍、高陛、許獻同撰","summary":"國朝高嵀，高嶐、高廷珍、高陛、許獻同撰。嵀等四人皆高攀龍之裔，獻亦攀龍同縣人也。其書分《建置》、《院規》、《會語》、《祀典》、《列傳》、《公移》、《文翰》、《典守》、《著述》、《軼事》十門。意在博搜廣采，而體例冗雜頗甚。所附諸人，又多牽附。不特孫承澤濫廁其間，即宋犖平生，亦僅刻意于文章，未嘗聞其講學也。","edition":"兩江總督采進本"}],"juan_count":{"number":22},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=899699","type":"text"},{"id":"shidianguji-yongzhengshiyikanben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02086510","type":"text+image","metadata":{"edition":"雍正十一年刊本","version":"v3","total_page":1294,"paragraph_count":14549,"check_type":"AI整理"}},{"id":"shidianguji-guangxukeben","name":"识典古籍","url":"https://www.shidianguji.com/book/NLG312001066712","type":"text+image","metadata":{"edition":"光緒7年刻本","version":"v2","total_page":1390,"paragraph_count":2643,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL547BoCU7":{"id":"GYL547BoCU7","type":"work","title":"南溪書院志","authors":[{"name":"葉廷祥、郭以隆、紀延譽、陳翹卿同","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《南溪書院志》•四卷","author_info":"明葉廷祥、郭以隆、紀延譽、陳翹卿同撰","summary":"明葉廷祥、郭以隆、紀延譽、陳翹卿同撰。廷祥官尤溪縣知縣。以隆稱署縣事，疑為丞簿之類。延譽、翹卿則尤溪教諭、訓導也，其裏貫均未詳。南溪者，朱子之父松作尉尤溪，實生朱子於其地。理宗嘉熙初，尤溪令李修，以時方崇尚道學，人爭攀附，遂於其地建二朱先生祠，即書院所自昉也。志中載書院額為帝顯德祐元年所賜，而李韶所作記在嘉熙改元之歲，已稱南溪書院。則初建時已有此名，但賜額在後耳。其書僅紀書院之跡，所附詩文，多不雅馴。延譽之序，以朱松、朱子及宋理宗皆跳行別書，使君臣相並，則欲尊朱子而不知所以尊，悖謬甚矣。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":4},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=6628977","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02052531","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":196,"paragraph_count":1669,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL547Jyhcb":{"id":"GYL547Jyhcb","type":"work","title":"滄浪小志","authors":[{"name":"宋犖","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《滄浪小志》•二卷","author_info":"國朝宋犖撰","summary":"國朝宋犖撰。犖字牧仲，號漫堂，商邱人。由蔭生官至吏部尚書。是編乃犖為江蘇巡撫時得宋蘇舜欽滄浪亭舊址，重為修葺。因蒐輯前人傳記詩文而附以所作記一篇，詩一首，及尤侗、範承勳詩各一首，共為一集。當時頗稱其好事。然其所采，多為舜欽而作，與亭無涉。又南禪寺雖附近亭旁，而實非當日之故址。一概泛載，亦未免稍失斷限矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":2},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=438816","type":"text"},{"id":"shidianguji-kangxikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY2581","type":"text+image","metadata":{"edition":"康熙刻本","version":"v7","total_page":116,"paragraph_count":121,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL547MtzKq":{"id":"GYL547MtzKq","type":"work","title":"杏花村志","authors":[{"name":"郎遂","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《杏花村志》•十二卷","author_info":"國朝郎遂撰","summary":"國朝郎遂撰。遂字趙客，號西樵子，池州人。按，杜牧之為池陽守，清明日出遊，詩有“借問酒家何處有，牧童遙指杏花村”句，蓋泛言風景之詞。猶之楊柳岸、蘆荻洲耳。必指一村以實之，則活句反為滯相矣。然流俗相沿，多喜附會古跡，以誇飾土風。故遂居是村，即以古今名勝、建置及人物、藝文集為是編。蓋亦志乘之結習也。至於郎氏族系亦附錄其中，則並非志乘體矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":12}},"GYL547wV9Rq":{"id":"GYL547wV9Rq","type":"work","title":"增修雲林寺志","authors":[{"name":"厲鶚","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《增修雲林寺志》•八卷","author_info":"國朝厲鶚撰","summary":"國朝厲鶚撰。鶚有《遼史拾遺》，已著錄。是編成於乾隆甲子，以靈隱舊志脫漏尚多，且聖祖仁皇帝省方南幸，駐蹕山中，賜名雲林寺，不宜仍用舊名。故因前志而增輯之。首紀《宸恩》，次《山水》，次《禪祖》，次《法語》，次《檀越人物》，次《藝文詩詠》，而以《遺事雜記》終焉。","edition":"浙江巡撫采進本"}],"juan_count":{"number":8},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=264913","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=807605","type":"text"},{"id":"shidianguji-guangxushisikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02086483","type":"text+image","metadata":{"edition":"光緒十四年刻本","version":"v4","total_page":354,"paragraph_count":3307,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL547DyVYB":{"id":"GYL547DyVYB","type":"work","title":"破山興福寺志","authors":[{"name":"程嘉燧","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《破山興福寺志》•四卷","author_info":"明程嘉燧撰","summary":"明程嘉燧撰。嘉燧字孟陽，休寧人。崇禎末布衣。《明史•文苑傳》附載《唐時升傳》末。常熟縣西北十裏有破山，其麓有寺曰“興福”，乃齊梁間所建。是書一卷、二卷記山中古跡，而詩文附焉。三卷志建置。四卷志禪宗。序次雅潔，為山志中差善之本。","edition":"兩淮馬裕家藏本"}],"juan_count":{"number":4}},"GYL547G76ko":{"id":"GYL547G76ko","type":"work","title":"靈隱寺志","authors":[{"name":"孫治","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《靈隱寺志》•八卷","author_info":"國朝孫治撰","summary":"國朝孫治撰，徐增重編。治字宇台，仁和人。增字子能，吳縣人。其書因明萬曆中昌黎白珩之志，稍增損之。體例與他志略同。惟以宦遊寄寓之人概收之《人物》一門，則事涉創造，於義未安。","edition":"兩淮馬裕家藏本"}],"juan_count":{"number":8},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=607991","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1663440","type":"text"}]},"GYL547ZLhuZ":{"id":"GYL547ZLhuZ","type":"work","title":"江心志","authors":[{"name":"釋元奇","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《江心志》•十二卷","author_info":"國朝釋元奇撰","summary":"國朝釋元奇撰。江心寺在溫州府北永嘉江中，即謝靈運詩所謂“亂流趨正絕，孤嶼媚中川”者也。宋高宗嘗幸其地，稱為名勝。明釋成斌、郡人王暘穀始創為之志。元奇因舊本重加編輯。凡《紀跡》一卷，《敕書》一卷，《藝文》八卷，《世系》、《雜記》二卷。","edition":"浙江巡撫采進本"}],"juan_count":{"number":12},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=2318943","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02052541","type":"text+image","metadata":{"edition":"刻本","version":"v4","total_page":569,"paragraph_count":3345,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL5479cuQ3":{"id":"GYL5479cuQ3","type":"work","title":"天童寺集","authors":[{"name":"楊明","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《天童寺集》•二卷","author_info":"明楊明撰","summary":"明楊明撰。明不知何許人。天童寺在鄞縣東六十裏。晉永康間，義興禪師居此山，有童子來供薪水，久之辭去，自稱太白星。因是山名太白，寺名天童。茲編敍述形勝，綴以藝文。前序無姓名，疑即明所自作。中稱撰為七卷，今止兩卷，似尚非完帙也。","edition":"兩淮馬裕家藏本"}],"juan_count":{"number":2},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=2319510","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02052530","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":146,"paragraph_count":147,"check_type":"粗校"}}],"has_text":true,"has_image":true}}