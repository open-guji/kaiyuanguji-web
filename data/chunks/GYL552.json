{"GYL552FkEum":{"id":"GYL552FkEum","type":"work","title":"大學辨業","authors":[{"name":"李塨","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《大學辨業》•四卷、《聖經學規纂》•二卷、《論學》•二卷","author_info":"國朝李塨撰","summary":"國朝李塨撰。塨有《周易傳注》，已著錄。是編發明古《大學》之法，以辨俗學之非，大旨與其《大學傳注》同。首總論《大學》，次辨後儒所論《小學》、《大學》，次論《小學》，次辨後儒改易《大學》原本，次《大學》原文及全篇解，次《大學》之道至致知格物解，次辨後儒格物解，次其本亂至此謂知之至也解，次申論格物，次所謂誠其意者至末解，次申解全篇。其所爭在以格物為周禮三物。其謂孔子之時，古《大學》教法所謂六德、六行、六藝者，規矩尚存，故格物之學人人所習，不必再言。惟以明德、親民標其宗要，以誠意指其入手功夫而已。格物一傳，可不必補。其說較他家為巧，故當時學者多稱之。《聖經學規纂》二卷，則摘錄四書、五經之言學者，申明其說。《論學》二卷，則錄朋友問難之語。其凡例所謂《辨業》意有不盡者入之《學規》，《學規》意有不盡者入之《論學》是也。","edition":"直隸總督采進本"}],"juan_count":{"number":4},"related_works":[{"id":"GYLt1GCKa5M","title":"聖經學規纂"},{"id":"GYLt1GCeP3V","title":"大學辨業論學"}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=536573","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=319423","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=951276","type":"text"},{"id":"shidianguji-jifucongshu","name":"识典古籍","url":"https://www.shidianguji.com/book/CJF087","type":"text+image","metadata":{"edition":"畿輔叢書","version":"v4","total_page":490,"paragraph_count":497,"check_type":"粗校"}},{"id":"shidianguji-guangxuwudingzhouwan","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054455","type":"text+image","metadata":{"edition":"光緒五年定州王氏謙德堂刻畿輔叢書本","version":"v3","total_page":100,"paragraph_count":139,"check_type":"粗校"}},{"id":"shidianguji-guangxuwudingzhouwan-1","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL01060702","type":"text+image","metadata":{"edition":"光緒五年定州王氏謙德堂本","version":"v2","total_page":106,"paragraph_count":132,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL552T1D5h":{"id":"GYL552T1D5h","type":"work","title":"程功錄","authors":[{"name":"楊名時","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《程功錄》•五卷","author_info":"國朝楊名時撰","summary":"國朝楊名時撰。名時有《周易劄記》，已著錄。是編乃其講學劄記。體例全仿薛瑄《讀書錄》，然中間頗涉雜論。第四卷中剖析鉛汞之說，尤於儒理無關。其亦鄒注《參同契》意耶？以大旨醇實，故仍列之儒家焉。","edition":"兩江總督采進本"}],"juan_count":{"number":5},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7773906","type":"text"}]},"GYL5529arX9":{"id":"GYL5529arX9","type":"work","title":"困學錄集粹","authors":[{"name":"張伯行","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《困學錄集粹》•八卷","author_info":"國朝張伯行撰","summary":"國朝張伯行撰。其書摹《讀書》、《居業》二錄之體。一、二卷題曰河幹公餘，三、四、五卷題曰閩署公餘，六、七、八卷題庚寅至甲辰年。六卷以上皆述其自得之語，七卷以下頗辨陸九淵、王守仁、高攀龍、劉宗周諸人之誤。","edition":"副都御史黃登賢家藏本"}],"juan_count":{"number":8},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=484202","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1093932","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4543023","type":"text"},{"id":"shidianguji-tongzhizhongkezhengy","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054442","type":"text+image","metadata":{"edition":"同治重刻正誼堂全書本","version":"v3","total_page":359,"paragraph_count":3311,"check_type":"AI整理"}},{"id":"shidianguji-fuzhouzhengyishuyuan","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL01024596","type":"text+image","metadata":{"edition":"福州正誼書院續刊本","version":"v1","total_page":362,"paragraph_count":3507,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL552ymTBM":{"id":"GYL552ymTBM","type":"work","title":"廣字義","authors":[{"name":"黃叔璥","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《廣字義》•三卷","author_info":"國朝黃叔璥撰","summary":"國朝黃叔璥撰。叔璥有《南征記程》，已著錄。初，宋陳普作《字義》，凡一百五十三字，孫承澤嘗為增訂。叔璥複取陳淳《北溪字義》及程遠《原字訓》合承澤所訂裒為一書。每條之首題原字者，晉之舊。題廣義者，皆續增也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":3},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1749987","type":"text","details":"（Southern Song）陳普（陳石堂） 編（清）孫承澤 增，黃叔璥 續"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054499","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":174,"paragraph_count":199,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL5523nxx7":{"id":"GYL5523nxx7","type":"work","title":"廣近思錄","authors":[{"name":"張伯行","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《廣近思錄》•十四卷","author_info":"國朝張伯行撰","summary":"國朝張伯行撰。伯行是編採集宋張栻、呂祖謙、黃榦，元許衡，明薛瑄、胡居仁、羅欽順七家之遺書，以續朱子《近思錄》。分十四門，仍如朱子原書之目。","edition":"副都御史黃登賢家藏本"}],"juan_count":{"number":14},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=144324","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=150659","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1561842","type":"text"},{"id":"shidianguji-fuzhouzhengyishuyuan","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL01024592","type":"text+image","metadata":{"edition":"福州正誼書院續刊本","version":"v6","total_page":488,"paragraph_count":3314,"check_type":"AI整理"}},{"id":"shidianguji-tongzhizhongkezhengy","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054429","type":"text+image","metadata":{"edition":"同治重刻正誼堂全書本","version":"v2","total_page":485,"paragraph_count":4795,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL552CTTNw":{"id":"GYL552CTTNw","type":"work","title":"理學正宗","authors":[{"name":"竇克勤","role":"編","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《理學正宗》•十五卷","author_info":"國朝竇克勤編","summary":"國朝竇克勤編。克勤字敏修，號敬菴，柘城人。康熙戊辰進士。官翰林院檢討。是編列宋周子、張子、二程子、楊時、胡安國、羅從彥、李侗、朱子、張栻、呂祖謙、蔡沈、黃榦、元許衡，明薛瑄共十五人，人各一傳，並取其語錄答問及著作之切於講學者錄之，附以己見，而於太極、《通書》釋之更詳。大旨以朱子為宗。李侗以上，開其緒者也；黃榦以下，衍其傳者也；胡安國等皆互相羽翼者也。克勤自序又雲：尚有邵康節、蔡元定二公之書，俟學者既通六經、四書而後可及。蓋二人之學皆主於數，與主理者又小別耳。","edition":"河南巡撫采進本"}],"juan_count":{"number":15},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=673736","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=632092","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=8099112","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY1410","type":"text+image","metadata":{"edition":"刻本","version":"v20","total_page":1014,"paragraph_count":797,"check_type":"粗校"}},{"id":"shidianguji-kangxikedoujinganxia","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054446","type":"text+image","metadata":{"edition":"康熙刻竇靜庵先生遺書本","version":"v3","total_page":998,"paragraph_count":8750,"check_type":"AI整理"}},{"id":"shidianguji-guangxushidaxinghuan","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL01027138","type":"text+image","metadata":{"edition":"光绪十年大兴黄振河本","version":"v3","total_page":998,"paragraph_count":7217,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL552syZcK":{"id":"GYL552syZcK","type":"work","title":"性理辨義","authors":[{"name":"王建衡","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《性理辨義》•二十卷","author_info":"國朝王建衡撰","summary":"國朝王建衡撰。建衡有《讀史辨惑》，已著錄。是書分二十篇，而列目凡十有五，曰原理、原氣、原天、原生物、原性、原命、原道、原德、原倫、原學、原鬼神、原人鬼、原祭、原妖厲、雜論。其第一篇與十二篇皆題曰原理，自注謂前統論天地之理，後以在物之理言。第二篇、第三篇皆題曰原氣。第四篇、第五篇、第六篇皆題曰原天，而不自言其所以分。推究其文，則原氣二篇，一言陰陽，一言五行。原天三篇，一言天行及日月，一言星辰及推算，一言風雨露雷諸事也。大旨皆複衍宋儒而加以膠固。其原天三篇，則純述歐羅巴語而諱所自來焉。","edition":"直隸總督采進本"}],"juan_count":{"number":20}},"GYL552Q8cDu":{"id":"GYL552Q8cDu","type":"work","title":"天理主敬圖","authors":[{"name":"冉覲祖","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《天理主敬圖》•一卷","author_info":"國朝冉覲祖撰","summary":"國朝冉覲祖撰。其圖上標天理二字，明性道之重。中列存養、省察、講學、力行四項，為體道之功。下書一敬字，以示心法之要。蓋為姚江之學言超悟者而發。然古人著書，必言不能盡其意者乃圖以明之。若體認天理，而存養、省察、講學、力行以歸於主敬，此可以言詮者也。何必托諸繪畫乎？","edition":"河南巡撫采進本"}],"juan_count":{"number":1}},"GYL5526fZou":{"id":"GYL5526fZou","type":"work","title":"濂洛關閩書","authors":[{"name":"張伯行","role":"編","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《濂洛關閩書》•十九卷","author_info":"國朝張伯行編","summary":"國朝張伯行編。取宋五子之書，粗存梗概，各為之注。凡周子一卷，張子一卷，二程子十卷，朱子七卷。每條皆以某子曰字冠之。夫《正蒙》間涉汗漫，程、朱語錄浩繁，多所刊削，尚為有說，至周子《通書》言言精粹，朱子尚為全注，伯行乃剷除其大半，何耶？","edition":"副都御史黃登賢家藏本"}],"juan_count":{"number":19},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=833608","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7179261","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=3690618","type":"text"},{"id":"shidianguji-fuzhouzhengyishuyuan","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL01024582","type":"text+image","metadata":{"edition":"福州正誼書院續刊本","version":"v6","total_page":616,"paragraph_count":808,"check_type":"粗校"}},{"id":"shidianguji-tongzhizhongkezhengy","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054435","type":"text+image","metadata":{"edition":"同治重刻正誼堂全書本","version":"v5","total_page":612,"paragraph_count":4624,"check_type":"AI整理"}},{"id":"shidianguji-jianghuxieben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA07428","type":"text+image","metadata":{"edition":"江戶寫本","version":"v4","total_page":821,"paragraph_count":7096,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL552q6xkX":{"id":"GYL552q6xkX","type":"work","title":"讀書日記","authors":[{"name":"劉源淥","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《讀書日記》•六卷","author_info":"國朝劉源淥撰","summary":"國朝劉源淥撰。凡記疑五卷，冷語一卷，皆讀書劄記之言。其記疑本二十四卷，冷語本五卷，後歸安陸師為之刪定，更以今名。然《冷語》又有三卷一本。蓋天下之至易作者，莫如語錄。偶逢紙筆，即可成編。故諸本錯出如是也。","edition":"山東巡撫采進本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=2412888","type":"text"},{"id":"shidianguji-yongzhengwuliuxingbi","name":"识典古籍","url":"https://www.shidianguji.com/book/HY1666","type":"text+image","metadata":{"edition":"雍正五年(1727)劉行秉等刻本","version":"v11","total_page":231,"paragraph_count":279,"check_type":"粗校"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054490","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":342,"paragraph_count":2199,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL552baKod":{"id":"GYL552baKod","type":"work","title":"心印正說","authors":[{"name":"吳台碩","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《心印正說》•三十四卷","author_info":"國朝吳台碩撰","summary":"國朝吳台碩撰。台碩字位三，嘉定人，陸隴其之門人也。是書成於康熙壬申，以學術治功之要分立篇目，而各為論以發明之。凡三十四類，每類又各有子目。於洛、閩緒言及歷代史論多所徵引。又間有注釋，不知何人所增入也。其曰心印，當取心心相印之義，然二字乃佛語，非儒語也。其說序二篇，則仿《序卦傳》體，述其次第，亦涉擬經。陸隴其為之作序，不一糾正，何耶？","edition":"江蘇巡撫采進本"}],"juan_count":{"number":34}},"GYL552VsowV":{"id":"GYL552VsowV","type":"work","title":"嵩陽學凡","authors":[{"name":"景日昣","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《嵩陽學凡》•六卷","author_info":"國朝景日昣撰","summary":"國朝景日昣撰。日昣有《嵩岳廟史》，已著錄。是書依《大學》八條目，排纂諸家語錄。意取通俗，故言皆淺近，蓋曹端《夜行燭》之類。每門中分析子目至數百餘，亦不免於蕪雜。","edition":"副都御史黃登賢家藏本"}],"juan_count":{"number":6}},"GYL552mY471":{"id":"GYL552mY471","type":"work","title":"冷語","authors":[{"name":"劉源淥","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《冷語》•三卷","author_info":"國朝劉源淥撰","summary":"國朝劉源淥撰。其門人馬恒謙編。其書仿語類之體，大旨本朱子之說而衍之。其三卷中一條詆劉安世為邪人，謂其害甚於章惇、邢恕，以其與伊川不協也。然《宋史》具在，安世《盡言集》亦具在，果章惇、邢恕之不若乎？不問其人品之醇疵，但以附合道學者為正，稍相齟齬者為邪，則蔡京之薦楊時，當為北宋第一正人矣。佛家以敬信三寶與否定人之罪福，儒者不當如是也。","edition":"副都御史黃登賢家藏本"}],"juan_count":{"number":3},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=332706","type":"text"},{"id":"shidianguji-tongguangjianluantus","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL01023734","type":"text+image","metadata":{"edition":"同光年间六安涂氏本","version":"v2","total_page":301,"paragraph_count":539,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL552MDKWf":{"id":"GYL552MDKWf","type":"work","title":"性理纂要","authors":[{"name":"冉覲祖","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《性理纂要》•八卷","author_info":"國朝冉覲祖撰","summary":"國朝冉覲祖撰。覲祖有《易經詳說》，已著錄。是書前四卷為性理纂要附訓，五卷至八卷為性理纂要附評。自序謂，附訓者，周子《太極圖》、《通書》，張子《西銘》、《東銘》，程子《定性書》五者之訓詁。《太極圖》、《通書》、《西銘》本朱子之注，諸儒之說，《東銘》、《定性書》則雜考朱子及諸儒之說而參以己意。附評者，以程子之言為經，朱子之言為傳，諸儒為之羽翼，而以己意為之評。推覲祖之意，蓋以《性理》所載《太極圖》諸書為周、張、程所手著，故尊為經典，名之曰訓。其性理諸條以下則胡廣等裒集之言，故儕諸文史，目之曰評。然同一先儒之言，何必分疆別界。況評中所引程子之說不一而足，何所見忽尊而訓，忽卑而評也。","edition":"河南巡撫采進本"}],"juan_count":{"number":8},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=5659992","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054459","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":1101,"paragraph_count":12587,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL552vtrKZ":{"id":"GYL552vtrKZ","type":"work","title":"靜用堂偶編","authors":[{"name":"塗天相","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《靜用堂偶編》•十卷","author_info":"國朝塗天相撰","summary":"國朝塗天相撰。天相字燮菴，號存齋，一號迂叟，孝感人。康熙癸未進士，官至工部尚書。天相從熊賜履講學，所著有《謹庸齋劄記》、《守待錄》、《存齋閒話》等書，茲編又從諸書之中撮其大略。上編為學言、政言、學辨，凡五卷。下編為家訓、幼儀、雜箴、雜銘、雜誡、古今體詩、存齋詩話，亦五卷。","edition":"兩江總督采進本"}],"juan_count":{"number":10},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7199304","type":"text"},{"id":"shidianguji-kangxiliushixukeben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY1671","type":"text+image","metadata":{"edition":"康熙六十年(1721)序刻本","version":"v4","total_page":428,"paragraph_count":4013,"check_type":"AI整理"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054494","type":"text+image","metadata":{"edition":"刻本","version":"v4","total_page":388,"paragraph_count":738,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL552eSvfR":{"id":"GYL552eSvfR","type":"work","title":"尊道集","authors":[{"name":"朱搴","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《尊道集》•四卷","author_info":"國朝朱搴撰","summary":"國朝朱搴撰。搴字良一，黃陂人。是書成於康熙丁丑。第一卷為聖賢前編，自孔子至孟子事蹟，及後人論說。第二卷節取《伊洛淵源錄》。第三卷節取《伊洛淵源續錄》。第四卷為前明五子錄，紀薛瑄、胡居仁、羅欽順、顧憲成、高攀龍五人行誼，而兼及其言論。大指主於攻擊陸、王。","edition":"湖北巡撫采進本"}],"juan_count":{"number":4}},"GYL552Yhiwq":{"id":"GYL552Yhiwq","type":"work","title":"續小學","authors":[{"name":"葉鉁","role":"編","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《續小學》•六卷","author_info":"國朝葉鉁編","summary":"國朝葉鉁編。鉁號潛夫，嘉善人。是書成於康熙辛未。以朱子《小學》一書所采至宋淳熙而止，因續采自宋迄明諸儒言行可為師法者，仍以內外篇目分條類敘，自為之注。其立教第一篇末附幼儀三十則，則鉁所自撰也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=6200727","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054474","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":236,"paragraph_count":1732,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL552JJ2oR":{"id":"GYL552JJ2oR","type":"work","title":"小學稽業","authors":[{"name":"李塨","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《小學稽業》•五卷","author_info":"國朝李塨撰","summary":"國朝李塨撰。其序謂朱子《小學》所載天道、性命，上達也；親迎、朝覲，年及壯強者也。以及居官、告老諸條，皆非幼童事，且無分於《大學》。乃別輯此編。卷一為小學四字韻語，括其總綱，以便誦讀。卷二為食食能言，六年教數方名，七年別男女，八年入小學教讓，九年教數目，十年學幼儀諸條。卷三為學書。卷四為學記。卷五為十有五學樂，誦詩，舞勺。大旨以禮、樂、書、數為綱。其中如引曲禮履不上堂一節，在今日並無解履之事。引王制道路男子由右，婦人由左，車從中央一節，在今日亦跬步不可行。此虛陳古禮者也。又誦詩一條自造詩譜，舞勺一條自造舞譜，此又杜撰古樂者也。惟學書一篇，辨篆楷之分，極為精核。然亦非童子之所急，其郛廓正與親迎、朝覲等耳。","edition":"直隸總督采進本"}],"juan_count":{"number":5},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=561664","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=811947","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=5809695","type":"text"}]},"GYL552i1qJw":{"id":"GYL552i1qJw","type":"work","title":"近思續錄","authors":[{"name":"劉源淥","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《近思續錄》•四卷","author_info":"國朝劉源淥撰","summary":"國朝劉源淥撰。源淥字昆石，自號直齋，安邱人。是書因朱子《近思錄》篇目，采輯朱子《或問》、《語類》、《文集》分門編輯。前有康熙辛巳其門人陳舜錫、馬恒謙二序。舜錫序稱其每祭朱子，品物豐潔，極其誠敬。恒謙序稱其於《朱子文集》、《或問》、《語類》三書，沉潛反覆，撮輯纂敘，席不暇暖，手不停筆，二十餘年，凡三創草，三脫稿，乃成是書雲。","edition":"副都御史黃登賢家藏本"}],"juan_count":{"number":4},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=878891","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=907821","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=3854283","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054476","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":3117,"paragraph_count":21285,"check_type":"AI整理"}}],"has_text":true,"has_image":true}}