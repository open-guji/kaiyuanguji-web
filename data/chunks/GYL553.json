{"GYL553yYHKM":{"id":"GYL553yYHKM","type":"work","title":"女教經傳通纂","authors":[{"name":"任啟運","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《女教經傳通纂》•二卷","author_info":"國朝任啟運撰","summary":"國朝任啟運撰。啟運有《周易洗心》，已著錄。是編仿朱子《小學》之例，采諸經傳及《女誡》、《女訓》、《女史箴》等書，分十三類。曰立教，曰敬身，曰笄禮，曰昏禮，曰事父母舅姑，曰謹夫婦，曰辨內外，曰逮妾媵，曰生子，曰勤職，曰祭禮，曰喪禮，曰貞節。其子翔為之注。末有其門人傅洛等跋，稱尚有《女教史傳通纂》一書，仿《小學•外篇》之意。今未之見。據翔所附記，此書立教等十一門，乃啟運之妻所輯，笄禮、喪禮二門乃其妻沒後啟運所補。然啟運序中不及之，且其妻名氏翔亦未著，故仍以啟運之名著錄焉。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":2}},"GYL553Nnwu9":{"id":"GYL553Nnwu9","type":"work","title":"讀周子劄記","authors":[{"name":"崔紀","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《讀周子劄記》•","author_info":"國朝崔紀撰","summary":"國朝崔紀撰。紀有《成均課講周易》，已著錄。是書以《中庸》之旨發明《太極圖說》、《通書》之理。大意謂太極即《中庸》上天之載，其陰中有陽者，是太極之靜，而中即《中庸》所謂人心未發之中。陽中有陰者，是太極之動，而和即《中庸》所謂人心已發之和。其變四象而言五行，用意尤在於土，以明太極即不貳之誠。蓋本明薛瑄之說而益推衍之。紀所解《中庸》，以主靜為主，亦此意也。","edition":"無卷數，江蘇巡撫采進本"}]},"GYL5535ZLkP":{"id":"GYL5535ZLkP","type":"work","title":"陸子學譜","authors":[{"name":"李紱","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《陸子學譜》•二十卷","author_info":"國朝李紱撰","summary":"國朝李紱撰。是編發明陸九淵之學。首列八目，曰辨志，曰求放心，曰講明，曰踐履，曰定宗仰，曰辟異學，曰讀書，曰為政。次為友教。次為家學。次為弟子。次為門人。次為私淑。而終之以附錄。考陸氏學派之端委，蓋莫備於是書。惟其必欲牽朱入陸，以就其晚年全論之說，所列弟子如呂祖儉之類，亦不免有所假借。是則終為鄉曲之私耳。","edition":"江西巡撫采進本"}],"juan_count":{"number":20},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=693847","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=926178","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=926007","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY1402","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":1167,"paragraph_count":2051,"check_type":"粗校"}},{"id":"shidianguji-keben-1","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054506","type":"text+image","metadata":{"edition":"刻本","version":"v4","total_page":1174,"paragraph_count":13602,"check_type":"AI整理"}},{"id":"shidianguji-yongzhengwunuxuankeb","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02091962","type":"text+image","metadata":{"edition":"雍正無怒軒刻本","version":"v2","total_page":1169,"paragraph_count":13958,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL553KvM3M":{"id":"GYL553KvM3M","type":"work","title":"謀道續錄","authors":[{"name":"譚旭","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《謀道續錄》•二卷","author_info":"國朝譚旭撰","summary":"國朝譚旭撰。旭字東白，新建人。康熙丁酉副榜貢生。是書末有其門人呂步青跋，稱旭先有《謀道錄》，故此稱《續錄》。其學恪守程、朱，持論甚正，而不免於好辨，每爭競於一字一句之間，其細已甚。又朋友以書相質，詳為批閱是也。所見不合，兩存以待論定亦可也，乃往往注其人已改而仍載其原本之疵謬，以見駁正之功。此近於暴己之長，形人之短矣。","edition":"江西巡撫采進本"}],"juan_count":{"number":2}},"GYL553UY9cj":{"id":"GYL553UY9cj","type":"work","title":"餘山遺書","authors":[{"name":"勞史","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《餘山遺書》•十卷","author_info":"國朝勞史撰","summary":"國朝勞史撰。史字麟書，號餘山，餘姚人。是書謂易之為道，細無不該，遠無不屆。故多本易理以推人物之性，其說亦或偶似近理。然如推飛禽上升屬陽，陽象圓，圓者徑一而圍三。故鳥足三爪，為圍三，除去上一旱爪為徑一。本乎地者為植物，故走獸不能飛，屬陰。陰象方為坤，坤為牛，牛之蹄爪四，四合而二偶，故除去上二小旱爪，惟大爪，著地，是兩地而為二。萬物眾矣，恐不能一一準數而生也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":10}},"GYL553ms8UP":{"id":"GYL553ms8UP","type":"work","title":"恥亭遺書","authors":[{"name":"周宗濂","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《恥亭遺書》•十卷","author_info":"國朝周宗濂撰","summary":"國朝周宗濂撰。宗濂字簡菴，華亭人。雍正癸卯拔貢生。官潛山縣教諭。是書於《易》、《書》、《詩》、《春秋》、《禮記》、《周禮》、《儀禮》偶有所得，皆隨筆記錄，末附《日省錄》一卷。其說經諸條，多講章習見之語。至斥《禮記》祭法王立七廟凡有六謬，祭義天子巡狩先見百年，於理難通，尤為臆見。惟《日省錄》語多切實，蓋疏於考古而熟於講學者也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":10}},"GYL553g5EuM":{"id":"GYL553g5EuM","type":"work","title":"聖學輯要","authors":[{"name":"潘繼善","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《聖學輯要》•一卷","author_info":"國朝潘繼善撰","summary":"國朝潘繼善撰。繼善有《音律節略考》，已著錄。是書為目凡六，論致知、力行、存養、慎獨為一篇，論誠一篇，論仁義禮智為一篇，論學思知行為一篇，論主敬存省為一篇，論生質氣象為一篇。前有江永序，稱其學以敬為主。蓋新安為朱子之鄉，無不宗法洛、閩者，繼善亦隨其土俗雲。","edition":"兩江總督采進本"}],"juan_count":{"number":1},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/聖學輯要","type":"text"}]},"GYL553RfYkw":{"id":"GYL553RfYkw","type":"work","title":"知非錄","authors":[{"name":"鄧鍾嶽","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《知非錄》•一卷","author_info":"國朝鄧鍾嶽撰","summary":"國朝鄧鍾嶽撰。鍾嶽字東長，號悔廬，聊城人。康熙辛丑進士第一。官至禮部左侍郎。是編蓋其晚年講學所記，故取蘧伯玉事為名，猶其自號悔廬之意也。","edition":"山東巡撫采進本"}],"juan_count":{"number":1},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=5862579","type":"text"},{"id":"shidianguji-unknown","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054528","type":"text+image","metadata":{"edition":"未知","version":"v4","total_page":70,"paragraph_count":53,"check_type":"粗校"}},{"id":"shidianguji-unknown-1","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02021536","type":"text+image","metadata":{"edition":"未知","version":"v2","total_page":66,"paragraph_count":65,"check_type":"粗校"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02021397","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":79,"paragraph_count":62,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL553vczc7":{"id":"GYL553vczc7","type":"work","title":"張子淵源錄","authors":[{"name":"張鏐","role":"編","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《張子淵源錄》•十卷","author_info":"國朝張鏐編","summary":"國朝張鏐編。鏐號紫峰，樂陵人。雍正壬子舉人，官內閣中書是書以儀封張伯行所刻《張子全書》不無訛謬，因仿《近思》、《淵源》二錄之遺意，擇張子粹言以程、朱論定者匯為一集。間有刪節，皆從程、朱所辨，而張子晚年所未及改者也。凡西銘一卷，正蒙二卷，經學理窟二卷，語錄文集一卷，遺文一卷，拾遺文一卷，遺事一卷，弟子一卷。","edition":"山東巡撫采進本"}],"juan_count":{"number":10}},"GYL5532gjtb":{"id":"GYL5532gjtb","type":"work","title":"朱子晚年全論","authors":[{"name":"李紱","role":"編","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《朱子晚年全論》•八卷","author_info":"國朝李紱編","summary":"國朝李紱編。紱字巨來，號穆堂，臨川人。康熙己丑進士，官至內閣學士，兼禮部侍郎。朱、陸之徒，自宋代即如水火，厥後各尊所聞，轉相詬厲，於是執學問之異同，以爭門戶之勝負。其最著者，王守仁作《朱子晚年定論》，引朱以合陸。至萬曆中，東莞陳建作《學蔀通辨》，又尊朱以攻陸。程曈，朱子之鄉人也，因作《閑辟錄》以申朱子之說。紱，陸氏之鄉人也，乃又作此書以尊陸氏之學。大旨謂陳建之書與朱子之論，援據未全，且語錄出門人所記，不足為據，乃取朱子正、續、別三集所載，自五十歲至七十一歲與人答問及講義、題詞之類，排比編次，逐條各附考證論辨於下，以成是書。其說甚辨。案韓愈送王秀才序，稱孔子之道大而能博，學焉而各得其性之所近，故子貢之敏悟，曾子之篤實，皆得聞一貫之旨，而當時未嘗相非。後之儒者，各明一義，理亦如斯。惟其私見不除，人人欲希孔庭之俎豆，於是始於爭名，終於分黨，遂尋仇報復而不已，實非聖賢立教之本旨。即以近代而論，陸隴其力尊程、朱之學，湯斌遠紹陸、王之緒，而蓋棺論定，均號名臣。蓋各有所得，即各足自立，亦何必強而同之，使之各失故步乎？紱此書皆以朱子悔悟為言，又舉凡朱子所稱切實近理用功者，一概歸之心學。夫回也屢空，焦竑以心無墨擬，空諸所有解之矣，顏子其果受之乎？仍各尊所聞而已矣。","edition":"江西巡撫采進本"}],"juan_count":{"number":8},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4754574","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054501","type":"text+image","metadata":{"edition":"刻本","version":"v4","total_page":544,"paragraph_count":5202,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL553BFrcX":{"id":"GYL553BFrcX","type":"work","title":"白鹿洞規條目","authors":[{"name":"王澍","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《白鹿洞規條目》•二十卷","author_info":"國朝王澍撰","summary":"國朝王澍撰。澍有《禹貢譜》，已著錄。是編取朱子《白鹿洞規》為綱，而分類條析，證以經史百家之語。自序雲：始自戊寅四月，迄癸未十月，中更六年，凡三易稿雲。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":20}},"GYL553aHMLK":{"id":"GYL553aHMLK","type":"work","title":"筆記","authors":[{"name":"程大純","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《筆記》•二卷","author_info":"國朝程大純撰","summary":"國朝程大純撰。大純字漢舒，孝感人。康熙中由貢生官黃岡縣教諭。是書皆講學之語。其謂陸、王之學雖矯枉過正，然用以救口耳之學，不為無功。所見頗為平允。若以程子配孔子，朱子配孟子，則聖賢之於大儒，自有分際，未必二子所敢居矣。","edition":"湖北巡撫采進本"}],"books":["CXVzwx1Mf1h"],"juan_count":{"number":2},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/宋景文筆記","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7950627","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054533","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":228,"paragraph_count":1289,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL553dFKu1":{"id":"GYL553dFKu1","type":"work","title":"日省編","authors":[{"name":"馮昌臨","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《日省編》•一卷","author_info":"國朝馮昌臨撰","summary":"國朝馮昌臨撰。昌臨有《易學參記》，已著錄。是書取《太極圖說》、《西銘》及劉宗周《人極圖》三篇，以為體道修身之本。後有玩《日省編》附語，取先儒舊說，間以己意附釋焉。","edition":"浙江巡撫采進本"}],"juan_count":{"number":1}},"GYL553XQkUX":{"id":"GYL553XQkUX","type":"work","title":"虛穀遺書","authors":[{"name":"何國材","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《虛穀遺書》•三卷","author_info":"國朝何國材撰","summary":"國朝何國材撰。國材字維楚，江西新城人。是編凡分四種，祖陸九淵求放心之說而為《心學釋疑》，本王守仁致良知之說而為《格物質疑》，采魏伯陽《參同契》之說而著《易圖測》，仿嶽元聲研幾私乘之說而為《研幾錄》。大旨堅護陸、王，為門戶而著書，非為學問而著書也。","edition":"江西巡撫采進本"}],"juan_count":{"number":3}},"GYL553H14L7":{"id":"GYL553H14L7","type":"work","title":"經書性理類輯精要錄","authors":[{"name":"王士陵","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《經書性理類輯精要錄》•六卷","author_info":"國朝王士陵撰","summary":"國朝王士陵撰。士陵有《易經纂言》，已著錄。是編采五經、四書與《性理大全》之文，分類編次。凡道體一卷，為學一卷，為政二卷，實履一卷，聖賢一卷。別為子目四十三，子目之中又別為子目二十，各雜采坊本講章之文，而附以己見。","edition":"兵部侍郎紀昀家藏本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=3254040","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054522","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":863,"paragraph_count":9360,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL553izXcb":{"id":"GYL553izXcb","type":"work","title":"載道集","authors":[{"name":"許焞","role":"編","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《載道集》•六十卷","author_info":"國朝許焞編","summary":"國朝許焞編。焞字純也，海寧人。雍正癸丑進士。官翰林院編修。此編錄歷代之文，大旨以道學諸儒為主，而其餘類及焉。冠以大學聖經一章，中庸哀公問政一章。次以家語三章。次為孔子弟子門人子思、孟子、孟母、樂克、東周賢士之言。又次為東周論著，自漢至唐，大體分王言、臣言、論著三類，而隋則增王門弟子之言一類，尊王通也。宋、元、明則論著之外增言行一類，以有講學諸儒也。終以張履祥之書。其凡例謂千古之聖人，莫尊於洙泗；有明之儒者，莫醇於楊園。以孔子始，以張子終，垂希聖希賢之則也。然於百世之下，尊一人與孔子相終始，談何容易乎？","edition":"浙江巡撫采進本"}],"juan_count":{"number":60}},"GYL553pnRBd":{"id":"GYL553pnRBd","type":"work","title":"棉陽學准","authors":[{"name":"藍鼎元","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《棉陽學准》•五卷","author_info":"國朝藍鼎元撰","summary":"國朝藍鼎元撰。鼎元有《平臺紀略》，已著錄。雍正戊申鼎元以普甯縣知縣署理潮陽。因經理其學校，作是編以訓士。卷一曰同人規約，卷二曰講學禮儀、丁祭禮儀，書田志，卷三、卷四曰閑存錄，卷五曰道學源流、太極要義、西銘要義。棉陽者，潮陽古地名也。","edition":"江西巡撫采進本"}],"juan_count":{"number":5},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=8147136","type":"text","details":"藍鼎元著"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1319025","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=5560941","type":"text"},{"id":"shidianguji-guangxuwuben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL01025152","type":"text+image","metadata":{"edition":"光緒五年本","version":"v2","total_page":345,"paragraph_count":2962,"check_type":"AI整理"}},{"id":"shidianguji-congshujichengsanbia","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02119974","type":"text+image","metadata":{"edition":"叢書集成三編","version":"v2","total_page":332,"paragraph_count":659,"check_type":"AI整理"}},{"id":"shidianguji-jindaizhongguoshilia","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02026805","type":"text+image","metadata":{"edition":"近代中國史料叢刊影印本","version":"v2","total_page":334,"paragraph_count":631,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL5538UdTd":{"id":"GYL5538UdTd","type":"work","title":"學舫","authors":[{"name":"吳雲","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《學舫》•","author_info":"國朝吳雲撰","summary":"國朝吳雲撰。雲有《雲穀寺志》，已著錄。是編每條標目，各載門人某述，而玩其文辭，乃出一手。大抵雲有所講論，輒筆於書，特分署門人之名，以摹仿程、朱語錄體例耳。其議論頗多迂誕。如論河圖，謂嬰兒首有發漩，為人之河圖；黃河居中，眾水分流，為地之河圖；三垣五行，日月列宿，為天之河圖；未免穿鑿。論《周易》大旨，謂易字從日從月，日月往來即易。聖人非作易，乃抄易耳。陰取《參同契》之說，又未免剿襲。至詩學一條，謂詩必以賡歌、擊壤為歸，尤萬不可行之高論也。","edition":"無卷數，山東巡撫采進本"}]},"GYL553E8TUK":{"id":"GYL553E8TUK","type":"work","title":"集程朱格物法","authors":[{"name":"王澍","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《集程朱格物法》•一卷、《集朱子讀書法》•一卷","author_info":"國朝王澍撰","summary":"國朝王澍撰。陸、王之學主於靜悟，故以讀書為粗跡，而所謂格物者亦以為格去物欲，還虛明之本體。故澍取程、朱格物之要語與朱子讀書章程，排比聯絡，融會其意，各為一篇，以救其弊。其詞澍所自撰，其理則洛、閩之緒言，故皆謂之集焉。","edition":"兩江總督采進本"}],"juan_count":{"number":1},"related_works":[{"id":"GYLt1FBFW4o","title":"集朱子讀書法"}]},"GYL553skPkK":{"id":"GYL553skPkK","type":"work","title":"女學","authors":[{"name":"藍鼎元","role":"編","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《女學》•六卷","author_info":"國朝藍鼎元編","summary":"國朝藍鼎元編。鼎元以周禮天官有九嬪掌婦學之法，謂婦人不可不學。然自班氏《女誡》以外，若劉向《列女傳》，擇而不精；鄭氏《女孝經》，精而不詳；至《女訓》、《女史》、《閨範》、《女範》等書，尤為鄙陋淺率。因采經傳格言，參摭史傳，分為德、言、容、功四篇，章區類別，間綴論斷，其體例皆本之朱子《小學》。","edition":"福建巡撫采進本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=693505","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=5275521","type":"text","details":"藍鼎元著"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4632573","type":"text"},{"id":"shidianguji-guangxuwuben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL01025155","type":"text+image","metadata":{"edition":"光绪五年本","version":"v4","total_page":415,"paragraph_count":1754,"check_type":"AI整理"}},{"id":"shidianguji-congshujichengsanbia","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02119962","type":"text+image","metadata":{"edition":"叢書集成三編","version":"v2","total_page":415,"paragraph_count":865,"check_type":"AI整理"}},{"id":"shidianguji-jindaizhongguoshilia","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02026808","type":"text+image","metadata":{"edition":"近代中國史料叢刊影印本","version":"v1","total_page":419,"paragraph_count":708,"check_type":"AI整理"}}],"has_text":true,"has_image":true}}