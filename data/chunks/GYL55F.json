{"GYL55FoMciB":{"id":"GYL55FoMciB","type":"work","title":"急救良方","authors":[{"name":"張時徹","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《急救良方》•二卷","author_info":"明張時徹編","summary":"明張時徹編。分三十九門，專為荒村僻壤之中不諳醫術者而設。故藥取易求，方皆簡易，不甚推究脈證也。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":2},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/急救良方","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=80569","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1640403","type":"text"},{"id":"shidianguji-mingkeben","name":"识典古籍","url":"https://www.shidianguji.com/book/NCM011X411999023361","type":"text+image","metadata":{"edition":"明刻本","version":"v3","total_page":280,"paragraph_count":1247,"check_type":"AI整理"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054955","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":162,"paragraph_count":1556,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55Fzr29M":{"id":"GYL55Fzr29M","type":"work","title":"痘證理辨","authors":[{"name":"汪機","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《痘證理辨》•一卷、《附方》•一卷","author_info":"明汪機撰","summary":"明汪機撰。前列諸家治痘方法，後引浙中魏氏之說以辨之。自序雲，嘉靖庚寅，痘災盛行。因探索群書，見有論痘瘡者，纂為一編。其論痘皆主於火。然痘雖胎火之毒，而虛實異稟，則攻補異宜。又多兼雜證，不可拘以一說也。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":1},"additional_works":[{"book_title":"附方","n_juan":1}]},"GYL55FDdQ3q":{"id":"GYL55FDdQ3q","type":"work","title":"安老懷幼書","authors":[{"name":"劉宇","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《安老懷幼書》•四卷","author_info":"明劉宇編","summary":"明劉宇編。宇字志大，河南人。成化壬辰進士，官至山西按察司副使。初，宋鹹淳中，陳直撰《養老奉親書》。元大德間，鄒鈜續為《壽親養老新書》。黃應紫合為一篇刻之。宇於成化戊戌得其本，宏治庚戌重為刊行，改名《安老書》，仍為三卷。後六年丙辰，複得霅川婁氏《恤幼集》，又補刻於後，總為四卷，題曰《安老懷幼書》。霅川婁氏，明洪武永樂間御醫也，宇得之於其曾孫雲。","edition":"浙江朱彝尊家曝書亭藏本"}],"juan_count":{"number":4},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7608798","type":"text"},{"id":"shidianguji-jianghuxieben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA07843","type":"text+image","metadata":{"edition":"江戶寫本","version":"v9","total_page":717,"paragraph_count":816,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL55FSbnmM":{"id":"GYL55FSbnmM","type":"work","title":"醫開","authors":[{"name":"王世相","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《醫開》•七卷","author_info":"明王世相撰","summary":"明王世相撰。世相字季鄰，號清溪，蒲州人。呂柟之門人也。官延川縣知縣。是書凡分二十四類。首載或問數條，謂醫學至丹溪而集大成，蓋亦主滋陰降火之說者。","edition":"浙江範懋柱家天一閣藏本"}],"juan_count":{"number":7}},"GYL55FwvjS7":{"id":"GYL55FwvjS7","type":"work","title":"運氣易覽","authors":[{"name":"汪機","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《運氣易覽》•三卷","author_info":"明汪機撰","summary":"明汪機撰。機有《針灸問對》，已著錄。是編取《素問》中五運六氣之說詳加辨論，所衍各圖，亦頗有發明。然治病自以脈證為主，拘泥司天在泉，終無當於經旨也。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":3},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=320841","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=3982233","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054960","type":"text+image","metadata":{"edition":"刻本","version":"v4","total_page":202,"paragraph_count":982,"check_type":"AI整理"}},{"id":"shidianguji-jiajingshierchengqia","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02092745","type":"text+image","metadata":{"edition":"嘉靖十二年程鐈刻本","version":"v3","total_page":217,"paragraph_count":2028,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55F7tCLF":{"id":"GYL55F7tCLF","type":"work","title":"醫方選要","authors":[{"name":"周文採","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《醫方選要》•十卷","author_info":"明周文採編","summary":"明周文採編。李時珍《本草綱目》引作周良采，字之訛也。其裏貫未詳。是書乃其為蜀獻王椿侍醫時，承獻王之命所作，則洪武中人也。每門皆抄錄古方，而各冠以論。嘉靖二十三年，通政使顧可學奏進，詔禮部重錄付梓，仍行兩京各省翻刻。前有獻王序及文采自序，並載禮部尚書費寀題覆疏二篇，蓋亦翻刻本也。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":10},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7461594","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054912","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":972,"paragraph_count":7433,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55F54HKu":{"id":"GYL55F54HKu","type":"work","title":"傷寒治例","authors":[{"name":"劉純","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《傷寒治例》•一卷","author_info":"明劉純撰","summary":"明劉純撰。其體例與《雜病治例》相同，不標六經，亦不分表裏，但以現證九十五種為綱，而每證推其病源與其治法。亦成化己亥蕭謙所刻也。","edition":"通行本"}],"juan_count":{"number":1},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4152318","type":"text"},{"id":"shidianguji-jianghuxieben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA06240","type":"text+image","metadata":{"edition":"江戶寫本","version":"v7","total_page":156,"paragraph_count":195,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054911","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":122,"paragraph_count":1238,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55FHEzYo":{"id":"GYL55FHEzYo","type":"work","title":"醫學管見","authors":[{"name":"何瑭","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《醫學管見》•一卷","author_info":"明何瑭撰","summary":"明何瑭撰。瑭號柏齊，懷慶人。弘治壬戌進士，官至南京右副都禦史。諡文定。事蹟具《明史•儒林傳》。是書凡二十二篇，自記謂因讀《素問》及《玉機微義》二書而作。其說皆主於大補大攻，非中和之道。其第十九篇論久病元氣太虛，病氣太盛，當以毒藥攻之，尤不可訓。其論金石藥一條，則名言也。","edition":"通行本"}],"juan_count":{"number":1},"resources":[{"id":"shidianguji-wenzhengxieben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA07991","type":"text+image","metadata":{"edition":"文政04年寫本","version":"v4","total_page":42,"paragraph_count":426,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL55FPgW47":{"id":"GYL55FPgW47","type":"work","title":"神應經","authors":[{"name":"陳會","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《神應經》•一卷","author_info":"明陳會撰","summary":"明陳會撰，劉瑾補輯。會字善同，稱宏綱先生。瑾字永懷，號恒菴。均不知何許人。瑾所附論皆冠以臣字，亦不知何時進禦本也。案宦官劉瑾，武宗時流毒海內，終以謀逆伏誅，斷無人肯襲其姓名者，此書當在正德前矣。所論皆針灸之法，有歌訣，有圖有說，傳寫訛謬，不甚可據。前有宗派圖一頁，稱梓桑君席宏達九傳至席華叔，十傳至席信卿，十一傳至會。會傳二十四人，嫡傳者二人，一曰康叔達，一即瑾也。又有席宏達誓詞，謂傳道者必盟天歃血，立誓以傳，當於宗派圖下注其姓名，如或妄傳非人，私相付度，陰有天刑，明有陽譴云云。是直道家野談耳。","edition":"浙江朱彝尊家曝書亭藏本"}],"juan_count":{"number":1},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/神應經","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=659688","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=8782629","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054929","type":"text+image","metadata":{"edition":"刻本","version":"v5","total_page":134,"paragraph_count":858,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-zhengbaokanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA08694","type":"text+image","metadata":{"edition":"正保02年刊本","version":"v2","total_page":136,"paragraph_count":1156,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55FkV1rP":{"id":"GYL55FkV1rP","type":"work","title":"攝生眾妙方","authors":[{"name":"張時徹","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《攝生眾妙方》•十一卷","author_info":"明張時徹編","summary":"明張時徹編。時徹字維靜，鄞縣人。嘉靖癸未進士，官至南京兵部尚書。事蹟附見《明史•張邦奇傳》。是編分四十七門，標目繁碎。自序雲，每見愈病之方，輒錄而藏之。蓋隨時抄集而成，未為賅備。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":11},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=8244813","type":"text"},{"id":"shidianguji-yinxianzhangshiyueyu","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL01060140","type":"text+image","metadata":{"edition":"鄞縣張氏約園刻四明叢書本","version":"v5","total_page":670,"paragraph_count":3456,"check_type":"AI整理"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054950","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":655,"paragraph_count":5619,"check_type":"AI整理"}},{"id":"shidianguji-qingfanhengwangfumin","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ892411999031723149192","type":"text+image","metadata":{"edition":"青藩衡王府明隆慶3年刻本","version":"v2","total_page":858,"paragraph_count":4990,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55FAkoC3":{"id":"GYL55FAkoC3","type":"work","title":"袖珍小兒方","authors":[{"name":"徐用宣","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《袖珍小兒方》•十卷","author_info":"明徐用宣撰","summary":"明徐用宣撰。用宣，衢州人。《藝文志稿》作徽州人，蓋字形相近而訛。其書以《脈訣》為首，《方論針灸圖形》次之。總七十二門六百二十四方，蒐采頗備，惟論斷多襲舊文，無所發明耳。是書作於永樂中，嘉靖十一年贛撫錢宏重刊，以是書原本宋錢乙也。","edition":"浙江範懋柱家天一閣藏本"}],"juan_count":{"number":10},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=2334780","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054922","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":265,"paragraph_count":2451,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55Fbxayu":{"id":"GYL55Fbxayu","type":"work","title":"醫學正傳","authors":[{"name":"虞摶","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《醫學正傳》•八卷","author_info":"明虞摶撰","summary":"明虞摶撰。摶字天民，自號花溪恒德老人。義烏人。是書成於正德乙亥。其學以朱震亨為宗，而參以張機、孫思邈、李杲諸家之說，各選其方之精粹者次於《丹溪要語》之後，複為或問五十條以申明之。","edition":"浙江範懋柱家天一閣藏本"}],"juan_count":{"number":8},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/醫學正傳","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=353314","type":"text"}]},"GYL55FrBXiX":{"id":"GYL55FrBXiX","type":"work","title":"靈秘十八方加減","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《靈秘十八方加減》•一卷","author_info":"舊本題德府良醫所良醫濟南胡嗣廉校編","summary":"舊本題德府良醫所良醫濟南胡嗣廉校編。前有嘉靖十七年可泉子序，雲不知何人所輯，則嗣廉但校正編次耳，非所撰也。其書以世人多用《和劑局方》，不知加減之用。因以此十八方各詳其因證加減之法，以便於用。然病機萬變，相似者多，但據證以減藥味，似非必中之道，仍與執《局方》者等也。十八方後又附補中益氣湯等四方，共為二十二方，亦不知何人所加。或即嗣廉續入歟？","edition":"浙江巡撫采進本"}],"juan_count":{"number":1},"resources":[{"id":"shidianguji-tianbaoxieben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA08883","type":"text+image","metadata":{"edition":"天保15年寫本","version":"v5","total_page":92,"paragraph_count":75,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL55FVRhmh":{"id":"GYL55FVRhmh","type":"work","title":"醫史","authors":[{"name":"李濂","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《醫史》•十卷","author_info":"明李濂撰","summary":"明李濂撰。濂有《祥符人物志》，已著錄。是編採錄古來名醫，自《左傳》醫和以下，迄元李杲，見於史傳者五十五人。又采諸家文集所載，自宋張擴以下，迄於張養正，凡十人。其張機、王叔和、王冰、王履、戴原禮、葛應雷六人，則濂為之補傳。每傳之後，濂亦各附論斷。然如醫和診晉侯而知趙孟之死，據和所稱主不能禦，吾是以雲，蓋以人事天道斷之，而濂以為太素脈之祖。扁鵲傳中趙簡子、齊桓公、虢君各不同時，自為《史記》好奇之誤，而濂不訂正。葛洪自屬道家，但偶集方書，不聞治驗，乃一概收入。則陶宏景之撰《名醫別錄》，有功《本草》，何以見遺？褚澄遺書，偽託顯然，乃不能辨別，反證為真本。至於宋僧智緣，本傳但有善醫二字，別無治驗，特乙太素脈知名，與張擴之具有醫案者迥別。載之醫家，尤為濫及，遼濟魯古亦更無一事可述，但以長亦能醫，專事針灸二語，遽為立傳，則當立傳者又何限乎？濂他書頗可觀，而此書乃冗雜特甚，殊不可解。惟其論倉公神醫乃生五女而不生男，其師公乘陽慶亦年七十餘無子，以證醫家無種子之術，其理為千古所未發，有足取焉。","edition":"浙江範懋柱家天一閣藏本"}],"juan_count":{"number":10},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/醫史","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=337624","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=976881","type":"text"},{"id":"shidianguji-kanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA05708","type":"text+image","metadata":{"edition":"刊本","version":"v11","total_page":346,"paragraph_count":563,"check_type":"粗校"}},{"id":"shidianguji-jiajingershiliuxukan","name":"识典古籍","url":"https://www.shidianguji.com/book/SDZJ0331","type":"text+image","metadata":{"edition":"嘉靖二十六年序刊本","version":"v8","total_page":362,"paragraph_count":448,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02093842","type":"text+image","metadata":{"edition":"刻本","version":"v6","total_page":339,"paragraph_count":360,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL55FL7bQb":{"id":"GYL55FL7bQb","type":"work","title":"保嬰撮要","authors":[{"name":"薜鎧","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《保嬰撮要》•八卷","author_info":"明薜鎧撰","summary":"明薜鎧撰。鎧字良武，吳縣人。弘治中官太醫院醫士。是編分門纂輯，於幼科證治最為詳悉。其論乳下嬰兒有疾必調治其母，母病子病，母安子安。且雲小兒苦於服藥，亦當令母服之，藥從乳傳，其效自捷。皆前人所未發。其子太醫院院使己，又以其所治驗附於各門之後，皆低一格書之。後人集己遺書為《薛氏醫案》，此書亦在其中。考卷首蘇州府知府林懋舉序，有請己纂而約之之語。疑鎧但草創此書，其編纂成帙則實出己手。後人收入己書，蓋由於此。此本為嘉靖丙辰所刊，猶未編《醫案》以前單行之帙也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":8},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/保嬰撮要","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=664599","type":"text"},{"id":"shidianguji-mingkeben","name":"识典古籍","url":"https://www.shidianguji.com/book/NCM011X411999011346","type":"text+image","metadata":{"edition":"明刻本","version":"v5","total_page":3493,"paragraph_count":23223,"check_type":"AI整理"}},{"id":"shidianguji-chengyingkanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA08447","type":"text+image","metadata":{"edition":"承應03年刊本","version":"v5","total_page":1656,"paragraph_count":3477,"check_type":"AI整理"}},{"id":"shidianguji-mingkeben-1","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ89241199901134699999","type":"text+image","metadata":{"edition":"明刻本","version":"v2","total_page":2243,"paragraph_count":7720,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55F2BgU7":{"id":"GYL55F2BgU7","type":"work","title":"雜病治例","authors":[{"name":"劉純","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《雜病治例》•一卷","author_info":"明劉純撰","summary":"明劉純撰。純有《玉機微義》，已著錄。是書成於永樂戊子，末附蘭室誓戒四則，敘其父橘泉翁受醫術於朱震亨。純承其家學，又從其鄉馮庭榦、許宗魯、邱克容遊，盡得其法。因撮舉綱要，著為一編，分七十二證，每證各標其攻補之法。蓋皆其相傳口訣，故略而弗詳。初無刊本。成化己亥，上元縣知縣長安蕭謙觀政戶部時，奉命賞軍甘州，始從純後人得其本，為鋟版以傳。","edition":"浙江範懋柱家天一閣藏本"}],"juan_count":{"number":1},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/雜病治例","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=300148","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7627935","type":"text"},{"id":"shidianguji-jianghuchuxieben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA08376","type":"text+image","metadata":{"edition":"江戶初寫本","version":"v3","total_page":122,"paragraph_count":1323,"check_type":"AI整理"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054910","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":123,"paragraph_count":1187,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55FenVzF":{"id":"GYL55FenVzF","type":"work","title":"衛生集","authors":[{"name":"周宏","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《衛生集》•四卷","author_info":"明周宏撰","summary":"明周宏撰。宏始末未詳。前有正德庚辰宏自序，複系以五言律詩一章，詞頗近俚。其論外感法仲景，內傷法東垣，濕熱法河間，雜病法丹溪，尚屬持平之論。然亦大略如是，未可執為定法也。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":4},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7370169","type":"text"},{"id":"shidianguji-mingjiajingkeben","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ89241199901119082193","type":"text+image","metadata":{"edition":"明嘉靖刻本","version":"v1","total_page":746,"paragraph_count":7281,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55Fhf6r3":{"id":"GYL55Fhf6r3","type":"work","title":"萬氏家抄濟世良方","authors":[{"name":"萬表","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《萬氏家抄濟世良方》•六卷","author_info":"明萬表編","summary":"明萬表編，其孫邦孚增輯。表有《海寇議》，已著錄。邦孚字汝永，官都督僉事。是編原本抄集古方，分門別類，凡五卷。邦孚又益以經驗諸方及脈訣藥性，共為六卷，亦頗有可用之方。至首載呂仙降乩贈詩五首，以美是書，則語怪而不可訓矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1856670","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054944","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":1055,"paragraph_count":10435,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55FYLzUw":{"id":"GYL55FYLzUw","type":"work","title":"藥鏡","authors":[{"name":"蔣儀","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《藥鏡》•四卷","author_info":"明蔣儀撰","summary":"明蔣儀撰。儀，嘉興人。正德甲戌進士，其曆官未詳。是編前後無序跋。惟凡例謂醫鏡之鐫，駢車海內。今梓藥性，仍以鏡名。其載藥性，分溫、熱、平、寒為四部，各以儷語括其主治。後附拾遺、疏原、滋生三賦，以補所未備。詞句鄙淺，徒便記誦而已。","edition":"浙江巡撫采進本"}],"juan_count":{"number":4},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=5138679","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054934","type":"text+image","metadata":{"edition":"刻本","version":"v5","total_page":246,"paragraph_count":316,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL55Fu6pRm":{"id":"GYL55Fu6pRm","type":"work","title":"心印紺珠經","authors":[{"name":"李湯卿","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《心印紺珠經》•二卷","author_info":"明李湯卿撰","summary":"明李湯卿撰。湯卿不知何許人。是書為嘉靖丁未嘉興府知府趙瀛所校刊。上卷曰原道統，曰推運氣，曰明形氣，曰評脈法。下卷曰察病機，曰理傷寒，曰演治法，曰辨藥性，曰十八劑。融會諸家之說，議論頗為純正。惟以十八劑為主，而欲以輕清暑火解甘淡緩寒調奪濕補平榮澀和溫數字該之，未免失之拘泥。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":2},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=5407902","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02054958","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":243,"paragraph_count":2250,"check_type":"AI整理"}},{"id":"shidianguji-mingkeben","name":"识典古籍","url":"https://www.shidianguji.com/book/NCM011X411999010902","type":"text+image","metadata":{"edition":"明刻本","version":"v1","total_page":788,"paragraph_count":7316,"check_type":"AI整理"}}],"has_text":true,"has_image":true}}