{"GYL55kpsvud":{"id":"GYL55kpsvud","type":"work","title":"研山齋圖繪集覽","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《研山齋圖繪集覽》·三卷","author_info":"不著撰人名氏","summary":"不著撰人名氏。卷首有退翁小序。退翁，孫承澤別號也。然集中多稱先宮保公評云云，疑承澤采掇舊文，為古來畫家作傳，草創未竟，其後人抄錄成帙，因以所作畫跋附綴於後，成此編也。其書於古來畫家，先敘本末，後述所見真跡，附以跋語。上卷起顧愷之訖包鼎，共四十二家，末附不知姓名《洛神圖》一則。下卷起蘇軾訖鄒之麟，亦四十二家，末附總題明四家畫冊一則，及題冬日賞菊卷二則。自序稱八十二老人，則又在《庚子銷夏記》之後，為其晚年所記矣。原本目錄以王宰、衛賢、邊鸞三人連名，而以《石榴猴鼠圖》、《花竹禽石圖》、《高士圖》三畫並列，勘驗書中所載，則宰跡不傳，石榴猴鼠二圖屬鸞，《高士圖》屬賢，與目互異。又目錄終於明四家，而書末冬日賞菊卷乃軼不載，當時草草編輯，此亦明驗。且其文已多具《庚子銷夏記》中，此特其隨筆記錄之初稿，其中同異之處，皆以《庚子銷夏記》為長，故附存其目，不復錄焉。","edition":"編修勵守謙家藏本"}],"juan_count":{"number":3}},"GYL55k9xkm5":{"id":"GYL55k9xkm5","type":"work","title":"書畫史","authors":[{"name":"陳繼儒","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《書畫史》·一卷","author_info":"明陳繼儒撰","summary":"明陳繼儒撰。繼儒有《邵康節外紀》，已著錄。此編雜錄書畫家瑣碎之事，間及名跡。所載闕略不備，無裨考證。如載岐陽石鼓、王祥臥冰處、劉蛻文塚之類，亦多傷於氾濫。末附以書畫金湯四則，一善趣，一惡魔，一莊嚴，一落劫，各舉十數事以為品騭，尤不脫小品陋習。蓋一時風尚使然也。","edition":"浙江孫仰曾家藏本"}],"juan_count":{"number":1},"resources":[{"id":"shidianguji-wanlishenshishangbai","name":"识典古籍","url":"https://www.shidianguji.com/book/HY6435","type":"text+image","metadata":{"edition":"萬曆沈氏尚白齋刻本","version":"v6","total_page":46,"paragraph_count":48,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY5952","type":"text+image","metadata":{"edition":"刻本","version":"v4","total_page":22,"paragraph_count":31,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL55kFhxUf":{"id":"GYL55kFhxUf","type":"work","title":"畫志","authors":[{"name":"沈與文","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《畫志》·一卷","author_info":"明沈與文撰","summary":"明沈與文撰。與文自稱姑餘山人。是編所載畫家，起唐王維，迄元商琦，僅十九人。後附宋葉夢得《評畫行》一篇。與文為之注。","edition":"浙江範懋柱家天一閣藏本"}],"juan_count":{"number":1},"resources":[{"id":"shidianguji-mingchaoben","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ892412000000416164105","type":"text+image","metadata":{"edition":"明抄本","version":"v1","total_page":22,"paragraph_count":48,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55kmGLQf":{"id":"GYL55kmGLQf","type":"work","title":"歷代畫家姓氏韻編","authors":[{"name":"顧仲清","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《歷代畫家姓氏韻編》·七卷","author_info":"國朝顧仲清撰","summary":"國朝顧仲清撰。仲清字咸三，號松壑，嘉興人。工繪事，尤長於畫蝶，有詠蝶詩三百首。此書首卷為帝王藩封之善畫者。末為釋、道、閨秀、外國，其中則取畫家姓氏依韻編次，取便尋檢，無所考證也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":7}},"GYL55kXbduR":{"id":"GYL55kXbduR","type":"work","title":"書學彙編","authors":[{"name":"萬斯同","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《書學彙編》·十卷","author_info":"國朝萬斯同撰","summary":"國朝萬斯同撰。斯同有《讀禮質疑》，已著錄。是編錄歷代善書之人，上自倉頡，下迄明季，共一千五十四人。其中如皇甫規妻，舊雲不知何氏，此據張懷瓘《書斷》，知其姓馬。後魏江式請定《正文字疏》，稱漢講學大夫秦近，小學元士爰禮，此據《漢書》以為王莽時官。董羽謂劉德昇即劉表，為書家之祖，此據《三國志》云表字景升，非德昇。宣和《書譜》稱詹思遠史亡其系，此據《晉書》知為應璩之孫，詹字曰思遠。譜又稱王邃行書有羲、獻法，此據《晉書》知邃為元帝時人，在羲、獻之前。又稱陳達為陳人，劉瑉為北齊人，此據史知達為晉人，瑉為南齊人。又稱唐有盧革、楊邠書，此據史言革、邠皆不知學，未必真跡。又稱南唐有李霄遠，此據《十國春秋》知為李蕭遠。《宋史》鮑由，此以為即鮑慎由，避孝宗諱。以及模搨蘭亭之《說斷》從褚遂良，昇元祖帖之《說斷》為南唐元宗，皆頗有考證。然此書作於國初，迨康熙中禦定《佩文齋書畫譜》出，則此為滄海之一粟矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":10},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=907455","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02055693","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":453,"paragraph_count":4035,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55kaUEmD":{"id":"GYL55kaUEmD","type":"work","title":"畫法年紀","authors":[{"name":"郭礎","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《畫法年紀》·一卷","author_info":"國朝郭礎撰","summary":"國朝郭礎撰。礎字石公，江都人。順治壬辰進士，官至順德府知府。是編紀歷代善畫人名，自晉以迄於國朝，附載古畫品目。卷帙太狹，未免掛漏。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":1}},"GYL55ksoDcs":{"id":"GYL55ksoDcs","type":"work","title":"漢溪書法通解","authors":[{"name":"戈守智","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《漢溪書法通解》·八卷","author_info":"國朝戈守智撰","summary":"國朝戈守智撰。守智字達夫，平湖人。是集成於乾隆庚午。採錄古人論書之語，分述古、執筆、運筆、結字、訣法、譜序六門。冠以述古篇，則守智之所自撰。大致欲仿竇臮《述書賦》，而淹貫宏通終不逮古也。","edition":"安徽巡撫采進本"}],"juan_count":{"number":8},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=3302961","type":"text"},{"id":"shidianguji-qianlongjiyungekeben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY1691","type":"text+image","metadata":{"edition":"乾隆霽雲閣刻本","version":"v10","total_page":412,"paragraph_count":793,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02055714","type":"text+image","metadata":{"edition":"刻本","version":"v4","total_page":392,"paragraph_count":2460,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55kQTpcP":{"id":"GYL55kQTpcP","type":"work","title":"研山齋墨蹟集覽","authors":[{"name":"孫承澤","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《研山齋墨蹟集覽》·一卷、《法書集覽》·三卷","author_info":"國朝孫承澤撰","summary":"國朝孫承澤撰。承澤有《尚書集解》，已著錄。是書前有小序，即《庚子銷夏記》之序，其文亦與《庚子銷夏記》同，惟前後編次頗異，蓋即《銷夏記》之稿本也。後附元人破臨安所得宋書畫目一卷，前亦有承澤序。今本《銷夏錄》無之。核其所列，即元王惲《玉堂嘉話》之文。殆以與《秋澗集》重出，故始載之而終刪之歟？","edition":"編修勵守謙家藏本"}],"juan_count":{"number":1},"related_works":[{"id":"GYLt1FJ4WPh","title":"法書集覽"}]},"GYL55kyYRLT":{"id":"GYL55kyYRLT","type":"work","title":"月湖讀畫錄","authors":[{"name":"王梁","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《月湖讀畫錄》·一卷","author_info":"國朝王梁撰","summary":"國朝王梁撰。梁，震澤人。是編以所見名畫各為品評。其中宋、元人畫，僅寥寥數軸，餘皆明代及近時人也。其筆墨蹊徑則全仿李日華《六研齋筆記》、《紫桃軒雜綴》諸書雲。","edition":"江西巡撫采進本"}],"juan_count":{"number":1}},"GYL55k6Pr7Z":{"id":"GYL55k6Pr7Z","type":"work","title":"遊鶴堂墨藪","authors":[{"name":"周之士","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《遊鶴堂墨藪》·二卷","author_info":"明周之士撰","summary":"明周之士撰。之士字士貴，自號四明居士，齊興人。禦定《佩文齋書畫譜》列之書家傳中，然亦惟采瞿九思序此書之語，是其始末無可考矣。書中稱董其昌為恩師，則其昌弟子也。其書上卷論字體源流及筆法大旨，排唐而宗晉。下卷評書家優劣，所稱明代能書諸家，儼然以己名列其中。亦可謂躁於自表矣。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":2}},"GYL55ke5qGB":{"id":"GYL55ke5qGB","type":"work","title":"草韻彙編","authors":[{"name":"陶南望","role":"編","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《草韻彙編》·二十六卷","author_info":"國朝陶南望編","summary":"國朝陶南望編。南望字遜亭，上海人。是書成於康熙中。輯錄秦程邈迄明朱克誠，共三百四十一家。草法分韻編次，其平、上、去三韻乃南望手輯，入聲一韻則其友人侯昌言等續訂。蓋本《辨疑》、《匯辨》諸書，稍加釐正，然傳刻失真，恐未足據為模範也。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":26},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=155889","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1273470","type":"text"},{"id":"shidianguji-kanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA00404","type":"text+image","metadata":{"edition":"刊本","version":"v6","total_page":1434,"paragraph_count":5785,"check_type":"AI整理"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02055698","type":"text+image","metadata":{"edition":"刻本","version":"v5","total_page":1427,"paragraph_count":6316,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55kU2jFu":{"id":"GYL55kU2jFu","type":"work","title":"無聲詩史","authors":[{"name":"薑紹書","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《無聲詩史》·七卷","author_info":"國朝薑紹書撰","summary":"國朝薑紹書撰。紹書字二酉，丹陽人。所著《韻石齋筆談》，自稱前明嘗為南京工部郎，其階則不可考矣。是編蒐輯前明畫家，自洪武以至崇禎，為四卷，附以女史一卷。自卷六以下則或真跡不存，或品格未高，偶然點染，不以畫名者，亦附著焉。後有嘉興李光暎跋，謂鄉人李芳與同時褚勳均未載入，頗以掛漏為憾。然是書采摭博而敍述無法，如倪瓚以明初尚存，故列之明代矣。王鐸已歸命國朝，官至禮部尚書，亦列之明代，是何例乎？劉基之傳，即曰公鼎彝之跡載在國史，茲不復贅矣。岳正一傳，乃全述直諫之事。張靈一傳，亦備述狂誕之行。連篇累牘，於繪事了無關涉，又何例也？至於末附其子彥初一傳，稱其寫山水小景，頗具倪、黃邱壑。蓋不學而能，尤為創見。童烏不秀，是以附載法言，以十七歲之少年方學渲染，即列傳於古人之中，抑又異矣。","edition":"編修勵守謙家藏本"}],"juan_count":{"number":7},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=5837094","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=3868326","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4864311","type":"text"},{"id":"shidianguji-kangxiwushijiujiaxin","name":"识典古籍","url":"https://www.shidianguji.com/book/SDZJ0007","type":"text+image","metadata":{"edition":"康熙五十九年嘉兴李氏观妙斋重刊本","version":"v16","total_page":433,"paragraph_count":862,"check_type":"粗校"}},{"id":"shidianguji-kangxiwushijiuliguan","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02094483","type":"text+image","metadata":{"edition":"康熙五十九年李光暎觀妙齋刻本","version":"v4","total_page":392,"paragraph_count":235,"check_type":"粗校"}},{"id":"shidianguji-guangxushiliuhuiyinx","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL01024252","type":"text+image","metadata":{"edition":"光绪十六年汇印新会刘氏本","version":"v4","total_page":320,"paragraph_count":1458,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55k3RsYs":{"id":"GYL55k3RsYs","type":"work","title":"寶繪錄","authors":[{"name":"張泰階","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《寶繪錄》·二十卷","author_info":"明張泰階撰","summary":"明張泰階撰。泰階字爰平，上海人。萬曆己未進士。其家有寶繪樓，自言多得名畫真跡，操論甚高。然如曹不興畫，據南齊謝赫《古畫品錄》，已僅見其一龍首，不知泰階何緣得其《海戍圖》。又顧愷之、陸探微、展子虔、張僧繇，卷軸累累，皆前古之所未睹，其閻立本、吳道元、王維、李思訓、鄭虔諸人，以朝代相次，僅廁名第六、七卷中，幾以多而見輕矣，揆以事理，似乎不近。且所列歷代諸家跋語，如出一手，亦復可疑也。","edition":"江西巡撫采進本"}],"juan_count":{"number":20},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1852173","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=3325335","type":"text"},{"id":"shidianguji-guangxuliudongxiangr","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL11203797","type":"text+image","metadata":{"edition":"光緒六年東鄉饒玉成校刊本","version":"v5","total_page":874,"paragraph_count":3388,"check_type":"AI整理"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02055667","type":"text+image","metadata":{"edition":"刻本","version":"v4","total_page":890,"paragraph_count":2166,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55kCqMcs":{"id":"GYL55kCqMcs","type":"work","title":"唐詩畫譜","authors":[{"name":"黃鳳池","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《唐詩畫譜》·五卷","author_info":"明黃鳳池撰","summary":"明黃鳳池撰。鳳池，徽州人。是書刊於天啟中。取唐人五六七言絕句詩各五十首，繪為圖譜，而以原詩書於左方。凡三卷。末二卷為花鳥譜，但有圖而無詩。則鳳池自集其畫，附詩譜以行也。","edition":"內府藏本"}],"juan_count":{"number":5},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1918521","type":"text"}]},"GYL55kJdFBu":{"id":"GYL55kJdFBu","type":"work","title":"畫譜","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《畫譜》·六卷","author_info":"不著撰人名氏","summary":"不著撰人名氏。首唐六如《畫譜》一卷，次《五言唐詩畫譜》一卷，次《六言唐詩畫譜》一卷，次《七言唐詩畫譜》一卷，次《木本花譜》一卷，次《草本花譜》一卷，次扇譜一卷。譜首各有小序，蓋明季坊本也。","edition":"內府藏本"}],"juan_count":{"number":6}},"GYL55kviWL7":{"id":"GYL55kviWL7","type":"work","title":"國朝畫徵錄","authors":[{"name":"張庚","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《國朝畫徵錄》·三卷、《續錄》·二卷","author_info":"國朝張庚撰","summary":"國朝張庚撰。庚有《通鑒綱目釋地糾謬》，已著錄。是編記國朝畫家，每人各為小傳。然時代太近，其人多未經論定，不盡足徵。","edition":"浙江巡撫采進本"}],"juan_count":{"number":3},"additional_works":[{"book_title":"續錄","n_juan":2}],"resources":[{"id":"shidianguji-qianlongjiangtaitang","name":"识典古籍","url":"https://www.shidianguji.com/book/HY1589","type":"text+image","metadata":{"edition":"乾隆蔣泰、湯之昱刻本","version":"v5","total_page":251,"paragraph_count":2337,"check_type":"粗校"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02055718","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":241,"paragraph_count":1827,"check_type":"AI整理"}},{"id":"shidianguji-qianlongsikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02094515","type":"text+image","metadata":{"edition":"乾隆四年刻本","version":"v2","total_page":158,"paragraph_count":1544,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55khejuh":{"id":"GYL55khejuh","type":"work","title":"石村畫訣","authors":[{"name":"孔衍栻","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《石村畫訣》·一卷","author_info":"國朝孔衍栻撰","summary":"國朝孔衍栻撰。衍栻字石村，曲阜人。是書皆自記其作畫之法。","edition":"衍聖公孔昭煥家藏本"}],"juan_count":{"number":1}},"GYL55kMYXu9":{"id":"GYL55kMYXu9","type":"work","title":"草書集韻","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《草書集韻》·五卷","author_info":"不著編輯者名氏","summary":"不著編輯者名氏。取漢章帝以下至於元人草法，依韻編次。每字之下，各注其人。其編次用洪武正韻。蓋明人作也。","edition":"內府藏本"}],"juan_count":{"number":5},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=3942519","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02055684","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":181,"paragraph_count":822,"check_type":"AI整理"}}],"has_text":true,"has_image":true}}