{"GYL55o3pAaB":{"id":"GYL55o3pAaB","type":"work","title":"欽定西清古鑒","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《欽定西清古鑒》•四十卷","author_info":"乾隆十四年奉敕撰","summary":"乾隆十四年奉敕撰。以內府庋藏古鼎彝尊罍之屬案器為圖，因圖系說，詳其方圓圍徑之制，高廣輕重之等，並鉤勒款識，各為釋文。其體例雖仿《考古》、《博古》二圖，而摹繪精審，毫釐不失，則非二圖所及。其考證雖兼取歐陽修、董逌、黃伯思、薛尚功諸家之說，而援據經史，正誤析疑，亦非修等所及。如周文王鼎銘之魯公，斷為伯禽而非周公、周晉薑鼎銘之文侯，據虎賁云云與書文侯之命，合，斷為文侯虎而非文公重耳；漢定陶鼎，據《漢書•地理志•濟陰郡注》，宣帝甘露二年更名定陶，斷此鼎為宣帝中定陶共王康作而非趙共王恢，皆足正《博古圖》姓名之訛。又如商祖癸鼎，《博古圖》謂我之字從戈者，敵物之我也云云，則斥其雜用王安石《字說》。王氏銅虹燭錠，《博古圖》謂是薦熟食器，則於周素錠引說文以錠為鐙正之，亦足糾其訓釋之舛。其他如周召夫鼎、周魚鼎之屬，辨駁尤多。又如周單卣銘爵字景字從《博古圖》，豐字則從鐘鼎款識，於兩家皆取所長，銘首凶字則證其不當作冏，於兩家並訂其失，商瞿卣舊無實證，則引《竹書紀年》註定瞿為武乙之名。並能參考異同，補苴罅漏。至周象尊，據器訂《周禮》司尊彝注飾以象骨之非、周犠尊，據器訂鄭注飾以翡翠之非，周虎錞，引周官鼓人以金錞和鼓鄭注，證《南史》灌之以水及以器盛水於下，以芒莖當心跪注之非，則尤有裨於經史之學。又周邢侯方彝銘十八月乙亥，證以《管子》十三月令人之魯，二十四月魯梁之民歸齊，二十八月萊莒之君請複之數語，以破歐陽修、蔡襄、劉敞輩不解洛鼎銘十有四月之疑，尤從來考古者所未到。蓋著述之中，考證為難；考證之中，圖譜為難；圖譜之中，惟鐘鼎款識義通乎六書，制兼乎三禮，尤難之難。讀是一編而三代法物恍然如睹。聖天子稽古右文，敦崇實學，昭昭乎有明驗矣。"}],"books":["CXVzwSPgwUs","CXZVBejsU63"],"juan_count":{"number":40},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=285549","type":"text"},{"id":"shidianguji-guangxusanshisijiche","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL01035318","type":"text+image","metadata":{"edition":"光緒三十四年集成圖書公司本","version":"v8","total_page":3702,"paragraph_count":7439,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55oFzso5":{"id":"GYL55oFzso5","type":"work","title":"硯史","authors":[{"name":"米芾","role":"撰","dynasty":"宋"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《硯史》•一卷","author_info":"宋米芾撰","summary":"宋米芾撰。芾有《畫史》，已著錄。是書首冠以用品一條，論石當以發墨為上。後附性品一條，論石質之堅軟。樣品一條，則備列晉硯、唐硯以迄宋代形制之不同。中記諸硯，自玉硯至蔡州白硯，凡二十六種，而於端、歙二石辨之尤詳。自謂皆曾目擊經用者，非此則不錄，其用意殊為矜慎。末記所收青翠疊石一，正紫石一，皆指為歷代之瑰寶，而獨不及所謂南唐硯山者，或當時尚未歸寶晉齋中，或已為薛紹彭所易歟？芾本工書法，凡石之良楛，皆出親試，故所論具得硯理，視他家之耳食者不同。其論歷代製作之變，考據尤極精確，有足為文房鑒古之助者焉。","edition":"浙江鮑士恭家藏本"}],"books":["CXVzwTFmi6T"],"juan_count":{"number":1},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/硯史","type":"text"},{"id":"wikisource-siku","name":"维基文库（四庫全書本）","url":"https://zh.wikisource.org/wiki/硯史_(四庫全書本)","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=667209","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=587123","type":"text"},{"id":"shidianguji-sikuquanshuben","name":"识典古籍","url":"https://www.shidianguji.com/book/SK1710","type":"text+image","metadata":{"edition":"四庫全書本","version":"v1","total_page":35,"paragraph_count":65,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL55oKcUJ3":{"id":"GYL55oKcUJ3","type":"work","title":"硯譜","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《硯譜》•一卷","author_info":"不著撰人名氏","summary":"不著撰人名氏。舊載左圭《百川學海》中，亦無序跋年月。皆雜錄硯之出產與其故實。中間載有歐陽修、蘇軾、唐詢、鄭樵諸人之說，則南宋人所為。然尤袤、陳振孫二家書目皆不載，或偶遺也。其書僅三十二條，不為贍博，采摭亦間有疏舛。如以端溪子石為在大石中生，尚沿舊說，未加考正。又如許漢陽以碧玉為硯，其事出穀神子《博異記》，乃龍女之硯，非漢陽之硯，徵引亦為訛誤。以其宋人舊帙，流傳既久，尚有一二足資多識者，故附著諸家硯譜之次，以備檢核焉。","edition":"浙江吳玉墀家藏本"}],"books":["CXVzwU83E7q"],"juan_count":{"number":1},"resources":[{"id":"wikisource-siku","name":"维基文库（四庫全書本）","url":"https://zh.wikisource.org/wiki/硯譜_(四庫全書本)","type":"text"},{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/硯譜","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=354215","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=62672","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY5965","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":22,"paragraph_count":29,"check_type":"粗校"}},{"id":"shidianguji-sikuquanshuben","name":"识典古籍","url":"https://www.shidianguji.com/book/SK1714","type":"text+image","metadata":{"edition":"四庫全書本","version":"v1","total_page":18,"paragraph_count":68,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL55oZKrej":{"id":"GYL55oZKrej","type":"work","title":"欽定西清硯譜","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《欽定西清硯譜》•二十五卷","author_info":"乾隆四十三年奉敕撰","summary":"乾隆四十三年奉敕撰。每硯各圖其正面背面，間及側面。凡奉有禦題、禦銘、禦璽及前人款識、印記，悉皆案體臨摹，而詳述其尺度材質、形制及收藏賞鑒姓名，系說於後。其舊人銘跋，並附錄宸章之後，下逮臣工奉敕所題，亦得備書。其序先以陶之屬，上自漢瓦，下逮明制，凡六卷。次為石之屬，則自晉王廞璧水硯以至國朝朱彝尊井田硯，凡十五卷，共為硯二百，為圖四百六十有四。其後三卷曰附錄，為硯四十有一，為圖百有八，則今松花、紫金、駝基、紅絲諸品及仿製澄泥各種皆備列焉。古澤斑駁，珍產駢羅，誠為目不給賞，而奎藻璘《王扁》，徵名案狀，如化工肖物，尤與帝鴻之制，周武之銘，同照映萬古。然睿慮深長，不忘咨儆，恒因器以寓道，亦即物以警心。伏讀禦制序有雲，惜淪棄，悟用人，慎好惡，戒玩物，無不三致意焉。信乎聖人之心所見者大，不徒視為文房翰墨之具矣。內廷所貯本，總二十四冊，今案冊為卷，而以原目為首卷，凡二十五卷。"}],"books":["CXVzwUZwKhR"],"juan_count":{"number":25},"resources":[{"id":"wikisource-siku","name":"维基文库（四庫全書本）","url":"https://zh.wikisource.org/wiki/欽定西清硯譜_(四庫全書本)","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=897246","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=561537","type":"text"},{"id":"shidianguji-sikuquanshuben","name":"识典古籍","url":"https://www.shidianguji.com/book/SK1716","type":"text+image","metadata":{"edition":"四庫全書本","version":"v3","total_page":1874,"paragraph_count":2653,"check_type":"粗校"}},{"id":"shidianguji-neifuqingchaoben","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ892411999029499161446","type":"text+image","metadata":{"edition":"內府清抄本","version":"v2","total_page":1932,"paragraph_count":7024,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55oqDY5V":{"id":"GYL55oqDY5V","type":"work","title":"欽定錢錄","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《欽定錢錄》•十六卷","author_info":"乾隆十五年奉敕撰","summary":"乾隆十五年奉敕撰。卷一至卷十三，詳列歷代之泉布，自伏羲氏迄明崇禎，以編年為次。第十四卷列外域諸品。第十五、十六卷以吉語、異錢、厭勝諸品殿焉。考《錢譜》始見於《隋志》，不雲誰作。其書今不傳。唐封演以下諸家所錄，今亦不傳。其傳者以宋洪遵《泉志》為最古，毛氏汲古閣所刊是也。然所分正品、偽品、不知年代品、奇品、神品諸目，既病淆雜，又大抵未睹其物，多據諸書所載想像圖之，如聶崇義之圖三禮。或諸書但有其名而不言其形模文字者，則概作外圓內方之輪郭，是又何貴於圖耶？至所箋釋，率多臆測，尤不足據為定論。是編所錄，皆以內府儲藏，得於目睹者為據，故不特字跡花紋，一一酷肖，即圍徑之分寸毫釐，色澤之丹黃青綠，亦窮形盡相，摹繪逼真。而考證異同，辨訂真偽，又皆根據典籍，無一語鑿空。蓋一物之微，亦見責實之道，與稽古之義焉。至於觀其輕重厚薄，而究其法之行不行；觀其良窳精粗，而知其政之舉不舉。千古錢幣之利弊，一覽具睹，又不徒為博物之資矣。"}],"books":["CXVzwVasL9d"],"juan_count":{"number":16},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=914397","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=676750","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=830181","type":"text"},{"id":"shidianguji-sikuquanshuben","name":"识典古籍","url":"https://www.shidianguji.com/book/SK1721","type":"text+image","metadata":{"edition":"四庫全書本","version":"v2","total_page":924,"paragraph_count":1035,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55ojULMu":{"id":"GYL55ojULMu","type":"work","title":"墨史","authors":[{"name":"陸友","role":"撰","dynasty":"元"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《墨史》•二卷","author_info":"元陸友撰","summary":"元陸友撰。友字友仁，亦字宅之，平江人。其書集古來精於制墨者，考其事蹟，勒為一書。於魏得韋誕一人，於晉得張金一人，於劉宋得張永一人，於唐得李陽冰以下十九人，於宋得柴珣以下一百三十餘人，於金得劉法、楊文秀二人。又詳載高麗、契丹、西域之墨，附錄雜記二十五則，皆墨之典故也。其間蒐羅隱僻，頗為博贍。其論奚廷珪非李廷珪一條，據《墨經》所載，易水奚鼐之子超，鼏之子起，又別敘歙州李超，超子廷珪以下世家，是族有奚、李之異，居有易、歙之分。惟其名偶同，所謂《墨經》者，今雖不知為何本，然宋紹聖中李孝美作《墨譜》，已有是說，亦可以旁資參考也。案《徐顯稗傳》，載友仁生市廛闤闠間，父以市布為業，獨能異其所好，攻苦於學，善為歌詩，工八分隸楷，博極群物。奎章閣鑒書博士柯九思、侍書學士虞集服其精識，相與言於文宗。未及任用而二人去職，友亦南歸，自號硯北生，著《硯史》、《墨史》、《印史》，所為詩文有《杞菊軒稿》。今皆亡佚，惟《研北雜誌》及是書尚存雲。","edition":"兩江總督采進本"}],"books":["CXVzwVB6qnf"],"juan_count":{"number":2},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/墨史","type":"text"},{"id":"wikisource-siku","name":"维基文库（四庫全書本）","url":"https://zh.wikisource.org/wiki/墨史_(四庫全書本)","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=6719361","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=355031","type":"text"},{"id":"shidianguji-sikuquanshuben","name":"识典古籍","url":"https://www.shidianguji.com/book/SK1719","type":"text+image","metadata":{"edition":"四庫全書本","version":"v2","total_page":86,"paragraph_count":116,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-zhibuzuzhaicongshu","name":"识典古籍","url":"https://www.shidianguji.com/book/CZBZZ087","type":"text+image","metadata":{"edition":"知不足齋叢書","version":"v1","total_page":75,"paragraph_count":136,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL55oxFyfd":{"id":"GYL55oxFyfd","type":"work","title":"香譜","authors":[{"name":"陳敬","role":"撰","dynasty":"宋"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《香譜》•四卷","author_info":"宋陳敬撰","summary":"宋陳敬撰。敬字子中，河南人。其仕履未詳。首有至治壬戌熊朋來序，亦不載敬之本末。是書凡集沈立、洪芻以下十一家之《香譜》，匯為一書。徵引既繁，不免以博為長，稍逾限制。若香名、香品、歷代凝和製造之方，載之宜也。至於經傳中字句偶涉而實非龍涎迷迭之比，如卷首引《左傳》黍稷馨香，寥寥數則，以為溯源經傳，殊屬無謂。此仿《齊民要術》首援經典之例，而失之者也。其實本出經典之事，乃往往掛漏。如鬱金香載《說文》之說，而《周禮》鬱人條下鄭康成之注乃獨遺之，則又舉遠而略近矣。然十一家之譜，今不盡傳，敬能薈稡群言，為之總匯。佚文遺事，多賴以傳，要於考證不為無益也。","edition":"江蘇巡撫采進本"}],"books":["CXVzwW1Np9m"],"juan_count":{"number":4},"resources":[{"id":"shidianguji-kehouyinben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY6034","type":"text+image","metadata":{"edition":"刻後印本","version":"v4","total_page":65,"paragraph_count":300,"check_type":"粗校"}},{"id":"shidianguji-sikuquanshuben","name":"识典古籍","url":"https://www.shidianguji.com/book/SK1722","type":"text+image","metadata":{"edition":"四庫全書本","version":"v3","total_page":82,"paragraph_count":315,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-qingchaoben","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ89241199902622048895","type":"text+image","metadata":{"edition":"清抄本","version":"v1","total_page":112,"paragraph_count":1258,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55oCRy9Z":{"id":"GYL55oCRy9Z","type":"work","title":"歙州硯譜","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《歙州硯譜》•一卷","author_info":"不著撰人名氏，惟卷末題有大宋治平丙午歲重九日十字","summary":"不著撰人名氏，惟卷末題有大宋治平丙午歲重九日十字。考之陳振孫《書錄解題》，載有《歙硯圖譜》一卷，稱太子中舍知婺源縣唐積撰，治平丙午歲云云其年月與此相合，然則此即積書矣。中分采發、石坑、攻取、品目、脩斫、名狀、石病、道路、匠手、攻器十門，所志開鑿成造之法甚詳。蓋歙石顯於南唐，宋人以其發墨，頗好用之。土人藉是為生，往往多作形勢以希售。米芾嘗譏其好為端樣，以平直鬥樣為貴，滯墨甚可惜。而此書名狀門內實首列端樣，亦可以考見一時風尚也。《書錄解題》作《圖譜》，米芾亦稱今之制見《歙州硯圖》，而此本有譜無圖，蓋左圭刊入《百川學海》時病繪圖繁費，削而不載，今則無從考補矣。","edition":"浙江鮑士恭家藏本"}],"books":["CXVzwTU17Ao"],"juan_count":{"number":1},"resources":[{"id":"wikisource-siku","name":"维基文库（四庫全書本）","url":"https://zh.wikisource.org/wiki/歙州硯譜_(四庫全書本)","type":"text"},{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/歙州硯譜","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=409320","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=997519","type":"text"},{"id":"shidianguji-sikuquanshuben","name":"识典古籍","url":"https://www.shidianguji.com/book/SK1711","type":"text+image","metadata":{"edition":"四庫全書本","version":"v1","total_page":18,"paragraph_count":58,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL55onLwDh":{"id":"GYL55onLwDh","type":"work","title":"墨法集要","authors":[{"name":"沈繼孫","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《墨法集要》•一卷","author_info":"明沈繼孫撰","summary":"明沈繼孫撰。繼孫，洪武時人，但自署其籍為姑蘇，餘不可考。惟倪瓚《雲林集》有贈沈生賣墨詩序曰，沈學翁隱居吳市，燒墨以自給，所謂不汲汲於富貴，不戚戚於貧賤者也。煙細而膠清，墨若點漆。近世不易得矣。因賦贈焉。時代、姓氏、裏貫一一相符，則學翁殆繼孫之字歟？繼孫自雲，初受教於三衢墨師，後又從一僧得墨訣，遂並錄成書。凡為圖二十有一，圖各有說。實近代造墨家之所祖也。古墨皆松煙，南唐李廷珪始兼用桐油，後楊振、陳道真諸家皆述其法。元、明以來，松煙之制漸廢，惟油煙獨行。繼孫所制，今不傳，其工拙雖莫可考，而此書由浸油以至試墨，敘次詳核，各有條理，班班然古法具存，亦可謂深於茲事矣。世傳《晁氏墨經》，其說太略，而明以來方氏、程氏諸譜，又斤斤惟花紋模式之是矜，不若是書之縷析造法，切於實用。錄而傳之，是亦利用之一端，非他雜家技術徒為戲玩者比也。","edition":"永樂大典本"}],"books":["CXVzwVNgcvj","CXYqSFSQ3xT","CXZVBfzRVC3"],"juan_count":{"number":1},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/墨法集要","type":"text"},{"id":"wikisource-siku","name":"维基文库（四庫全書本）","url":"https://zh.wikisource.org/wiki/墨法集要_(四庫全書本)","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=87018","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=2212719","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4640064","type":"text"},{"id":"shidianguji-guangxuershiwuguangy","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL06210598","type":"text+image","metadata":{"edition":"光緒二十五年廣雅書局刻本","version":"v2","total_page":104,"paragraph_count":147,"check_type":"AI整理"}},{"id":"shidianguji-sikuquanshuben","name":"识典古籍","url":"https://www.shidianguji.com/book/SK1720","type":"text+image","metadata":{"edition":"四庫全書本","version":"v1","total_page":106,"paragraph_count":181,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55ocwT9h":{"id":"GYL55ocwT9h","type":"work","title":"墨譜","authors":[{"name":"李孝美","role":"撰","dynasty":"宋"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《墨譜》•三卷","author_info":"宋李孝美撰","summary":"宋李孝美撰。孝美字伯揚，自署趙郡人。蓋唐俗稱郡望，未知實籍何地，其仕履亦未詳也。前有紹聖乙亥馬涓序，及李元膺序，與《通考》所載合。然二序皆稱《墨譜》，而《通考》則題曰《墨苑》，與序互異。案書中出灰、磨試二條，注曰出《墨苑》，則《墨苑》別為一書，《通考》誤矣。此本題曰《墨譜法式》，與《通考》又別。案書分三卷，上卷曰圖，中卷曰式，下卷曰法。則法式乃其中之子目，安得複為總名。且既曰《墨譜》，又曰《法式》，文意重疊，於體例尤乖、殆亦後人妄改。今惟據原序名曰《墨譜》，以存其舊。上卷凡采松、造窯、發火、取煙、和制、入灰、出灰、磨試八圖，然惟采松、造窯二圖有說，餘皆有說而佚其圖。中卷凡祖氏、奚庭珪、李超、李廷珪、李承晏、李文用、李惟慶、陳贇、張遇、盛氏、柴珣、宣道、宣德、猛州貢墨、順州貢墨及不知名氏十六家之式，亦各繪面圖漫圖。惟以奚庭珪、李廷珪分為二人，且謂奚不如李遠甚，與《南唐書》奚庭珪賜姓為李之說異。然兩無顯證，義可並存。其目列盛氏在柴珣前，而圖則盛在柴後，蓋傳寫誤也。下卷凡牛皮膠、鹿角膠、減膠、冀公墨、仲將墨、庭珪墨、古墨、油煙墨、敘藥品膠十一法，而牛皮膠有二法，庭珪墨有二法，古墨有三法，油煙墨有六法，實二十法。其持論皆剖析毫芒，具有精理。自明以來，油煙盛行，松煙之制久絕。孝美所論，雖今人所不能用，然古法古式藉以得傳，固博物者所當知矣。","edition":"浙江範懋柱家天一閣藏本"}],"books":["CXVzwUmUQz3"],"juan_count":{"number":3},"resources":[{"id":"shidianguji-panyingzhiruweiguanm","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ892411999028011148070","type":"text+image","metadata":{"edition":"潘膺祉如韋館明萬曆刻本","version":"v2","total_page":176,"paragraph_count":824,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55oPBNwZ":{"id":"GYL55oPBNwZ","type":"work","title":"歙硯說","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《歙硯說》•一卷、《辨歙石說》•一卷","author_info":"不著撰人名氏","summary":"不著撰人名氏。陳振孫《書錄解題》載之，亦雲皆不著姓名。左圭《百川學海》列於唐《積譜》後，卷末有跋，稱紹興三十年十二月，弟左承議郎尚書禮部員外郎兼國史院編修官邁跋。跋中稱景伯兄治歙，既揭蘇氏《文房譜》於四寶堂，又別刻硯說三種云云。案景伯為洪邁兄洪適之字，則此二書似出於適，然與邁跋三種之說不合。考適《盤洲集》有蘇易簡《文房四譜》跋，稱說歙硯者凡三家，品諸李者有《墨苑》，以踵此編。然則此二種蓋與唐積之譜共為三種，皆適所刻，以附於《文房譜》之後者，實非適所自撰也。《硯說》兼紀採石之地，琢石之法及其品質之高下。《歙石說》則專論其紋理星暈，凡二十七種，辨別頗為詳悉。唐詢《北海公硯錄》見於《郡齋讀書志》者，今其本久已失傳，惟此書引有兩條，及無名氏《硯譜引》有一條，猶可以考見什一雲。","edition":"浙江鮑士恭家藏本"}],"books":["CXVzwTgt8BR"],"juan_count":{"number":1},"related_works":[{"id":"GYLt1FQxtRV","title":"辨歙石說"}],"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/歙硯說","type":"text"},{"id":"shidianguji-sikuquanshuben","name":"识典古籍","url":"https://www.shidianguji.com/book/SK1712","type":"text+image","metadata":{"edition":"四庫全書本","version":"v1","total_page":24,"paragraph_count":66,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL55otnSj1":{"id":"GYL55otnSj1","type":"work","title":"香譜","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《香譜》•二卷","summary":"舊本不著撰人名氏。左圭《百川學海》題為宋洪芻撰。芻字駒父，南昌人。紹聖元年進士，靖康中官至諫議大夫，謫沙門島以卒。所作《香譜》，《宋史•藝文志》著錄。周紫芝《太倉稊米集》有題洪駒父《香譜》後曰，曆陽沈諫議家，昔號藏書最多者。今世所傳《香譜》，蓋諫議公所自集也，以為盡得諸家所載香事矣。以今洪駒父所集觀之，十分未得其一二也。余在富川，作妙香寮。永興郭元壽賦長篇，其後貴池丞劉君穎與餘凡五賡其韻，往返十篇。所用香事頗多，猶有一二事駒父譜中不錄者云云。則當時推重芻譜在沈立譜之上。然晁公武《讀書志》稱芻譜集古今香法，有鄭康成漢宮香、南史小宗香、真誥嬰香、戚夫人迫駕香、唐員半千香，所記甚該博，然《通典》載歷代祀天用水沈香獨遺之云云。此本有水沈香一條，而所稱鄭康成諸條乃俱不載，卷數比《通考》所載芻譜亦多一卷，似非芻作。沈立譜久無傳本，《書錄解題》有侯氏《萱堂香譜》二卷，不知何代人，或即此書耶？其書凡分四類，曰香之品，香之異，香之事，香之法，亦頗賅備，足以資考證也。","edition":"內府藏本"}],"juan_count":{"number":2},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/香譜","type":"text"},{"id":"wikisource-siku","name":"维基文库（四庫全書本）","url":"https://zh.wikisource.org/wiki/香譜_(四庫全書本)","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=227843","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=779387","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=411350","type":"text"},{"id":"shidianguji-kehouyinben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY6034","type":"text+image","metadata":{"edition":"刻後印本","version":"v4","total_page":65,"paragraph_count":300,"check_type":"粗校"}},{"id":"shidianguji-sikuquanshuben","name":"识典古籍","url":"https://www.shidianguji.com/book/SK1722","type":"text+image","metadata":{"edition":"四庫全書本","version":"v3","total_page":82,"paragraph_count":315,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-qingchaoben","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ89241199902622048895","type":"text+image","metadata":{"edition":"清抄本","version":"v1","total_page":112,"paragraph_count":1258,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55o9WgSK":{"id":"GYL55o9WgSK","type":"work","title":"文房四譜","authors":[{"name":"蘇易簡","role":"撰","dynasty":"宋"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《文房四譜》•五卷","author_info":"宋蘇易簡撰","summary":"宋蘇易簡撰。易簡字太簡，梓州銅山人。太平興國五年進士，官至參知政事。以禮部侍郎出知鄧州，移知陳州卒。事蹟具《宋史》本傳。是書凡《筆譜》二卷，《硯譜》、《墨譜》、《紙譜》各一卷，而筆格水滴附焉。各述原委本末，及其故實，殿以辭賦詩文，合為一書。前有徐鉉序，末有雍熙三年九月自序，謂因閱書秘府，集成此譜。考歐陽詢《藝文類聚》，每門皆前列事蹟，後附文章，易簡蓋仿其體式，然詢書兼羅眾目。其專舉一器一物，輯成一譜，而用歐陽氏之例者，則始自易簡。後來《硯箋》、《蟹錄》，皆沿用成規，則謂自易簡創法可也。其搜采頗為詳博，如梁元帝《忠臣傳》、顧野王《輿地志》之類，雖不免自類書之中轉相援引，其他徵引，則皆唐、五代以前之舊籍，足以廣典據而資博聞。當時甚重其書，至藏於秘閣，亦有以矣。《宋史》本傳但稱文房四譜，與此本同。尤袤《遂初堂書目》作《文房四寶譜》，又有《續文房四寶譜》。考洪邁《歙硯說跋》，稱揭蘇氏文房譜於四寶堂，當由是而俗呼四寶，因增入書名，後來病其不雅，又改題耳。","edition":"浙江吳玉墀家藏本"}],"books":["CXVzwT3dgj1"],"juan_count":{"number":5},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/文房四譜","type":"text"},{"id":"wikisource-siku","name":"维基文库（四庫全書本）","url":"https://zh.wikisource.org/wiki/文房四譜_(四庫全書本)","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=253429","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=238108","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=332313","type":"text"},{"id":"shidianguji-sikuquanshuben","name":"识典古籍","url":"https://www.shidianguji.com/book/SK1709","type":"text+image","metadata":{"edition":"四庫全書本","version":"v4","total_page":241,"paragraph_count":472,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-guangxuwushibaguianl","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL01024393","type":"text+image","metadata":{"edition":"光绪五至十八年归安陆氏本","version":"v2","total_page":246,"paragraph_count":2134,"check_type":"AI整理"}},{"id":"shidianguji-longshantongshimingk","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ89241199901488836907","type":"text+image","metadata":{"edition":"龍山童氏明刻本","version":"v1","total_page":158,"paragraph_count":1357,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55oVfaJK":{"id":"GYL55oVfaJK","type":"work","title":"硯箋","authors":[{"name":"高似孫","role":"撰","dynasty":"宋"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《硯箋》•四卷","author_info":"宋高似孫撰","summary":"宋高似孫撰。似孫有《剡錄》，已著錄。是書成於嘉定癸未。前有自序，序末數語，隱澀殆不可解。與所作《蟹略序》體格，仿佛相似。陳振孫稱似孫之文好以怪僻為奇，殆指此類歟？其書第一卷為端硯，分子目十九。卷中硯圖一類列四十二式，注曰歙石亦如之，然圖已不具，意傳寫佚之也。第二卷為歙硯，分子目二十。第三卷為諸品硯，凡六十五種。第四卷則前人詩文。其詩文明題曰端硯歙硯者，已附入前二卷內，是卷所載，皆不標名品，故別附之諸品後耳。《宋志》所錄《硯譜》，今存者尚有四五家，大抵詳於材產質性，而罕及其典故。似孫此書獨晚出，得備采諸家之說，又其學本淹博，能旁徵群籍以為之佐證，故敍述頗有可觀。中間稍有滲漏者，如李後主青石硯為陶穀所碎一條，乃出無名氏《硯譜》中，為曾慥《類說》所引，今其原書收入左圭《百川學海》，尚可檢核，似孫竟以為出自《類說》，未免失於根據。然其大致馴雅，終與龐雜者不同。如端州線石為諸品所不載，據王安石詩增入，亦殊賅洽。錢曾《讀書敏求記》亦稱唐人言吳融《八韻賦》古今無敵，惜乎亡來已久。此存得《古瓦研賦》一篇，巋然魯靈光也。則亦頗資考據矣。","edition":"浙江巡撫采進本"}],"books":["CXVzwULKK3d"],"juan_count":{"number":4},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/硯箋","type":"text"},{"id":"wikisource-siku","name":"维基文库（四庫全書本）","url":"https://zh.wikisource.org/wiki/硯箋_(四庫全書本)","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=737985","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=944993","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=268585","type":"text"},{"id":"shidianguji-kanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA09283","type":"text+image","metadata":{"edition":"刊本","version":"v8","total_page":120,"paragraph_count":580,"check_type":"粗校"}},{"id":"shidianguji-sikuquanshuben","name":"识典古籍","url":"https://www.shidianguji.com/book/SK1715","type":"text+image","metadata":{"edition":"四庫全書本","version":"v1","total_page":141,"paragraph_count":477,"check_type":"粗校"}},{"id":"shidianguji-panyingzhiruweiguanm","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ89241199901999845472","type":"text+image","metadata":{"edition":"潘膺祉如韋館明萬曆42年刻本","version":"v1","total_page":151,"paragraph_count":854,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55o6gmRy":{"id":"GYL55o6gmRy","type":"work","title":"奇器圖說","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《奇器圖說》•三卷、《諸器圖說》•一卷","author_info":"《奇器圖說》，明西洋人鄧玉函撰","summary":"《奇器圖說》，明西洋人鄧玉函撰。《諸器圖說》，明王徵撰。徵，涇陽人。天啟壬戌進士，官揚州府推官。嘗詢西洋奇器之法於玉函，玉函因以其國所傳文字口授，徵譯為是書。其術能以小力運大，故名曰重，又謂之力藝。大旨謂天地生物，有數，有度，有重。數為演算法，度為測量，重則即此力藝之學，皆相資而成，故先論重之本體，以明立法之所以然，凡六十一條。次論各色器具之法，凡九十二條。次起重十一圖，引重四圖，轉重二圖，取水九圖，轉磨十五圖，解木四圖，解石、轉碓、書架、水日晷、代耕各一圖，水銃四圖，圖皆有說，而於農器水法尤為詳備。其第一卷之首，有表性言解、來德言解二篇，俱極誇其法之神妙，大都荒誕恣肆，不足究詰。然其制器之巧，實為甲於古今寸有所長，自宜節取。且書中所載，皆裨益民生之具，其法至便，而其用至溥。錄而存之，固未嘗不可備一家之學也。諸器圖說，凡圖十一，各為之說，而附以銘贊，乃徵所自作，亦具有思致雲。","edition":"兩淮鹽政采進本"}],"books":["CXVzwSp4Mvf"],"juan_count":{"number":3},"additional_works":[{"book_title":"諸器圖說","n_juan":1}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=712947","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=809757","type":"text"},{"id":"shidianguji-guangxushiwuben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL01036332","type":"text+image","metadata":{"edition":"光緒十五年本","version":"v7","total_page":191,"paragraph_count":285,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-renxushanghaiboguzha","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL08000356","type":"text+image","metadata":{"edition":"壬戌年上海博古齋本","version":"v4","total_page":372,"paragraph_count":655,"check_type":"粗校"}},{"id":"shidianguji-sikuquanshuben","name":"识典古籍","url":"https://www.shidianguji.com/book/SK1708","type":"text+image","metadata":{"edition":"四庫全書本","version":"v2","total_page":636,"paragraph_count":1423,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55ofrjrw":{"id":"GYL55ofrjrw","type":"work","title":"墨經","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《墨經》•一卷","summary":"舊載毛晉《津逮秘書》中。原本題曰晁氏撰，不著時代名字。諸書引之，亦但曰《晁氏墨經》。考何薳《春渚紀聞》雲：晁季一生平無他嗜，獨見墨喜動眉宇，其所制銘曰晁季一寄寂軒造者，不減潘、陳。又稱其與賀方回、張秉道、康為章皆能精究和膠之法，其制皆如犀璧。此書中論膠雲，有上等煤而膠不如法，墨亦不佳；如得膠法，雖次煤能成善墨。與所言精究和膠亦合，疑為晁季一作也。然晁公武《讀書後志》但有董秉《墨譜》一卷，而不及此書，不應其從父之作公武不見，是為可疑。考《讀書志》子部之敘，九曰小說，十曰天文曆算，十一曰兵家，十二曰類家，十三曰雜藝，十四曰醫書，十五曰神仙，十六曰釋書。而今本所刊小說之尾碼以王氏《神仙傳》、葛洪《神仙傳》二種，並不列神仙之標題，以下即別標釋書類。是今本佚其子部五類，類書一類適在所佚之中（按：《後志》載《墨譜》於類書），其不載亦不足疑矣。季一名貫之，晁說之之兄弟行。朱弁《風月堂詩話》稱其官一曰檢討，一曰察院，不知實終於何職，其事蹟亦無考雲。","edition":"兩江總督采進本"}],"books":["CXVzwUyZkW3"],"juan_count":{"number":1},"resources":[{"id":"wikisource-siku","name":"维基文库（四庫全書本）","url":"https://zh.wikisource.org/wiki/墨經_(四庫全書本)","type":"text"},{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/墨經","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1774227","type":"text"},{"id":"shidianguji-jiajingzhihuanguanke","name":"识典古籍","url":"https://www.shidianguji.com/book/HY7083","type":"text+image","metadata":{"edition":"嘉靖祗洹館刻本","version":"v3","total_page":22,"paragraph_count":37,"check_type":"粗校"}},{"id":"shidianguji-sikuquanshuben","name":"识典古籍","url":"https://www.shidianguji.com/book/SK1718","type":"text+image","metadata":{"edition":"四庫全書本","version":"v1","total_page":24,"paragraph_count":40,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL55oSnySX":{"id":"GYL55oSnySX","type":"work","title":"端溪硯譜","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《端溪硯譜》•一卷","author_info":"不著撰人名氏","summary":"不著撰人名氏。末有淳熙十年東平榮{艸巳}跋曰，右縉雲葉樾交叔傳此譜，稍異於眾人之說，不知何人所撰，稱徽祖為太上皇，必紹興初人云云。是當時已不詳其出誰手矣。其書前論石之所出與石質石眼，次論價，次論形制，而終以石病。考端硯始見李賀詩，然柳公權論硯首青、絳二州，不言端石，蘇易簡《文房四譜》亦尚以青州紅絲硯為首。後端硯獨重於世，而鑒別之法亦漸以精密。此譜所載，於地產之優劣，石品之高下，皆剖晰微至，可以依據。至於當時以子石為貴，而此獨辨其妄，榮{艸巳}以為稍異於眾人之說，蓋指此類。然自米芾《硯史》已雲遍詢石工，未嘗有子石。芾為浛洸縣尉，嘗親至端州得其詳，而其言正與此合。亦足以知其說之確也。","edition":"浙江鮑士恭家藏本"}],"books":["CXVzwTum9C3"],"juan_count":{"number":1},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/端溪硯譜","type":"text"},{"id":"wikisource-siku","name":"维基文库（四庫全書本）","url":"https://zh.wikisource.org/wiki/端溪硯譜_(四庫全書本)","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=202752","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=239674","type":"text"},{"id":"shidianguji-sikuquanshuben","name":"识典古籍","url":"https://www.shidianguji.com/book/SK1713","type":"text+image","metadata":{"edition":"四庫全書本","version":"v1","total_page":16,"paragraph_count":30,"check_type":"粗校"}}],"has_text":true,"has_image":true}}