{"GYL55xPphdZ":{"id":"GYL55xPphdZ","type":"work","title":"酒譜","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《酒譜》•一卷","author_info":"舊本題臨安徐炬撰","summary":"舊本題臨安徐炬撰，不著時代。所載賜酺條中有洪武南市十四樓及顧佐奏禁挾妓事，是明人也。其序自雲，采唐汝陽王璡等十三家書而成。然引據每多訛舛，如以梁劉孝標松子玉漿、衛卿雲液二句為送酒與蘇軾之啟，以魏武帝何以解憂、惟有杜康二句為出焦贛《易林》，以月泉吟社村歌聒耳烏鹽角、社酒柔情玉練槌二句與李白遙看漢水鴨頭綠、正似葡萄初潑醅二句皆為杜甫詩，以《水經注》劉白墮之事為出《五鬥先生傳》，以前定錄松醪春之名為東坡詩。如斯之類，幾於條條有之，亦可謂不學無術矣。","edition":"內府藏本"}],"books":["CXVzwYK38n3"],"juan_count":{"number":1},"resources":[{"id":"shidianguji-sikuquanshuben","name":"识典古籍","url":"https://www.shidianguji.com/book/SK1734","type":"text+image","metadata":{"edition":"四庫全書本","version":"v2","total_page":11,"paragraph_count":40,"check_type":"粗校"}},{"id":"shidianguji-kehouyinben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY6033","type":"text+image","metadata":{"edition":"刻後印本","version":"v2","total_page":54,"paragraph_count":484,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL55xqdRWF":{"id":"GYL55xqdRWF","type":"work","title":"飲食須知","authors":[{"name":"賈銘","role":"撰","dynasty":"元"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《飲食須知》•八卷","author_info":"元賈銘撰","summary":"元賈銘撰。銘，海寧人，自號華山老人。元時嘗官萬戶。入明已百歲，太祖召見，問其平日頤養之法。對雲，要在慎飲食。因以此書進覽，賜宴禮部而回。至百有六歲乃卒。書中所載，自水火以及蔬果諸物，各疏其反忌，皆從諸家本草中摘敘成書。自序謂物性有相反相忌，《本草》疏注各物，皆損益相半，令人莫可適從，茲專選其反忌，匯成一編。然別無出於《本草》之外者，不足取也。","edition":"編修程晉芳家藏本"}],"juan_count":{"number":8},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/飲食須知","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=461589","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=941049","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02055910","type":"text+image","metadata":{"edition":"刻本","version":"v6","total_page":204,"paragraph_count":288,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-xuehaileibian","name":"识典古籍","url":"https://www.shidianguji.com/book/CXHLB370","type":"text+image","metadata":{"edition":"學海類編","version":"v4","total_page":156,"paragraph_count":480,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL55xx7cs1":{"id":"GYL55xx7cs1","type":"work","title":"天廚聚珍妙饌集","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《天廚聚珍妙饌集》•一卷","author_info":"不著撰人名氏","summary":"不著撰人名氏。所言皆製造飲食法度科例，分類編次。有汝陽史維泉序，曰，東原鬻書，李順之購得善本，目之曰《天廚聚珍妙饌集》，將鋟梓以廣其傳。蓋舊有其書，而李順之刻之，為題此名，當時已不知誰所作矣。","edition":"永樂大典本"}],"juan_count":{"number":1}},"GYL55x7L67y":{"id":"GYL55x7L67y","type":"work","title":"茶疏","authors":[{"name":"許次紓","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《茶疏》•一卷","author_info":"明許次紓撰","summary":"明許次紓撰。次紓字然明，錢塘人。是書凡三十九則，論採摘收貯烹點之法頗詳。中間擇水一條，誤以金山頂上井為中泠泉，考證殊為疏舛。","edition":"內府藏本"}],"juan_count":{"number":1},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/茶疏","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=806171","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY5968","type":"text+image","metadata":{"edition":"刻本","version":"v4","total_page":32,"paragraph_count":89,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL55xTPcH5":{"id":"GYL55xTPcH5","type":"work","title":"酒史","authors":[{"name":"馮時化","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《酒史》•六卷","author_info":"明馮時化撰","summary":"明馮時化撰。前有隆慶庚申趙惟卿序，稱時化字應龍，別號與川，晚自號無懷山人，而不著其裏籍。其書分酒系、酒品、酒獻、酒述、酒餘、酒考，皆酒之詩文與故實，然舛陋殊甚。其酒考中一條雲，羽觴見王右軍，其《蘭亭序》雲，羽觴隨波，則其他可知矣。卷末載吳淑《事類賦》中《酒賦》一篇，以補其遺，題曰燕山居士，亦不知其為何許人也。又浙江鮑士恭家別本，其文並同，而改題曰徐渭撰。案書中所載有袁宏道《觴政酒評》，渭集雖宏道所編，然宏道實不及見渭，渭何由收宏道作乎？其為坊賈偽題明矣。","edition":"內府藏本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4712082","type":"text"},{"id":"shidianguji-wanlishenshishangbai","name":"识典古籍","url":"https://www.shidianguji.com/book/HY6380","type":"text+image","metadata":{"edition":"萬曆沈氏尚白齋刻本","version":"v6","total_page":182,"paragraph_count":347,"check_type":"粗校"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02055900","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":180,"paragraph_count":155,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL55xc1QrT":{"id":"GYL55xc1QrT","type":"work","title":"酒部匯考","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《酒部匯考》•十八卷","author_info":"不著撰人名氏","summary":"不著撰人名氏。卷三末載國朝康熙三十年禁止直隸所屬地方以蒸酒糜米穀上諭一條，當為近人所著矣。所錄自經史以及稗乘詩詞凡涉於酒者徵采頗富。分為匯考六卷，總論一卷，紀事五卷，雜錄、外編各一卷，藝文四卷。然編次錯雜，殊乏體裁。每卷之首，空前二行，而以酒部匯考為子目。意其欲輯類書而未成，此其一門之賸稿也。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":18}},"GYL55xevhZh":{"id":"GYL55xevhZh","type":"work","title":"疏食譜","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《疏食譜》•一卷","summary":"明汪士賢《山居雜誌》載此書，題曰清漳陳達叟撰，不著時代。《千頃堂書目》亦作達叟，題曰宋人。考左圭《百川學海》載有此書，則宋人無疑。然《百川學海》所刻，其序自稱本心翁，而書前標題乃作門人清漳友善書堂陳達叟編，則達叟乃編其師之書，非所自撰也。所載食品二十種，各系以贊，皆粗糲草具，故曰疏食。《千頃堂書目》加草作蔬，失其旨矣。","edition":"內府藏本"}],"juan_count":{"number":1}},"GYL55xWDXHR":{"id":"GYL55xWDXHR","type":"work","title":"觴政","authors":[{"name":"袁宏道","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《觴政》•一卷","author_info":"明袁宏道撰","summary":"明袁宏道撰。宏道字無學，公安人。萬曆壬辰進士，官至吏部稽勳司郎中。事蹟具《明史•文苑傳》。是書紀觴政凡十六則。前有宏道引語，謂采古科之簡正者，附以新條，為醉鄉甲令。朱國楨《湧幢小品》曰，袁中郎不善飲而好談飲，著有《觴政》一篇，即此書也。","edition":"內府藏本"}],"juan_count":{"number":1},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=483162","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY5971","type":"text+image","metadata":{"edition":"刻本","version":"v5","total_page":21,"paragraph_count":47,"check_type":"粗校"}},{"id":"shidianguji-wanlishenshishangbai","name":"识典古籍","url":"https://www.shidianguji.com/book/HY6281","type":"text+image","metadata":{"edition":"萬曆沈氏尚白齋刻本","version":"v4","total_page":18,"paragraph_count":39,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL55xArJv3":{"id":"GYL55xArJv3","type":"work","title":"茶史","authors":[{"name":"劉源長","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《茶史》•二卷","author_info":"國朝劉源長撰","summary":"國朝劉源長撰。源長字介祉，淮安人。是編上卷記茶品，下卷記飲茶，其分子目三十，冗碎殊甚。卷端題名，自稱曰八十翁。蓋暮年頤養，姑以寄意而已，不足以言著書也。","edition":"浙江汪啟淑家藏本"}],"juan_count":{"number":2},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/茶史","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=57197","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=756533","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=5618082","type":"text"},{"id":"shidianguji-kanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA09301","type":"text+image","metadata":{"edition":"刊本(後印)","version":"v15","total_page":254,"paragraph_count":478,"check_type":"粗校"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02055896","type":"text+image","metadata":{"edition":"刻本","version":"v4","total_page":224,"paragraph_count":184,"check_type":"粗校"}},{"id":"shidianguji-chaoben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02095383","type":"text+image","metadata":{"edition":"抄本","version":"v3","total_page":223,"paragraph_count":1924,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55xiVcDD":{"id":"GYL55xiVcDD","type":"work","title":"飲膳正要","authors":[{"name":"和斯輝","role":"撰","dynasty":"元"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《飲膳正要》•三卷","author_info":"元和斯輝撰","summary":"元和斯輝撰。和斯輝官飲膳太醫，其始末未詳。是編前有天曆三年進書奏，稱世祖設掌飲膳太醫四人。於《本草》內選無毒，無相反，可久食，補益藥味，與飲食相宜，調和五味。及以每日所造珍品禦膳，所職何人，所用何物，標注於曆，以驗後效。和斯輝自延祐間選充是職，因以進用奇珍異饌，湯膏煎造，及諸家本草名醫方術，並日所必用穀肉果菜，取其性味補益者，集成一書。虞集奉敕為之序。所言皆當時之制，其中如鄒店井水之類，頗足以資考證。惟神仙服食一門，詞多荒誕耳。","edition":"浙江範懋柱家天一閣藏本"}],"juan_count":{"number":3},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/飲膳正要","type":"text"},{"id":"wikisource-sibu-congkan","name":"维基文库（四部叢刊本）","url":"https://zh.wikisource.org/wiki/飲膳正要_(四部叢刊本)","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=968624","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=343825","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=852245","type":"text"}]},"GYL55xtYiDV":{"id":"GYL55xtYiDV","type":"work","title":"饌史","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《饌史》•一卷","author_info":"不著撰人名氏，舊本題曰元人，亦臆度之也","summary":"不著撰人名氏，舊本題曰元人，亦臆度之也。其書雜記飲食故事。所采如《酉陽雜俎》、《東京夢華錄》、《武林舊事》之類，大抵習見。又以《饌史》為名，而波及食量，已為支蔓。乃並劉邕嗜痂，權長孺嗜爪甲，鮮于叔明嗜臭蟲事，亦並闌入。皆與饌無涉，益乖體例矣。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":1},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=259405","type":"text"}]},"GYL55xERDZZ":{"id":"GYL55xERDZZ","type":"work","title":"水品","authors":[{"name":"徐獻忠","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《水品》•二卷","author_info":"明徐獻忠撰","summary":"明徐獻忠撰。獻忠有《吳興掌故集》，已著錄。是編皆品煎茶之水。上卷為總論，一曰源，二曰清，三曰流，四曰甘，五曰寒，六曰品，七曰雜說。下卷詳記諸水，自上池水至金山寒穴泉，目錄列三十四名，而書中多噴霧崖瀑、萬縣西山包泉、雲陽縣天師泉、潼川鹽亭縣飛龍泉、遂寧縣靈泉五名。蓋目錄偶脫。又麻姑山神功泉，目錄在鐵篩泉後，而書則居前，亦誤倒也。其上卷第六篇中駁陸羽所品虎邱石水及二瀑水、吳松江水、張又新所品淮水，第七篇中駁羽煮水初沸調以鹽味之說，亦自有見，然時有自相矛盾者。如上卷論瀑水不可飲，下卷乃列噴霧崖瀑，引張商英之說以為偏宜煮茗。下卷濟南諸泉條中，論珍珠泉湧出珠泡為山氣太盛，不可飲，天臺桐柏宮水條，又謂湧起如珠，甘冽入品。恐亦一時興到之言，不必盡為典要也。舊本題曰《水品全帙》，立名殊不可解。考田崇衡、蔣灼二跋皆稱《水品》，無全帙字，疑書僅一冊，藏弆家插架題簽，於《水品》下寫全帙字，傳寫者誤連為書名也。今從舊跋，仍題曰《水品》焉。","edition":"浙江巡撫采進本"}],"juan_count":{"number":2},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4941606","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02055898","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":64,"paragraph_count":47,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL55xZ689D":{"id":"GYL55xZ689D","type":"work","title":"酒概","authors":[{"name":"沈沈","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《酒概》•四卷","author_info":"明沈沈撰","summary":"明沈沈撰。自題曰震旦醚民囦囦父。前有自序一首，則稱曰褐之父。囦囦沈沈，名號詭譎，不知何許人。每卷所署校正姓氏，皆稱海陵，則刻於泰州者也。其書仿陸羽《茶經》之體，以類酒事。一卷三目，曰酒、名、器。二卷七目，曰釋、法、造、出、稱、量、飲。三卷六目，曰評、僻、寄、緣、事、異。四卷六目，曰功、德、戒、亂、令、文。雜引諸書，體例叢碎，至以孔子為酒聖，阮籍、陶潛、王績、邵雍為四配，尤妄誕矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":4},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1965165","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02055902","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":371,"paragraph_count":2411,"check_type":"AI整理"}},{"id":"shidianguji-kangxiliuqianjikeyon","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02095385","type":"text+image","metadata":{"edition":"康熙劉謙吉刻雍正六年劉乃大補修本","version":"v2","total_page":374,"paragraph_count":3344,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL55xn4Wrj":{"id":"GYL55xn4Wrj","type":"work","title":"易牙遺意","authors":[{"name":"韓奕","role":"撰","dynasty":"元"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《易牙遺意》•二卷","author_info":"舊本題元韓奕撰","summary":"舊本題元韓奕撰。奕字公望，平江人。生於元文宗時，入明遁跡不仕，終於布衣。是編仿《古食經》之遺，上卷為醞造、脯鮓、蔬菜三類，下卷為籠造、爐造、糕餅、湯餅、齋食、果實、諸湯、諸藥八類。周履靖校刊，稱為當時豪家所珍。考奕與王賓、王履齊名，明初稱吳中三高士，未必營心刀俎若此，或好事者偽撰，託名於奕耶。周氏《夷門廣牘》、胡氏《格致叢書》、曹氏《學海類編》所載古書，十有九偽，大抵不足據也。","edition":"副都御史黃登賢家藏本"}],"juan_count":{"number":2},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/易牙遺意","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=579188","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=965497","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=2205129","type":"text"},{"id":"shidianguji-yimenguangdu","name":"识典古籍","url":"https://www.shidianguji.com/book/CYMCD044","type":"text+image","metadata":{"edition":"夷門廣牘","version":"v3","total_page":99,"paragraph_count":197,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-maoshijigugechaoben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02095394","type":"text+image","metadata":{"edition":"毛氏汲古閣抄本","version":"v3","total_page":101,"paragraph_count":66,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL55xLx6mm":{"id":"GYL55xLx6mm","type":"work","title":"湯品","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《湯品》•","author_info":"不著撰人名氏","summary":"不著撰人名氏。分十六品。首為煎法，以老嫩言者凡三品。次為注法，以緩急言者凡三品。次以器標者凡五品。次以薪論者凡五品。大抵餖飣成書，不足以資觀覽。","edition":"無卷數，副都御史黃登賢家藏本"}]},"GYL55xHLWGo":{"id":"GYL55xHLWGo","type":"work","title":"煮泉小品","authors":[{"name":"田藝衡","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《煮泉小品》•一卷","author_info":"明田藝衡撰","summary":"明田藝衡撰。藝衡有《大明同文集》，已著錄。是書凡分十類，一源泉，二石流，三清寒，四甘香，五宜茶，六靈水，七異泉，八江水，九井水，十緒談。大抵原本舊文，未能標異於《水品》、《茶經》之外。","edition":"內府藏本"}],"juan_count":{"number":1},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/煮泉小品","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=127870","type":"text"},{"id":"shidianguji-wanlishenshishangbai","name":"识典古籍","url":"https://www.shidianguji.com/book/HY6261","type":"text+image","metadata":{"edition":"萬曆沈氏尚白齋刻本","version":"v6","total_page":42,"paragraph_count":102,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL55x3iVd1":{"id":"GYL55x3iVd1","type":"work","title":"茗史","authors":[{"name":"萬邦寧","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《茗史》•二卷","author_info":"明萬邦寧撰","summary":"明萬邦寧撰。邦寧，奉節人。天啟壬戌進士。是書不載焙造煎試諸法，惟雜采古今茗事。多從類書撮錄而成，未為博奧。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":2},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=451313","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02055895","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":65,"paragraph_count":417,"check_type":"AI整理"}}],"has_text":true,"has_image":true}}