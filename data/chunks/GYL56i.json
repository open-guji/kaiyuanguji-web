{"GYL56ihJgGP":{"id":"GYL56ihJgGP","type":"work","title":"養生雜纂","authors":[{"name":"周守忠","role":"撰","dynasty":"宋"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《養生雜纂》·二十二卷、附《月覽》·二卷","author_info":"宋周守忠撰","summary":"宋周守忠撰。守忠號{容木}菴，（案{容木}古文松字。）不知何許人。初以養生宜忌之事按月編錄，名《日月覽》。後於嘉定壬午又廣為《雜纂》。首為總敘三篇，次以事類分為十三部。後人以《月覽》附刻於後，其為一書，總題曰《養生雜類》，非其本名也。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":22},"related_works":[{"id":"GYLt1FydJUX","title":"養生月覽"}]},"GYL56ipVBQs":{"id":"GYL56ipVBQs","type":"work","title":"補妒記","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《補妒記》·八卷","author_info":"舊本題曰京兆王績編","summary":"舊本題曰京兆王績編，不著時代。案晁公武《讀書志》載有此書一卷，謂不知何人所輯。陳振孫《書錄解題》亦有此書，稱王績撰。因古有宋虞之《妒記》，今不傳，故補之。其題名與此相合，當即振孫所見之本。其書自一卷至六卷紀商、周迄五季妒婦之事，第七卷曰雜妒，謂淫亂而妒及事涉神怪者，第八卷曰總敘，乃要說文章。自涼張續《妒婦賦》以下並闕，故振孫所稱治妒二方已無之。然振孫既雲古《妒記》不傳，而書中又有采自《妒記》者，不知何據，殆於類書剽取之。至第七卷內宋仁宗尚、楊二美人事，乃注雲見《宋史》，則明人已有所附益，非復宋代原書矣。","edition":"浙江鄭大節家藏本"}],"juan_count":{"number":8}},"GYL56iWTtmV":{"id":"GYL56iWTtmV","type":"work","title":"臥遊錄","authors":[{"name":"朱呂祖謙","role":"撰","dynasty":"宋"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《臥遊錄》·一卷","author_info":"舊本題宋朱呂祖謙撰","summary":"舊本題宋朱呂祖謙撰。祖謙有《古周易》，已著錄。是書前有嘉定九年王深源序，後有嘉靖壬午顧元慶跋。凡四十五則，前二十一則全錄劉義慶《世說新語》，次十八則全錄蘇軾雜著及《陶潛集》，惟後二則不知為誰語。其言參差不倫，了無取義，祖謙必不如是之陋。此本出陳繼儒《普秘笈》中，殆明人依託也。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":1},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/臥遊錄","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=583314","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY6342","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":30,"paragraph_count":41,"check_type":"粗校"}},{"id":"shidianguji-sunmingzhimingchongz","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ892411999013195121893","type":"text+image","metadata":{"edition":"孫明志明崇禎6年抄本","version":"v1","total_page":30,"paragraph_count":295,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56iPU92o":{"id":"GYL56iPU92o","type":"work","title":"帝皇龜鑑","authors":[{"name":"王欽若","role":"撰","dynasty":"宋"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《帝皇高抬貴手》·三十四卷","author_info":"舊本題宋王欽若撰","summary":"舊本題宋王欽若撰，欽若事蹟具《宋史》本傳，是書考宋以來史志書目皆不著錄。詳檢其文，即《冊府元龜》中帝王一部。卷首欽若序，即原書之總類也。偽妄剽竊之書，本不足辨，而既有傳本，恐滋疑誤，是以存而論之焉。","edition":"兩淮馬裕家藏本"}],"juan_count":{"number":34}},"GYL56iCSc87":{"id":"GYL56iCSc87","type":"work","title":"研山齋珍玩集覽","authors":[{"name":"孫炯","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《研山齋珍玩集覽》•","author_info":"國朝孫炯撰","summary":"國朝孫炯撰。炯字挈菴，大興人，吏部侍郎承澤之孫也。是書取《退穀隨筆》中所論銅、玉、磁器及筆、墨、硯、紙、印章、文玩與刻版、繡繪、刻絲之屬，益以炯所見聞，編成此帙。炯自為序。其中論刻版一條，稱其家有宋版《本草綱目》四函。考《本草綱目》乃明萬曆中李時珍所作，安得有宋版也！","edition":"無卷數，編修勵守謙家藏本"}]},"GYL56iG1Wmd":{"id":"GYL56iG1Wmd","type":"work","title":"老老恒言","authors":[{"name":"曹廷棟","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《老老恒言》•五卷","author_info":"國朝曹廷棟撰","summary":"國朝曹廷棟撰。廷棟有《易准》，已著錄。是書皆言衰年頤養之法。前二卷詳晨昏動定之宜，次二卷列居處備用之要，末附粥譜一卷，借為調養之需。蓋廷棟年七十五時作也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":5},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4675731","type":"text"},{"id":"shidianguji-guangxusixiushuisuns","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL01027208","type":"text+image","metadata":{"edition":"光緒四年秀水孫氏望雲仙館本","version":"v7","total_page":225,"paragraph_count":216,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-qianlongsanshibazike","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02056995","type":"text+image","metadata":{"edition":"乾隆三十八年自刻本","version":"v5","total_page":295,"paragraph_count":1925,"check_type":"AI整理"}},{"id":"shidianguji-caotingdongqingqianl","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ892411999012168120040","type":"text+image","metadata":{"edition":"曹庭棟清乾隆38年刻本","version":"v1","total_page":296,"paragraph_count":2384,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56idjmcs":{"id":"GYL56idjmcs","type":"work","title":"文苑英華鈔","authors":[{"name":"高似孫","role":"編","dynasty":"宋"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《文苑英華鈔》·四卷","author_info":"宋高似孫編","summary":"宋高似孫編。似孫有《剡錄》，已著錄。是編乃採摘《文苑英華》中典雅字句可供文章之用者，仿洪邁《經子法語》之例，鈔合成帙。刻本仍以原目為次，不分卷數。以似孫原序考之，當時實分四卷也。其中以諸本參校，如呂令開《蓮峰賦》，別本皆作氣開秋爽，此本作氣涵秋爽。賈至《早朝詩》別本皆作共沐恩波鳳池上，朝朝染翰侍君王，此本作共沐恩波鳳池裏，終朝默默侍君王。李群玉《黃陵廟詩》別本皆作回風日暮吹芳芷，此本作東風日暮吹香芷，皆小有異同。韓愈《汴州東西水門記》別本俱作請紀成績，此本作皆請紀其成績，又遂極其危句此本作遂持危，亦皆《韓集舉正》、《韓文考異》所未載，其搜羅亦頗該洽。自序謂周必大奉敕校《文苑英華》，是書有助焉。然摘錄不具首尾，僅為詞科餖飣之學爾。","edition":"浙江巡撫采進本"}],"juan_count":{"number":4}},"GYL56i5uiuu":{"id":"GYL56i5uiuu","type":"work","title":"廣社","authors":[{"name":"張雲龍","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《廣社》•","author_info":"明張雲龍撰","summary":"明張雲龍撰。雲龍字爾陽，華亭人。是書成於崇禎末年，乃因陶邦彥所作《燈謎》而廣之。前載作謎諸格，取字義相似者配合一句，暗射成語。後借詩韻平仄分注，以備採用。然語多鈍置，頗乏巧思。","edition":"無卷數，內府藏本"}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=981762","type":"text"},{"id":"shidianguji-chongzhenkeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02097212","type":"text+image","metadata":{"edition":"崇禎刻本","version":"v3","total_page":523,"paragraph_count":4227,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56ia8B7u":{"id":"GYL56ia8B7u","type":"work","title":"經子法語","authors":[{"name":"洪邁","role":"撰","dynasty":"宋"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《經子法語》·二十四卷","author_info":"宋洪邁撰","summary":"宋洪邁撰。邁有《史記法語》，已著錄。邁兄弟並以詞科起家，此書蓋即摘經子新穎字句以備程試之用者。凡易一卷，書二卷，詩三卷，周禮二卷，禮記四卷，《儀禮》、《公羊傳》、《穀梁傳》、《孟子》、《荀子》、《列子》、《國語》、《太玄經》各一卷，莊子四卷。體例略如類書，但不分門目，與經義絕不相涉。朱彝尊以《易法語》一卷、《詩法語》一卷之類散入《經義考》各門之中，題曰未見，未免失考矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":24},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=3754779","type":"text"},{"id":"shidianguji-zhejiangxunfucaijinb","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02057000","type":"text+image","metadata":{"edition":"浙江巡撫採進本","version":"v1","total_page":377,"paragraph_count":3773,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56iKd7Gb":{"id":"GYL56iKd7Gb","type":"work","title":"初學藝引","authors":[{"name":"李仕學","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《初學藝引》•二十三卷","author_info":"國朝李仕學撰","summary":"國朝李仕學撰。仕學字亨敏，號遜齋，揭陽人。是編本為初學遊藝而作。首冠以格言一卷，其餘分六引，曰文引，曰詩引，曰書引，曰畫引，曰琴引，曰棋引。其文引凡五卷，首論文，次《左傳》選，次《莊子》選，次《史記》選，次《韓文》選。其詩引凡三卷，首卷分論詩、詩體、詩學三篇，次卷選漢、魏六朝，唐詩，末卷專論樂府，分總論、訂律、憲音、宮調、歌法、題解諸目。其書引凡四卷，分論書、書體、書法、書學等目，畫引四卷亦如之。其琴引四卷則仿《史記》之例，編為《琴史》。首以古帝王始制琴及善琴者為十二本紀，而孔子與焉，又表古今人物及七絃十三徽與手勢、指法等為十表，又撰禮書、樂書、天官書、定制書、擇材書、操縵書、正音書為八書。其三十世家則能以琴世其家者，其七十列傳則古今善琴之人也。編末棋引二卷，則自出新意，取邵子之易數以為棋局。其凡例謂以堯夫為弈秋，四大為枰，分野為罫，日月為子，晦明為黑白，嬗遞升降為劫數輸贏。名曰《棋局新書》，示與舊譜不同也。其書分八目：一曰說局，總說大意；二曰先天成局，即邵子之日月星辰水火土石也；三曰方圓正局，即先天方圓二圖合而圖之，象天包地外，地處天中也；四曰奇偶變局，即日月星辰水火土石八卦，八而重之為六十四卦，六而變之為三百八十四卦也；五曰得數定算，則以元會運世歲月日時為經，而以十二、三十之數反覆相乘也；六曰爛柯甲子，蓋一元十二會全圖也；七曰長安舊聞，則自巳會第三十運至午會第十一運之圖，蓋邵子嘗推數起唐堯甲辰，迄宋之熙寧，仕學此書複增而益之，至於本朝也；八曰棋閣測議，蓋引黃氏管窺之說，以總古今全局也。其名書之意，不過以一元有三百六十運，一會有三百六十世，推之年月日時，其三百六十之數，皆與棋合，故以棋局名焉。其亦妄作聰明，弊精神於無用之地矣。","comment":"──右“雜家類”雜品之屬，二十六部，一百七十二卷內三部無卷數，皆附《存目》。","edition":"浙江巡撫采進本"}],"juan_count":{"number":23},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4000872","type":"text"},{"id":"shidianguji-qianlongshufangjukeb","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02056998","type":"text+image","metadata":{"edition":"乾隆漱芳居刻本","version":"v3","total_page":261,"paragraph_count":2549,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56iksauu":{"id":"GYL56iksauu","type":"work","title":"石屏新語","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《石屏新語》·二卷","author_info":"舊題宋戴復古撰","summary":"舊題宋戴復古撰。復古字式之，天臺黃岩人。居南塘石屏山，因以自號。是編以《石屏新語》為名，則當為復古所手著。乃編中惟錄張詢《古五代新說》、陳郁《藏一話腴》二種，而多所刪節，當是後人依託其名，抄撮成帙也。","edition":"浙江吳玉墀家藏本"}],"juan_count":{"number":2}},"GYL56it9TmH":{"id":"GYL56it9TmH","type":"work","title":"古今藝苑談概上集","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《古今藝苑談概上集》·六卷、《下集》·六卷","author_info":"舊本題俞文豹撰","summary":"舊本題俞文豹撰。案文豹宋人，所著《吹劍錄外集》，已著錄。此編多引明代諸書，蓋偽託也。書中雜采故實，無所辨論，每條下各列書名，而疏舛特甚。如鄒忌妻妾事出《戰國策》，而注曰《十二國春秋》；列子攫金於市事，末增吏大笑之四字；當為無知書賈抄撮說部，偽立新名也。","edition":"兩江總督采進本"}],"juan_count":{"number":6},"additional_works":[{"book_title":"下集","n_juan":6}]},"GYL56iwiNQo":{"id":"GYL56iwiNQo","type":"work","title":"澄懷錄","authors":[{"name":"周密","role":"撰","dynasty":"宋"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《澄懷錄》·二卷","author_info":"宋周密撰","summary":"宋周密撰。密有《志雅堂雜鈔》，已著錄。是書采唐宋諸人所紀登涉之勝與曠達之語，匯為一編。皆節載原文，而注書名其下，亦《世說新語》之流別，而稍變其體例者也。明人喜摘錄清談，目為小品，濫觴所自，蓋在此書矣。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":2},"resources":[{"id":"shidianguji-baichuangaoshimingji","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ892411999005792100328","type":"text+image","metadata":{"edition":"百川高氏明嘉靖26年抄本","version":"v1","total_page":61,"paragraph_count":376,"check_type":"AI整理"}},{"id":"shidianguji-qingchaoben","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ89241199902120066306","type":"text+image","metadata":{"edition":"清抄本","version":"v1","total_page":47,"paragraph_count":537,"check_type":"AI整理"}},{"id":"shidianguji-liwentianjiaqingguan","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ892411999011044113533","type":"text+image","metadata":{"edition":"李文田家清光緒2年抄本","version":"v1","total_page":74,"paragraph_count":443,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56i33847":{"id":"GYL56i33847","type":"work","title":"博物要覽","authors":[{"name":"穀泰","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《博物要覽》•十六卷","author_info":"明穀泰撰","summary":"明穀泰撰。泰字寧宇，官蜀王府長史。其書一卷紀碑刻，二卷紀書，三卷紀畫，四卷紀銅器，五卷紀窯器，六卷紀硯，七卷紀黃金，八卷紀銀，九卷紀珠，十卷紀寶石，十一卷紀玉，十二卷紀瑪瑙、珊瑚，十三卷紀琥珀、蜜蠟、玻璃等物，十四卷紀水晶、玳瑁、犀角、象等物，十五卷紀香，十六卷紀漆器、奇石。皆隨所見聞，摭錄成帙，未能該備，所論碑版書畫，尤為簡陋。書成於天啟中，而中有稱明太祖者。殆後人傳寫所改歟？","edition":"兩淮馬裕家藏本"}],"juan_count":{"number":16},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=394196","type":"text","details":"（Ming）谷泰（谷應泰）"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1891407","type":"text"},{"id":"shidianguji-chaoben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02097208","type":"text+image","metadata":{"edition":"抄本","version":"v6","total_page":327,"paragraph_count":1333,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56iStz7y":{"id":"GYL56iStz7y","type":"work","title":"徽言","authors":[{"name":"司馬光","role":"編","dynasty":"宋"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《徽言》·一卷","author_info":"宋司馬光編","summary":"宋司馬光編。光手抄諸子史集精語，置諸座右以自警。自題其首云「迂叟年六十八」，蓋元祐初為相時也。後有陳振孫跋，載光自題其末雲，餘此書類舉人抄書，然舉子所抄獵其辭，餘所抄核其意，舉人志科名，余志道德。今是編已失其題末，未知陳氏所載為全文否。又陳氏稱自《國語》以下六書，今惟《國語》、《家語》、《韓詩外傳》、《孟子》、《荀子》五書，疑有佚闕。又每條下間有題識數字者，卷末又列所欲取書名二十二種，蓋未完之稿，後人以光手書重之耳。","edition":"浙江范懋柱家天一閣藏本"}],"juan_count":{"number":1}},"GYL56i8q1d9":{"id":"GYL56i8q1d9","type":"work","title":"莝錄","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《莝錄》•三卷","author_info":"不著撰人名氏","summary":"不著撰人名氏。卷首題抄自袁陶齋，亦不知陶齋何人也。所載凡十一類。文房通用至養育禽獸皆載其名義，與一切新法。大旨仿《多能鄙事》諸書為之，而瑣屑彌甚。","edition":"浙江範懋柱家天一閣藏本"}],"juan_count":{"number":3}}}