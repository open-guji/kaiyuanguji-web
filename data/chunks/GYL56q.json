{"GYL56q6YWoR":{"id":"GYL56q6YWoR","type":"work","title":"掌錄","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《掌錄》·","author_info":"舊本題繡雲居士撰","summary":"舊本題繡雲居士撰，不著姓名時代。其抄書格紙，邊頁刊繡雲居土，蓋猶其手稿。卷首小序之末有私印曰李輅，而卷中天臺陳剛中一條下有自注亦稱輅少失屺恃，則李輅所作。又上闌有一條雲，吾邑顧升伯入丁未會場，特落一人名而登所善門生李光元。考文秉《定陵注略》，載萬曆丁未，湯賓尹為同考官，有陰毀申時行子朱卷，而改中江西李光元事，非顧升伯，所記為誤。然可知輅為萬曆以後人也。其書雜抄說部，漫無體例，多取之於《說郛》，亦無異聞。其曰掌錄，意其取《拾遺記》蘇秦、張儀錄書掌中事也。","edition":"無卷數，安徽巡撫采進本"}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=8979558","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=5994054","type":"text"},{"id":"shidianguji-unknown","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02057700","type":"text+image","metadata":{"edition":"未知","version":"v3","total_page":147,"paragraph_count":1289,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56qjNmao":{"id":"GYL56qjNmao","type":"work","title":"倘湖樵書","authors":[{"name":"來集之","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《倘湖樵書》·十二卷","author_info":"明來集之撰","summary":"明來集之撰。集之有《讀易隅通》，已著錄。是書初編六卷，二編六卷，皆采摭唐、宋、元、明諸家之說，以類相從，排纂其文。而總括立一標目，或雜引古書而論之，或先立論而以古書證之。徵摭繁富，頗有考證之處。而細大不捐，蕪雜特甚，亦多有迂僻可笑者。如論經篇中引《名賢錄》所載宋章樵遇李全之亂，率諸生盛服坐堂上講誦，寇至斂刃而退事；又引《宋濂集》所紀宋鄭霖講《中庸》一篇，使寇退不敢攻城事，以為讀經之效，勝於修齋。其他引讀經卻鬼治病事，不一而足。然則以孔門聖籍為二氏之符籙經懺矣。","edition":"安徽巡撫采進本"}],"juan_count":{"number":12},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=682826","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=2311458","type":"text"},{"id":"shidianguji-kangxitanghuxiaozhuk","name":"识典古籍","url":"https://www.shidianguji.com/book/HY1571","type":"text+image","metadata":{"edition":"康熙倘湖小築刻本","version":"v7","total_page":2646,"paragraph_count":20961,"check_type":"AI整理"}},{"id":"shidianguji-kangxitanghuxiaozhuk-1","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02097452","type":"text+image","metadata":{"edition":"康熙倘湖小築刻本","version":"v1","total_page":2452,"paragraph_count":22103,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56qf2BSf":{"id":"GYL56qf2BSf","type":"work","title":"諸子拔萃","authors":[{"name":"李雲翔","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《諸子拔萃》·八卷","author_info":"明李雲翔編","summary":"明李雲翔編。雲翔字為霖，江都人。是書成於天啟丁卯，取坊本諸子匯函割裂其文，分為二十六類。其杜撰諸子名目，則一仍其舊。古今荒誕鄙陋之書，至諸子匯函而極，此書又為之重佁。天下之大，亦何事靡有也。","edition":"內府藏本"}],"juan_count":{"number":8}},"GYL56qM6GWB":{"id":"GYL56qM6GWB","type":"work","title":"培壘居雜錄","authors":[{"name":"鄭端允","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《培壘居雜錄》·四卷","author_info":"明鄭端允編","summary":"明鄭端允編。端允字思孟，海鹽人，鄭曉之曾孫也。是書雜采諸家勸戒之言，至《太上感應篇》亦所不遺。雖意主訓誨，而其言不盡出於儒者，蓋雜家流也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":4}},"GYL56qynTjD":{"id":"GYL56qynTjD","type":"work","title":"讀書十六觀","authors":[{"name":"陳繼儒","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《讀書十六觀》·一卷","author_info":"明陳繼儒撰","summary":"明陳繼儒撰。采古人成語，自呂獻可以下凡十六條，聯綴成編，以為讀書之法。命名之義，蓋擬浮屠氏之《十六觀經》也。後有跋雲，寫前觀畢，夢有老人自稱斫輪翁云云。雖本寓言，究涉荒渺。此編嘗刻入《秘笈》中，與書畫史誤合為一，今析出別著於錄焉。","edition":"浙江孫仰曾家藏本"}],"juan_count":{"number":1}},"GYL56qnzN5m":{"id":"GYL56qnzN5m","type":"work","title":"博學匯書","authors":[{"name":"來集之","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《博學匯書》·十二卷","author_info":"明來集之撰","summary":"明來集之撰。凡讀書所得，隨筆記錄，不分門目，惟以類相從，鱗次櫛比，俾可互證。視他書叢雜無次者，較為過之。然所采多小說家言，如《拾遺》、《洞冥》諸記，是豈足取以為據乎？","edition":"內府藏本"}],"juan_count":{"number":12},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1202310","type":"text"},{"id":"shidianguji-unknown","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02057748","type":"text+image","metadata":{"edition":"未知","version":"v5","total_page":2456,"paragraph_count":11421,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56qUE5oD":{"id":"GYL56qUE5oD","type":"work","title":"湘煙錄","authors":[{"name":"閔元京淩義渠同","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《湘煙錄》·十六卷","author_info":"明閔元京淩義渠同編","summary":"明閔元京淩義渠同編。元京字子京，烏程人。義渠之舅也。未詳其所終。義渠字駿甫，此書亦題為烏程人，而太學題名碑作歸安人，蓋二縣同為湖州倚郭也。天啟乙丑進士，官至大理寺卿。崇禎甲申殉國難，世祖章皇帝賜諡忠介。事蹟具《明史·本傳》。其人自足不朽，而其書乃不出明末山人之習。所分咫聞、清檢、蘭訊、鼎書、奩史、談啁、金荃補、革志、詺目、偏記十門，標名詭異，大致欲仿段成式《酉陽雜俎》。其雜采新事，各注所出之書則欲仿馮贄《雲仙雜記》，意在標舉幽異，而不免於剽竊類書，如杜甫舊雨今雨之語見於本集，原非僻書，而注曰《六帖》，不知白居易《六帖》無唐事，有唐事者乃宋孔傳《續六帖》，是既已疏漏，且複舛誤。又卷首參訂姓名列董斯張為第二，而書中多引《廣博物志》，即斯張所纂《類書》，既非其所自撰，何不出斯張所著書名乎？捃拾無根，斯亦顯證矣。","edition":"浙江吳玉墀家藏本"}],"juan_count":{"number":16},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=379118","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=2630370","type":"text"},{"id":"shidianguji-chaoben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY7144","type":"text+image","metadata":{"edition":"抄本","version":"v5","total_page":399,"paragraph_count":1911,"check_type":"AI整理"}},{"id":"shidianguji-tianqikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02057710","type":"text+image","metadata":{"edition":"天啓刻本","version":"v2","total_page":426,"paragraph_count":3788,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56q2vvJT":{"id":"GYL56q2vvJT","type":"work","title":"愧林漫錄","authors":[{"name":"瞿式耜","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《愧林漫錄》·十卷","author_info":"明瞿式耜撰","summary":"明瞿式耜撰。式耜字起田，常熟人。萬曆丙辰進士，官至右僉都御史，巡撫廣西。進文淵閣大學士，兼兵部尚書。大兵下廣西，抗節死之。事蹟具《明史》本傳。乾隆四十一年賜諡忠節。是編成於崇禎丙子。雜抄諸儒之言，分為學問、居心、規家、酬世、在位、積德、讀書、究竟、攝生、依隱十篇，儒、墨兼陳，蓋林居時錄以自警。大旨歸於為善而已，非辯別學術之書也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":10}},"GYL56qQfB9h":{"id":"GYL56qQfB9h","type":"work","title":"廣百川學海","authors":[{"name":"馮可賓","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《廣百川學海》·","author_info":"舊本題明馮可賓編","summary":"舊本題明馮可賓編。可賓，益都人。天啟壬戌進士。是編於正續《百川學海》之外，捃拾說部以廣之，分為十集，以十幹標目。然核其所載，皆正續《說郛》所有，版亦相同，蓋奸巧書賈於《說郛》印版中抽取此一百三十種，別刊序文目錄，改題此名，托言出於可賓也。","edition":"無卷數，兩江總督采進本"}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=580762","type":"text","details":"馮可賓"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=6510291","type":"text"}]},"GYL56qHUg1D":{"id":"GYL56qHUg1D","type":"work","title":"偶得紺珠","authors":[{"name":"黃秉石","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《偶得紺珠》·一卷","author_info":"明黃秉石撰","summary":"明黃秉石撰。秉石字複子，江寧人。萬曆中以薦為推官，官至嚴州府同知。是編雜采諸書，餖飣少緒，又多不注出典。蓋隨手筆記，未有詮次體例也。","edition":"內府藏本"}],"juan_count":{"number":1},"resources":[{"id":"shidianguji-chaoben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02057709","type":"text+image","metadata":{"edition":"鈔本","version":"v2","total_page":266,"paragraph_count":2417,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56qXtN9d":{"id":"GYL56qXtN9d","type":"work","title":"雲薖淡墨","authors":[{"name":"木增","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《雲薖淡墨》·六卷","author_info":"明木增撰","summary":"明木增撰。增字生白，雲南麗江土司，世襲土知府。以助餉征蠻功，晉秩左布政使。年甫三十，即謝職。天啟五年，特給誥命以旌其忠。增好讀書，多與文士往還。是書蓋其隨筆摘抄之本，大抵直錄諸書原文，無所闡發。又多參以釋典道藏之語，未免糅雜失倫。特以其出自蠻陬，故當時頗傳之雲。","edition":"浙江吳玉墀家藏本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=148431","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=3876990","type":"text"},{"id":"shidianguji-chongzhenshiyimuyiqi","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02057716","type":"text+image","metadata":{"edition":"崇禎十一年木懿喬等刻本","version":"v2","total_page":1212,"paragraph_count":8959,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56qDpPeo":{"id":"GYL56qDpPeo","type":"work","title":"厚語","authors":[{"name":"錢蓘","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《厚語》·四卷","author_info":"明錢蓘撰","summary":"明錢蓘撰。蓘字懋登，海鹽人。萬曆中由貢生官於潛縣訓導。是編皆錄長厚之事可為世法者，故曰《厚語》。分十六類，皆以明人居前，而古事以類列於後。其凡例謂耳目所逮，尤易信從雲。","edition":"浙江巡撫采進本"}],"juan_count":{"number":4},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=8014500","type":"text"},{"id":"shidianguji-chaoben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02057705","type":"text+image","metadata":{"edition":"鈔本","version":"v2","total_page":341,"paragraph_count":2742,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56qbTGo9":{"id":"GYL56qbTGo9","type":"work","title":"子史碎語","authors":[{"name":"胡尚洪","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《子史碎語》·二十四卷","author_info":"明胡尚洪編","summary":"明胡尚洪編。尚洪字叔開，宣城人。是編成於天啟丙寅，《明史·藝文志》著錄。然皆采摭諸書，餖飣而成。分造化、人事、君道、臣術四門，又分子目三百八十有三，煩碎冗雜，無複條理。《三墳》、《天祿閣外史》、《心書》之類，皆偽妄顯然者，亦皆採錄。至如割裂郭象《莊子注》謂之郭子，亦自我作古，前此未聞也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":24}},"GYL56qvDZ5h":{"id":"GYL56qvDZ5h","type":"work","title":"家規輯要","authors":[{"name":"胡爌","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《家規輯要》·","author_info":"明胡爌撰","summary":"明胡爌撰。爌有《拾遺錄》，已著錄。是書仿《溫公家範》、《呂氏鄉約》之意，采輯舊文，排纂成編。大概為中人以下設也。","edition":"無卷數，江西巡撫采進本"}]},"GYL56qrbxaj":{"id":"GYL56qrbxaj","type":"work","title":"堯山堂外紀","authors":[{"name":"蔣一葵","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《堯山堂外紀》·一百卷","author_info":"明蔣一葵撰","summary":"明蔣一葵撰。一葵字仲舒，常州人。堯山其讀書堂名也。是書取記傳所載軼聞瑣事，擇其稍僻者，輯為一編。上起古初，下迄明代，每代俱以人名標目。雅俗並陳，真偽並列，殊乏簡汰之功。至以明諸帝分編入各卷之中，尤非體例矣。","edition":"浙江鮑士恭家藏本"}],"juan_count":{"number":100},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/堯山堂外紀","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7910635","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=618052","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7762902","type":"text"},{"id":"shidianguji-wanlikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY1535","type":"text+image","metadata":{"edition":"萬曆刻本","version":"v29","total_page":3290,"paragraph_count":5443,"check_type":"AI整理"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02097387","type":"text+image","metadata":{"edition":"刻本","version":"v7","total_page":3583,"paragraph_count":4380,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56qACo9q":{"id":"GYL56qACo9q","type":"work","title":"檢蠹隨筆","authors":[{"name":"楊宗吾","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《檢蠹隨筆》·三十卷","author_info":"明楊宗吾撰","summary":"明楊宗吾撰。宗吾字伯相，成都人。官錦衣衛指揮。大學士廷和之曾孫，修撰慎之孫也。是書為類二十有四，采掇瑣碎，分條編載，體近類書，而當時邸報及其祖父遺事亦間附焉。又有數條乃駁陳耀文正楊之非，及陳建通紀載楊廷和事之誤。又麗句、瑣語二門，專取詩文詞藻，與全書體例皆不相類，殊為猥難。自序稱不問人之棄取，惟意是采。今古駁雜，積成數卷，蓋亦道其實也。","edition":"兩江總督采進本"}],"juan_count":{"number":30},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=8457042","type":"text"},{"id":"shidianguji-wanlisanshisanwangsh","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02057702","type":"text+image","metadata":{"edition":"萬曆三十三年王尚修刻本","version":"v2","total_page":219,"paragraph_count":1877,"check_type":"AI整理"}}],"has_text":true,"has_image":true}}