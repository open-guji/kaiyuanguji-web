{"GYL56rAfw5Z":{"id":"GYL56rAfw5Z","type":"work","title":"銷夏","authors":[{"name":"陳繼儒","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《銷夏》·四卷","author_info":"明陳繼儒撰","summary":"明陳繼儒撰。其書雜錄清勝之事，取其可以銷夏，如冰荷玉帳見於諸小說家者，靡不採錄。纖仄瑣碎，亦可謂徒費心力矣。","edition":"內府藏本"}],"juan_count":{"number":4},"resources":[{"id":"wikisource-白居易","name":"维基文库（白居易）","url":"https://zh.wikisource.org/wiki/銷暑_(白居易)","type":"text"}]},"GYL56rXZpaj":{"id":"GYL56rXZpaj","type":"work","title":"枕函小史","authors":[{"name":"閔於忱","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《枕函小史》·","author_info":"明閔於忱編","summary":"明閔於忱編。於忱始末未詳。是編凡分二種，一曰譚史，采蘇米志林議論，二曰癖史，雜記古人癖事。各加評點，總不出明季佻纖之習。","edition":"無卷數，內府藏本"}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4042887","type":"text"},{"id":"shidianguji-kanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA06680","type":"text+image","metadata":{"edition":"刊本","version":"v12","total_page":304,"paragraph_count":364,"check_type":"粗校"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY6710","type":"text+image","metadata":{"edition":"刻本","version":"v8","total_page":312,"paragraph_count":165,"check_type":"粗校"}},{"id":"shidianguji-mingsongyunguankezhu","name":"识典古籍","url":"https://www.shidianguji.com/book/SDZJ0108","type":"text+image","metadata":{"edition":"明松筠馆刻朱墨套印本","version":"v2","total_page":666,"paragraph_count":550,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL56rHokNb":{"id":"GYL56rHokNb","type":"work","title":"古今韻史","authors":[{"name":"陳繼儒","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《古今韻史》·十二卷","author_info":"明陳繼儒撰","summary":"明陳繼儒撰。是書摭拾諸書雋語，分類編次。凡韻人二卷，韻事二卷，韻語三卷，韻詩二卷，韻詞二卷，韻物一卷。皆以古事與明人事參錄，亦《世說新語》之支流，而纖佻彌甚。","edition":"副都御史黃登賢家藏本"}],"juan_count":{"number":12},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7253031","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02057817","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":588,"paragraph_count":5031,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56rmTxMD":{"id":"GYL56rmTxMD","type":"work","title":"迪吉錄","authors":[{"name":"顏茂猷","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《迪吉錄》·九卷","author_info":"明顏茂猷撰","summary":"明顏茂猷撰。茂猷字壯其，又字仰子，平湖人。崇禎甲戌特賜進士。是編分官鑒、公鑒二門，皆雜錄諸書因果之事。","edition":"內府藏本"}],"juan_count":{"number":9},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=5465019","type":"text"},{"id":"shidianguji-mingmokeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02057868","type":"text+image","metadata":{"edition":"明末刻本","version":"v2","total_page":1524,"paragraph_count":14158,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56r3Sk5d":{"id":"GYL56r3Sk5d","type":"work","title":"群碎錄","authors":[{"name":"陳繼儒","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《群碎錄》·一卷","author_info":"明陳繼儒撰","summary":"明陳繼儒撰。其書隨筆紀錄，不暇考辨，故以群碎為名。前有自跋，謂讀書者一字一語不忍棄之。然不應瑣雜如是也。","edition":"內府藏本"}],"juan_count":{"number":1},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=543095","type":"text"},{"id":"shidianguji-wanlikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY6431","type":"text+image","metadata":{"edition":"萬曆年刻本","version":"v4","total_page":54,"paragraph_count":102,"check_type":"粗校"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY5916","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":46,"paragraph_count":104,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL56rq8Ehd":{"id":"GYL56rq8Ehd","type":"work","title":"明百家小說","authors":[{"name":"沈廷松","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《明百家小說》·一百九卷","author_info":"舊本題明沈廷松編","summary":"舊本題明沈廷松編。廷松號石閭，未詳其爵裏。前有自序，題甲戌小寒日，當為崇禎七年。而其書乃全與國朝陶珽《續說郛》同，蓋坊賈以不全《說郛》偽鐫序目售欺也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":109}},"GYL56rtjqCb":{"id":"GYL56rtjqCb","type":"work","title":"讀書止觀錄","authors":[{"name":"吳應箕","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《讀書止觀錄》·五卷","author_info":"明吳應箕撰","summary":"明吳應箕撰。應箕字次尾，貴池人。崇禎壬午副榜貢生。順治元年大兵破南京，殉節死。事蹟附見《明史·邱祖德傳》。明末稱複社五秀才，應箕為首。其克全晚節，尤不愧完人。然是書乃襲陳繼儒《讀書十六觀》之餘緒，推而衍之，雜引古人論讀書作文之語，而稍以己意為論斷，語意儇佻，頗類明末山人之派。又每條之末必終以讀書者當觀此六字，五卷皆然，蓋仿《十六觀》中讀書者當作是觀之例，尤病於效顰。","edition":"浙江巡撫采進本"}],"juan_count":{"number":5},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/讀書止觀錄","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=552190","type":"text"},{"id":"shidianguji-minguojiuguichiliush","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02057877","type":"text+image","metadata":{"edition":"民國九年貴池劉氏唐石簃刻貴池先生遺書本","version":"v3","total_page":67,"paragraph_count":477,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56rhkz9M":{"id":"GYL56rhkz9M","type":"work","title":"昨非齋日纂","authors":[{"name":"鄭瑄","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《昨非齋日纂》·二十卷","author_info":"明鄭瑄撰","summary":"明鄭瑄撰。瑄字漢奉，閩縣人。崇禎辛未進士，官至應天巡撫。此書皆記古人格言懿行，區為二十類，每類各為小引。然議論佻淺，徵引亦多雜糅。冥果一類，皆出小說家言，尤不可為典要。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":20}},"GYL56rEEqj5":{"id":"GYL56rEEqj5","type":"work","title":"辟寒","authors":[{"name":"陳繼儒","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《辟寒》·四卷","author_info":"明陳繼儒撰","summary":"明陳繼儒撰。繼儒既作《銷夏》四卷，又成此書，義例與《銷夏》相類。如狨座蹲鴟之類，皆泛載之，尤為拉雜。","edition":"內府藏本"}],"juan_count":{"number":4}},"GYL56rUhDiw":{"id":"GYL56rUhDiw","type":"work","title":"可如","authors":[{"name":"董德鏞","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《可如》·六卷","author_info":"明董德鏞撰","summary":"明董德鏞撰。德鏞字孔昭，鄞縣人。其書取禽獸魚蟲之事，合於忠孝節義者，分類摘錄，共六十三門。每門又各為標目，皆冠以可如二字，如雲可如鴨、可如鵝之類，頗為近俚。自序謂諸書所載，散見而不聚，隱而義未顯，故特表以出之。其名禽獸魚蟲，其事則人也。其曰可如者，蓋心存乎勸戒也。逐條之下，附以評語。大抵憤世嫉俗之詞，有所激而然也。昔開封阮漢聞嫉明末將帥之怯懦，因輯古來婦人行兵制勝之事，編為二卷，題曰女雲台，以深愧之。德鏞此編，其用意與之相類。蓋明之末造，人心世道無不極敝，故士大夫發憤著書，往往如是雲。","edition":"浙江巡撫采進本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7460607","type":"text"}]},"GYL56re6hnw":{"id":"GYL56re6hnw","type":"work","title":"萃古名言","authors":[{"name":"趙民獻","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《萃古名言》·四卷","author_info":"明趙民獻編","summary":"明趙民獻編。民獻，雲南人。其書刻於崇禎初年。康熙中交河王琯官迤西道時得之於其子孫，已殘闕失次。琯複增損其文，後任湖廣學政時以授胡之太刊之。琯任滿攜版北歸，楚士子複為重刻。故是書有南北二本，此即南本也。其書舉先儒嘉言懿行分類編輯，凡四十六門，多不載所出。其凡例雲，或趙氏所自言，或他書所嘗見，故不復細加分別。然體例殊不畫一，各門之後，之太又添綴評語，尤為蛇足。琯字昭玉，交河人。康熙癸丑進士，官湖廣提學副使。此本皆題王琯，蓋傳刻之誤。之太字聽岩，黃州人，其仕履未詳。","edition":"浙江巡撫采進本"}],"juan_count":{"number":4},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=6006252","type":"text"},{"id":"shidianguji-chongzhenyuankeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02057835","type":"text+image","metadata":{"edition":"崇禎元年刻本","version":"v2","total_page":559,"paragraph_count":4823,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56raXo9R":{"id":"GYL56raXo9R","type":"work","title":"搗堅錄","authors":[{"name":"朱廷旦","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《搗堅錄》·二十四卷","author_info":"明朱廷旦撰","summary":"明朱廷旦撰。廷旦字爾兼，一號旋菴子，嘉善人。天啟中貢生。是書分一百類，每類各為小序，陳勸戒之旨，而徵引故實列於後，其末又綴以評論。其凡例謂主於破疑掃疾，故刺惡之條，溢於獎善。稱搗堅者，謂如病之刺其堅也。所言多主禍福，蓋欲世俗易省耳。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":24}},"GYL56rMU2j1":{"id":"GYL56rMU2j1","type":"work","title":"福壽全書","authors":[{"name":"陳繼儒","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《福壽全書》·","author_info":"明陳繼儒撰","summary":"明陳繼儒撰。皆錄前賢格言遺事，自惜福以至好還，凡分二十類。多以因果為說，蓋意在懲惡勸善。而徵引糅雜，遂近於小說家言。","edition":"無卷數，內府藏本"}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=951999","type":"text"},{"id":"shidianguji-mingmokeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02057822","type":"text+image","metadata":{"edition":"明末刻本","version":"v3","total_page":755,"paragraph_count":5870,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56r772S3":{"id":"GYL56r772S3","type":"work","title":"珍珠船","authors":[{"name":"陳繼儒","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《珍珠船》·四卷","author_info":"明陳繼儒撰","summary":"明陳繼儒撰。是書雜采小說家言，湊集成編，而不著所出，既病冗蕪，亦有訛舛。蓋明人好剿襲前人之書而割裂之，以掩其面目。萬曆以後，往往皆然，繼儒其尤著者也。","edition":"內府藏本"}],"juan_count":{"number":4},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/珍珠船","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=926700","type":"text"},{"id":"shidianguji-wanlishenshishangbai","name":"识典古籍","url":"https://www.shidianguji.com/book/HY6426","type":"text+image","metadata":{"edition":"萬曆沈氏尚白齋刻本","version":"v9","total_page":260,"paragraph_count":516,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL56rxQ7Z1":{"id":"GYL56rxQ7Z1","type":"work","title":"韋弦自佩錄","authors":[{"name":"朱輔","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《韋弦自佩錄》·十二卷","author_info":"明朱輔撰","summary":"明朱輔撰。輔號杲庵，建德人。官至簡州知州。此書取唐、宋以來議論事實可為法戒者，分類摘載。分十二門，頗雜以禪門，宗旨未為精粹。嘗再刻於壺關。及桂林兵燹，散佚。康熙四十一年，其子雯重刻於江寧。前有王士禎序，稱仿白孔《六帖》而作。然《六帖》乃類書，無所不備，此只錄前言往行，實趙善璙《自警編》之流，士禎所言非也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":12}},"GYL56rR5dDy":{"id":"GYL56rR5dDy","type":"work","title":"廣銷夏","authors":[{"name":"周詩雅","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《廣銷夏》·一卷、《廣辟寒》·一卷、《銷夏補》·一卷、《辟寒補》·一卷、《銷夏再》一卷、《辟寒再》一卷、《寒夏合再》一卷","author_info":"明周詩雅撰","summary":"明周詩雅撰。詩雅有《南北史抄》，已著錄。是編本陳繼儒《銷夏》、《辟寒》二書，更著此以推衍之。編拾叢雜，較之繼儒原書，風更下矣。","edition":"編修勵守謙家藏本"}],"juan_count":{"number":1},"related_works":[{"id":"GYLt1FbA3z7","title":"廣辟寒"},{"id":"GYLt1FbSB6o","title":"銷夏補"},{"id":"GYLt1Fbkz4w","title":"辟寒補"},{"id":"GYLt1Fc5o35","title":"銷夏再"},{"id":"GYLt1FcQc1D","title":"辟寒再"},{"id":"GYLt1FcjQyM","title":"寒夏合再"}]}}