{"GYL56uHAve3":{"id":"GYL56uHAve3","type":"work","title":"人道譜","authors":[{"name":"閔忠","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《人道譜》·","author_info":"國朝閔忠撰","summary":"國朝閔忠撰。忠，歸安人。是書仿劉宗周《人譜》之意，以孝、弟、忠、信、禮、義、廉、恥為人之要，分為八集，各為標目，雜采史事而各引先儒之說以發明之。","edition":"無卷數，浙江巡撫采進本"}]},"GYL56ubHazK":{"id":"GYL56ubHazK","type":"work","title":"查浦輯聞","authors":[{"name":"查嗣瑮","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《查浦輯聞》·二卷","author_info":"國朝查嗣瑮撰","summary":"國朝查嗣瑮撰。嗣瑮字德尹，海寧人。康熙庚辰進士，官至翰林院侍講。是書乃抄撮雜家之言可資博覽者，大抵皆節錄原文，無所考據，間有自附新語，不過數條。下卷內有西湖事蹟十餘則，乃以補吳煒《錢塘志》所未及者。其以《鶴林玉露》為葛立方作，未免筆誤。至以楊瑀為楊琚，以葉子奇為葉子才，則校刊者之疏也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":2},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=8585493","type":"text","details":"（Qing）查嗣〓"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02058089","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":256,"paragraph_count":418,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL56ux66nb":{"id":"GYL56ux66nb","type":"work","title":"學統存","authors":[{"name":"宋士宗","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《學統存》·二十四卷","author_info":"國朝宋士宗撰","summary":"國朝宋士宗撰。士宗有《史學正藏》，已著錄。是書分二十四門，各為一卷，多摘錄前人之說。其自序謂周有老、莊，宋有象山，明有文成，兼之宗杲、大鑒輩日與吾黨爭理，即濂、洛、關、閩複生，不能驟起而勝也。大抵攻陸、王之學以尊程、朱。然書名學統，而中多雜引史事及說部諸書，龐雜不可枚舉。至志異一門，尤多怪誕不經之語，如《清異錄》所載繾綣司氤氳大使之類，豈亦有關於道學之統乎？","edition":"江西巡撫采進本"}],"juan_count":{"number":24}},"GYL56uXmNCF":{"id":"GYL56uXmNCF","type":"work","title":"經術要義","authors":[{"name":"高元標","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《經術要義》·四卷","author_info":"國朝高元標撰","summary":"國朝高元標撰。元標字琴山，嘉興人。其書雜采舊文，分門排纂，自孝行至閨範，凡二十五目。末附報應一門，所徵引尤涉荒誕，標曰《經術要義》，未免名實不符矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":4}},"GYL56uiRQHM":{"id":"GYL56uiRQHM","type":"work","title":"範家集略","authors":[{"name":"秦坊","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《範家集略》·六卷","author_info":"國朝秦坊撰","summary":"國朝秦坊撰。坊字表行，號儼塵，無錫人。是編分身范、程范、文范、言范、說范、閨范，自周、秦以及明代，凡前賢格言懿行，匯為一帙。然頗冗雜，如宋太祖誓碑一事，既以帝王之事雜於臣庶中，而不殺柴氏子孫，亦無預於身範也。","edition":"原任工部右侍郎李友棠家藏本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7966221","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=395000","type":"text"},{"id":"shidianguji-tongzhishizhongkeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02058091","type":"text+image","metadata":{"edition":"同治十年重刻本","version":"v2","total_page":576,"paragraph_count":6286,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56u9wje7":{"id":"GYL56u9wje7","type":"work","title":"秦氏閨訓新編","authors":[{"name":"秦雲爽","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《秦氏閨訓新編》·十二卷","author_info":"國朝秦雲爽撰","summary":"國朝秦雲爽撰。雲爽有《紫陽大旨》，已著錄。是書成於康熙丙寅，因呂氏《閨範》而增損之，而分為後妃、女主、女道、兄弟、婦道、妯娌、嫡庶、母道、後母、雜錄、處變十一目，則體例略殊。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":12}},"GYL56u6Npzb":{"id":"GYL56u6Npzb","type":"work","title":"學仕要箴","authors":[{"name":"張圻","role":"編","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《學仕要箴》·五卷","author_info":"國朝張圻編","summary":"國朝張圻編。圻字邑翼，昆山人。卷首徐元文序，謂莘田侍禦始集仕學格言，圻續為纂輯，凡分十類，曰存心，曰省身，曰型家，曰處物，曰養蒙，曰舉業，曰居官，曰臨民，曰仕宦，曰慎刑。首標蔣伊鑒定，伊即序所稱莘田侍禦。是此書實伊所作，而圻稍增益之，其標曰鑒定者，蓋讓其名於圻耳。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":5},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=2708853","type":"text"},{"id":"shidianguji-kangxikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02058062","type":"text+image","metadata":{"edition":"康熙刻本","version":"v2","total_page":96,"paragraph_count":853,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56uDc1zX":{"id":"GYL56uDc1zX","type":"work","title":"庸行篇","authors":[{"name":"牟允中","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《庸行篇》·八卷","author_info":"國朝牟允中撰","summary":"國朝牟允中撰。允中字叔庸，天津衛人。是書因揚州史典《願體集》而參補之。皆先正格言，分門編輯，自達觀以至警醒，凡三十三類。每類采輯數十則，大都取其明白顯易，可以訓俗化愚。其立教類有允中自著讀書之法，兼論及於時文，並引八股講論數條，蓋以訓其家塾子弟者也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":8}},"GYL56uuDVvo":{"id":"GYL56uuDVvo","type":"work","title":"訓俗遺規","authors":[{"name":"陳宏謀","role":"編","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《訓俗遺規》·五卷","author_info":"國朝陳宏謀編","summary":"國朝陳宏謀編。宏謀有《大學衍義輯要》，已著錄。此書乃其為江蘇按察使時以獄訟繁多，因集古今名言人人易曉者，勒成四卷，刊佈宣諭。後無錫華希閔為之重刻，又益以邵寶《手帖》、顧憲成《示兒帖》、高攀龍《家訓》及國朝張英《聰訓齋語》，及其先世悰韡所著《家勸》，共為一編雲。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":5},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=6685332","type":"text"},{"id":"shidianguji-qianlongwushiwuhanyi","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02058104","type":"text+image","metadata":{"edition":"乾隆五十五年含英閣刻道光增補本","version":"v2","total_page":555,"paragraph_count":5537,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56u2ovM5":{"id":"GYL56u2ovM5","type":"work","title":"敦行錄","authors":[{"name":"張鵬翮","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《敦行錄》·二卷","author_info":"國朝張鵬翮撰","summary":"國朝張鵬翮撰。鵬翮有《忠武志》，已著錄。是書輯古來嘉言善行，以敦本適用分上下卷，中間又分二十一門。書成於康熙丁巳。後十年丁卯，慈谿縣知縣方允獻為之注，蓋鵬翮官浙江巡撫時也。所紀皆厚德之事，而以徵驗一篇終之，則近乎因果之說，涉於有為而為矣。故列之雜家類焉。","edition":"浙江巡撫采進本"}],"juan_count":{"number":2}},"GYL56uLstqu":{"id":"GYL56uLstqu","type":"work","title":"讀書樂趣","authors":[{"name":"伍涵芬","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《讀書樂趣》·八卷","author_info":"國朝伍涵芬撰","summary":"國朝伍涵芬撰。涵芬字芝軒，於潛人。康熙丁卯舉人。是書首載朱子《四時讀書樂歌》，以見命名之意。然四詩《晦庵集》不載，據《仙居縣誌》，載此四詩題為縣人翁森作。稱森字秀卿，號一瓢，宋亡後隱居不仕，著有《一瓢集》云云，則涵芬題為朱子者誤也。書中分蕩胸、澄心、澹緣、怡情、論文、勵業、品詩七類。而怡情類半載《花譜》，品詩類附入己作，亦龐雜之甚。","edition":"內府藏本"}],"juan_count":{"number":8},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1162698","type":"text"},{"id":"shidianguji-qianlongsishijiukebe","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02058077","type":"text+image","metadata":{"edition":"乾隆四十九年刻本","version":"v3","total_page":576,"paragraph_count":6460,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56uqbuRq":{"id":"GYL56uqbuRq","type":"work","title":"閑家編","authors":[{"name":"王士俊","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《閑家編》·八卷","author_info":"國朝王士俊撰","summary":"國朝王士俊撰。士俊字犀川，平越人。康熙辛丑進士，官至河東總督。是編分家訓、家禮、家政、家壺四門，又各立子目。皆雜引古書，間參以己見，大抵習見之詞。其家壺之名又頗嫌杜撰，於古無稽也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":8},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=8123157","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY1395","type":"text+image","metadata":{"edition":"刻本","version":"v14","total_page":795,"paragraph_count":1601,"check_type":"粗校"}},{"id":"shidianguji-yongzhengshieryangzh","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02058097","type":"text+image","metadata":{"edition":"雍正十二年養拙堂刻本","version":"v3","total_page":771,"paragraph_count":6879,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL56uU75qq":{"id":"GYL56uU75qq","type":"work","title":"孝史類編","authors":[{"name":"黃齊賢","role":"編","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《孝史類編》·十卷","author_info":"國朝黃齊賢編","summary":"國朝黃齊賢編。齊賢字敬思，嘉興人。是編前列孝經，次述歷代帝王孝行，次述歷代孝子，各以事蹟相似者分類紀之，凡二十有二門。孝為百行之原，發於至性，各不相師，未可冗陳條目。至於修道度親一門，尤為二氏之言，非儒者之道矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":10}},"GYL56uerVdq":{"id":"GYL56uerVdq","type":"work","title":"會心錄","authors":[{"name":"孔尚任","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《會心錄》·四卷","author_info":"國朝孔尚任撰","summary":"國朝孔尚任撰。尚任有《節序同風錄》，已著錄。是編雜采古人清言佳事，略如沈括《清夜錄》、周密《志雅堂雜抄》之例。自序雲，不考出處，不次前後，不分體例，間有複訛者，亦懶於刪。蓋林居多暇，姑以寄意而已，非有意於著書也。","edition":"衍聖公孔昭煥家藏本"}],"juan_count":{"number":4}},"GYL56umwd5R":{"id":"GYL56umwd5R","type":"work","title":"範身集略","authors":[{"name":"秦坊","role":"編","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《範身集略》·八卷","author_info":"國朝秦坊編","summary":"國朝秦坊編。坊《範家集略》以身範為先，然僅書中之一門，未為賅備，故繼為此編，專明範身之義。分為八部，曰成部，應部，容部，貞部，慎部，坦部，辨部，誡部。每一部為一卷，各有子目，共二十六目。《範家集略》皆不載所出之典，而此所徵引，必注某人某文，體例較善。然捃摭既富，亦不免儒、墨兼陳。","edition":"浙江巡撫采進本"}],"juan_count":{"number":8}},"GYL56uQVVLs":{"id":"GYL56uQVVLs","type":"work","title":"硯北雜錄","authors":[{"name":"黃叔琳","role":"編","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《硯北雜錄》·","author_info":"國朝黃叔琳編","summary":"國朝黃叔琳編。叔琳有《硯北易抄》，已著錄。是書上至天文、地理，下至昆蟲、草木，凡經史所載，旁及稗官小說，據其所見，各為採錄，亦間附以己意。大抵主於由博返約，以為考據之資。中多簽題粘補之處，皆叔琳晚年手自刪改，蓋猶未定之本也。","edition":"無卷數，編修勵守謙家藏本"}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=3398415","type":"text"},{"id":"shidianguji-hanyangyeshichaoben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02058081","type":"text+image","metadata":{"edition":"漢陽葉氏鈔本","version":"v1","total_page":695,"paragraph_count":8334,"check_type":"AI整理"}}],"has_text":true,"has_image":true}}