{"GYL57HAswoV":{"id":"GYL57HAswoV","type":"work","title":"茹古略集","authors":[{"name":"程良孺","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《茹古略集》·三十卷","author_info":"明程良孺撰","summary":"明程良孺撰。良孺有《讀書考定》，已著錄。是書三十卷，凡三百九十四篇。每篇皆採擷藻麗之詞，聯為偶語，其體全同事類賦。自序稱不奇不已，不幽不已，不僻不已不合其奇者、幽者、僻者以成一家言不已。然觀所徵引，實了不異人也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":30},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=2222685","type":"text"},{"id":"shidianguji-kangxiliushisuncheng","name":"识典古籍","url":"https://www.shidianguji.com/book/HY7210","type":"text+image","metadata":{"edition":"康熙六十年(1721)孫程大畢韻樓刻本","version":"v1","total_page":1592,"paragraph_count":2006,"check_type":"粗校"}},{"id":"shidianguji-chongzhenyunlouzikeb","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02059473","type":"text+image","metadata":{"edition":"崇禎韻樓自刻本","version":"v2","total_page":1619,"paragraph_count":10781,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57HhpwJw":{"id":"GYL57HhpwJw","type":"work","title":"麗句集","authors":[{"name":"許之吉","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《麗句集》·六卷","author_info":"明許之吉撰","summary":"明許之吉撰。之吉爵裏未詳。其書采前人儷偶之語，或一聯或數十聯，分門編次，亦楊慎《謝華啟秀》之類。","edition":"內府藏本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1270752","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY1371","type":"text+image","metadata":{"edition":"刻本","version":"v7","total_page":958,"paragraph_count":483,"check_type":"粗校"}},{"id":"shidianguji-tianqikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02059577","type":"text+image","metadata":{"edition":"天啓刻本","version":"v3","total_page":945,"paragraph_count":7225,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57HZ55BD":{"id":"GYL57HZ55BD","type":"work","title":"四六霞肆","authors":[{"name":"何偉然","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《四六霞肆》·十六卷","author_info":"明何偉然撰","summary":"明何偉然撰，吳正炳、吳宗邵增刪。偉然有《廣快書》，已著錄。正炳字訒齋，宗邵字敬齋，並休寧人。是編采掇故實，撰為駢偶之詞。分類編次，而總注於每門之後。詞既拙俗，注尤弇陋，殆無一長之可取。","edition":"內府藏本"}],"juan_count":{"number":16},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=221487","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4335057","type":"text"}]},"GYL57HUmAtX":{"id":"GYL57HUmAtX","type":"work","title":"傭吹錄首集","authors":[{"name":"文德翼","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《傭吹錄首集》·二十卷、《次集》·二十一卷","author_info":"明文德翼撰","summary":"明文德翼撰。德翼有《宋史存》，已著錄。是書皆採集古人新巧字句，蓋沿楊慎《謝華啟秀》而廣之者。然多不著出典，時有訛誤，間作品題，亦皆儇佻之語，蓋又兼涉竟陵之習者也。","edition":"副都禦史黃登賢家藏本"}],"juan_count":{"number":20},"additional_works":[{"book_title":"次集","n_juan":21}]},"GYL57HyaZBM":{"id":"GYL57HyaZBM","type":"work","title":"古今事物原始","authors":[{"name":"徐炬","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《古今事物原始》·三十卷","author_info":"明徐炬撰","summary":"明徐炬撰。炬有《酒譜》，已著錄。是書仿《事物紀原》之體，稍附益之，而蕪雜太甚。蓋制度器數，皆可考其淵源，至日月星辰，山川草木，鳥獸蟲魚，與天地而俱生，豈能確究其始？轉輾援引，彌見糾紛。至於鳥獸、花草諸門，每類之首，或括以偶語一聯，或括以律詩二句，乃從而釋之，尤弇陋之甚矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":30}},"GYL57H7K39y":{"id":"GYL57H7K39y","type":"work","title":"五經總類","authors":[{"name":"張雲鸞","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《五經總類》·四十卷","author_info":"明張雲鸞撰","summary":"明張雲鸞撰。雲鸞字羽臣，號泰岩，無錫人。崇禎初嘗以所輯《經書講義》獻之闕下。此編複取五經及《周禮》、《孝經》之語，分門排比，共為七十二類，厘上下二集。自跋謂大要不外經濟、學術兩端，上集為經濟，下集為學術。今案其目次，以天道、地道、君德、臣德、聖學等為經濟，而以衣服、飲食、器用、宮室、草木、鳥獸等皆入之學術。未為允協。然雲鸞此書，不過為舉業之用，本不為經義立言，亦無足深論。今退置類書類中，庶核其實焉。","edition":"內府藏本"}],"juan_count":{"number":40}},"GYL57HrSjtK":{"id":"GYL57HrSjtK","type":"work","title":"事類通考","authors":[{"name":"劉葉","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《事類通考》·十卷","author_info":"明劉葉撰","summary":"明劉葉撰。葉字芝華，饒州人。是書於古今事實分類纂輯，凡七十七門。隸事而間以評論，或似劄記，或似語錄，或似對句，體例莫能名狀。觀其以年少初登第，皇都得意回十字，分標十卷之號，則其書可知也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":10}},"GYL57HESrT1":{"id":"GYL57HESrT1","type":"work","title":"古今好議論","authors":[{"name":"呂一經","role":"編","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《古今好議論》·十五卷","author_info":"明呂一經編","summary":"明呂一經編。一經字子傳，號非庵，吳縣人。崇禎辛未進士，官至河南提學副使。是書輯漢、唐以下迄於明季諸儒議論，分經學、經濟二門。經學為類二十有二，經濟為類二十有四，共五百五十六則，蓋以備場屋策論之用者也。","edition":"編修勵守謙家藏本"}],"juan_count":{"number":15},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=3055653","type":"text"},{"id":"shidianguji-chongzhenkanben","name":"识典古籍","url":"https://www.shidianguji.com/book/NA06766","type":"text+image","metadata":{"edition":"崇禎09年刊本","version":"v4","total_page":1220,"paragraph_count":913,"check_type":"粗校"}},{"id":"shidianguji-chongzhenkeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02059490","type":"text+image","metadata":{"edition":"崇禎刻本","version":"v2","total_page":963,"paragraph_count":9311,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57HRCGF1":{"id":"GYL57HRCGF1","type":"work","title":"事物考","authors":[{"name":"傅岩","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《事物考》·八卷","author_info":"明傅岩撰","summary":"明傅岩撰。岩字野清，義烏人。崇禎甲戌進士，官至監察禦史。其書大抵本高承《事物紀原》而稍為附益，兼增入明代地名、官制、禮儀，抄合成書，不免罣漏。如輿地言舜分十二州，不著其名；幽并、營商、周異制，亦無剖辨。又謂漕運為起於秦之飛輓，不知《管子》所載粟行三百里諸條，即漕運之原始，載於《通典》者甚詳。謂唐始以上柱國為勳官，不知隋制勳官已先列上柱國，唐特沿隋之舊。謂後漢改常侍曹為吏部，不知後漢只改為吏曹，至魏時始改為吏部。其舛略往往似此。唯所載明初文臣無諡，及五軍營制諸條，頗足參證明《會典》諸書之互異耳。","edition":"浙江朱彝尊家曝書亭藏本"}],"juan_count":{"number":8},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1034133","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=726751","type":"text"},{"id":"shidianguji-jiajingsishierheqimi","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02098244","type":"text+image","metadata":{"edition":"嘉靖四十二年何起鳴刻本","version":"v5","total_page":465,"paragraph_count":2092,"check_type":"AI整理"}},{"id":"shidianguji-jiajingsishierheqimi-1","name":"识典古籍","url":"https://www.shidianguji.com/book/HY7200","type":"text+image","metadata":{"edition":"嘉靖四十二年(1563)何起鳴刻本","version":"v4","total_page":486,"paragraph_count":4229,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57Hv1eXq":{"id":"GYL57Hv1eXq","type":"work","title":"策統綱目","authors":[{"name":"卓有見","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《策統綱目》·三十九卷","author_info":"明卓有見撰","summary":"明卓有見撰。有見，莆田人。其書以邱濬《大學衍義補》、湛若水《聖學格物通》二書為本，分立四門，曰經傳格言，曰史鑒證義，曰諸儒論議，曰國朝事實，頗略於古義而詳於時務。蓋亦林駉《源流至論》之類，專為射策而作者。","edition":"福建巡撫采進本"}],"juan_count":{"number":39}},"GYL57H3ekoZ":{"id":"GYL57H3ekoZ","type":"work","title":"五車韻瑞","authors":[{"name":"淩稚隆","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《五車韻瑞》·一百六十卷","author_info":"明淩稚隆撰","summary":"明淩稚隆撰。稚隆有《春秋左傳評注測義》，已著錄。是編因《韻府群玉》而稍變其體例，每韻之下，先列小篆一字，然後隨韻隸事。其排纂之序，曰經，曰史，曰子，曰集，曰雜。又以賦頌歌詩之類分體標名，綴列於後。其曰雜者，蓋仙經佛典之言。考梁阮孝緒作《七錄》，以釋道別為門目，不入子家。稚隆區而別之，猶為有說，至賦頌歌詩諸體本皆集部之文，而別立諸名，殊無義例。昔陰氏《韻府群玉》，前人病其龐雜無倫，然其時去宋未遠，多見舊本，故朱彝尊跋其書，尚以所引杜詩老去詩篇渾漫與句為足資考證。稚隆此書，名為廣所未備，而舛謬彌滋，且往往杜撰增添，非本書所有。如平淮西碑下引舊《唐史》一條，並載入千載斷碑人膾炙，不知世有段文昌二句；此二句乃宋人之語，為蔡京改撰儲祥觀碑而作，《舊唐書》實無此文。如雲別一《舊唐史》，則唐、宋以來著錄者實無此目。如斯之類，觸處皆然。又出陰氏書下，謝肇淛序乃謂《韻府群玉》為耳食，獨盛推此編，可謂曲阿所好矣。","edition":"通行本"}],"juan_count":{"number":160},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=87723","type":"text"},{"id":"shidianguji-unknown","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02059421","type":"text+image","metadata":{"edition":"未知","version":"v2","total_page":4758,"paragraph_count":44328,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57Hn3Ttj":{"id":"GYL57Hn3Ttj","type":"work","title":"文苑匯雋","authors":[{"name":"孫丕顯","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《文苑匯雋》·二十四卷","author_info":"明孫丕顯撰","summary":"明孫丕顯撰。丕顯字啟周，自稱閩人。未詳其邑裏。其書分二十九門，抄撮類書，體例殊為猥雜。","edition":"浙江巡撫采進本"}],"juan_count":{"number":24},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=3114894","type":"text"},{"id":"shidianguji-wanlisanshiliukeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02059583","type":"text+image","metadata":{"edition":"萬曆三十六年刻本","version":"v3","total_page":1129,"paragraph_count":11024,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57HdUMAo":{"id":"GYL57HdUMAo","type":"work","title":"廣韻藻","authors":[{"name":"方夏","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《廣韻藻》·六卷","author_info":"明方夏撰","summary":"明方夏撰。夏字南明，自號養春子，長洲人。是編取楊慎《韻藻》，刪其繁複，而廣其未備，然掛漏仍多。惟慎書假借均字為韻字，夏獨改從今文，立心篤實，不涉炫俗釣名之習，為寸有所長耳。","edition":"內府藏本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4156227","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY1368","type":"text+image","metadata":{"edition":"刻本","version":"v15","total_page":1086,"paragraph_count":1456,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-chongzhenshiwufangla","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02059571","type":"text+image","metadata":{"edition":"崇禎十五年方來刻本","version":"v1","total_page":1070,"paragraph_count":8733,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57HMafk3":{"id":"GYL57HMafk3","type":"work","title":"六經纂要","authors":[{"name":"顏茂猷","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《六經纂要》·","author_info":"明顏茂猷撰","summary":"明顏茂猷撰。茂猷有《迪吉錄》，已著錄。考顧炎武《日知錄》，茂猷鄉試會試皆以全作五經題取旨中式，嗣後始立五經中額。今觀此書，凡分君臣、人倫、修治三門，割剝字句，無所發明，蓋即其揣摩之本也。自序謂稽古之力，食報於諸聖人，所見亦雲淺矣。","edition":"無卷數，江蘇巡撫采進本"}]},"GYL57HJ4Swy":{"id":"GYL57HJ4Swy","type":"work","title":"名物考","authors":[{"name":"劉侗","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《名物考》·十卷","author_info":"明劉侗撰","summary":"明劉侗撰。侗有《帝京景物略》，已著錄。是書分二十三部，附物理考、通微志二篇，皆采輯類書而成。卷帙無多，搜羅甚隘，不足以供考核也。","edition":"內府藏本"}],"juan_count":{"number":10}}}