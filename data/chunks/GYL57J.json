{"GYL57JmQ7Mh":{"id":"GYL57JmQ7Mh","type":"work","title":"希姓補","authors":[{"name":"單隆周","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《希姓補》·五卷","author_info":"國朝單隆周撰","summary":"國朝單隆周撰。隆周字昌其，蕭山人。初，明楊慎撰《希姓》二卷，隆周以其尚有闕誤，撰此補之，亦仍以四聲編次，每韻先列原編，次列補人補姓以及訂誤。自唐以後，譜學失傳，訛異日增，紀載難遍。隆周是書，亦但就所見錄之，未能無所舛漏也。","edition":"內府藏本"}],"juan_count":{"number":5},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=6215229","type":"text"},{"id":"shidianguji-kangxikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02059663","type":"text+image","metadata":{"edition":"康熙刻本","version":"v2","total_page":446,"paragraph_count":3857,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57JQGnbH":{"id":"GYL57JQGnbH","type":"work","title":"汲古編","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《汲古編》·四卷","author_info":"不著撰人名氏","summary":"不著撰人名氏。其書雜抄古事，分七十三門，名目冗瑣，時代顛舛。如孔融在北海，為賊所攻，流矢雨集，矛戟內接，融憑幾安坐云云。此謂之鎮靜則可，而列之智略門中，是未見本傳下文城破融遁之事也。伊尹耕有莘之野，樂堯舜之道，三聘就湯，阿衡作相，此自名臣類中事，而列之忠烈門中，與程嬰、公孫杵臼相連，殆不可理解矣。每門之末，必留空紙數頁，蓋隨意雜抄，草創未定之本，故疏謬如是也。","edition":"江西巡撫采進本"}],"juan_count":{"number":4}},"GYL57J39Tps":{"id":"GYL57J39Tps","type":"work","title":"古史彙編","authors":[{"name":"韓孔贊","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《古史彙編》·四卷","author_info":"明韓孔贊撰","summary":"明韓孔贊撰。孔贊字羲一，裏貫未詳。是書摭諸史典故，分四十七門，起於唐虞，終於明代，大致仿《文獻通考》而敍述簡略，僅足供舉業對策之用。","edition":"浙江巡撫采進本"}],"juan_count":{"number":4}},"GYL57JtdJMd":{"id":"GYL57JtdJMd","type":"work","title":"氏族箋釋","authors":[{"name":"熊峻運","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《氏族箋釋》·八卷","author_info":"國朝熊峻運撰","summary":"國朝熊峻運撰。峻運字在湄，新建人。其書取百家姓氏，以文義別為纂次。凡四百六十八姓，每姓各綴以四六儷語，略注事狀，以備應酬尋檢之用。於氏族源流，未嘗有所考證也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":8}},"GYL57JaehZh":{"id":"GYL57JaehZh","type":"work","title":"典制紀略","authors":[{"name":"孫承澤","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《典制紀略》·","author_info":"國朝孫承澤撰","summary":"國朝孫承澤撰。承澤有《尚書集解》，已著錄。承澤熟於典故，是編廣徵博引，頗資考核。但中雖分官制、河道、漕運、鹽茶、錢鈔、禮樂諸門，而河道前後複見，禮教之後又雜入學田、刻書數條，貢舉之中又雜入趙捴謙精於六書一段，田賦之後複載錢法二則，三司使一條又不附於官職之內，顛倒龐雜，毫無次第。蓋偶得一二事，則隨筆書之，故中多空行。且間有添補之處，亦有刪汰之處，蓋未定之書，後人錄其殘稿耳。","edition":"無卷數，浙江巡撫采進本"}]},"GYL57JAKxyM":{"id":"GYL57JAKxyM","type":"work","title":"類雅","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《類雅》·二十卷","author_info":"不著撰人名氏","summary":"不著撰人名氏。中風雨類引《蠡海集》，乃明王逵撰。又鳥類引《埤雅》廣要，乃明牛衷撰，則明人作也。其書皆由抄撮而成，亦往往不詳出典。如開卷蔚藍天一條，乃陸遊《老學菴筆記》之語，而失注書名，又日禦一條雲天子有日官，諸侯有日禦，陳子昂詩還丹奔日禦，卻老餌雲芽，注曰律曆志，何史律曆志中有此語乎？其疏舛可知矣。","edition":"浙江汪啟淑家藏本"}],"juan_count":{"number":20}},"GYL57J6m4Kq":{"id":"GYL57J6m4Kq","type":"work","title":"子史匯纂","authors":[{"name":"馮廷章","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《子史匯纂》·二十四卷","author_info":"明馮廷章撰","summary":"明馮廷章撰。廷章字子建，常熟人。是書分二十四類，每類之中又別為子目，雖以子史為名，而亦兼采詞賦。自序謂一尺之箠，方寸之木，無或遺棄。又謂上極天道，下該人事，六合之內，略在其間，其自譽甚力。卷首列徵引書目千餘種，唐、宋諸志不著錄者十之六七，明以來諸家書目不著錄者十之九，廷章何自得之乎？","edition":"浙江巡撫采進本"}],"juan_count":{"number":24}},"GYL57JDtscs":{"id":"GYL57JDtscs","type":"work","title":"萬年統紀","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《萬年統紀》·十二卷","author_info":"不著撰人名氏","summary":"不著撰人名氏。所引明代諸書，皆仍其皇明之稱，則明人矣。首紀歷代帝王，不以時代為次，而以年數為先後，由初生至四萬五千六百歲止為第一卷。次紀孔子誕生至七十二歲止為第二卷。以下載歷代臣民，自初生至一千百有餘歲，釐為七卷，末載佛氏、神仙二家，各為一卷，列女為一卷。采摭頗富。然所徵引，多出小說，不足為據也。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":12}},"GYL57JeDcDD":{"id":"GYL57JeDcDD","type":"work","title":"經世篇","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《經世篇》·十二卷","author_info":"舊本題昆山顧炎武撰","summary":"舊本題昆山顧炎武撰。其書門類，悉依場屋策目，每目一篇，附以諸家雜說，頗為弇陋。蓋應科舉者抄撮類書為之，而坊賈託名於炎武也。","edition":"編修汪如藻家藏本"}],"juan_count":{"number":12}},"GYL57JTUCRD":{"id":"GYL57JTUCRD","type":"work","title":"天華山房秘藏玉杵臼","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《天華山房秘藏玉杵臼》·三卷","summary":"原本無序錄。卷首一行，題曰西湖龖赫主人吳培鼎九牧父搗。培鼎亦不知何許人。案六書精蘊，龖音遝，震怖也。二龍並飛，威靈震赫，見者氣奪。自號必取龖字，已極誕妄，其搗字之義，又因玉杵臼而附會之，更屬不經。觀卷中所載，即取《唐類函》抄撮十之二三，去其總類。又於諸細目中前後亂其部分，蓋明季書賈作偽以欺人者也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":3}},"GYL57Jhjq1H":{"id":"GYL57Jhjq1H","type":"work","title":"考古類編","authors":[{"name":"柴紹炳","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《考古類編》·十二卷","author_info":"國朝柴紹炳撰","summary":"國朝柴紹炳撰。紹炳有《古韻通》，已著錄。是書分三十三門，凡有關於典章制度者，皆摘其指要，貫串成篇。自序謂取便童蒙，比於《小學紺珠》之類，蓋為舉業後場設也。原名《通考纂要》，雍正甲辰，華亭姚培謙為之評注，改題今名。","edition":"通行本"}],"juan_count":{"number":12}},"GYL57JM5NmM":{"id":"GYL57JM5NmM","type":"work","title":"大政管窺","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《大政管窺》·四卷","author_info":"不著撰人名氏，皆科舉之策略也","summary":"不著撰人名氏，皆科舉之策略也。分敘吏、敘戶、敘禮、敘經，六曹舉其三，而四部舉其一。體例無所取義，必非完書，蓋經生家偶存之殘稿耳。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":4},"resources":[{"id":"shidianguji-chaoben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02059642","type":"text+image","metadata":{"edition":"鈔本","version":"v3","total_page":1327,"paragraph_count":11644,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57JxEtrb":{"id":"GYL57JxEtrb","type":"work","title":"歷朝人物氏族會編","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《歷朝人物氏族會編》·十卷","author_info":"舊本題曰禾川南裏松山逸叟穎侯氏撰","summary":"舊本題曰禾川南裏松山逸叟穎侯氏撰。不著名姓。檢卷首名字二印，一曰尹敏，一曰穎侯，知此書即尹敏作。書中多載明末殉節諸臣，知為國初人，其始末則未之詳也。其書以《重編百家姓》孔師東魯、孟席齊梁諸句為綱，而雜引歷代人物列其下，然舛謬百出。如孔氏條雲，出宋郯子之後，師氏條雲師曠晉樂師，孟氏條雲孟蔑字獻子，如斯之類，觸目皆是，殊不足據為典要也。","edition":"江西巡撫采進本"}],"juan_count":{"number":10}},"GYL57JXBAd5":{"id":"GYL57JXBAd5","type":"work","title":"類姓登科考","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《類姓登科考》·六卷","author_info":"不著撰人名氏，亦無序跋","summary":"不著撰人名氏，亦無序跋。其書取明一代登進士者以姓類從，而各注鄉貫科分甲第於名下。其仕宦顯達者，並注其官階爵諡，或一家世膺是選者則注曰某為某子，某為某孫，某為某之兄弟。紀載頗為詳賅。所注下逮崇禎之末，則國朝人編也。考《唐書·藝文志》有崔氏《顯慶登科記》五卷，姚康《科第錄》十六卷，李奕《登科錄》二卷。晁公武《讀書志》載《樂史》采唐武德迄天祐進士及諸科登名者為《登科記》三十卷。陳振孫《書錄解題》又載洪適《唐登科記》十五卷。是書詳列科名，蓋猶古例。又唐林罕《元和姓纂》以四聲分編，宋謝維新《合璧事類》所列諸姓故實，則以鄉塾所誦之百家姓趙、錢、孫、李諸字為綱，此本蓋用維新之例。其百家姓所不載者，則附錄第六卷末焉。","edition":"浙江巡撫采進本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4420191","type":"text"},{"id":"shidianguji-chaoben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02059646","type":"text+image","metadata":{"edition":"鈔本","version":"v1","total_page":1431,"paragraph_count":13493,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57JHTnGP":{"id":"GYL57JHTnGP","type":"work","title":"對類","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《對類》·二十卷","author_info":"不著撰人名氏，亦不詳時代","summary":"不著撰人名氏，亦不詳時代。凡二十門，蓋村塾課蒙之本。驗其格式，猶明中葉所刊也。","edition":"兩江總督采進本"}],"juan_count":{"number":20},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=72177","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=2143977","type":"text"},{"id":"shidianguji-mingneifujingchangka","name":"识典古籍","url":"https://www.shidianguji.com/book/SDZJ0234","type":"text+image","metadata":{"edition":"明内府经厂刊本","version":"v14","total_page":1082,"paragraph_count":6980,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY7221","type":"text+image","metadata":{"edition":"刻本","version":"v5","total_page":1684,"paragraph_count":16668,"check_type":"AI整理"}},{"id":"shidianguji-zhengtongshiersiliji","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02059632","type":"text+image","metadata":{"edition":"正統十二年司禮監刻本","version":"v2","total_page":1007,"paragraph_count":11485,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57Jpy21D":{"id":"GYL57Jpy21D","type":"work","title":"廣群輔錄","authors":[{"name":"徐汾","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《廣群輔錄》·六卷","author_info":"國朝徐汾撰","summary":"國朝徐汾撰。汾字武令，錢塘人。是書補陶潛《聖賢群輔錄》之闕，自西晉以前，陶氏所遺者補之，自東晉以迄明代則續之。案《群輔錄》託名陶潛，實為偽本，原書既不足據，續編亦病繁蕪，至所載明代七才子、十才子之類，皆末流標榜之目，尤為冗濫。王晫《今世說》載汾喜著書，苦無由得錢易楮翰，常於破幾上起草，束麻濡煤作字。其編摩可謂苦心，書則未為善本也。","edition":"浙江鮑士恭家藏本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=2567199","type":"text"},{"id":"shidianguji-kangxijiukeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02059668","type":"text+image","metadata":{"edition":"康熙九年刻本","version":"v5","total_page":234,"paragraph_count":1438,"check_type":"AI整理"}}],"has_text":true,"has_image":true}}