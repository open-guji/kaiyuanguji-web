{"GYL57KCeb11":{"id":"GYL57KCeb11","type":"work","title":"三才彙編","authors":[{"name":"龔在升","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《三才彙編》·四卷","author_info":"國朝龔在升撰","summary":"國朝龔在升撰。在升字聞，嘉善人。順治己亥進士，官蘇州府推官。是書分類編纂，為科舉對策之用。間附議論，如郊社主合祀，樂律用李文利之說，皆非確論也。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":4},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1346463","type":"text"},{"id":"shidianguji-kangxiwumaoshijiguge","name":"识典古籍","url":"https://www.shidianguji.com/book/HY7251","type":"text+image","metadata":{"edition":"康熙五年(1666)毛氏汲古閣刻本","version":"v4","total_page":712,"paragraph_count":6294,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57KPMJwZ":{"id":"GYL57KPMJwZ","type":"work","title":"姓氏譜","authors":[{"name":"李繩遠","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《姓氏譜》·六卷","author_info":"國朝李繩遠撰","summary":"國朝李繩遠撰。繩遠字斯年，嘉興人。其書雜抄《萬姓統譜》而成，舛漏頗甚。疑其錄以備用，本非欲著書也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":6}},"GYL57KpWQsy":{"id":"GYL57KpWQsy","type":"work","title":"石樓臆編","authors":[{"name":"周綸","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《石樓臆編》·五卷","author_info":"國朝周綸撰","summary":"國朝周綸撰。綸字膺垂，松江華亭人。康熙中官國子監學正。是書分吏、戶、禮、兵、刑、工六門，中立五十九目。自漢、唐迄於本朝凡關六曹政事者，俱類紀之，於國初以來章疏案牘，亦頗有所徵引。大旨以為場屋對策之用，然書生局於裏閈，凡官府故事，未能明習。掛漏殊多，不足盡資考校也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":5},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=3033204","type":"text"},{"id":"shidianguji-kangxikeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02059806","type":"text+image","metadata":{"edition":"康熙刻本","version":"v3","total_page":777,"paragraph_count":6700,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57K1ooW7":{"id":"GYL57K1ooW7","type":"work","title":"二酉匯刪","authors":[{"name":"王訓","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《二酉匯刪》·二十四卷","author_info":"國朝王訓撰","summary":"國朝王訓撰。訓字敷彝，安邱人。順治丁亥進士。是書分十六門，一百七十子目，大為科舉答策而設。有采自本書者，亦有轉相稗販，迷其出典者，如敬廩篇中關龍逢冕危石履春冰語，本出自《苻子》，乃漏去關字，但稱龍逢曰，似一人姓龍名逢，而所注書名乃作《諫桀》二字，又似龍逢所著之書名曰《諫桀》也。知其抄撮類書，非根柢之學矣。","edition":"山東巡撫采進本"}],"juan_count":{"number":24},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4786410","type":"text"},{"id":"shidianguji-unknown","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02059679","type":"text+image","metadata":{"edition":"未知","version":"v3","total_page":1192,"paragraph_count":14490,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57KhNbaw":{"id":"GYL57KhNbaw","type":"work","title":"古事苑","authors":[{"name":"鄧志謨","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《古事苑》·十二卷","author_info":"國朝鄧志謨撰","summary":"國朝鄧志謨撰。志謨字景南，饒安人。是書成於康熙丙寅。捃摭古事，裁為儷偶，凡六十篇，其注釋則各附篇末。大致欲仿吳淑《事類賦》，而不能諧以聲韻，貫以脈絡，遂各為無首無尾，不相聯貫之四六雲。","edition":"內府藏本"}],"juan_count":{"number":12},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=536558","type":"text","details":"鄧志謨、戴珉"}]},"GYL57KT1bHy":{"id":"GYL57KT1bHy","type":"work","title":"李氏類纂","authors":[{"name":"李繩遠","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《李氏類纂》·五十卷","author_info":"國朝李繩遠撰","summary":"國朝李繩遠撰。是編蓋偶抄諸家類書，以備自用。故職官首宗人府，用今制也，而雲國朝置大宗正院。改宗人府宗人令一人，乃前朝故事，而以為國朝。此沿襲抄錄，而事同未去葛龔者矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":50}},"GYL57KdogwR":{"id":"GYL57KdogwR","type":"work","title":"同姓名錄","authors":[{"name":"王廷燦","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《同姓名錄》·八卷","author_info":"國朝王廷燦撰","summary":"國朝王廷燦撰。廷燦，錢塘人。康熙辛酉舉人。官崇明縣知縣。是書蓋因梁元帝及明太常寺卿餘寅兩《同姓名錄》而廣之。寅書止於金、元，廷燦則兼及明代。然如甯都魏禧，至康熙己未尚薦舉博學鴻詞，而取與崇禎末年之魏沖相配，題曰兩魏叔子，則取州縣戶籍而閱之，同姓名者萬人可得，何止此八卷乎？又卷三全抄梁元帝書，卷五亦全抄餘寅書，又何貴乎屋下屋也。","edition":"浙江鮑士恭家藏本"}],"books":["CXVzxkY3zRm"],"juan_count":{"number":8},"resources":[{"id":"shidianguji-sikuquanshuben","name":"识典古籍","url":"https://www.shidianguji.com/book/SK1993","type":"text+image","metadata":{"edition":"四庫全書本","version":"v4","total_page":1322,"paragraph_count":4774,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL57KKnQJ3":{"id":"GYL57KKnQJ3","type":"work","title":"教養全書","authors":[{"name":"應捴謙","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《教養全書》·四十一卷","author_info":"國朝應捴謙撰","summary":"國朝應捴謙撰。捴謙有《周易集解》，已著錄。是書分選舉、學校、治官、田賦、水利、國計、漕運、治河、師役、鹽法十考，節引史文，而取前人評論各參其下，體例略仿《文獻通考》，於明代事實，所載尤詳。捴謙間附斷語，議論亦多醇正。然以視馬端臨之精博，則猶未能遽相方駕矣。其中不載律算者，以徐光啟已有成書；不載輿地者，以顧炎武、顧祖禹二人方事纂輯故也。","edition":"浙江汪啟淑家藏本"}],"juan_count":{"number":41},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=8614905","type":"text"},{"id":"shidianguji-jiuchaoben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02059736","type":"text+image","metadata":{"edition":"舊鈔本","version":"v6","total_page":2494,"paragraph_count":22901,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57Kt5KXV":{"id":"GYL57Kt5KXV","type":"work","title":"五經類編","authors":[{"name":"周世樟","role":"編","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《五經類編》·二十八卷","author_info":"國朝周世樟編","summary":"國朝周世樟編。世樟字章成，太倉人。是編摘取五經之語，分為十門，每門又分子目，皆以備時文之用。末附諸經略說、經義辨訛、辨疑各數條，亦皆無關考證。","edition":"通行本"}],"juan_count":{"number":28},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=8208516","type":"text"},{"id":"shidianguji-unknown","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02059810","type":"text+image","metadata":{"edition":"未知","version":"v3","total_page":1708,"paragraph_count":14041,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57Kwgv2T":{"id":"GYL57Kwgv2T","type":"work","title":"同人傳","authors":[{"name":"陳祥裔","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《同人傳》·四卷","author_info":"國朝陳祥裔撰","summary":"國朝陳祥裔撰。祥裔有《蜀都碎事》，已著錄。是書自秦、漢以迄元、明，凡同姓名者，採集成冊，末附父子同名字者數人，采摭頗詳，去取亦頗矜慎。如《太平廣記》中再生之王翰，與唐詩人王翰相同，《通幽記》神婚之李伯禽，與李白子伯禽相類，事既不經，人無可考，今概不錄，知非漫無別擇，愛奇嗜瑣者也。惟皆不著所出，是其一短耳。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":4}},"GYL57KXKVaf":{"id":"GYL57KXKVaf","type":"work","title":"韻粹","authors":[{"name":"朱彝尊","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《韻粹》·一百七卷","author_info":"舊本題國朝朱彝尊撰","summary":"舊本題國朝朱彝尊撰。彝尊有《經義考》，已著錄。是書采古人新穎之語，分韻編次，韻為一卷，所摭不為不富。然惟摭詞賦，而不及經史。其詞賦引據他書者，亦即以詞賦為出典，其病與蘇頌《文選雙字類要》略同。彝尊學有本原，著述最富，不應為此餖飣之學，其生平文字內未嘗言及此書，書中時有闕行闕字，亦似未完之本。疑為摭拾私記以備詞賦之用，後人重其淹博，轉相傳寫，遂漸至於流布耳。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":107}},"GYL57KkwWET":{"id":"GYL57KkwWET","type":"work","title":"行年錄","authors":[{"name":"魏方泰","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《行年錄》·","author_info":"國朝魏方泰撰","summary":"國朝魏方泰撰。方泰字日乾，號魯峰，江西廣昌人。康熙癸未進士，官至禮部右侍郎，翰林院學士。是書取古人事蹟有年可紀者，各以其年編之，每一歲為一篇。其但有幾十歲字而不得其畸零之數者則各立幾十餘一篇，其並無幾十字可考者，則分立初生、童幼、少壯、老年四篇，而冠以各朝曆及制令，附以生辰同生，學生、遺腹、前後身四篇。原本不分卷數，亦無目錄，次第頗為顛倒。如凡例稱冠以各朝曆，而此本以前後身為冠，知非方泰之舊矣。所列儒異兼陳，不免稍失於雜。又隨所見聞即據其書載人，不復究其本源，亦稍失之疏略。","edition":"無卷數，禮部尚書曹秀先家藏本"}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7695894","type":"text"},{"id":"shidianguji-qianlongshiqijiakebe","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02059771","type":"text+image","metadata":{"edition":"乾隆十七年家刻本","version":"v6","total_page":3938,"paragraph_count":38219,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57K5Ni9d":{"id":"GYL57K5Ni9d","type":"work","title":"古今疏","authors":[{"name":"朱虛","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《古今疏》·十五卷","author_info":"國朝朱虛撰","summary":"國朝朱虛撰。虛字邵齋，號可菴，又號介庵，曹州人。順治丁亥進士。官至紹興府知府。其書仿《廣雅》、《釋名》之例，自天地日月至蟲魚草木，各自為篇，加以解釋。但徵引浩繁，不詳所出。使舊文新義，無自而分，縱有依託，末由考證。是則抄撮著書之通病也。","edition":"內府藏本"}],"juan_count":{"number":15},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=2391051","type":"text"},{"id":"shidianguji-shunzhiwanjuanloukeb","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02059693","type":"text+image","metadata":{"edition":"順治萬卷樓刻本","version":"v2","total_page":1277,"paragraph_count":11732,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57KatQEB":{"id":"GYL57KatQEB","type":"work","title":"宮閨小名錄","authors":[{"name":"尤侗","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《宮閨小名錄》·四卷，《後錄》·一卷","author_info":"國朝尤侗撰","summary":"國朝尤侗撰。侗有《明史·藝文志》，已著錄。是編補陸龜蒙、洪適、王銍、溫豫、張邦幾諸錄之遺，上起於漢，下迄於明，凡女子以名傳者，皆分類編載。一曰後妃，附以公主、外戚。二曰列女，附以妓妾之有節行者。三曰妾婢，附以雜類。四曰妓女，五曰外傳，附以寇盜。六曰仙鬼，附以劍俠。每類又有補遺。其補錄未盡者，閩縣余懷又續為後錄一卷，侗並跋而刻之。其舊錄所已有者，亦列其名而不著事蹟，注曰已見。其蒐采頗勤，然侗本摛華掞藻，以詞賦為工，懷亦選伎徵歌，以風流自命，考證之學，皆非所長。如明代宮人瓊蓮媚蘭之類皆收，而王滿堂、楊金英之類名在國史乃遺之，據杜甫詩收其婢阿稽，而劉整之婢綠草載於《文選》乃遺之，據魏文帝詩收劉勳妻王宋，據元稹詩收其女小迎，而焦仲卿妻蘭芝，葛沙門妻郭小玉，左思女紈素、蕙芳並見《玉台新詠》乃遺之。至李波小妹歌之雍容、東飛伯勞歌之莫愁、喬知之詩之窈娘、李白詩之女平陽伎金陵子、李商隱詩之柳枝、杜牧詩之定子、白居易詩之都子、元稹詩之念奴、秦觀詩之邊朝華、晏殊詩之劉蘇哥、歐陽修詩之嬌兒以及裴度之黃娥、司空圖之鸞台，失之眉睫之前者尤不可勝舉。他如唐李冶乃女道士，元薛蘭英、蕙英乃富民之女，有《聯芳集》，而列之妓女之中；石崇妾綠珠見於本傳，竇滔妾趙陽臺見於《璿璣圖序》，而乃不入之婢妾。則門目顛倒，紫雲一人，既入仙鬼，又入補遺。隔六頁而兩見；趙娟一人，既附王韞秀，又別為一條，越一卷而重出；則排纂多疏。以錦瑟為令狐楚之青衣，猶據《劉攽詩話》；至於段文昌家之膳祖，猶夜來之稱針神；鮑生之四弦，猶蘇軾之胡琴婢；皆以藝稱，非其名字。一概列入，乖謬殊深。甚至同時婦女，連篇累牘，益無體例矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":4},"additional_works":[{"book_title":"後錄","n_juan":1}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=788581","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=677718","type":"text"},{"id":"shidianguji-qianlongsishijiuzhan","name":"识典古籍","url":"https://www.shidianguji.com/book/HY2452","type":"text+image","metadata":{"edition":"乾隆四十九年(1784)長洲尤氏刻本","version":"v14","total_page":280,"paragraph_count":90,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-kangxiershijiukeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02059759","type":"text+image","metadata":{"edition":"康熙二十九年刻本","version":"v4","total_page":279,"paragraph_count":954,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL57KGAoo5":{"id":"GYL57KGAoo5","type":"work","title":"千家姓文","authors":[{"name":"崔冕","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《千家姓文》·一卷","author_info":"國朝崔冕撰","summary":"國朝崔冕撰。冕字貢收，巢縣人。是編以村塾所傳《百家姓》語無文義，因就史傳詳加繙閱，得複姓三十四，單姓九百七十二，計千餘六姓，聯屬其文。較原書為雅馴然，不及王應麟《姓氏急就篇》典核有據也。前有康熙癸卯冕自序。又有如皋冒國柱序。其注即國柱所作，皆但雲某代有某人，而不著所出，亦無徵不信矣。","edition":"兩江總督采進本"}],"juan_count":{"number":1}},"GYL57K92zW3":{"id":"GYL57K92zW3","type":"work","title":"三才藻異","authors":[{"name":"屠粹忠","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《三才藻異》·三十三卷","author_info":"國朝屠粹忠撰","summary":"國朝屠粹忠撰。粹忠號芝岩，定海人。順治戊戌進士，官至兵部尚書。是編取故實可備題詠者，分類標題，其目盈萬，各括以四言二韻，蓋類書之支流，而《蒙求》之變體也。然襞績成文，繁蕪無當。自序謂曆二十四載而成，亦勞而無補矣。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":33},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=8880843","type":"text"},{"id":"shidianguji-kangxiershibaxuxuyua","name":"识典古籍","url":"https://www.shidianguji.com/book/HY7250","type":"text+image","metadata":{"edition":"康熙二十八年(1689)栩栩園刻本","version":"v9","total_page":2924,"paragraph_count":25425,"check_type":"AI整理"}}],"has_text":true,"has_image":true}}