{"GYL57LvdNpP":{"id":"GYL57LvdNpP","type":"work","title":"經濟宏詞","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《經濟宏詞》·十二卷","author_info":"是書前有凡例，題汪學信四如父編次，卷首又題新安太易父汪以時選輯","summary":"是書前有凡例，題汪學信四如父編次，卷首又題新安太易父汪以時選輯。無序無跋，未審果出誰手。凡分十二門，皆明人之文，可以為場屋答策之用者，其凡例亦自稱取便制舉業雲。","edition":"浙江巡撫采進本"}],"juan_count":{"number":12}},"GYL57L4v72P":{"id":"GYL57L4v72P","type":"work","title":"政典彙編","authors":[{"name":"王芝藻","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《政典彙編》·八卷","author_info":"國朝王芝藻撰","summary":"國朝王芝藻撰。芝藻有《大易疏義》，已著錄。是書以天下之事統於六曹，自周官始，後世或因或革，總不出其範圍。因分曹排纂古事，刪繁提要，隨事附以論斷。其所取材，大抵《通典》、《通考》二書為多，而元、明之事則多采自王圻《續通考》及邱濬《大學衍義補》雲。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":8}},"GYL57LSWJKH":{"id":"GYL57LSWJKH","type":"work","title":"考古略","authors":[{"name":"王文清","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《考古略》·八卷","author_info":"國朝王文清撰","summary":"國朝王文清撰。文清有《周禮會要》，已著錄。文清初著有《考古源流》四百七十五卷，乃匯采《三通》、《玉海》、《冊府元龜》、《通鑒綱目》、《大事紀》、《學海津逮》、《性理》諸書而成，未及刊佈。此本乃先摘其淺近切要者，輯以成編，故名曰略。","edition":"湖南巡撫采進本"}],"juan_count":{"number":8}},"GYL57LFoaNj":{"id":"GYL57LFoaNj","type":"work","title":"根黃集","authors":[{"name":"楊文源","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《根黃集》·十卷","author_info":"國朝楊文源撰","summary":"國朝楊文源撰。文源，長泰人。是書以三禮之文，割裂排纂，分律呂、封建、井田、學校、祭祀為五門，每門之中又各為子目。其曰根黃者，取黃鍾為萬事根本意也。卷前則敬錄聖祖禦制黃鍾為萬事根本說一篇，與朱子請修三禮劄子一首，以志編輯所自。其訓釋辨論，一以欽定義疏為折衷，間亦附以己見。其凡例雲，仿朱子《儀禮經傳通解》，然書中所錄，多與四子書典故相發明，仍不過舉業津梁而已。故今列之類書類焉。","edition":"福建巡撫采進本"}],"juan_count":{"number":10}},"GYL57LKNV2F":{"id":"GYL57LKNV2F","type":"work","title":"三體摭韻","authors":[{"name":"朱昆田","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《三體摭韻》·十二卷","author_info":"國朝朱昆田撰","summary":"國朝朱昆田撰。昆田字西畯，秀水人，彝尊子也。承其家學，亦以博涉為功。是編仿陰氏《韻府》之例，采前人新豔字句，排纂成編，所錄至元而止，惟取騷賦詩三體，故以為名。捃拾頗為繁富，然詞人琢語，莩甲新意者十之一，鎔鑄舊文者十之九，未可一字一句據為根底。即以一東韻而論，阿童為王濬小字，見《三國志》注，乃雲出蘇軾詩。鶴氃氋而不舞乃羊祜事，見《世說新語》，乃雲本陸龜蒙詩。此猶雲惟引詞賦，不及子史也。至於椒風殿名見《兩都賦》，乃引崔國輔詩。唐弓字見庾信《三月三日華林園馬射賦序》，乃引賀知章詩。比紅兒自有羅虯本詩，乃引陸遊詩，是即詞賦之中已舍前取後。他如已引古詩之魚戲蓮葉東，又引岑德詩之蓮東自可戲，別出蓮東一條，已引衛象詩之鵲血琱弓濕未乾，又引梅堯臣詩之休調鵲血弓，別出鵲血弓一條，更繁複少緒。至梁簡文帝詩之劍飾丹陽銅，字本從金，乃訛收於桐字下。則校讎亦未精矣。蓋草創未定之本。後人以其名父之子，遂錄傳之，不知反為昆田累也。","edition":"浙江朱彝尊家曝書亭藏本"}],"juan_count":{"number":12},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=60683","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=3749574","type":"text"}]},"GYL57L1JWXR":{"id":"GYL57L1JWXR","type":"work","title":"古事比","authors":[{"name":"方中德","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《古事比》·五十三卷","author_info":"國朝方中德撰","summary":"國朝方中德撰。中德字用伯，桐城人。其書以古事之相類者，排比成編。然徵引雖博，掛漏實多。如父子一門中，分世業、世經術為二。以世業屬之隨會士匄、王羲之、獻之，以經術屬之韋賢、劉向父子，古今豈僅此一二家耶？蓋四部之書，浩如煙海，軼聞瑣記，僕數難窮，欲以數十卷書，一一比類而合之，不免自為其難，宜其顧此失彼耳。","edition":"浙江巡撫采進本"}],"juan_count":{"number":53},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7883574","type":"text"},{"id":"shidianguji-kangxisishiwusuishan","name":"识典古籍","url":"https://www.shidianguji.com/book/HY1586","type":"text+image","metadata":{"edition":"康熙四十五年(1706)邃上居刻本","version":"v11","total_page":3361,"paragraph_count":25384,"check_type":"AI整理"}},{"id":"shidianguji-kangxisishiwushuzhon","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02059827","type":"text+image","metadata":{"edition":"康熙四十五年書種齋刻本","version":"v3","total_page":3253,"paragraph_count":27758,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57LhhfxK":{"id":"GYL57LhhfxK","type":"work","title":"古今記林","authors":[{"name":"汪士漢","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《古今記林》·二十九卷","author_info":"國朝汪士漢撰","summary":"國朝汪士漢撰。士漢有《秘書》二十一種，已著錄。是書分二十七類，自正史以迄百家，隨筆摘錄。自謂義例有二，一紀淑慝以示勸戒，一蒐瑰琦以資見聞。然大約從類書中抄撮而成。","edition":"安徽巡撫采進本"}],"juan_count":{"number":29},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7045398","type":"text"},{"id":"shidianguji-qianlongwujurentangk","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02059896","type":"text+image","metadata":{"edition":"乾隆五年居仁堂刻本","version":"v5","total_page":1433,"paragraph_count":12445,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57Ln1aF1":{"id":"GYL57Ln1aF1","type":"work","title":"古學捷錄","authors":[{"name":"陳應麐","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《古學捷錄》·十卷","author_info":"國朝陳應麐撰","summary":"國朝陳應麐撰。應麐原名應明，字縉英，莆田人。其書為科舉答策而作，凡十篇，每篇各有子目。所采皆明人類書，殊多舛誤。","edition":"安徽巡撫采進本"}],"juan_count":{"number":10}},"GYL57LzyxxX":{"id":"GYL57LzyxxX","type":"work","title":"唐句分韻初集","authors":[{"name":"馬瀚","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《唐句分韻初集》·四卷、《二集》·四卷、《續集》·二卷、《四集》·五卷","author_info":"國朝馬瀚撰","summary":"國朝馬瀚撰。瀚字炎洲，順天人。其書以唐人詩句分一百七韻，編次以為集句之用。《初集》、《二集》兼取五言、七言，《續集》、《四集》則惟取七言。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":4},"additional_works":[{"book_title":"二集","n_juan":4},{"book_title":"續集","n_juan":2},{"book_title":"四集","n_juan":5}]},"GYL57LW7tpF":{"id":"GYL57LW7tpF","type":"work","title":"考古原始","authors":[{"name":"王文清","role":"編","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《考古原始》·六卷","author_info":"國朝王文清編","summary":"國朝王文清編。初，明嘉靖中，桐城趙釴撰《古今原始》十四卷，以歷代帝王編年紀載，各著其事所自始。文清以趙書原本自天皇氏至陰康氏荒渺無稽，為之刊削，依聖經斷自伏羲，並補正訛闕，訖明神宗而止。考世本多載事始，其書久佚，馮贄事始亦無傳本。文清此書，餖飣牽合，亦與趙氏書相等。又不著出典，益不足徵。至卷末補遺各條，尤如兔園冊子。文清嘗纂《考古略》一書，其凡例中自敍生平所著述，不及是書，殆坊賈所託名也。","edition":"湖南巡撫采進本"}],"juan_count":{"number":6},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=1448937","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02059889","type":"text+image","metadata":{"edition":"刻本","version":"v2","total_page":334,"paragraph_count":3458,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57LaXAoq":{"id":"GYL57LaXAoq","type":"work","title":"春秋經傳類聯","authors":[{"name":"王繩曾","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《春秋經傳類聯》·","author_info":"國朝王繩曾撰","summary":"國朝王繩曾撰。繩曾字武沂，無錫人。雍正庚戌進士，官揚州府教授。是書取春秋經傳之詞，稍加點竄鎔鑄，集為對偶，凡三十四類。自序有曰，宋徐晉卿《春秋類對賦》，拘於聲韻，選詞難工，事弗類從，猶如野戰，乃猶列入經解，得與諸家炳如列星，並垂不朽。茲編分類彙集，聯為駢體，以便記誦。寧律不諧，不使句弱；甯句不工，毋使語俗。開府之長，庶幾有取乎？其自命甚高。所稱開府之長，殆以倪璠注《庾信集》稱其善用《左傳》歟。然晉卿何足道，而殫竭心力爭此不足重輕之短長，是亦可已不已矣。","edition":"無卷數，浙江巡撫采進本"}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=741552","type":"text"},{"id":"shidianguji-yongzhengshierduosui","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02059892","type":"text+image","metadata":{"edition":"雍正十二年多歲草堂刻本","version":"v2","total_page":142,"paragraph_count":1009,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57LrKUXh":{"id":"GYL57LrKUXh","type":"work","title":"讀古紀源","authors":[{"name":"何懋永","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《讀古紀源》·九卷","author_info":"國朝何懋永撰","summary":"國朝何懋永撰。懋永字念修，山陰人。其書分為二編，一曰三才緯略，一曰六官綜制。共分為九考。皆抄撮類書，非根柢之學。","edition":"山東巡撫采進本"}],"juan_count":{"number":9}},"GYL57L8XhXM":{"id":"GYL57L8XhXM","type":"work","title":"典引輯要","authors":[{"name":"丁昌遂","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《典引輯要》·十八卷","author_info":"國朝丁昌遂撰","summary":"國朝丁昌遂撰。昌遂字秀崖，懷寧人。是書成於康熙庚寅，雜采舊文，各隱括大略而分類編之。其凡例謂制藝一道，固發自性靈，間亦取證於古典。是編所輯，足供舉業家之考證。其宗旨如是，書可知矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":18}},"GYL57LC9J2K":{"id":"GYL57LC9J2K","type":"work","title":"廣事類賦","authors":[{"name":"華希閔","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《廣事類賦》·四十卷","author_info":"國朝華希閔撰","summary":"國朝華希閔撰。希閔字豫原，無錫人，康熙庚子舉人。希閔因校刻吳淑《事類賦》，病其未備，乃廣為此編，附刻其後，凡二十七門，一百九十一子目，亦如淑例自注，然終不逮淑書也。","edition":"內府藏本"}],"juan_count":{"number":40},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=632088","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=6516072","type":"text"},{"id":"shidianguji-unknown","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02059862","type":"text+image","metadata":{"edition":"未知","version":"v4","total_page":1177,"paragraph_count":12634,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57LNwPfm":{"id":"GYL57LNwPfm","type":"work","title":"文獻通考節貫","authors":[{"name":"周宗濂","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《文獻通考節貫》·十卷","author_info":"國朝周宗濂撰","summary":"國朝周宗濂撰。宗濂有《恥亭遺書》，已著錄。是書取馬端臨《文獻通考》、王圻《續通考》首尾編次，仍如二十四門之舊。惟帝系象緯、物異、四裔、節義、方外六門，以難於節錄置之，其因文附見者，如戶口考之奴婢占役，學校考之祠祭褒贈諸條，亦多刊削。蓋意主便於記誦，為場屋對策之用。固不能以著書體例繩之耳。","edition":"江蘇周厚堉家藏本"}],"juan_count":{"number":10},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=6720462","type":"text"},{"id":"shidianguji-qianlongshiwuzhuyouc","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02059875","type":"text+image","metadata":{"edition":"乾隆十五年竹友草堂刻本","version":"v3","total_page":473,"paragraph_count":3291,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57Le8mJo":{"id":"GYL57Le8mJo","type":"work","title":"杜韓集韻","authors":[{"name":"汪文柏","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《杜韓集韻》·三卷","author_info":"國朝汪文柏撰","summary":"國朝汪文柏撰。文柏字秀青，號柯庭，嘉興人。官兵馬司指揮。其書取杜、韓二家詩句，案今韻摘出，編於字下，以為吟詠者取資。每卷各分上、中、下。凡杜、韓所未押者，則存其韻於部尾。所摘之句，不著原題。蓋宋人《十二先生詩宗》之類也。","edition":"編修汪如藻家藏本"}],"juan_count":{"number":3}}}