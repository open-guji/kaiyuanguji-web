{"GYL57b97Euu":{"id":"GYL57b97Euu","type":"work","title":"過庭紀餘","authors":[{"name":"陶越","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《過庭紀餘》•三卷","author_info":"國朝陶越撰","summary":"國朝陶越撰。越字艾村，秀水人。是書乃雜綴聞見瑣事。以多聞之其父口述，故以過庭為名。間有《志乘》所遺佚，足裨考核者，而大抵過涉冗碎。又所載生平遊幕事蹟，亦未免近於自誇。","comment":"──右“小說家類”雜事之屬，一百一部，四百七十五卷，內七部無卷數，皆附《存目》。","edition":"編修汪如藻家藏本"}],"juan_count":{"number":3},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=6588033","type":"text"},{"id":"shidianguji-chaoben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02060141","type":"text+image","metadata":{"edition":"鈔本","version":"v1","total_page":186,"paragraph_count":1651,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57bPWw4K":{"id":"GYL57bPWw4K","type":"work","title":"龍城錄","authors":[{"name":"柳宗元","role":"撰","dynasty":"唐"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《龍城錄》·二卷","author_info":"舊本題唐柳宗元撰","summary":"舊本題唐柳宗元撰。宋葛嶠始編之柳集中，然《唐·藝文志》不著錄。何薳《春渚紀聞》以為王銍所偽作。《朱子語錄》亦曰：柳文後龍城錄雜記，王銍之為也。子厚敍事文字，多少筆力，此記衰弱之甚，皆寓古人詩文中不可知者於其中，似暗影出。今觀錄中所載帝命取書事，似為韓愈調張籍詩天官遣六丁，雷電下取將二句作解。趙師雄羅浮夢事，似為蘇軾梅花詩月下縞衣來扣門作解。朱子所論，深得其情。莊季裕作《雞肋編》，乃引此錄駁《金華圖經》。季裕與銍為同時人，或其書初出，偽跡未露，故不暇致詳歟？然自南宋以來，詞賦家已沿為故實，不可複廢。是亦王充所謂俗語不實，流為丹青者矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":2},"related_works":[{"id":"GYL583Xk5g3","title":"五百家注音辨柳先生文集","relation":"part_of"}],"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/龍城錄","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=177407","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY6816","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":24,"paragraph_count":28,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL57b1Bk8F":{"id":"GYL57b1Bk8F","type":"work","title":"硯北叢錄","authors":[{"name":"黃叔琳","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《硯北叢錄》•","author_info":"國朝黃叔琳撰","summary":"國朝黃叔琳撰。叔琳有《研北易抄》，已著錄。是編卷首有魏兆龍序，稱為叔琳巡撫浙江時罷官以後所偶錄。皆雜采唐、宋、元明及近時說部，亦益以耳目所聞見。大抵多文人嘲戲之詞，如《諧史》、《笑林》之類。或著出處，或不著出處，為例不一，亦未分卷帙。蓋憂患之中藉以遣日而已，意不在於著書也。","edition":"無卷數，編修勵守謙家藏本"}]},"GYL57bGLRuq":{"id":"GYL57bGLRuq","type":"work","title":"幽怪錄","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《幽怪錄》·一卷、《續幽怪錄》·一卷","author_info":"《幽怪錄》，唐牛僧孺撰","summary":"《幽怪錄》，唐牛僧孺撰。僧儒事蹟具《新唐書》本傳。《唐書·藝文志》作《玄怪錄》。朱國楨《湧幢小品》，曰：牛僧孺撰《玄怪錄》，楊用修改為《幽怪錄》。因世廟時重玄字，用修不敢不避。其實一書，非刻之誤也。然《宋史·藝文志》載李德裕《幽怪錄》十四卷，則此名為複矣。《唐志》作十卷，今止一卷，殆鈔合而成，非其舊本。晁公武《讀書志》雲，僧孺為宰相，有聞於世，而著此等書。周秦行紀之謗，蓋有以致之也。末附唐李複言《續錄》一卷。考《唐志》及《館閣書目》皆作五卷，《通考》則作十卷，雲分仙術、感應二門。今僅殘篇數頁，並不成卷矣。然志怪之書，無關風教，其完否亦不必深考也。","edition":"兩淮鹽政采進本"}],"juan_count":{"number":1},"additional_works":[{"book_title":"續幽怪錄","n_juan":1}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4027371","type":"text"},{"id":"shidianguji-chaoben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02060149","type":"text+image","metadata":{"edition":"抄本","version":"v6","total_page":257,"paragraph_count":260,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL57b5VeQw":{"id":"GYL57b5VeQw","type":"work","title":"漢世說","authors":[{"name":"章撫功","role":"編","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《漢世說》•十四卷","author_info":"國朝章撫功編","summary":"國朝章撫功編。撫功字仁豔，錢塘人。是書仿劉義慶《世說新語》體例，以紀漢人言行。大抵以《史記》、《漢書》為主，而雜以他書附益之。分十四門，曰德行，曰言語，曰政事，曰文學，曰方正，曰雅量，曰識鑒，曰賞譽，曰品藻，曰清介，曰才智，曰英氣，曰義烈，曰寵禮。與義慶原本小異，其采摭亦備。然事皆習見，無他異聞，又分類往往不確。如龔遂刺昌邑王過，自宜入方正；鄧禹師行有紀，自應入政事，乃俱入之德行。至射的山仙人取箭，自是志怪之說，入之此書，尤無體例也。其凡例雲，書以語名，始《論語》也。國語紀言，不參以事。陸賈《新語》，馬上翁每奏稱善。臨川《世說》一書，諸多士所共撰述。始自竹林，迄於江左。風流簡遠，少許勝多，最為可貴。茲編獨尊兩漢，意專敍事，故不以《新語》名篇云云。案劉向先有《世說》，故義慶所撰，別名《世說新書》，後人乃改為《新語》。黃伯思《東觀餘論》考之最詳，非以記言而謂之《新語》，撫功之說殊誤，至義慶所述，上接東漢，何得雲始自竹林，益為失檢矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":14},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=6683067","type":"text"},{"id":"shidianguji-qiyanshutangchaoben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02060140","type":"text+image","metadata":{"edition":"七硯書堂鈔本","version":"v4","total_page":97,"paragraph_count":140,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL57baDezs":{"id":"GYL57baDezs","type":"work","title":"劍俠傳","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《劍俠傳》·二卷","author_info":"舊本題為唐人撰","summary":"舊本題為唐人撰，不著名氏。載明吳琯《古今逸史》中。皆紀唐代劍俠之事，與《太平廣記》一百九十三卷至一百九十六卷所載豪俠四卷文盡相同。次序及句下夾註如潘將軍條下所附忘其名疑為潘鶻硉也九字，亦複吻合，但訛鶻硉為鶴碎耳。蓋明人剿襲《廣記》之文，偽題此名也。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":2},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/劍俠傳","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=942530","type":"text"},{"id":"shidianguji-lvqianziminglongqing","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ892412000000568161938","type":"text+image","metadata":{"edition":"履謙子明隆慶3年刻本","version":"v2","total_page":154,"paragraph_count":170,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57bhQA9M":{"id":"GYL57bhQA9M","type":"work","title":"括異志","authors":[{"name":"張師正","role":"撰","dynasty":"宋"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《括異志》·十卷","author_info":"舊本題宋張師正撰","summary":"舊本題宋張師正撰。師正字不疑。熙甯中為辰州帥。《文獻通考》載師正擢甲科後，宦遊四十年不得志，於是推變怪之理，參見聞之異，得二百五十篇，魏泰為之序。此本不載魏序，蓋傳寫佚之。然王銍《默記》以是書即魏泰作。蓋泰為曾布之婦兄，而銍則曾紆之婿，猶及識泰，其言當必不誣也。","edition":"內府藏本"}],"juan_count":{"number":10},"resources":[{"id":"wikisource-sibu-congkan","name":"维基文库（四部叢刊本）","url":"https://zh.wikisource.org/wiki/括異志_(四部叢刊本)","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=398447","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=470396","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=836682","type":"text"},{"id":"shidianguji-sibucongkanchangshuq","name":"识典古籍","url":"https://www.shidianguji.com/book/SBCK372","type":"text+image","metadata":{"edition":"四部叢刊常熟瞿氏鐵琴銅劍樓藏景宋鈔本","version":"v7","total_page":236,"paragraph_count":368,"has_translation":true,"check_type":"精校"}},{"id":"shidianguji-chaoben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02060158","type":"text+image","metadata":{"edition":"抄本","version":"v4","total_page":276,"paragraph_count":146,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL57byz9Mq":{"id":"GYL57byz9Mq","type":"work","title":"峽山神異記","authors":[{"name":"黃輔","role":"撰","dynasty":"宋"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《峽山神異記》·一卷","author_info":"宋黃輔撰","summary":"宋黃輔撰。輔裏籍未詳。是書作於嘉定戊寅。輔時辟為瀧水縣令。自序謂予備員西征，始聞峽山非常可駭之事，始猶未敢以為然。及觀前賢所記，由東坡以來，連篇累牘，悉出於名公巨卿之口，以其人之可信，則事必可信矣。訪《峽山集》舊版散失，於是裒集傳之。然其敍述飛來殿，謂至德元年峽有三神人化為方士，夜扣潁州貞俊禪師曰，本峽居清遠上流，吾欲建道場，師能去否？俊諾之。是夕風雨驟作，黎明薄霽，啟戶而觀，則佛殿與神像已運至山中矣。俊師乃於峰前石上安坐。本淮南西路舒州延祚寺之所移。其事涉於語怪，是小說之支流，非地志之正體也。","edition":"永樂大典本"}],"juan_count":{"number":1}},"GYL57bm1keK":{"id":"GYL57bm1keK","type":"work","title":"青瑣高議前集","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《青瑣高議前集》·十卷、《後集》·十卷","author_info":"不著撰人名氏","summary":"不著撰人名氏。晁公武《讀書志》及《宋史·藝文志》皆著錄，亦皆不雲誰作。趙與旹《賓退錄》稱為劉斧《青瑣高議》，當必親見其標題。前有孫副樞序。不稱名而舉其官，他書亦無此例，其為裏巷俗書可知也。所紀皆宋時怪異事蹟，及諸雜傳記，多乖雅馴，每條下各為七字標目。如張乖崖明斷分財，回處士磨鏡題詩之類，尤近於傳奇。間有稱議曰者，寥寥數言，亦多陳腐。《讀書志》稱其詞意鄙淺，良非輕詆。公武所錄作十八卷，《宋史·藝文志》亦同，此本乃多兩卷，或坊賈傳刻，又有所竄入歟？蔡絛《鐵圍山叢談》稱所載孫勔射黿被追，見韓琦為紫府真人事，其說不謬。然稱為青瑣小說，或又其別名也。孫勔事，《魏公別錄》、《魏公家傳》皆載之。周煇《清波雜誌》又考其同異，謂當以《家傳》為正。其所引王老志別一說，即蔡絛語也。韓琦名德，何必死作閻羅王乃足取重。斧作小說，侈談神怪可矣。士大夫以為實事而記於家傳、別錄，好事者又校正其異同，相率說夢，不亦傎乎？","edition":"兩淮鹽政采進本"}],"juan_count":{"number":10},"additional_works":[{"book_title":"後集","n_juan":10}],"resources":[{"id":"shidianguji-mingchaoben","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ89241199901942049849","type":"text+image","metadata":{"edition":"明抄本","version":"v2","total_page":542,"paragraph_count":5026,"check_type":"AI整理"}},{"id":"shidianguji-qingchaoben","name":"识典古籍","url":"https://www.shidianguji.com/book/NGJ892412000001757154692","type":"text+image","metadata":{"edition":"清抄本","version":"v2","total_page":439,"paragraph_count":975,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57bpafHq":{"id":"GYL57bpafHq","type":"work","title":"雲齋廣錄","authors":[{"name":"李獻民","role":"撰","dynasty":"宋"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《雲齋廣錄》·八卷、《後集》·一卷","author_info":"宋李獻民撰","summary":"宋李獻民撰。獻民字彥文，延津人。是書前有政和辛卯獻民自序。所載皆一時豔異雜事，文既冗遝，語尤猥褻。晁公武《讀書志》、陳振孫《書錄解題》俱雲十卷，分九門。今止存六門，曰士林清話，曰詩話錄，曰靈怪，曰麗情，曰奇異，曰神仙，共八卷。末有後集一卷，曰盈盈傳，乃作者自述所遇。然首稱皇祐中，中稱嘉祐五年，皆仁宗年號，與獻民時代不相及。則傳中所謂餘者乃別一人，而佚其名，非獻民自稱也。其書大致與劉斧《青瑣高議》相類。然斧書雖俗，猶時有勸戒，此則純乎誨淫而已。以向來諸家著錄，今姑存其目焉。","edition":"內府藏本"}],"juan_count":{"number":8},"additional_works":[{"book_title":"後集","n_juan":1}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=4420263","type":"text"},{"id":"shidianguji-qianyinben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02060168","type":"text+image","metadata":{"edition":"鉛印本","version":"v7","total_page":97,"paragraph_count":772,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57bWhSCo":{"id":"GYL57bWhSCo","type":"work","title":"陸氏集異記","authors":[{"name":"比部郎中陸勳","role":"撰","dynasty":"唐"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《陸氏集異記》·四卷","author_info":"舊本題唐比部郎中陸勳撰","summary":"舊本題唐比部郎中陸勳撰。《書錄解題》及《宋史·藝文志》並作二卷。陳振孫曰：語怪之書也。凡三十二事，言犬怪者居三之一。此書較陳氏所載多二卷，而事較振孫所記之數多三四倍，亦不多言犬怪，豈後人附會，非其本書歟？","edition":"兩江總督采進本"}],"juan_count":{"number":4}},"GYL57budZDh":{"id":"GYL57budZDh","type":"work","title":"五色線","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《五色線》·二卷","author_info":"不著編輯者名氏","summary":"不著編輯者名氏。載毛晉《津逮秘書》中。考《中興館閣書目》有此書名。然是書雜引諸小說新誕之語，或不紀所出，割裂舛謬，不可枚舉。至謂楚襄王夢神女事出《史記》，其庸妄可知。未知果宋時舊本否也。","edition":"內府藏本"}],"juan_count":{"number":2},"resources":[{"id":"shidianguji-jigugekanben","name":"识典古籍","url":"https://www.shidianguji.com/book/SDZJ0553","type":"text+image","metadata":{"edition":"汲古阁刊本","version":"v8","total_page":185,"paragraph_count":745,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL57bCxGg7":{"id":"GYL57bCxGg7","type":"work","title":"山海經釋義","authors":[{"name":"王崇慶","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《山海經釋義》·十八卷、《圖》·二卷","author_info":"明王崇慶撰","summary":"明王崇慶撰。崇慶有《周易議卦》，已著錄。是書全載郭璞注。崇慶間有論說，詞皆膚淺。其圖亦書肆俗工所臆作，不為典據。","edition":"通行本"}],"juan_count":{"number":18},"additional_works":[{"book_title":"圖","n_juan":2}],"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=7430721","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY1457","type":"text+image","metadata":{"edition":"刻本","version":"v7","total_page":610,"paragraph_count":894,"check_type":"粗校"}},{"id":"shidianguji-wanlishiqidayetangke","name":"识典古籍","url":"https://www.shidianguji.com/book/SDZJ0183","type":"text+image","metadata":{"edition":"萬曆時期大業堂刻本","version":"v10","total_page":632,"paragraph_count":569,"check_type":"AI整理"}},{"id":"shidianguji-wanlidayetangkeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02060143","type":"text+image","metadata":{"edition":"萬曆大業堂刻本","version":"v7","total_page":572,"paragraph_count":2772,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57bT8XZH":{"id":"GYL57bT8XZH","type":"work","title":"獨異志","authors":[{"name":"李冘","role":"撰","dynasty":"唐"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《獨異志》·二卷","author_info":"唐李冘撰","summary":"唐李冘撰。《唐·藝文志》作李元。未詳孰是。其書雜錄古事，亦及唐代瑣聞，大抵語怪者居多。如女媧兄妹為夫婦事，皆《齊東》之語。又如《列子》海人狎鷗、愚公移山事，皆摭寓言為實事，尤為膠固。至王涯為仇士良所害，本非文宗之命，乃稱涯為天兵梟戮，則悖謬甚矣。","edition":"江蘇巡撫采進本"}],"juan_count":{"number":2},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/獨異志","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=812770","type":"text"},{"id":"shidianguji-keben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02098972","type":"text+image","metadata":{"edition":"刻本","version":"v3","total_page":141,"paragraph_count":309,"has_translation":true,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL57bdqFVq":{"id":"GYL57bdqFVq","type":"work","title":"錄異記","authors":[{"name":"杜光庭","role":"撰","dynasty":"蜀"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《錄異記》·八卷","author_info":"蜀杜光庭撰","summary":"蜀杜光庭撰。光庭有《了證歌》，已著錄。此書《宋志》作十卷，與今本異。白雲霽《道藏目錄》收於洞元部記傳類恭字型大小中。然光庭雖道士，而此書所述實無與於道家。卷首沈士龍題辭謂光庭以方術事蜀孟昶，故成此書以取悅。考陶岳《五代史補》，光庭以唐僖宗幸蜀時入道，其後曆事王建、王衍，未入後蜀。即以此書而論，其記蜀丁卯年會昌廟城壕側龜著金書玉字大吉字，則王建天複七年也。又稱蜀皇帝乾德元年己卯七月十五日庚辰降誕廣聖節，王彥徽得白龜以進，則王衍元年也。凡此皆為前蜀王氏誕陳符瑞，以雲悅昶。失考甚矣。其言皆荒誕不足信。《冶城客論》曰：廣成先生杜光庭撰《仙傳錄異》等書，率多自作，故人有無稽之言謂之杜撰。然則光庭之妄，前人已言之矣。","edition":"兩江總督采進本"}],"juan_count":{"number":8},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/錄異記","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=633612","type":"text"},{"id":"ctext-1","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=171680","type":"text"},{"id":"ctext-2","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=5275038","type":"text"},{"id":"shidianguji-shanghaihanfenlouyin","name":"识典古籍","url":"https://www.shidianguji.com/book/DZ0591","type":"text+image","metadata":{"edition":"上海涵芬樓影印明《正統道藏》本","version":"v5","total_page":154,"paragraph_count":168,"has_translation":true,"check_type":"精校"}},{"id":"shidianguji-chongzhenkeben","name":"识典古籍","url":"https://www.shidianguji.com/book/HY6536","type":"text+image","metadata":{"edition":"崇禎年刻本","version":"v13","total_page":177,"paragraph_count":200,"check_type":"粗校"}},{"id":"shidianguji-chongzhenkeben-1","name":"识典古籍","url":"https://www.shidianguji.com/book/HY6535","type":"text+image","metadata":{"edition":"崇禎年刻本","version":"v6","total_page":176,"paragraph_count":167,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL57bKuLZM":{"id":"GYL57bKuLZM","type":"work","title":"續玄怪錄","authors":[{"name":"李複言","role":"撰","dynasty":"唐"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《續玄怪錄》·四卷","author_info":"唐李複言撰","summary":"唐李複言撰。是書世有二本：其附載牛僧孺《幽怪錄》末者，蓋從《說郛》錄出。一即此本，凡二十三事，與《唐志》卷數亦不符。蓋從《太平廣記》錄出者，雖稍多於《說郛》本，然亦非完帙也。","edition":"浙江範懋柱家天一閣藏本"}],"juan_count":{"number":4},"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/續玄怪錄","type":"text"}]}}