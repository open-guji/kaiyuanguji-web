{"GYL57d7YQj9":{"id":"GYL57d7YQj9","type":"work","title":"快雪堂漫錄","authors":[{"name":"馮夢禎","role":"撰","dynasty":"明"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《快雪堂漫錄》·一卷","author_info":"明馮夢禎撰","summary":"明馮夢禎撰。夢禎有《歷代貢舉志》，已著錄。是編為陸烜奇晉齋所刻，皆記見聞異事。語怪者十之三，語因果者十之六，記翰林舊例、大同米價、回回人義僕、節婦、虞長孺、漢印、吳茂昭品龍井茶、李於麟棄岕茶，以及栽蘭、藏茶、炒茶、茉莉酒、造印色、鑄鏡、造糊、造色紙諸法，為雜家言者十之一。故從其多者，入之小說家焉。","edition":"浙江巡撫采進本"}],"juan_count":{"number":1},"resources":[{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=3640719","type":"text"},{"id":"shidianguji-qianlongsanshisiluxu","name":"识典古籍","url":"https://www.shidianguji.com/book/HY6723","type":"text+image","metadata":{"edition":"乾隆三十四年(1769)陸烜奇晋齋刻本","version":"v4","total_page":66,"paragraph_count":42,"has_translation":true,"check_type":"粗校"}},{"id":"shidianguji-qianlongpinghulushik","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02060207","type":"text+image","metadata":{"edition":"乾隆平湖陸氏刻奇晉齋叢書本","version":"v1","total_page":67,"paragraph_count":537,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57d3yW5d":{"id":"GYL57d3yW5d","type":"work","title":"燃犀集","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《燃犀集》·四卷","author_info":"不著撰人名氏，自稱茂苑樹瓠子","summary":"不著撰人名氏，自稱茂苑樹瓠子。有嘉靖辛酉自序。摘取小說家所錄神怪之事，匯錄成編。大都與他書複出，無可采也。","edition":"通行本"}],"juan_count":{"number":4}}}