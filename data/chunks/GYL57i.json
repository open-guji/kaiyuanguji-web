{"GYL57iNJEqu":{"id":"GYL57iNJEqu","type":"work","title":"觚賸","authors":[{"name":"鈕琇","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《觚賸》·八卷、《續編》·四卷","author_info":"國朝鈕琇撰","summary":"國朝鈕琇撰。琇字玉樵，吳江人。康熙壬子拔貢生。曆官至陝西知府。是編成於康熙庚辰，皆記明末國初雜事。隨所至之地，錄其見聞。凡吳觚三卷，燕觚、豫觚、秦觚各一卷，粵觚二卷。續編成於康熙甲午，分類排纂為言觚、事觚、人觚、物觚四卷，體例與初編略殊。各有琇自序。琇本好為儷偶之詞，故敍述是編，幽豔淒動，有唐人小說之遺。然往往點綴敷衍，以成佳話，不能盡核其實也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":8},"additional_works":[{"book_title":"續編","n_juan":4}],"resources":[{"id":"wikisource","name":"维基文库","url":"https://zh.wikisource.org/wiki/觚賸","type":"text"},{"id":"ctext","name":"CText","url":"https://ctext.org/wiki.pl?if=gb&res=583219","type":"text"},{"id":"shidianguji-kangxilinyetangkeben","name":"识典古籍","url":"https://www.shidianguji.com/book/CADAL02096974","type":"text+image","metadata":{"edition":"康熙臨野堂刻本","version":"v1","total_page":383,"paragraph_count":3933,"check_type":"AI整理"}}],"has_text":true,"has_image":true},"GYL57iZ3edu":{"id":"GYL57iZ3edu","type":"work","title":"果報見聞錄","authors":[{"name":"楊式傳","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《果報見聞錄》·一卷","author_info":"國朝楊式傳撰","summary":"國朝楊式傳撰。式傳字雪崖，鄞縣人。是編皆述善惡之報，而大旨歸心於二氏。其逆婦小善免死一條，雖意主戒殺，然婦欲殺姑，罪通於天矣，豈偶救數鳥之命，即可以贖乎？殆不可訓也。","edition":"大學士英廉購進本"}],"juan_count":{"number":1}},"GYL57iJdxVV":{"id":"GYL57iJdxVV","type":"work","title":"有明異叢","authors":[{"name":"傅燮詷","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《有明異叢》·十卷","author_info":"國朝傅燮詷撰","summary":"國朝傅燮詷撰。是書記明一代怪異之事，亦分十類，與《史異纂》門目相同。皆從小說中撮抄而成，漫無體例。如尹蓬頭騎鐵鶴上升，正德中上蔡知縣霍恩為流賊所殺，頭出白氣，及天啟丙寅王恭廠災之類，往往一事而兩見。又有實非怪異而載者，如事異門內胡壽昌毀延平淫祠而絕無妖，任高妻女三人罵賊沒水，次日浮出面如生，術異門內汪機以藥治狂癇，物異門內蕭縣嶽飛祠內竹生花，雜異門內漳州火藥局災，大石飛去三百步之類，皆事理之常，安得別神其說？至如譯異門內謂黑婁在嘉峪關西，近土魯番，其地山川草木禽獸皆黑，男女亦然，今土魯番以外鹹入版圖，安有是種類乎？其妄可知矣。","edition":"浙江巡撫采進本"}],"juan_count":{"number":10}},"GYL57iF2MzX":{"id":"GYL57iF2MzX","type":"work","title":"史異纂","authors":[{"name":"傅燮詷","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《史異纂》·十六卷","author_info":"國朝傅燮詷撰","summary":"國朝傅燮詷撰。燮詷字去異，靈壽人。工部尚書維鱗子，官至汀州府知府。是書雜纂災祥怪異之事，自上古至元，悉據正史采入，凡外傳雜記，皆不錄。分天異、地異、祥異、人異、事異、術異、譯異、鬼異、物異、雜異十門。","edition":"浙江巡撫采進本"}],"juan_count":{"number":16}},"GYL57ioQevs":{"id":"GYL57ioQevs","type":"work","title":"牡丹榮辱志","authors":[{"name":"邱璿","role":"撰","dynasty":"宋"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《牡丹榮辱志》·一卷","author_info":"舊本題宋邱璿撰","summary":"舊本題宋邱璿撰。考宋邱璿字道源，黟縣人。天聖五年進士，官至殿中丞。邵博《聞見後錄》記當時有邱濬者，以易卦推驗歷代，謂元豐正當豐卦。《靖康要錄》記欽宗以郭京為將，蓋取邱濬詩郭京，楊式、劉無忌，皆在東南臥白雲之識，其字皆從睿從水。此本亦題曰字道源，蓋即其人。而名乃作璿，殆傳寫誤歟？尤侗《明·藝文志》乃以是書為明邱濬作，又誤中之誤矣。厲鶚《宋詩紀事》稱濬有《洛陽貴尚錄》，今未見。此書亦品題牡丹，以姚黃為王，魏紅為妃，而以諸花各分等級役屬之，又一一詳其宜忌，其體略如李商隱《雜纂》。非論花品，亦非種植，入之農家為不倫，今附之小說家焉。","edition":"內府藏本"}],"juan_count":{"number":1}},"GYL57i4BaVd":{"id":"GYL57i4BaVd","type":"work","title":"矩齋雜記","authors":[{"name":"施閏章","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《矩齋雜記》·二卷","author_info":"國朝施閏章撰","summary":"國朝施閏章撰。閏章仕履已附見《青原志略》條下。是書多記見聞雜事，兼涉神怪，舊載《閏章外集》中，蓋《河東集》後附《龍城錄》之例。然終為不類，今析出別著錄焉。","edition":"江西巡撫采進本"}],"juan_count":{"number":2}},"GYL57iBQmVZ":{"id":"GYL57iBQmVZ","type":"work","title":"雷譜","authors":[{"name":"金侃","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《雷譜》·一卷","author_info":"國朝金侃撰","summary":"國朝金侃撰。侃字亦陶，吳縣人。其書雜錄雷之典故與雷之果報。雖意主戒惡，而所摭皆小說家言。","edition":"浙江巡撫采進本"}],"juan_count":{"number":1}},"GYL57izFSRm":{"id":"GYL57izFSRm","type":"work","title":"開顏集","authors":[{"name":"周文玘","role":"撰","dynasty":"宋"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《開顏集》·二卷","author_info":"宋周文玘撰","summary":"宋周文玘撰。文玘嘗官試秘書省校書郎，其裏籍未詳。此書《通考》作三卷，此本僅上下二卷，而所載三十五事與自序合，疑《通考》誤二為三也。《文獻通考》作文規，《書錄解題》謂文規未知何人，然此刻本玘字甚分明，亦疑《通考》傳寫之誤。其書皆古來詼諧事，各注出典。然其中如《世說》濟尼一條，無可笑者，《列子》攫金一條，增吏大笑之四字；《後漢書》袁隗婦一條，增隗大笑之四字。皆非本文，亦一病也。","edition":"浙江範懋柱家天一閣藏本"}],"juan_count":{"number":2}},"GYL57iccZHR":{"id":"GYL57iccZHR","type":"work","title":"信徵錄","authors":[{"name":"徐慶","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《信徵錄》·一卷","author_info":"國朝徐慶撰","summary":"國朝徐慶撰。慶字賓溪，自署曰烏山人，不知何地之烏山也，是編雜記果報，語多荒誕。夫福善禍淫，天有顯道，即明神肸蚃，亦當在杳冥之間。至於人鬼對言，幽明相接，指陳獄牘，判決是非，如虞山孫振先竊銀因果記之類，何其怪而不經也。命曰信徵，豈其然乎？","edition":"大學士英廉購進本"}],"juan_count":{"number":1}},"GYL57is2FRq":{"id":"GYL57is2FRq","type":"work","title":"東坡問答錄","authors":[{"name":"蘇軾","role":"撰","dynasty":"宋"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《東坡問答錄》·一卷","author_info":"舊本題宋蘇軾撰","summary":"舊本題宋蘇軾撰。所記皆與僧了元往復之語，詼諧謔浪，極為猥褻。又載佛印環疊字詩，及東坡長亭詩。詞意鄙陋，亦出委巷小人之所為。偽書中之至劣者也。","edition":"內府藏本"}],"juan_count":{"number":1}},"GYL57iVS48w":{"id":"GYL57iVS48w","type":"work","title":"鄢署雜抄","authors":[{"name":"汪為熹","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《鄢署雜抄》·十四卷","author_info":"國朝汪為熹撰","summary":"國朝汪為熹撰。為熹字若木，桐鄉人。康熙末官鄢陵知縣。欲修縣誌而未果，因摭其地之遺聞瑣事綴為此書。自序稱事涉鄢陵者十之六七，涉省郡別州縣者十之三四，合以身之所曆，目之所睹，得十四卷。大抵多采稗官說部一切神怪之言，蓋本儲地志之材。而繙閱既多，捃摭遂濫，又嗜奇愛博，不忍棄去，乃裒而成帙，別以雜鈔為名。是特說部之流，非圖經之體也。今存目於小說家中，庶從其類。至卷首冠以康熙五十二年覃恩敕命，莫喻其理，殆見《唐宋文集》有以告身冠集首者，故亦效之歟？不知彼乃後人所加，非所自編。又皆施於專集非施於筆記之類也。","edition":"浙江巡撫采進本"}],"juan_count":{"number":14}},"GYL57i7qrr3":{"id":"GYL57i7qrr3","type":"work","title":"冥報錄","authors":[{"name":"陸圻","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《冥報錄》·二卷","author_info":"國朝陸圻撰","summary":"國朝陸圻撰。圻有《新婦譜》，已著錄。此編皆記冥途因果之事，意主勸善。其真妄不可究詰也。","edition":"大學士英廉購進本"}],"juan_count":{"number":2},"resources":[{"id":"shidianguji-shuolingben","name":"识典古籍","url":"https://www.shidianguji.com/book/7457451936153862156","type":"text+image","metadata":{"edition":"說鈴本","version":"v1","total_page":148,"paragraph_count":328,"check_type":"粗校"}}],"has_text":true,"has_image":true},"GYL57ijqkHM":{"id":"GYL57ijqkHM","type":"work","title":"笑海叢珠","authors":[{"name":"陸龜蒙","role":"撰","dynasty":"唐"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《笑海叢珠》·一卷","author_info":"舊本題唐陸龜蒙撰","summary":"舊本題唐陸龜蒙撰。然書中有蘇軾、黃庭堅、僧了元及黨進事，龜蒙生於唐末，何得預知？其為妄人依託可知矣。","edition":"永樂大典本"}],"juan_count":{"number":1}},"GYL57igBTvw":{"id":"GYL57igBTvw","type":"work","title":"簪雲樓雜記","authors":[{"name":"陳尚古","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《簪雲樓雜記》•一卷","author_info":"國朝陳尚古撰","summary":"國朝陳尚古撰。尚古字雲瞻，德清人。是編雜記瑣聞，多涉語怪。其足資考證者，惟述魏忠賢養女任氏冒稱明熹宗皇后張氏一事耳。","comment":"──右“小說家類”異聞之屬，六十部，三百五十二卷，內一部無卷數，皆附《存目》。","edition":"大學士英廉購進本"}],"juan_count":{"number":1}},"GYL57iRpTdy":{"id":"GYL57iRpTdy","type":"work","title":"曠園雜誌","authors":[{"name":"吳陳琬","role":"撰","dynasty":"清"}],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《曠園雜誌》·二卷","author_info":"國朝吳陳琬撰","summary":"國朝吳陳琬撰。陳琬有《春秋三傳同異考》，已著錄。是書皆記見聞雜事，而涉神怪者十之七八。惟所記楊維垣偽題柩字，棄城夜遁，為劫盜所殺，非死於國事，及葬明莊烈帝始末，二事足備考證耳。","edition":"大學士英廉購進本"}],"juan_count":{"number":2}},"GYL57ivdqvo":{"id":"GYL57ivdqvo","type":"work","title":"漁樵閒話","authors":[],"indexed_by":[{"source":"欽定四庫全書總目","source_bid":"GY4HvsY3w3u","title_info":"《漁樵閒話》·二卷","author_info":"舊題宋蘇軾撰","summary":"舊題宋蘇軾撰。明陳繼儒刻入《普秘笈》中，名為《漁樵閒話錄》。案晁公武《讀書志》中有此書，作《漁樵閒話》，無錄字。公武又雲，設為問答及史傳雜事，不知何人所為，亦不言出自軾手。書中多引唐小說，議論皆極淺鄙。疑宋時流俗相傳有是書，而明人重刻者複假軾以行耳。","edition":"內府藏本"}],"juan_count":{"number":2}}}